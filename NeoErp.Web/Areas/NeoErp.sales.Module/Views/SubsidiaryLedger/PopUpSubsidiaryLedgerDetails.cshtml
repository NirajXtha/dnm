    function GridSearch() {
        var $input = $(event.target);
        var $gridElement = $input.closest(".k-grid");
        var grid = $gridElement.data("kendoGrid");
        var searchValue = $input.val();

        grid.dataSource.filter({
            logic: "or",
            filters: [
                { field: "SUB_EDESC", operator: "contains", value: searchValue },
                { field: "PARTICULARS", operator: "contains", value: searchValue },
                { field: "Voucher_no", operator: "contains", value: searchValue },
                { field: "manual_no", operator: "contains", value: searchValue },
            ]
        });
    }

