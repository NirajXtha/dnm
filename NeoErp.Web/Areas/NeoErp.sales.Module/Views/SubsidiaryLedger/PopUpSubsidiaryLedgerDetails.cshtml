    function LedgerBindGrid(readurl, refresh) {

        var dataSource = new kendo.data.DataSource({
            requestStart: showLoading,
            type: "json",
            transport: {
                read: {
                    url: readurl, // <-- Get data from here.
                    dataType: "json", // <-- The default was "jsonp".
                    type: "post",
                    contentType: "application/json; charset=utf-8"
                },
                parameterMap: function (options, type) {

                    var paramMap = JSON.stringify($.extend(options, ReportFilter.filterAdditionalData()));

                    //  paramMap.formDate = $("#FromDateVoucher").val();
                    delete paramMap.$inlinecount; // <-- remove inlinecount parameter.
                    delete paramMap.$format; // <-- remove format parameter.
                    return paramMap;
                }
            },

            schema: {
                data: "data", // records are returned in the "data" field of the response
                total: "total",
                model: {
                    fields: {
                        voucher_date: { type: "date" },
                        Miti: { type: "string" },
                        manual_no: { type: "string" },
                        Voucher_no: { type: "string" },
                        PARTICULARS: { type: "string" },
                        dr_amount: { type: "number" },
                        OPEN_AMOUNT: { type: "number" },
                        cr_amount: { type: "number" },
                        SUB_EDESC: { type: "string" },
                        Balance: { type: "number" },
                        BalanceHeader: { type: "string" },


                    }
                },

            },
            aggregate: [{ field: "dr_amount", aggregate: "sum" },
            { field: "cr_amount", aggregate: "sum" }, { field: "OPEN_AMOUNT", aggregate: "sum" }],
            serverFiltering: true,
            serverGrouping: false,
            serverAggregates: false,
            //serverSorting: true,
            //serverFiltering: true,
            //serverPaging: true,
            serverPaging: false,
            //serverSorting: true,
            pageSize: 20,

        });
        var grid = $("#@Model.GridName").kendoGrid({
            dataSource: dataSource,

            toolbar: kendo.template($("#toolbar-template").html()),
            excel: {
                fileName: "Subsidiary Ledger Details",
                //proxyURL: "//demos.telerik.com/kendo-ui/service/export",
                allPages: true
            },
            excelExport: function (e) {
                var gridElement = $("#@Model.GridName");
                var sheet = e.workbook.sheets[0];
                var rows = sheet.rows;

                // Get column count BEFORE inserting header rows
                var colCount = (rows.length > 0 && rows[0].cells) ? rows[0].cells.length : 5;

                // Clean up the footer row: strip HTML tags from cell values
                if (rows.length > 0) {
                    var lastRow = rows[rows.length - 1];
                    if (lastRow && lastRow.cells) {
                        for (var i = 0; i < lastRow.cells.length; i++) {
                            var cell = lastRow.cells[i];
                            if (cell.value && typeof cell.value === 'string' && cell.value.indexOf('<') >= 0) {
                                var tempDiv = document.createElement('div');
                                tempDiv.innerHTML = cell.value;
                                var textContent = (tempDiv.textContent || tempDiv.innerText || '').trim();
                                var match = textContent.match(/[\d,]+\.?\d*/);
                                if (match) {
                                    var num = parseFloat(match[0].replace(/,/g, ''));
                                    cell.value = isNaN(num) ? textContent : num;
                                } else {
                                    cell.value = textContent;
                                }
                            }
                        }
                    }
                }

                // Build date range string (AD + BS dates)
                var fromAD = $("#FromDateVoucher").val() || '';
                var toAD = $("#ToDateVoucher").val() || '';
                var fromBS = $("#fromInputDateVoucher").val() || '';
                var toBS = $("#toInputDateVoucher").val() || '';

                var fromStr = fromAD + (fromBS ? ' (' + fromBS + ')' : '');
                var toStr = toAD + (toBS ? ' (' + toBS + ')' : '');
                var dateRange = fromStr + ' to ' + toStr;

                // Helper to build a plain info row
                function makeInfoRow(label, value) {
                    return {
                        height: 18,
                        cells: [{
                            value: label + value,
                            bold: true,
                            fontSize: 11,
                            colSpan: colCount
                        }]
                    };
                }

                // Insert rows at top in REVERSE order (each unshift pushes to row 1)
                rows.unshift(makeInfoRow("Date Range: ", dateRange));
                rows.unshift(makeInfoRow("Report Name :- ", "Subsidiary Ledger Details"));
                rows.unshift(makeInfoRow("Branch Name :- ", branchName));
                rows.unshift(makeInfoRow("Company Name :- ", companyName));

                // Hide loading spinner after export
                kendo.ui.progress(gridElement, false);
            },

            pdf: {
                allPages: true,
                avoidLinks: true,
                pageSize: "auto",
                //paperSize: [1100 , 1430],
                margin: {
                    top: "2m",
                    left: "1cm",
                    right: "1cm",
