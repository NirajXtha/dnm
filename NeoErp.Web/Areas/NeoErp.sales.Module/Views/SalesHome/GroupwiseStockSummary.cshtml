<script>
    // Define global URL
    var urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupwiseStockSummaryReport";

    // Function to show modal
    function showFilterModal() {
        $('#filterModalPopup').modal('show');
    }

    // On dropdown change (if needed)
    $('#reportType').first().on('change', function () {
        handleReportSelection($(this).val());
    });

    // On "Apply" button click inside modal
    $(document).ready(function () {
        $("#show_rep").on("click", function (e) {
            e.preventDefault(); // prevent form submit if any
            // Get selected values from dropdowns
            var multiUnit = $("#multiUnit").data("kendoDropDownList")?.value() || "";
            var valuationMethod = $("#valuationMethod").data("kendoDropDownList")?.value() || "";
            // Get selected radio button values
            var purchaseOption = $("input[name='purchaseOption']:checked").val() || "";
            var salesOption = $("input[name='salesOption']:checked").val() || "";
            //Get checkbox states
            var hideUnit = $("#togglePanColUnit").is(":checked");
            var hideAmount = $("#togglePanColumn").is(":checked");
            // Store globally if needed
            window.reportFilters = {
                multiUnit,
                valuationMethod,
                purchaseOption,
                salesOption,
                hideUnit,
                hideAmount
            };
            $('#filterModalPopup').modal('hide');
            BindGrid(urltest, window.reportFilters);
            // Optional logging
            console.log("Filters applied:", window.reportFilters);
            //BindGrid(urltest);
        });
    });
</script>
<script>
    var reportConfig = GetReportSetting("MonthwiseCustProdNetSales");
    function getDateFormat(date) {
        return kendo.format("{0:" + reportConfig.dateFormat + "}", date);
    }

    $(".applydp").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
    })

    $("#loadAdvancedFilters").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
    });

    $(document).ready(function () {
        DateFilter.init(function () {
            consolidate.init(function () {
                BindGrid(urltest);
            });
        });

        fileMailSender.init();

        var urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupwiseStockSummaryReport";

        $("#RunQuery").click(function (evt) {
            evt.preventDefault();
            urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupwiseStockSummaryReport";
            KendoGridRefresh(urltest);
        });

    });

    function KendoGridRefresh(readUrl) {
        $('#grid').data("kendoTreeList").destroy();
        $('#grid').val('');
        $('#grid').html('');
        BindGrid(readUrl)
    }

    //let grandTotalAppendedFlag = false;
    function BindGrid(urltest, filters = {}) {
    $('#filterModalPopup').modal('hide');

    var companyName = '@workingContent.CurrentUserinformation.company_name';
    var fromADdate = $("#FromDateVoucher").val();
    var toADdate = $("#ToDateVoucher").val();
    var fromBSdate = $("#fromInputDateVoucher").val();
    var toBSdate = $("#toInputDateVoucher").val();
    var branches = ReportFilter.getBranchs();
    let grandTotalAppendedFlag = false;
    const {
        multiUnit = "",
        valuationMethod = "",
        purchaseOption = "",
        salesOption = "",
        hideUnit = false,
        hideAmount = false
    } = filters;

    const requestData = {
        company_name: companyName,
        fromADdate,
        toADdate,
        fromBSdate,
        toBSdate,
        branches,
        multiUnit,
        valuationMethod,
        purchaseOption,
        salesOption
    };

    $.ajax({
        url: urltest,
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify(requestData),
        success: function (response) {
            console.log("TreeList Data:", response);

            response.forEach(item => {
                const qty = parseFloat(item.CLOSING_QTY) || 0;
                const amt = parseFloat(item.CLOSING_AMT) || 0;
                item.RATE = qty !== 0 ? amt / qty : 0;

                item.PUR_REMARK = "";

                // Optional: Only compare if fields exist
                if (item.PUR_ITEM_CODE && item.PUR_QUANTITY != null && item.PUR_CALC_QUANTITY != null) {
                    const purQty = parseFloat(item.PUR_QUANTITY) || 0;
                    const calcQty = parseFloat(item.PUR_CALC_QUANTITY) || 0;
                    const diff = purQty - calcQty;

                    if (diff > 0) {
                        item.PUR_REMARK = "excess";
                    } else if (diff < 0) {
                        item.PUR_REMARK = "short";
                    }
                }
            });


            const grandRow = response.find(x =>
                x.ITEM_EDESC && x.ITEM_EDESC.toLowerCase().includes("grand total")
            );

            response = response.filter(x =>
                !(x.ITEM_EDESC && x.ITEM_EDESC.toLowerCase().includes("grand total"))
            );

            const grandRowData = grandRow;

            // Define columns
            var columns = [
                { field: "ITEM_EDESC", title: "Chart of Item", width: 300, locked: true },
                { field: "ITEM_CODE", title: "Item Code", width: 80 },
                {
                    field: "INDEX_MU_CODE",
                    title: "Unit",
                    width: 80,
                    template: function (dataItem) {
                        return dataItem.INDEX_MU_CODE && dataItem.INDEX_MU_CODE !== "None" ? dataItem.INDEX_MU_CODE : "";
                    }
                },
                { field: "OPEN_QTY", title: "Opening Stock Qty", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "OPEN_AMT", title: "Opening Stock Amt", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PURCHASE_QTY", title: "Purchase GRN Qty", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PURCHASE_AMT", title: "Purchase GRN Amt", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PRO_REC_QTY", title: "Production Receipt Qty", width: 140, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PRO_REC_AMT", title: "Production Receipt Amt", width: 140, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SALES_RET_QTY", title: "Sales Return COGS Qty", width: 150, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SALES_RET_AMT", title: "Sales Return COGS Amt", width: 150, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SR_AMT", title: "Sales Return Invoice Amt", width: 120, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "CIR_QTY", title: "Goods Return Qty", width: 120, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "CIR_AMT", title: "Godds Return Amt", width: 120, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PRO_ISS_QTY", title: "Production Issue Qty", width: 140, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "PRO_ISS_AMT", title: "Production Issue Amt", width: 140, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SALES_QTY", title: "Sales COGS Qty", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SALES_AMT", title: "Sales COGS Amt", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "SI_AMT", title: "Sales Invoice Amt", width: 120, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                { field: "DN_AMT", title: "Debit Note Sales Amt", width: 120, format: "{0:N2}", attributes: { style: "text-align:right;" } },
