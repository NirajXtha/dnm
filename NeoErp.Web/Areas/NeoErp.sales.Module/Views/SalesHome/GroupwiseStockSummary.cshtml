    function toggleAmountColumns(gridId, checkboxId) {
        const grid = $(gridId).data("kendoTreeList");
        const isChecked = $(checkboxId).is(":checked");
        if (!grid) return;

        const columns = [
            "OPEN_AMT", "PURCHASE_AMT", "PRO_REC_AMT", "SALES_RET_AMT", "SR_AMT",
            "CIR_AMT", "PRO_ISS_AMT", "SALES_AMT", "SI_AMT", "DN_AMT", "CN_AMT",
            "STK_TRANS_AMT", "PURCHASE_RET_AMT", "GOODS_ISS_AMT", "STK_REC_AMT",
            "SALES_NET_AMT", "SRE_AMT", "CLOSING_AMT"
        ];

        columns.forEach(col => {
            isChecked ? grid.hideColumn(col) : grid.showColumn(col);
        });
    }

    function toggleUnitColumn(gridId, checkboxId) {
        const grid = $(gridId).data("kendoTreeList");
        const isChecked = $(checkboxId).is(":checked");
        if (!grid) return;
        isChecked ? grid.hideColumn("INDEX_MU_CODE") : grid.showColumn("INDEX_MU_CODE");
    }


    function filterTreeWithParents(data, searchTerm) {
    if (!searchTerm) return data;

       const lookup = {};
      data.forEach(item => {
         lookup[item.MASTER_ITEM_CODE] = item;
    });

    const matchedIds = new Set();

    function findMatches(item) {
    const match = Object.values(item).some(val =>
    val && typeof val === "string" && val.toLowerCase().includes(searchTerm)
    );

    if (match) {
    let current = item;
    // Add current item and all its parents to the matched set
    while (current) {
    matchedIds.add(current.MASTER_ITEM_CODE);
    current = lookup[current.PRE_ITEM_CODE];
    }
    }
    }

    data.forEach(findMatches);

    return data.filter(d => matchedIds.has(d.MASTER_ITEM_CODE));
