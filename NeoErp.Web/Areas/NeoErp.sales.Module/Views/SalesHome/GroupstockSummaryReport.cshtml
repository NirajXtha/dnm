        function getDateFormat(date) {
            return kendo.format("{0:" + reportConfig.dateFormat + "}", date);
        }

        $(".applydp").on("click", function (evt) {
            evt.preventDefault();
            $("#RunQuery").trigger("click");
        })

        $("#loadAdvancedFilters").on("click", function (evt) {
            evt.preventDefault();
            $("#RunQuery").trigger("click");
        });

        $(document).ready(function () {
            DateFilter.init(function () {
                consolidate.init(function () {
                    // Pass the global filters so applied item/report filters aren't lost on load
                    BindGrid(urltest, window.reportFilters || {});
                });
            });

            fileMailSender.init();

            var urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupstockSummaryReport";

            $("#RunQuery").click(function (evt) {
                evt.preventDefault();
                urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupstockSummaryReport";
                KendoGridRefresh(urltest);
            });

        });

        function KendoGridRefresh(readUrl) {
            $('#grid').data("kendoTreeList").destroy();
            $('#grid').val('');
            $('#grid').html('');
            // Pass global filters so refreshing the grid keeps them
            BindGrid(readUrl, window.reportFilters || {});
        }

        //let grandTotalAppendedFlag = false;
        function BindGrid(urltest, filters = {}) {
            $('#filterModalPopup').modal('hide');

            var companyName = '@workingContent.CurrentUserinformation.company_name';
            var fromADdate = $("#FromDateVoucher").val();
            var toADdate = $("#ToDateVoucher").val();
            var fromBSdate = $("#fromInputDateVoucher").val();
            var toBSdate = $("#toInputDateVoucher").val();
            var branches = ReportFilter.getBranchs();
            let grandTotalAppendedFlag = false;
            const {
                multiUnit = "",
                valuationMethod = "",
                multiLocation = "",
                purchaseOption = "",
                salesOption = "",
                hideUnit = false,
                hideAmount = false,
                itemMasterCodes = [],   // G-type group MASTER_ITEM_CODEs → LIKE filter (desktop parity)
                itemLeafCodes = []    // I-type leaf ITEM_CODEs         → IN filter
            } = filters;

            const requestData = {
                company_name: companyName,
                fromADdate,
                toADdate,
                fromBSdate,
                toBSdate,
                branches,
                multiUnit,
                valuationMethod,
                multiLocation,
                purchaseOption,
                salesOption,
                selectedMasterCodes: itemMasterCodes,  // G-type: backend builds LIKE 'code%'
                selectedItems: itemLeafCodes      // I-type: backend builds IN ('code1',...)
            };

            $.ajax({
                url: urltest,
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(requestData),
                success: function (response) {
                    console.log("TreeList Data:", response);

                    response.forEach(item => {
                        const qty = parseFloat(item.CLOSING_QTY) || 0;
                        const amt = parseFloat(item.CLOSING_AMT) || 0;
                        item.RATE = qty !== 0 ? amt / qty : 0;

                        item.PUR_REMARK = "";

                        // Optional: Only compare if fields exist
                        if (item.PUR_ITEM_CODE && item.PUR_QUANTITY != null && item.PUR_CALC_QUANTITY != null) {
                            const purQty = parseFloat(item.PUR_QUANTITY) || 0;
                            const calcQty = parseFloat(item.PUR_CALC_QUANTITY) || 0;
                            const diff = purQty - calcQty;

                            if (diff > 0) {
                                item.PUR_REMARK = "excess";
                            } else if (diff < 0) {
                                item.PUR_REMARK = "short";
                            }
                        }
                    });


                    const grandRow = response.find(x =>
                        x.ITEM_EDESC && x.ITEM_EDESC.toLowerCase().includes("grand total")
