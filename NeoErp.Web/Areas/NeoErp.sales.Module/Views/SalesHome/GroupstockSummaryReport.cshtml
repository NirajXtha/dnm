    <script>
        // Define global URL
        var urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetGroupstockSummaryReport";

        // Function to show modal
        function showFilterModal() {
            $('#filterModalPopup').modal('show');
        }

        // On dropdown change (if needed)
        $('#reportType').first().on('change', function () {
            handleReportSelection($(this).val());
        });

        // On "Apply" button click inside modal
        $(document).ready(function () {
            $("#show_rep").on("click", function (e) {
                e.preventDefault(); // prevent form submit if any
                // Get selected values from dropdowns
                var multiUnit = $("#multiUnit").data("kendoDropDownList")?.value() || "";
                var valuationMethod = $("#valuationMethod").data("kendoDropDownList")?.value() || "";
                var multiLocation = $("#multiLocation").data("kendoDropDownList")?.value() || "";
                // Get selected radio button values
                var purchaseOption = $("input[name='purchaseOption']:checked").val() || "";
                var salesOption = $("input[name='salesOption']:checked").val() || "";
                //Get checkbox states
                var hideUnit = $("#togglePanColUnit").is(":checked");
                var hideAmount = $("#togglePanColumn").is(":checked");
                // Get previously applied item codes from the Item Filter modal
                var itemSelection = window.selectedItemCodes || { masterCodes: [], leafCodes: [] };
                // Store globally
                window.reportFilters = {
                    multiUnit,
                    valuationMethod,
                    multiLocation,
                    purchaseOption,
                    salesOption,
                    hideUnit,
                    hideAmount,
                    itemMasterCodes: itemSelection.masterCodes || [],
                    itemLeafCodes: itemSelection.leafCodes || []
                };

                $('#filterModalPopup').modal('hide');
                BindGrid(urltest, window.reportFilters);
                // Optional logging
                console.log("Filters applied:", window.reportFilters);
            });

            // When Report Filter modal closes without Apply, no tree action needed
            $('#filterModalPopup').on('hidden.bs.modal', function () { });
        });
    </script>
    <script>
