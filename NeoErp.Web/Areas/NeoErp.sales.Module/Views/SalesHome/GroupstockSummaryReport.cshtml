</style>
<style>
    #filterModalPopup .k-list-container::-webkit-scrollbar {
        width: 6px;
    }

    #filterModalPopup .k-list-container::-webkit-scrollbar-thumb {
        background-color: #999;
        border-radius: 4px;
    }

    #filterModalPopup .k-list-container::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    #filterModalPopup .k-list-container {
        scrollbar-width: thin;
        scrollbar-color: #999 #f1f1f1;
    }
</style>
<style>
    /* ── Prevent locked-column pane collapsing on TreeList re-render ── */
    #grid {
        width: 100% !important;
    }

    #grid .k-grid-header-locked,
    #grid .k-grid-content-locked {
        min-width: 0;
        /* let Kendo control the width */
        overflow: visible;
    }

    /* Make the grid fill remaining screen height better */
    #grid .k-grid-content,
    #grid .k-grid-content-locked {
        overflow-y: auto;
    }

    /* Keep page-bar from overlapping grid after filter re-render */
    .page-content .page-bar {
        position: relative;
        z-index: 10;
    }
</style>


