            <script>
                $(document).ready(function () {

                    // ── MultiUnit & ValuationMethod dropdowns (inside Report Filter modal) ──
                    $("#multiUnit").kendoDropDownList({
                        optionLabel: "Select Unit...",
                        dataSource: ["Unit Index", "Carton", "Kg", "Liter", "Pair", "Pieces"],
                        value: "Pieces"
                    });
                    $("#valuationMethod").kendoDropDownList({
                        optionLabel: "Select Method...",
                        dataSource: ["Average", "Wt.Average", "FIFO", "As Per Tran"],
                        value: "FIFO"
                    });

                    var apiLocationUrl = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetAllLocation";

                    $("#multiLocation").kendoDropDownList({
                        optionLabel: "Select Location...",
                        height: 180,
                        popup: {
                            appendTo: $("#filterModalPopup") // render inside modal so it can't escape the boundary
                        },
                        dataSource: new kendo.data.DataSource({
                            transport: {
                                read: {
                                    url: apiLocationUrl,
                                    dataType: "json",
                                    type: "GET"
                                }
                            },
                            serverFiltering: false,
                            schema: {
                                data: "DATA",
                                model: {
                                    fields: {
                                        LOCATION_CODE: { type: "string" },
                                        LOCATION_EDESC: { type: "string" }
                                    }
                                }
                            }
                        }),
                        dataTextField: "LOCATION_EDESC",
                        dataValueField: "LOCATION_CODE",
                        filter: "contains"
                    });

                    // ── Hierarchical Item Tree Filter ──────────────────────────────────────
                    var _allItemNodes = [];

                    function buildItemMap(items) {
                        var mapByMasterCode = {};
                        var allNodes = [];

                        // First pass: create node objects and register groups by MASTER_ITEM_CODE
                        items.forEach(function (item) {
                            var node = $.extend({}, item, { children: [] });
                            // In case of duplicate MASTER_ITEM_CODEs, the G-type should take precedence as parent lookup
                            if (!mapByMasterCode[node.MASTER_ITEM_CODE] || node.GROUP_SKU_FLAG === "G") {
                                mapByMasterCode[node.MASTER_ITEM_CODE] = node;
                            }
                            allNodes.push(node);
                        });

                        var roots = [];
                        // Second pass: link children to parents using PRE_ITEM_CODE -> MASTER_ITEM_CODE
                        allNodes.forEach(function (node) {
                            var parentCode = node.PRE_ITEM_CODE;
                            var parentNode = mapByMasterCode[parentCode];

                            // Prevent a node from being its own parent
                            if (parentNode && parentNode !== node) {
                                parentNode.children.push(node);
                            } else {
                                // If no parent found, or parentCode is "00", it's a root
                                if (!parentCode || parentCode === "00" || !parentNode) {
                                    roots.push(node);
                                }
                            }
                        });
                        return { map: mapByMasterCode, roots: roots };
                    }

                    function renderTreeNodes(nodes, $ul) {
                        nodes.forEach(function (node) {
                            var hasChildren = node.children && node.children.length > 0;
                            var isGroup = node.GROUP_SKU_FLAG === "G";
                            var $li = $("<li>").css({ listStyle: "none", margin: "1px 0 1px 14px", padding: 0 });
                            var $row = $("<div>").css({ display: "flex", alignItems: "center", gap: "4px", padding: "1px 0" });

                            if (hasChildren) {
                                var $toggle = $("<span class='tree-toggle'>").text("\u25B6").css({
                                    cursor: "pointer", fontSize: "9px", color: "#555",
                                    userSelect: "none", display: "inline-block", width: "12px", flexShrink: 0
                                });
                                $row.append($toggle);
                            } else {
                                $row.append($("<span>").css({ width: "12px", display: "inline-block", flexShrink: 0 }));
                            }

                            var safeId = "itcb_" + node.MASTER_ITEM_CODE.replace(/[^a-zA-Z0-9]/g, "_");
                            var $cb = $("<input type='checkbox'>")
                                .attr("id", safeId)
                                .attr("data-master-code", node.MASTER_ITEM_CODE)
                                .attr("data-item-code", node.ITEM_CODE || "")
                                .attr("data-flag", node.GROUP_SKU_FLAG || "I")
                                .css({ cursor: "pointer", flexShrink: 0 });

                            var displayText = (node.ITEM_CODE ? node.ITEM_CODE + " - " : "") + node.ITEM_EDESC;
                            var $lbl = $("<label>").attr("for", safeId)
                                .text(displayText)
                                .css({ cursor: "pointer", margin: 0, fontWeight: isGroup ? "bold" : "normal", color: isGroup ? "#333" : "#555" });

                            $row.append($cb).append($lbl);
                            $li.append($row);

                            if (hasChildren) {
                                var $childUl = $("<ul>").css({ padding: 0, margin: 0, display: "none" })
                                    .attr("data-parent-code", node.MASTER_ITEM_CODE);
                                renderTreeNodes(node.children, $childUl);
                                $li.append($childUl);
                                $row.find(".tree-toggle").on("click", function () {
                                    var isOpen = $childUl.is(":visible");
                                    $childUl.toggle(!isOpen);
                                    $(this).text(isOpen ? "\u25B6" : "\u25BC");
                                });
                            }
                            $ul.append($li);
                        });
                    }

                    function cascadeDown($cb, checked) {
                        $cb.closest("li").find("input[type='checkbox']").prop("checked", checked).prop("indeterminate", false);
                    }

                    function bubbleUp($cb) {
                        var $parentUl = $cb.closest("ul[data-parent-code]");
                        if (!$parentUl.length) return;
                        var $siblings = $parentUl.find("> li > div > input[type='checkbox']");
                        var total = $siblings.length, checked = 0, indet = 0;
                        $siblings.each(function () { if (this.checked) checked++; else if (this.indeterminate) indet++; });
                        var parentCode = $parentUl.attr("data-parent-code");
                        var $parentCb = $("#itemTreeContainer").find("input[data-master-code='" + parentCode + "']");
                        if (checked === total) { $parentCb.prop("checked", true).prop("indeterminate", false); }
                        else if (checked === 0 && indet === 0) { $parentCb.prop("checked", false).prop("indeterminate", false); }
                        else { $parentCb.prop("checked", false).prop("indeterminate", true); }
                        bubbleUp($parentCb);
                    }

                    window.getSelectedItemCodes = function () {
                        var masterCodes = [];   // MASTER_ITEM_CODE of G-type groups → LIKE filter
                        var leafCodes = [];   // ITEM_CODE of I-type leaf items    → IN filter
                        $("#itemTreeContainer input[type='checkbox']:checked").each(function () {
                            var flag = $(this).attr("data-flag");
                            var masterCode = $(this).attr("data-master-code");
                            var itemCode = $(this).attr("data-item-code");
                            if (flag === "G" && masterCode) {
                                masterCodes.push(masterCode);   // becomes LIKE 'xx.xx.xx%'
                            } else if (itemCode) {
                                leafCodes.push(itemCode);        // becomes IN ('686','687',...)
                            }
                        });
                        return { masterCodes: masterCodes, leafCodes: leafCodes };
                    };

                    window.clearTreeSelection = function () {
                        $("#itemTreeContainer input[type='checkbox']").prop("checked", false).prop("indeterminate", false);
                        $("#selectAllItems").prop("checked", false).prop("indeterminate", false);
                        $("#itemTreeSearch").val("");
                        $("#itemTreeContainer li").show();
                        $("#itemTreeContainer ul[data-parent-code]").hide();
                        $("#itemTreeContainer .tree-toggle").text("\u25B6");
                    };

                    function filterItemTree(query) {
                        var q = query.toLowerCase().trim();
                        if (!q) {
                            $("#itemTreeContainer li").show();
                            $("#itemTreeContainer ul[data-parent-code]").hide();
                            $("#itemTreeContainer .tree-toggle").text("\u25B6");
                            return;
                        }
                        $("#itemTreeContainer li").hide();
                        $("#itemTreeContainer li").each(function () {
                            var text = $(this).find("> div label").text().toLowerCase();
                            if (text.indexOf(q) >= 0) {
                                $(this).show();
                                $(this).parents("li").show();
                                $(this).parents("ul[data-parent-code]").show();
                            }
                        });
                        $("#itemTreeContainer ul[data-parent-code]:visible").each(function () {
                            $(this).closest("li").find("> div .tree-toggle").first().text("\u25BC");
                        });
                    }

                    // Load item tree from API
                    var itemApiUrl = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetAllItemByGroup";
                    $.ajax({
                        url: itemApiUrl, type: "GET", dataType: "json",
                        success: function (response) {
                            _allItemNodes = response.DATA || [];
                            var built = buildItemMap(_allItemNodes);
                            var $rootUl = $("<ul>").css({ padding: 0, margin: 0 });
                            renderTreeNodes(built.roots, $rootUl);
                            $("#itemTreeContainer").empty().append($rootUl);

                            // Checkbox change: cascade down + bubble up
                            $("#itemTreeContainer").on("change", "input[type='checkbox']", function () {
                                var checked = $(this).is(":checked");
                                cascadeDown($(this), checked);
                                bubbleUp($(this));
                                var total = $("#itemTreeContainer input[type='checkbox']").length;
                                var chk = $("#itemTreeContainer input[type='checkbox']:checked").length;
                                $("#selectAllItems").prop("checked", chk === total).prop("indeterminate", chk > 0 && chk < total);
                            });

                            // Select All
                            $("#selectAllItems").on("change", function () {
                                var checked = $(this).is(":checked");
                                $("#itemTreeContainer input[type='checkbox']").prop("checked", checked).prop("indeterminate", false);
                            });

                            // Search
                            $("#itemTreeSearch").on("input", function () { filterItemTree($(this).val()); });
                        },
                        error: function () {
                            $("#itemTreeContainer").html("<span style='color:red;font-size:11px;'>Failed to load items.</span>");
                        }
                    });

                    // ── Apply Item Filter button ──────────────────────────────────────────
                    $("#applyItemFilter").on("click", function () {
                        var selection = window.getSelectedItemCodes ? window.getSelectedItemCodes() : { masterCodes: [], leafCodes: [] };
                        window.selectedItemCodes = selection;
                        $("#itemFilterModal").modal("hide");
                        console.log("Item filter applied:", selection);

                        // Merge selected item codes into existing report filters and re-fetch immediately
                        var currentFilters = $.extend({}, window.reportFilters || {}, {
                            itemMasterCodes: selection.masterCodes,  // G-type groups → LIKE filter
                            itemLeafCodes: selection.leafCodes     // I-type items  → IN filter
                        });
                        window.reportFilters = currentFilters;
                        BindGrid(urltest, currentFilters);
                    });

                    // Clear tree when Item Filter modal is dismissed
                    $("#itemFilterModal").on("hidden.bs.modal", function () {
                        if (window.clearTreeSelection) {
                            window.clearTreeSelection();
                        }
                    });

                }); // end $(document).ready
            </script>

