                    // Column 7: QUANTITY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["QUANTITY"] || 0)}</b></td>`);

                    // Column 8: SECOND_QUANTITY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["SECOND_QUANTITY"] || 0)}</b></td>`);

                    // Column 9: UNIT_PRICE
                 //   footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["UNIT_PRICE"] || 0)}</b></td>`);

                    // Column 10: TOTAL_PRICE
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["TOTAL_PRICE"] || 0)}</b></td>`);

                    // Column 11: DUE_QTY (Pending Qty)
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["DUE_QTY"] || 0)}</b></td>`);

                    // Columns 12-13: CHALAN_DATE, CHALAN_NO (empty)
                    footerRow.append(`<td></td><td></td>`);

                    // Column 14: CHALAN_QTY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["CHALAN_QTY"] || 0)}</b></td>`);

                    // Column 15: CHALAN_ALT_QTY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["CHALAN_ALT_QTY"] || 0)}</b></td>`);

                    // Columns 16-17: SALES_DATE, SALES_NO (empty)
                    footerRow.append(`<td></td><td></td>`);

                    // Column 18: SALES_QTY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["SALES_QTY"] || 0)}</b></td>`);

                    // Column 19: SALES_ALT_QTY
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["SALES_ALT_QTY"] || 0)}</b></td>`);

                    // Column 20: SALES_VALUE
                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals["SALES_VALUE"] || 0)}</b></td>`);

                    // Append footer row and add to grid
                    footerWrapper.find("tbody").append(footerRow);
                    treeList.element.append(footerWrapper);

                    // Sync footer column widths with header cells exactly
                    const footerCells = footerWrapper.find("td");

                    footerCells.each(function(index) {
                        if (index < headerCells.length) {
                            const width = $(headerCells[index]).outerWidth();
                            $(this).css({
                                'width': width + 'px',
                                'min-width': width + 'px',
                                'max-width': width + 'px',
                                'box-sizing': 'border-box'
                            });
                        }
                    });

                    // Sync the footer table width with content table
                    const contentTable = treeList.tbody.closest('table');
                    footerWrapper.find('table').css('width', contentTable.width() + 'px');

                    // Synchronize horizontal scrolling - move footer content when grid scrolls
                    const contentWrap = treeList.element.find(".k-treelist-content, .k-grid-content");
                    const footerTable = footerWrapper.find("table");

                    // Remove any existing scroll handlers to prevent duplicates
                    contentWrap.off("scroll.footerSync");

                    // Sync footer position when content scrolls (using CSS transform for smooth scrolling)
                    contentWrap.on("scroll.footerSync", function() {
                        const scrollLeft = $(this).scrollLeft();
                        footerTable.css('transform', 'translateX(' + (-scrollLeft) + 'px)');
                    });
                },
