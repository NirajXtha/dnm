       // "UNIT_PRICE",
        "TOTAL_PRICE",
        "CHALAN_QTY",
        "CHALAN_ALT_QTY",
        "SALES_QTY",
        "SALES_ALT_QTY",
        "SALES_VALUE",
        "DUE_QTY"
    ];
    const monthTitles = [
        "Qty", "Alt Qty", "Total Amount",
        "Chalan Qty", "Chalan Alt Qty", "Sales Qty", "Sales Alt Qty", "Sales Amount",
        "Pending Quantity"
    ];

    $.ajax({
        url: readurl,
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify(requestData),
        success: function (response) {
            const rawData = response || [];

            // Use Maps for O(1) lookups and avoid repeated object spreads
            const regionMap = new Map();

            // Pre-init date parser helper (avoid kendo/date ops in hot loop)
            const toDate = (v) => {
                if (!v) return null;
                const d = new Date(v);
                return isNaN(d.getTime()) ? null : d;
            };

            for (let i = 0; i < rawData.length; i++) {
                const item = rawData[i];

                // Normalize once (Dates as Date objects for faster Kendo formatting)
                const orderDate = toDate(item.ORDER_DATE);
                const chalanDate = toDate(item.CHALAN_DATE);
                const salesDate = toDate(item.SALES_DATE);

                // Get or create region (parent)
                let regionNode = regionMap.get(item.CUSTOMER_EDESC);
                if (!regionNode) {
                    const parentId = `region_parent_${String(item.CUSTOMER_EDESC || '').replace(/\s+/g, '_')}`;
                    const totals = {};
                    for (let f = 0; f < monthFields.length; f++) totals[monthFields[f]] = 0;
                    regionNode = {
                        ...totals,
                        CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                        ORDER_NO: item.CUSTOMER_EDESC,
                        MASTER_REGION_CODE: parentId,
                        PRE_REGION_CODE: "",
                        isParent: true,
                        hasChildren: true,
                        products: new Map()
                    };
                    regionMap.set(item.CUSTOMER_EDESC, regionNode);
                }

                // Composite key without formatting/parsing in loop
                const productKey = [
                    item.ORDER_NO || "",
                    item.ORDER_DATE || "",
                    item.MITI || "",
                    item.EMPLOYEE_CODE || "",
                    item.ITEM_CODE || "",
                    item.MU_CODE || ""
                ].join('|');

                let existing = regionNode.products.get(productKey);
                if (!existing) {
                    // Create a lightweight child object, avoid heavy spreading
                    existing = {
                        CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                        ORDER_NO: item.ORDER_NO,
                        ORDER_DATE: orderDate,
                        MITI: item.MITI,
                        EMPLOYEE_CODE: item.EMPLOYEE_CODE,
                        EMPLOYEE_EDESC: item.EMPLOYEE_EDESC,
                        ITEM_CODE: item.ITEM_CODE,
                        ITEM_EDESC: item.ITEM_EDESC,
                        MU_CODE: item.MU_CODE,
                        CHALAN_DATE: chalanDate,
                        CHALAN_NO: item.CHALAN_NO,
                        SALES_DATE: salesDate,
                        SALES_NO: item.SALES_NO,
                        REFERENCE_NO: item.REFERENCE_NO,
                        REFERENCE_SERIAL_NO: item.REFERENCE_SERIAL_NO,
                        MASTER_REGION_CODE: `${String(item.CUSTOMER_EDESC || '').replace(/\s+/g, '_')}_${String(item.ORDER_NO || '').replace(/\W/g,'_')}_${item.ITEM_CODE || ''}_${item.EMPLOYEE_CODE || ''}`,
                        PRE_REGION_CODE: `region_parent_${String(item.CUSTOMER_EDESC || '').replace(/\s+/g, '_')}`,
                        isParent: false
                    };
                    // Initialize numeric fields
                    for (let f = 0; f < monthFields.length; f++) {
                        const fld = monthFields[f];
                        existing[fld] = Number(item[fld]) || 0;
                    }
                    regionNode.products.set(productKey, existing);
                } else {
                    // Aggregate duplicates into the same child
                    for (let f = 0; f < monthFields.length; f++) {
                        const fld = monthFields[f];
                        existing[fld] = (existing[fld] || 0) + (Number(item[fld]) || 0);
                    }
                }

                // Update parent totals (simple sum of raw rows for quick parent view)
                for (let f = 0; f < monthFields.length; f++) {
                    const fld = monthFields[f];
                    regionNode[fld] = (regionNode[fld] || 0) + (Number(item[fld]) || 0);
                }
            }

            // Flatten to TreeList data (parents + merged children)
            const transformedData = [];
            regionMap.forEach(region => {
                const parentNode = { ...region, products: undefined };
                transformedData.push(parentNode);
                region.products.forEach(child => transformedData.push(child));
            });

            // Compute grand totals from merged children only
            const grandTotals = {};
            for (let f = 0; f < monthFields.length; f++) grandTotals[monthFields[f]] = 0;
            regionMap.forEach(region => {
                region.products.forEach(child => {
                    for (let f = 0; f < monthFields.length; f++) {
                        const fld = monthFields[f];
                        grandTotals[fld] += (fld === 'DUE_QTY') ? Math.abs(child[fld] || 0) : (child[fld] || 0);
                    }
                });
            });

            // --- Column Definition ---
            const columns = [
                {
                    field: "ORDER_NO",
                    title: "Customer >>> Order No",
