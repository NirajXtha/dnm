<script>

    var reportConfig = GetReportSetting("NetSalesReport");
    function getDateFormat(date) {
        return kendo.format("{0:" + reportConfig.dateFormat + "}", date);
    }

    $(".applydp").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
    })

    $("#loadAdvancedFilters").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
    });

    $(document).ready(function () {
        window.reportFilters = {
            FormCodeFilter: ""
        };
        window.reportFilters = {
            FormCodeFilter: []
        };


        function clearMultiUnitSelectionAndFilters() {
            var multiSelect = $("#multiUnit").data("kendoMultiSelect");

            // 1. Clear the Kendo MultiSelect component (the visual dropdown)
            if (multiSelect) {
                // Clear the selected value(s) by setting the value to an empty array
                multiSelect.value([]);
                console.log("MultiSelect #multiUnit cleared visually.");
            } else {
                console.error("Kendo MultiSelect #multiUnit not found for clearing.");
            }


            if (window.reportFilters) {
                window.reportFilters.FormCodeFilter = [];
                console.log("Global filter window.reportFilters.FormCodeFilter cleared.");
            }
        }
        $("#filterModalPopup").on("hidden.bs.modal", function () {
            clearMultiUnitSelectionAndFilters();
        });
        // --- Button Click Handler (Applies Filters) ---

        $("#show_rep").on("click", function (e) {
            e.preventDefault();

            var multiSelect = $("#multiUnit").data("kendoMultiSelect");
            var FormCodeFilter = [];

            if (multiSelect) {
                FormCodeFilter = multiSelect.value();
                console.log("MultiSelect values captured:", FormCodeFilter);
            } else {
                console.error("Kendo MultiSelect not found!");
                var rawValue = $("#multiUnit").val();
                FormCodeFilter = rawValue ? (Array.isArray(rawValue) ? rawValue : [rawValue]) : [];
                console.log("Fallback value:", FormCodeFilter);
            }
            window.reportFilters = {
                FormCodeFilter: FormCodeFilter
            };

            console.log("window.reportFilters updated:", window.reportFilters);
            $('#filterModalPopup').modal('hide');
            console.log("Filters applied:", window.reportFilters);
            // Trigger grid refresh
            $("#RunQuery").trigger("click");
        });

        function getReportUrl(reportName) {
            return window.location.protocol + "//" + window.location.host + "/api/SalesHome/Get" + reportName;
        }

        var reportName = $("#reportSelector").val();
        var urltest = getReportUrl(reportName);

        DateFilter.init(function () {
            consolidate.init(function () {
                runGridBinding(reportName, urltest);
            });
        });

        fileMailSender.init();

        $("#RunQuery").click(function (evt) {
            evt.preventDefault();
            reportName = $("#reportSelector").val();
            urltest = getReportUrl(reportName);
            KendoGridRefresh(reportName, urltest);
        });

        $("#reportSelector").change(function () {
            reportName = $(this).val();
            urltest = getReportUrl(reportName);
            runGridBinding(reportName, urltest);
        });

        // Trigger refresh when applying date or advanced filters
        $(".applydp, #loadAdvancedFilters").on("click", function (evt) {
            evt.preventDefault();
            $("#RunQuery").trigger("click");
        });

        function runGridBinding(reportName, url, filters) {
            clearGrid();
            // Get filters from parameter, or default to the global window variable
            const currentFilters = filters || window.reportFilters || {};
            debugger;
            /* KendoGridTree();*/
            switch (reportName) {
                case "DatewisePurchaseDetailReport":
                    BindDatewisePurchaseDetailReportGrid(url, currentFilters);
                    break;
                case "BillwisePurchaseSummaryReport":
                    BindBillwisePurchaseSummaryReportGrid(url, currentFilters);
                    break;
                case "ProductwisePurchaseSummaryReport":
                    BindProductwisePurchaseSummaryReportGrid(url, currentFilters);
                    break;
                case "BillwisePurchaseReturnSummaryReport":
                    BindBillwisePurchaseReturnSummaryReportGrid(url, currentFilters);
                    break;
                case "PurchaseLandedCostSummaryReport":
                    BindPurchaseLandedCostSummaryReportGrid(url, currentFilters);
                    break;
            }
        }

        function KendoGridRefresh(reportName, readUrl) {
            runGridBinding(reportName, readUrl);
        }




            function BindDatewisePurchaseDetailReportGrid(readurl, currentFilters = {}) {
            if ($("#grid").data("kendoGrid")) {
                $("#grid").data("kendoGrid").destroy();
                $("#grid").empty(); // Clear old content to prevent duplicates
            }
            var companyName = ('@workingContent.CurrentUserinformation.company_name');
            var branchName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.branch_name));
            var fromADdate = $("#FromDateVoucher").val();
            var toADdate = $("#ToDateVoucher").val();
            var fromBSdate = $("#fromInputDateVoucher").val();
            var toBSdate = $("#toInputDateVoucher").val();
            var branches = ReportFilter.getBranchs();

            const {
                FormCodeFilter = [],
            } = currentFilters;

            console.log("currentFilters received:", currentFilters);
            console.log("FormCodeFilter extracted:", FormCodeFilter);

            const requestData = {
                // FormCodeFilter is already an array from MultiSelect
                // Ensure it's an array and filter out any empty values
                FormCodeFilter: Array.isArray(FormCodeFilter) ? FormCodeFilter.filter(v => v) : (FormCodeFilter ? [FormCodeFilter] : [])
            };

            console.log("requestData to be sent:", requestData);
            reportConfig = GetReportSetting("DatewisePurchaseDetailReport");
            var dataSource = new kendo.data.DataSource({
                type: "json",
                transport: {
                    read: {
                        url: readurl, // <-- Get data from here.
                        dataType: "json", // <-- The default was "jsonp".
                        type: "POST",
                        contentType: "application/json; charset=utf-8"
                    },
                    parameterMap: function (options, type) {
                        // Get the base filter data
                        var baseData = ReportFilter.filterAdditionalData();

                        // Merge FormCodeFilter into ReportFilters object
                        if (!baseData.ReportFilters) {
                            baseData.ReportFilters = {};
                        }
                        baseData.ReportFilters.FormCodeFilter = requestData.FormCodeFilter;

                        // Merge with kendo options
                        var paramMap = $.extend(options, baseData);

                        delete paramMap.$inlinecount; // <-- remove inlinecount parameter.
                        delete paramMap.$format; // <-- remove format parameter.

                        console.log("Final paramMap being sent:", paramMap);
                        return JSON.stringify(paramMap);
                    }
                },

                error: function (e) {
                    displayPopupNotification("Sorry error occured while processing data", "error");
                },
                serverFiltering: true,
                serverAggregates: true,
                schema: {
                    data: "DateWisePurchase", // records are returned in the "data" field of the response
                    total: function (response) {
                        // Ensure we get the total count of ALL records (not just current page)
                        return response.Total || response.total || (response.DateWisePurchase ? response.DateWisePurchase.length : 0);
                    },
                    aggregates: "AggregationResult",
                    model: {

                        fields: {
                            INVOICE_NO: { type: "string" },
                            MITI: { type: "string" },
                            ORDER_NO: { type: "string" },
                            FORM_CODE: { type: "string" },
                            FISCAL: { type: "string" },
                            PP_NO: { type: "string" },
                            SUPPLIER_INV_NO: { type: "string" },
                            SUPPLIER_CODE: { type: "string" },
                            SUPPLIER_EDESC: { type: "string" },
                            ADDRESS: { type: "string" },
                            TPIN_VAT_NO: { type: "string" },
                            CURRENCY_CODE: { type: "string" },
                            ITEM_CODE: { type: "string" },
                            ITEM_EDESC: { type: "string" },
                            PRODUCT_CODE: { type: "string" },
                            BRAND_NAME: { type: "string" },
                            CATEGORY: { type: "string" },
                            UPC: { type: "string" },
                            HS_CODE: { type: "string" },
                            UNIT: { type: "string" },
                            INVOICE_DATE: { type: "string" },
                            SUPPLIER_INV_DATE: { type: "string" },
                            DUE_DATE: { type: "string" },
                            EXCHANGE_RATE: { type: "number" },
                            INVOICE_TOTAL_PRICE: { type: "number" },
                            QUANTITY: { type: "number" },
                            UNIT_PRICE: { type: "number" },
                            TOTAL_PRICE: { type: "number" },
                            DISCOUNT: { type: "number" },
                            EXCISE_DUTY: { type: "number" },
                            ADD_CHARGE: { type: "number" },
                            TAXABLE_TOTAL_PRICE: { type: "number" },
                            VAT_TOTAL_PRICE: { type: "number" },
                            NON_VAT: { type: "number" },
                            TOTAL_IN_NRS: { type: "number" },
                            LANDED_IN_NRS: { type: "number" }
                        }

                    }
                },
                aggregate: [
                    { field: "QUANTITY", aggregate: "sum" },
                    { field: "TOTAL_PRICE", aggregate: "sum" },
                    { field: "EXCISE_DUTY", aggregate: "sum" },
                    { field: "DISCOUNT", aggregate: "sum" },
                    { field: "TAXABLE_TOTAL_PRICE", aggregate: "sum" },
                    { field: "TOTAL_IN_NRS", aggregate: "sum" },
                    { field: "LANDED_IN_NRS", aggregate: "sum" },
                    { field: "VAT_TOTAL_PRICE", aggregate: "sum" }

                ],

                serverPaging: true,
                //serverSorting: true,
                pageSize: reportConfig.defaultPageSize,
            });
            var grid = $("#grid").kendoGrid({
                dataSource: dataSource,
                toolbar: kendo.template($("#toolbar-template").html()),
                excel: {
                    fileName: "Datewise Purchase DetailReport",
                    allPages: true
                },
                excelExport: function (e) {
                    e.preventDefault();
                    var workbook = e.workbook;
                    var sheet = workbook.sheets[0];

                    // Step 1: Clean the footer (Grand Total) values by removing any HTML tags
                    for (var i = 0; i < sheet.rows.length; i++) {
                        var row = sheet.rows[i];

                        if (row.type === "footer") { // Only for footer rows
                            for (var j = 0; j < row.cells.length; j++) {
                                var cell = row.cells[j];

                                if (cell && cell.value && typeof cell.value === "string") {
                                    // Remove HTML tags and extra spaces
                                    cell.value = cell.value.replace(/<[^>]*>/g, '').trim();

                                    // Optional: if cell is numeric after cleanup, convert it to number
                                    if (!isNaN(cell.value.replace(/,/g, ""))) {
                                        cell.value = parseFloat(cell.value.replace(/,/g, ""));
                                    }
                                }
                            }
                        }
                    }

                    // Step 2: Add custom headers before the data rows
                    // Add date range header
                    sheet.rows.unshift({
                        cells: [{ value: "Date Range: " + fromADdate + " (" + fromBSdate + ")" + " to " + toADdate + " (" + toBSdate + ")", colSpan: 18 }]
                    });


                    // Add Report Name header
                    sheet.rows.unshift({
                        cells: [{ value: "Report Name :- Datewise Purchase Detail", colSpan: 18 }]
                    });

                    // Add Branch Name header
                    sheet.rows.unshift({
                        cells: [{ value: "Branch Name :- " + branchName, colSpan: 18 }]
                    });


                    // Add Company Name header
                    sheet.rows.unshift({
                        cells: [{ value: "Company Name :- " + companyName, colSpan: 18 }]
                    });

                    // Step 3: Create a final Workbook object
                    var WorkbookFinal = new kendo.ooxml.Workbook({
                        sheets: [{
                            columns: [
                                { width: 110 } // Optional: you can set widths properly if you want
                            ],
                            rows: sheet.rows
                        }]
                    });
                    // Step 4: Save the final Excel file
                    kendo.saveAs({
                        dataURI: WorkbookFinal.toDataURL(),
                        fileName: "Datewise Purchase Detail.xlsx"
                    });
                },
                height: window.innerHeight - 50,
                sortable: true,
                reorderable: true,
                groupable: true,
                resizable: true,
                filterable: {
                    extra: false,
                    operators: {
                        number: {
                            eq: "Is equal to",
                            neq: "Is not equal to",
                            gte: "is greater than or equal to	",
                            gt: "is greater than",
                            lte: "is less than or equal",
                            lt: "is less than",
                        },
                        string: {

                            eq: "Is equal to",
                            neq: "Is not equal to",
                            startswith: "Starts with	",
                            contains: "Contains",
                            doesnotcontain: "Does not contain",
                            endswith: "Ends with",
                        },
                        date: {

                            eq: "Is equal to",
                            neq: "Is not equal to",
                            gte: "Is after or equal to",
                            gt: "Is after",
                            lte: "Is before or equal to",
                            lt: "Is before",
                        }
                    }
                },
                columnMenu: true,
                columnMenuInit: function (e) {
                    wordwrapmenu(e);
                    checkboxItem = $(e.container).find('input[type="checkbox"]');
                },
                columnShow: function (e) {
                    if ($(".k-widget.k-reset.k-header.k-menu.k-menu-vertical").is(":visible") && checkboxItem != "")
                        SaveReportSetting('DatewisePurchaseDetailReport', 'grid');
                },
                columnHide: function (e) {
                    if ($(".k-widget.k-reset.k-header.k-menu.k-menu-vertical").is(":visible") && checkboxItem != "")
                        SaveReportSetting('DatewisePurchaseDetailReport', 'grid');
                },
                pageable: {
                    refresh: true,
                    pageSizes: reportConfig.itemPerPage,
                    buttonCount: 5
                },
                scrollable: {
                    virtual: true
                },
                dataBound: function (o) {
                    var grid = o.sender;
                    if (grid.dataSource.total() == 0) {
                        var colCount = grid.columns.length + 1;
                        $(o.sender.wrapper)
                            .find('tbody')
                            .append('<tr class="kendo-data-row" style="font-size:12px;"><td colspan="' + colCount + '" class="alert alert-danger">Sorry, no data :(</td></tr>');
                        displayPopupNotification("No Data Found Given Date Filter.", "info");
                    }
                    else {
                        //var g = $("#grid").data("kendoGrid");
                        //for (var i = 0; i < g.columns.length; i++) {
