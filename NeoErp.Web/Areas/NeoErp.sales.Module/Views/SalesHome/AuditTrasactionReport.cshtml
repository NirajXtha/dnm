    function KendoGridRefresh(readUrl) {
        // Properly destroy the existing Kendo Grid before recreating it.
        // Without this, each call stacks a new grid instance — each one fires
        // its own excelExport event, causing multiple simultaneous downloads.
        var existingGrid = $('#grid').data('kendoGrid');
        if (existingGrid) {
            existingGrid.destroy();
        }
        $('#grid').html('');
        BindGrid(readUrl);
    }
