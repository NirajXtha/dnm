    $(document).ready(function () {
        // Declare urltest BEFORE the callback so it is defined when BindGrid runs
        var urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetAuditTrasactionReport";

        DateFilter.init(function () {
            consolidate.init(function () {
                BindGrid(urltest);
            });
        });

        fileMailSender.init();

        $("#RunQuery").click(function (evt) {
            evt.preventDefault();
            urltest = window.location.protocol + "//" + window.location.host + "/api/SalesHome/GetAuditTrasactionReport";
            KendoGridRefresh(urltest);
        });
    });

    function BindGrid(readurl) {
        // Always destroy any existing grid instance before creating a new one.
        // This prevents stacked instances (each firing their own excelExport) when
        // BindGrid is called multiple times (by ManualEmailSender, RunQuery, page load etc.)
