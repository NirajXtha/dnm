        function BindSupplierwiseNetPurchaseReportGrid(readurl) {
                var companyName = '@workingContent.CurrentUserinformation.company_name';
                var branchName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.branch_name));
                var fromADdate = $("#FromDateVoucher").val();
                var toADdate = $("#ToDateVoucher").val();
                var fromBSdate = $("#fromInputDateVoucher").val();
                var toBSdate = $("#toInputDateVoucher").val();
                var branches = ReportFilter.getBranchs();

                const requestData = {
                    company_name: companyName,
                    fromADdate,
                    toADdate,
                    fromBSdate,
                    toBSdate,
                    branches,
                };

                // Define fields outside the loop for better performance
                const monthFields = [
                    "OPENING",
                    "BALANCE",
                    "SALES_QTY",
                    "SALES_VALUE",
                    "SALES_RET_QTY",
                    "SALES_RET_VALUE",
                    "NET_SALES_QTY",
                    "NET_SALES_VALUE"
                ];
                const monthTitles = [
                    "Opening", "Balance", "Purchase Quantity", "Purchase Value", "Purchase Return Quantity", "Purchase Return Value",
                    "Net Purchase Quantity", "Net Purchase Value"
                ];

                $.ajax({
                    url: readurl,
                    method: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(requestData),
                    success: function (response) {
                        const rawData = response || [];

                        // Use Map for O(1) lookups
                        const regionMap = new Map();

                        for (let i = 0; i < rawData.length; i++) {
                            const item = rawData[i];
                            const groupKey = item.CUSTOMER_EDESC;

                            // Get or create region (parent)
                            let regionNode = regionMap.get(groupKey);
                            if (!regionNode) {
                                const parentId = `region_parent_${String(groupKey || '').replace(/\s+/g, '_')}`;
                                const totals = {};
                                for (let f = 0; f < monthFields.length; f++) totals[monthFields[f]] = 0;

                                regionNode = {
                                    ...totals,
                                    CUSTOMER_EDESC: groupKey,
                                    ITEM_EDESC: groupKey,
                                    MASTER_REGION_CODE: parentId,
                                    PRE_REGION_CODE: "",
                                    isParent: true,
                                    hasChildren: true,
                                    products: new Map()
                                };
                                regionMap.set(groupKey, regionNode);
                            }

                            // Use PRODUCT_CODE as key (not ITEM_CODE)
                            const productKey = item.PRODUCT_CODE || item.ITEM_EDESC;

                            let existing = regionNode.products.get(productKey);
                            if (!existing) {
                                // Create child product node
                                existing = {
                                    CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                                    ITEM_EDESC: item.ITEM_EDESC,
                                    PRODUCT_CODE: item.PRODUCT_CODE,
                                    INDEX_MU_CODE: item.INDEX_MU_CODE,
                                    MASTER_REGION_CODE: `${String(groupKey || '').replace(/\s+/g, '_')}_${productKey}`,
                                    PRE_REGION_CODE: `region_parent_${String(groupKey || '').replace(/\s+/g, '_')}`,
                                    isParent: false
                                };
                                // Initialize numeric fields
                                for (let f = 0; f < monthFields.length; f++) {
                                    const fld = monthFields[f];
                                    existing[fld] = Number(item[fld]) || 0;
                                }
                                regionNode.products.set(productKey, existing);
                            } else {
                                // Aggregate duplicates
                                for (let f = 0; f < monthFields.length; f++) {
                                    const fld = monthFields[f];
                                    existing[fld] = (existing[fld] || 0) + (Number(item[fld]) || 0);
                                }
                            }

                            // Update parent totals
                            for (let f = 0; f < monthFields.length; f++) {
                                const fld = monthFields[f];
                                regionNode[fld] = (regionNode[fld] || 0) + (Number(item[fld]) || 0);
                            }
                        }

                        // Flatten to TreeList data
                        const transformedData = [];
                        regionMap.forEach(region => {
                            const parentNode = { ...region, products: undefined };
                            transformedData.push(parentNode);
                            region.products.forEach(child => transformedData.push(child));
                        });

                        // Calculate grand totals from merged children only
                        const grandTotals = {};
                        for (let f = 0; f < monthFields.length; f++) grandTotals[monthFields[f]] = 0;
                        regionMap.forEach(region => {
                            region.products.forEach(child => {
                                for (let f = 0; f < monthFields.length; f++) {
                                    const fld = monthFields[f];
                                    grandTotals[fld] += (child[fld] || 0);
                                }
                            });
                        });

                        // --- Column Definition ---

                        const columns = [
                            {
                                field: "ITEM_EDESC",
                                title: "Supplier Description",
                                width: 300,
                                //locked: true,
                                template: function (dataItem) {
                                    return dataItem.isParent ? `<b>${dataItem.CUSTOMER_EDESC}</b>` : `&nbsp;&nbsp;&nbsp;&nbsp; ${dataItem.ITEM_EDESC}`;
                                }
                            },
                            //{
                            //    field: "TPIN_VAT_NO",
                            //    title: "PAN",
                            //    width: 80,
                            //    template: function (dataItem) {
                            //        return dataItem.isParent ? "" : (dataItem.INDEX_MU_CODE && dataItem.TPIN_VAT_NO !== "None" ? dataItem.TPIN_VAT_NO : "");
                            //    }
                            //},
                            {
                                field: "INDEX_MU_CODE",
                                title: "UOM",
                                width: 80,
                                template: function (dataItem) {
                                    return dataItem.isParent ? "" : (dataItem.INDEX_MU_CODE && dataItem.INDEX_MU_CODE !== "None" ? dataItem.INDEX_MU_CODE : "");
                                }
                            }

                        ];

                        // Add numeric columns
                        for (let i = 0; i < monthFields.length; i++) {
                            columns.push({
                                field: monthFields[i],
                                title: monthTitles[i],
                                width: 130,
                                attributes: { style: "text-align:right;" },
                                template: function (dataItem) {
                                    return kendo.format("{0:N2}", dataItem[monthFields[i]] || 0);
                                }
                            });
                        }

                        const $grid = $("#grid");
                        const existingTreeList = $grid.data("kendoTreeList");
                        if (existingTreeList) {
                            existingTreeList.destroy();
                            $grid.empty();
                        }

                        $grid.kendoTreeList({
                            dataSource: new kendo.data.TreeListDataSource({
                                data: transformedData,
                                schema: {
                                    model: {
                                        id: "MASTER_REGION_CODE",
                                        parentId: "PRE_REGION_CODE",
                                        fields: {
                                            // Descriptive/Code Fields
                                            ITEM_EDESC: { type: "string" },
                                            PRODUCT_CODE: { type: "string" },
                                            INDEX_MU_CODE: { type: "string" },
                                            CUSTOMER_EDESC: { type: "string" },
                                            MASTER_REGION_CODE: { type: "string" },
                                            PRE_REGION_CODE: { type: "string" },
                                            TPIN_VAT_NO: { type: "string" },
                                            // Quantity and Value Fields (Treated as 'number' with default 0)
                                            BALANCE: { type: "number", defaultValue: 0 },
                                            OPENING: { type: "number", defaultValue: 0 },
                                            SALES_QTY: { type: "number", defaultValue: 0 },
                                            SALES_VALUE: { type: "number", defaultValue: 0 },
                                            SALES_RET_QTY: { type: "number", defaultValue: 0 },
                                            SALES_RET_VALUE: { type: "number", defaultValue: 0 },
                                            DEBIT_VALUE: { type: "number", defaultValue: 0 },
                                            CREDIT_VALUE: { type: "number", defaultValue: 0 },
                                            FREE_QTY: { type: "number", defaultValue: 0 },
                                            NET_SALES_QTY: { type: "number", defaultValue: 0 },
                                            NET_SALES_VALUE: { type: "number", defaultValue: 0 }
                                        }
                                    }
                                },
                                aggregate: []
                            }),
                            dataBound: function (e) {
                                const treeList = this;

                                // Remove existing footer if any
                                treeList.element.find(".k-grid-footer").remove();

                                // Create footer wrapper with proper structure
                                const footerWrapper = $('<div class="k-grid-footer"><div class="k-grid-footer-wrap" style="overflow: hidden;"><table><tbody></tbody></table></div></div>');
                                const footerRow = $("<tr class='k-footer-template'/>");

                                // Get header cells to match exact column structure
                                const headerCells = treeList.thead.find("th");

                                // Column 1: ITEM_EDESC - show "Grand Total"
                                footerRow.append(`<td style="text-align:left; padding-left:10px;"><b>Grand Total</b></td>`);

                                // Column 2: PRODUCT_CODE (empty)
                                footerRow.append(`<td></td>`);

                                // Column 3: INDEX_MU_CODE (empty)
                                footerRow.append(`<td></td>`);

                                // Add numeric columns
                                for (let i = 0; i < monthFields.length; i++) {
                                    footerRow.append(`<td style="text-align:right; padding-right:10px;"><b>${kendo.format("{0:N2}", grandTotals[monthFields[i]] || 0)}</b></td>`);
                                }

                                // Append footer row and add to grid
                                footerWrapper.find("tbody").append(footerRow);
                                treeList.element.append(footerWrapper);

                                // Sync footer column widths with header cells
                                const footerCells = footerWrapper.find("td");
                                footerCells.each(function (index) {
                                    if (index < headerCells.length) {
                                        const width = $(headerCells[index]).outerWidth();
                                        $(this).css({
                                            'width': width + 'px',
                                            'min-width': width + 'px',
                                            'max-width': width + 'px',
                                            'box-sizing': 'border-box'
                                        });
                                    }
                                });

                                // Sync the footer table width with content table
                                const contentTable = treeList.tbody.closest('table');
                                footerWrapper.find('table').css('width', contentTable.width() + 'px');

                                // Synchronize horizontal scrolling
                                const contentWrap = treeList.element.find(".k-treelist-content, .k-grid-content");
                                const footerTable = footerWrapper.find("table");

                                // Remove any existing scroll handlers to prevent duplicates
                                contentWrap.off("scroll.footerSync");

                                // Sync footer position when content scrolls
                                contentWrap.on("scroll.footerSync", function () {
                                    const scrollLeft = $(this).scrollLeft();
                                    footerTable.css('transform', 'translateX(' + (-scrollLeft) + 'px)');
                                });
                            },
                            toolbar: ["excel"],
                            excel: {
                                fileName: "Supplierwise NetPurchase.xlsx",
                                allPages: true,
                                filterable: true
                            },
                            excelExport: function (e) {
                                // 1. Initialize core workbook objects
                                var sheet = e.workbook.sheets[0];
                                var customRows = [];

                                // 2. Define totalColumns within this scope to prevent ReferenceErrors
                                var totalColumns = e.sender.columns.length;

                                // 3. Create the header rows matching the reference image layout
                                // Row 1: Company Name (Matches Screenshot A1)
                                customRows.push({
                                    cells: [{
                                        value: "Company Name :- " + (companyName || ""),
                                        bold: true,
                                        colSpan: totalColumns
                                    }]
                                });

                                // Row 2: Branch Name (Matches Screenshot A2)
                                // Using the branchName variable already initialized at the top of your function
                                customRows.push({
                                    cells: [{
                                        value: "Branch Name :- " + (branchName || ""),
                                        bold: true,
                                        colSpan: totalColumns
                                    }]
                                });

                                // Row 3: Report Name (Matches Screenshot A3)
                                customRows.push({
                                    cells: [{
                                        value: "Report Name :- Supplierwise NetPurchase",
                                        bold: true,
                                        colSpan: totalColumns
                                    }]
                                });

                                // Row 4: Date Range (Matches Screenshot A4)
                                customRows.push({
                                    cells: [{
                                        value: "Date Range: " + fromADdate + " (" + fromBSdate + ") to " + toADdate + " (" + toBSdate + ")",
                                        bold: true,
                                        colSpan: totalColumns
                                    }]
                                });

                                // Row 5: Empty spacer row to match image spacing
                                customRows.push({
                                    cells: [{ value: "", colSpan: totalColumns }]
                                });

                                // 4. Prepend the header rows to the spreadsheet
                                Array.prototype.unshift.apply(sheet.rows, customRows);

                                // 5. Build and append the Grand Total row at the bottom
                                var currentData = this.dataSource.data();
                                var currentGrandTotals = {};

                                // Initialize totals for numeric fields
                                monthFields.forEach(function (field) {
                                    currentGrandTotals[field] = 0;
                                });

                                // Sum leaf nodes only to ensure accuracy
                                currentData.forEach(function (item) {
                                    if (!item.isParent) {
                                        monthFields.forEach(function (field) {
                                            currentGrandTotals[field] += (Number(item[field]) || 0);
                                        });
                                    }
                                });

                                var grandTotalRow = { cells: [] };

                                // colSpan 3 aligns the "Grand Total" label under Product Group, Product Id, and UOM
                                grandTotalRow.cells.push({ value: "Grand Total", bold: true, colSpan: 3 });

                                // Append numeric totals with proper Excel formatting
                                monthFields.forEach(function (field) {
                                    grandTotalRow.cells.push({
                                        value: currentGrandTotals[field],
                                        type: "number",
                                        format: "#,##0.00",
                                        bold: true
                                    });
                                });

                                sheet.rows.push(grandTotalRow);
                            },
                            height: 450,
                            columns: columns,
                            filterable: {
                                mode: "row",
                                multi: true,
                                search: true,
                                extra: false
                            },
                            sortable: true,
                            reorderable: true,
                            editable: false,
                            resizable: true
                        });

                        // Add search functionality to the toolbar
                        const toolbar = $("#grid").closest(".k-grid").find(".k-grid-toolbar");
                        if (toolbar.length > 0) {
                            toolbar.append(
                                '<div style="float: right; margin-left: 10px; position: relative;">' +
                                '<input type="text" id="treelist-global-search" placeholder="Search..." style="width: 250px; padding: 5px 30px 5px 10px;" class="k-textbox" />' +
                                '<span class="k-icon k-i-search" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); pointer-events: none;"></span>' +
                                '</div>'
                            );
                        }

                        // Optimized filter function
                        function filterTreeWithParentsOptimized(dataSource, searchTerm) {
                            if (!searchTerm || searchTerm.trim() === "") {
                                // Clear all filters
                                dataSource.filter({});
                                return;
                            }

                            // Create filter conditions for all searchable fields
                            const filters = {
                                logic: "or",
                                filters: [
                                    { field: "ITEM_EDESC", operator: "contains", value: searchTerm },
                                    { field: "PRODUCT_CODE", operator: "contains", value: searchTerm },
                                    { field: "CUSTOMER_EDESC", operator: "contains", value: searchTerm },
                                    { field: "INDEX_MU_CODE", operator: "contains", value: searchTerm }
                                ]
                            };

                            // Apply the filter to the dataSource
                            dataSource.filter(filters);
                        }

                        // Debounced search
                        let searchTimeout;
                        $("#treelist-global-search").off("input").on("input", function () {
                            const searchValue = $(this).val().toLowerCase().trim();
                            const treeList = $("#grid").data("kendoTreeList");
                            clearTimeout(searchTimeout);
                            searchTimeout = setTimeout(function () {
                                if (treeList && treeList.dataSource) {
                                    filterTreeWithParentsOptimized(treeList.dataSource, searchValue);
                                }
                            }, 300);
                        });
                    },
                    error: function (err) {
                        console.error("Failed to load data:", err);
                        alert("Failed to load data. Please check console for details.");
                    }
                });
            }

            function clearGrid() {
            var gridElement = $("#grid");

            // Check if a Kendo Grid exists and destroy it
            var kendoGrid = gridElement.data("kendoGrid");
            if (kendoGrid) {
                kendoGrid.destroy();
            }

            // Check if a Kendo TreeList exists and destroy it
            var kendoTreeList = gridElement.data("kendoTreeList");
            if (kendoTreeList) {
                kendoTreeList.destroy();
            }

            // Finally, empty the grid container
            gridElement.empty();
        }
         // Initialize Universal Grid Print
                var companyName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.company_name));
                var branchName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.branch_name));

                const REPORT_DISPLAY_NAMES = {
                    "ProductwiseNetPurchaseReport": "Productwise NetPurchase Report",
                    "DatewiseNetPurchaseReport": "Datewise NetPurchase Report",
                    "PurchaseAboveOneLakh": "Purchase Above OneLakh",
                    "SupplierwiseNetPurchaseReport": "Supplierwise NetPurchase Report",
                    };

                UniversalGridPrint.init({
                    reportName: function() {
                        const value = $("#reportSelector").val();
                        return REPORT_DISPLAY_NAMES[value] || value;
                    },
                    companyName: companyName,
                    branchName: branchName
                });


    });




</script>


