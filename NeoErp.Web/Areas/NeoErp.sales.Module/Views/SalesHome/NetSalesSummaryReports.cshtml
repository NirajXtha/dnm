       function filterTreeWithParentsOptimized(data, searchTerm) {
            if (!searchTerm || !searchTerm.trim()) return data;

            const term = searchTerm.toLowerCase().trim();
            const matchedIds = new Set();

            // First pass: find all matching items
            for (let i = 0; i < data.length; i++) {
                const item = data[i];

                // Check if any searchable field matches
                const matches = (
                    (item.REGION_EDESC && item.REGION_EDESC.toLowerCase().includes(term)) ||
                    (item.EMPLOYEE_EDESC && item.EMPLOYEE_EDESC.toLowerCase().includes(term)) ||
                    (item.EMPLOYEE_CODE && item.EMPLOYEE_CODE.toLowerCase().includes(term)) ||
                    (item.INDEX_MU_CODE && item.INDEX_MU_CODE.toLowerCase().includes(term))
                );

                if (matches) {
                    matchedIds.add(item.MASTER_REGION_CODE);
                    // Also add parent if this is a child
                    if (item.PRE_REGION_CODE) {
                        matchedIds.add(item.PRE_REGION_CODE);
                    }
                }
            }

            // Second pass: return filtered data
            return data.filter(item => matchedIds.has(item.MASTER_REGION_CODE));
        }
       function filterTreeWithParents(data, searchTerm) {
            if (!searchTerm) return data;

            const term = searchTerm.toLowerCase();

            // Quick parent lookup: { MASTER_ITEM_CODE: item }
            const lookup = Object.fromEntries(
                data.map(item => [item.MASTER_ITEM_CODE, item])
            );

            const matchedIds = new Set();

            function markMatches(item) {
                const isMatch = Object.values(item).some(
                    val => typeof val === 'string' && val.toLowerCase().includes(term)
                );

                if (isMatch) {
                    // Bubble up: add this item and all its ancestors
                    let current = item;
                    while (current) {
                        matchedIds.add(current.MASTER_ITEM_CODE);
                        current = lookup[current.PRE_ITEM_CODE];
                    }
                }
            }

            data.forEach(markMatches);
            return data.filter(item => matchedIds.has(item.MASTER_ITEM_CODE));
        }
