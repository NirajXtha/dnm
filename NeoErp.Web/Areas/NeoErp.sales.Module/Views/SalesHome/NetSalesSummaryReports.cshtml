       function filterTreeWithParentsOptimizedEmployee(data, searchTerm) {
            if (!searchTerm || !searchTerm.trim()) return data;

            const term = searchTerm.toLowerCase().trim();
            const matchedIds = new Set();

            // First pass: find all matching items
            for (let i = 0; i < data.length; i++) {
                const item = data[i];

                // Check if any searchable field matches for employee-product data
                const matches = (
                    (item.EMPLOYEE_EDESC && item.EMPLOYEE_EDESC.toLowerCase().includes(term)) ||
                    (item.EMPLOYEE_CODE && item.EMPLOYEE_CODE.toLowerCase().includes(term)) ||
                    (item.ITEM_EDESC && item.ITEM_EDESC.toLowerCase().includes(term)) ||
                    (item.ITEM_CODE && item.ITEM_CODE.toLowerCase().includes(term)) ||
                    (item.INDEX_MU_CODE && item.INDEX_MU_CODE.toLowerCase().includes(term))
                );

                if (matches) {
                    matchedIds.add(item.MASTER_EMPLOYEE_CODE);
                    // Also add parent if this is a child
                    if (item.PRE_EMPLOYEE_CODE) {
                        matchedIds.add(item.PRE_EMPLOYEE_CODE);
                    }
                }
            }

            // Second pass: return filtered data
            return data.filter(item => matchedIds.has(item.MASTER_EMPLOYEE_CODE));
        }
