                        treeData.push(itemNode);

                        // Aggregate values up the tree
                        monthFields.forEach(f => {
                            const value = Number(item[f]) || 0;
                            customerMap[custKey][f] += value;
                            employeeMap[empKey][f] += value;
                            grandTotals[f] += value;
                        });
