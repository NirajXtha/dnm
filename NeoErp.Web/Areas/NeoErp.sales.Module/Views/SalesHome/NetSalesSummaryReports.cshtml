                                    id: "id",
                                    parentId: "parentId",
                                    fields: {
                                        ITEM_CODE: {
                                            type: "string"
                                        },
                                        ITEM_EDESC: {
                                            type: "string"
                                        },
                                        EMPLOYEE_EDESC: {
                                            type: "string"
                                        },
                                        CUSTOMER_EDESC: {
                                            type: "string"
                                        },
                                        INDEX_MU_CODE: {
                                            type: "string"
                                        },
                                        // Add all numeric fields
                                        ...monthFields.reduce((acc, field) => {
                                            acc[field] = {
                                                type: "number",
                                                defaultValue: 0
                                            };
                                            return acc;
                                        }, {})
                                    }
                                }
