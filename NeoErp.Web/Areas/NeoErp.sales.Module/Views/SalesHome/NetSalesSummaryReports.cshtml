                                CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                                nodeType: "customer",
                                hasChildren: true
                            };
                            monthFields.forEach(f => custNode[f] = 0);
                            customerMap[custKey] = custNode;
                            treeData.push(custNode);
                        }

                        // --- Level 3: Item Node (Leaf) ---
                        const itemNode = {
                            id: `item_${custKey}_${item.ITEM_CODE}`,
                            parentId: `cust_${custKey}`,
                            ITEM_EDESC: item.ITEM_EDESC,
                            ITEM_CODE: item.ITEM_CODE,
                            INDEX_MU_CODE: item.INDEX_MU_CODE,
                            nodeType: "item",
                            hasChildren: false
                        };
                        monthFields.forEach(f => {
                            itemNode[f] = Number(item[f]) || 0;
