                    response.forEach(item => {
                        const empKey = item.EMPLOYEE_CODE || item.EMPLOYEE_EDESC;
                        const custKey = `${empKey}|${item.CUSTOMER_CODE || item.CUSTOMER_EDESC}`;

                        // --- Level 1: Employee Node ---
                        if (!employeeMap[empKey]) {
