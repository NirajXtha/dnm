        function BindMonthwiseCustomerProductNetSalesGrid(readurl, currentFilters = {}) {
    var companyName = '@workingContent.CurrentUserinformation.company_name';
    var fromADdate = $("#FromDateVoucher").val();
    var toADdate = $("#ToDateVoucher").val();
    var fromBSdate = $("#fromInputDateVoucher").val();
    var toBSdate = $("#toInputDateVoucher").val();
    var branchname = '@workingContent.CurrentUserinformation.branch_name';
    let grandTotalAppendedFlag = false;
        const {
                FormCodeFilter = [],
            } = currentFilters;

            console.log("currentFilters received:", currentFilters);
            console.log("FormCodeFilter extracted:", FormCodeFilter);
    const requestData = {
        company_name: companyName,
        fromADdate,
        toADdate,
        fromBSdate,
        toBSdate,
        branches: branchname,
        FormCodeFilter
    };

       $.ajax({
           url: readurl,
           method: "POST",
           contentType: "application/json",
           data: JSON.stringify(requestData),
           success: function (response) {
               console.log("Original TreeList Data:", response);

               const grandRow = response.find(x =>
                   x.CUSTOMER_CODE && x.CUSTOMER_EDESC.toLowerCase().includes("grand total")
               );
               const rawData = response.filter(x =>
                   !(x.CUSTOMER_CODE && x.CUSTOMER_EDESC.toLowerCase().includes("grand total"))
               );
               const grandRowData = grandRow;

               const transformData = (data) => {
                   // Build lookup maps for performance optimization
                   const childrenByCusCode = new Map();
                   const itemsByMasterCode = new Map();

                   // Pre-build maps in a single pass
                   data.forEach(item => {
                       itemsByMasterCode.set(item.MASTER_CUSTOMER_CODE, item);
                       if (item.CUS_CODE) {
                           if (!childrenByCusCode.has(item.CUS_CODE)) {
                               childrenByCusCode.set(item.CUS_CODE, []);
                           }
                           childrenByCusCode.get(item.CUS_CODE).push(item);
                       }
                   });

                   const arBrothersLookup = {};
                   const tempTransformedData = [];

                   // First pass: Identify "A.R. Brothers" and regular groups/items using Map lookup
                   data.forEach(item => {
                       const children = childrenByCusCode.get(item.CUSTOMER_CODE) || [];
                       const hasChildrenMatchingCusCode = children.some(child =>
                           child.MASTER_CUSTOMER_CODE !== item.MASTER_CUSTOMER_CODE
                       );

                       if (item.GROUP_SKU_FLAG === "I" && hasChildrenMatchingCusCode) {
                           tempTransformedData.push({ ...item, hasChildren: true });
                           arBrothersLookup[item.CUSTOMER_CODE] = item.MASTER_CUSTOMER_CODE;
                       } else {
                           tempTransformedData.push({ ...item, hasChildren: false });
                       }
                   });

                   // Second pass: Re-parent items to "A.R. Brothers" if necessary
                   const reParentedData = tempTransformedData.map(item => {
                       const isItemToReparent = item.GROUP_SKU_FLAG === "I" && item.CUS_CODE && arBrothersLookup[item.CUS_CODE];
                       const isNotSelfParent = isItemToReparent && item.MASTER_CUSTOMER_CODE !== arBrothersLookup[item.CUS_CODE];

                       if (isItemToReparent && isNotSelfParent) {
                           return { ...item, PRE_CUSTOMER_CODE: arBrothersLookup[item.CUS_CODE] };
                       }
                       return item;
                   });

                   // Third pass: Create subgroups for leaf nodes with a different CUSTOMER_CODE than their parent
                   // Use Map for O(1) parent lookups instead of array.find()
                   const finalTransformedData = [];
                   const newGroups = new Map();
                   const processedItems = new Map();

                   reParentedData.forEach(item => {
                       // Use Map for fast parent lookup
                       const parent = processedItems.get(item.PRE_CUSTOMER_CODE);

                       // Skip creating subgroup if:
                       // 1. No parent exists
                       // 2. Item already has children (it's already a group node)
                       // 3. Item's CUSTOMER_CODE matches parent's CUSTOMER_CODE
                       // 4. Item's CUSTOMER_EDESC matches parent's CUSTOMER_EDESC (prevents duplicate like 'WESTERN REGION')
                       // 5. Item doesn't have ITEM_EDESC (it's a group, not a product)
                       const shouldSkipSubgroup = !parent
                           || item.hasChildren
                           || item.CUSTOMER_CODE === parent.CUSTOMER_CODE
                           || item.CUSTOMER_EDESC === parent.CUSTOMER_EDESC
                           || !item.ITEM_EDESC;

                       if (!shouldSkipSubgroup) {
                           const groupKey = `${item.PRE_CUSTOMER_CODE}-${item.CUSTOMER_CODE}`;

                           if (!newGroups.has(groupKey)) {
                               // Create a new subgroup for this customer_code
                               const newGroupId = `group_${item.PRE_CUSTOMER_CODE}_${item.CUSTOMER_CODE}`;
                               const newGroup = {
                                   MASTER_CUSTOMER_CODE: newGroupId,
                                   PRE_CUSTOMER_CODE: item.PRE_CUSTOMER_CODE,
                                   CUSTOMER_CODE: item.CUSTOMER_CODE,
                                   CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                                   hasChildren: true,
                               };
                               finalTransformedData.push(newGroup);
                               processedItems.set(newGroupId, newGroup);
                               newGroups.set(groupKey, newGroupId);
                           }

                           // Reassign the leaf node to the new subgroup
                           const updatedItem = {
                               ...item,
                               PRE_CUSTOMER_CODE: newGroups.get(groupKey),
                               hasChildren: false
                           };
                           finalTransformedData.push(updatedItem);
                           processedItems.set(updatedItem.MASTER_CUSTOMER_CODE, updatedItem);
                       } else {
                           // Add item as is
                           finalTransformedData.push(item);
                           processedItems.set(item.MASTER_CUSTOMER_CODE, item);
                       }
                   });

                   return finalTransformedData;
               };

               // Prepare data with a precomputed search blob for fast filtering
               const transformedData = transformData(rawData).map(it => ({
                   ...it,
                   __search: ((it.CUSTOMER_EDESC || '') + ' ' + (it.ITEM_EDESC || '') + ' ' + (it.ITEM_CODE || '') + ' ' + (it.CUSTOMER_CODE || '')).toLowerCase()
               }));
               console.log("Transformed TreeList Data:", transformedData);
               console.log(JSON.stringify(transformedData));

               // Cached maps for fast hierarchy lookups during search
               let byIdCache = null;
               let childrenByParentCache = null;
               let isFiltering = false;
               let searchingActive = false;

               // Hierarchical filter that includes ancestors and (for group/root) descendants
               const filterTreeWithParents = (data, searchValue) => {
                   const term = String(searchValue || '').toLowerCase().trim();
                   if (!term || term.length < 2) return data; // min 2 chars

                   // Build caches once
                   if (!byIdCache || !childrenByParentCache) {
                       byIdCache = new Map();
                       childrenByParentCache = new Map();
                       for (const row of data) {
                           byIdCache.set(row.MASTER_CUSTOMER_CODE, row);
                           const pid = row.PRE_CUSTOMER_CODE || null;
                           if (!childrenByParentCache.has(pid)) childrenByParentCache.set(pid, []);
                           childrenByParentCache.get(pid).push(row);
                       }
                   }

                   const filtered = [];
                   const added = new Set();

                   const addWithAncestors = (row) => {
                       const stack = [];
                       let current = row;
                       while (current) {
                           stack.unshift(current);
                           if (!current.PRE_CUSTOMER_CODE) break;
                           current = byIdCache.get(current.PRE_CUSTOMER_CODE);
                       }
                       for (const x of stack) {
                           if (!added.has(x.MASTER_CUSTOMER_CODE)) {
                               filtered.push(x);
                               added.add(x.MASTER_CUSTOMER_CODE);
                           }
                       }
                   };

                   const addDescendants = (parentId) => {
                       const kids = childrenByParentCache.get(parentId) || [];
                       for (const k of kids) {
                           if (!added.has(k.MASTER_CUSTOMER_CODE)) {
                               filtered.push(k);
                               added.add(k.MASTER_CUSTOMER_CODE);
                           }
                           addDescendants(k.MASTER_CUSTOMER_CODE);
                       }
                   };

                   const MAX_RESULTS = 6000;
                   for (const item of data) {
                       // Skip any grand total-like rows
                       if (item.CUSTOMER_EDESC && item.CUSTOMER_EDESC.toLowerCase().includes('grand total')) continue;

                       const hay = item.__search != null ? item.__search : ((item.CUSTOMER_EDESC || '') + ' ' + (item.ITEM_EDESC || '') + ' ' + (item.ITEM_CODE || '') + ' ' + (item.CUSTOMER_CODE || '')).toLowerCase();
                       if (hay.includes(term)) {
                           addWithAncestors(item);
                           // Only include subtree when item is a group/root
                           if (!item.PRE_CUSTOMER_CODE || item.GROUP_SKU_FLAG === 'G' || item.hasChildren) {
                               addDescendants(item.MASTER_CUSTOMER_CODE);
                           }
                       }
                       if (filtered.length > MAX_RESULTS) break;
                   }

                   return filtered;
               };

               const getItemDepth = (dataItem, allTransformedData) => {
                   let depth = 0;
                   let currentItem = dataItem;
                   while (currentItem && currentItem.PRE_CUSTOMER_CODE) {
                       const parent = allTransformedData.find(d => d.MASTER_CUSTOMER_CODE === currentItem.PRE_CUSTOMER_CODE);
                       if (parent) {
                           depth++;
                           currentItem = parent;
                       } else {
                           break;
                       }
                   }
                   return depth;
               };

               const getCustomerProductTemplate = (dataItem) => {
                   const depth = getItemDepth(dataItem, transformedData);
                   let content;
                   let paddingLeft = 0;

                   if (dataItem.GROUP_SKU_FLAG === "I") {
                       const isArBrothersLikeGroup = dataItem.hasChildren && !dataItem.ITEM_EDESC;
                       content = isArBrothersLikeGroup
                           ? `<b>${dataItem.CUSTOMER_EDESC}</b>`
                           : dataItem.ITEM_EDESC;
                   } else {
                       content = dataItem.CUSTOMER_EDESC || "";
                   }

                   const indentStep = 20;
                   paddingLeft = depth * indentStep;

                   return `<span style="padding-left: ${paddingLeft}px;">${content}</span>`;
               };

               const columns = [
                   {
                       field: "CUSTOMER_EDESC",
                       title: "Customer >>> Product",
                       template: getCustomerProductTemplate,
                       width: 400,
                       locked: true
                   },
                   { field: "ITEM_CODE", title: "Code", width: 80 },
                   {
                       field: "INDEX_MU_CODE",
                       title: "Unit",
                       width: 80,
                       template: dataItem => dataItem.INDEX_MU_CODE && dataItem.INDEX_MU_CODE !== "None" ? dataItem.INDEX_MU_CODE : ""
                   },
                   { field: "S_QTY", title: "Shrawan Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "S_VALUE", title: "Shrawan Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "B_QTY", title: "Bhadra Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "B_VALUE", title: "Bhadra Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "A_QTY", title: "Ashoj Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "A_VALUE", title: "Ashoj Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "K_QTY", title: "Karthik Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "K_VALUE", title: "Karthik Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "M_QTY", title: "Mangsir Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "M_VALUE", title: "Mangsir Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "P_QTY", title: "Poush Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "P_VALUE", title: "Poush Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Mg_QTY", title: "Magh Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Mg_VALUE", title: "Magh Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "F_QTY", title: "Falgun Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "F_VALUE", title: "Falgun Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "C_QTY", title: "Chaitra Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "C_VALUE", title: "Chaitra Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Bh_QTY", title: "Baisakh Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Bh_VALUE", title: "Baisakh Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "J_QTY", title: "Jseth Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "J_VALUE", title: "Jesth Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Aa_QTY", title: "Asar Quantity", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } },
                   { field: "Aa_VALUE", title: "Asar Value", width: 130, format: "{0:N2}", attributes: { style: "text-align:right;" } }
               ];

               const $grid = $("#grid");
               const existingTreeList = $grid.data("kendoTreeList");
               if (existingTreeList) {
                   existingTreeList.destroy();
                   $grid.empty();
               }

               $grid.kendoTreeList({
                   dataSource: new kendo.data.TreeListDataSource({
                       data: transformedData,
                       schema: {
                           model: {
                               id: "MASTER_CUSTOMER_CODE",
                               parentId: "PRE_CUSTOMER_CODE",
                               fields: {
                                   CUSTOMER_CODE: { type: "string" },
                                   ITEM_CODE: { type: "string" },
                                   ITEM_EDESC: { type: "string" },
                                   CUSTOMER_EDESC: { type: "string" },
                                   MASTER_CUSTOMER_CODE: { type: "string" },
                                   PRE_CUSTOMER_CODE: { type: "string" },
                                   GROUP_SKU_FLAG: { type: "string" },
                                   hasChildren: { type: "boolean" }
                               }
                           }
                       }
                   }),
                   rowTemplate: kendo.template($("#row-template").html()),
                   toolbar: kendo.template($("#toolbar-template1").html()),
                   excel: {
                       fileName: "BranchwiseCustomerProductSales.xlsx",
                       allPages: true,
                       filterable: true
                   },
                   excelExport: function (e) {
                       const sheet = e.workbook.sheets[0];

                       // Get current report key
                       const reportKey = $("#reportSelector").val();

                       // Generate headers using the helper function
                       const customRows = generateExcelHeaders(
                           companyName,
                           branchname,
                           reportKey,
                           fromADdate,
                           fromBSdate,
                           toADdate,
                           toBSdate,
                           sheet.columns.length
                       );

                       Array.prototype.unshift.apply(sheet.rows, customRows);

                       if (grandRowData) {
                           const grandTotalRow = { cells: [] };
                           grandTotalRow.cells.push({ value: "Grand Total", bold: true });
                           grandTotalRow.cells.push(...Array(2).fill({}));

                           columns.slice(3).forEach(col => {
                               const rawValue = grandRowData[col.field];
                               grandTotalRow.cells.push({
                                   value: rawValue,
                                   type: "number",
                                   format: col.format,
                                   bold: true
                               });
                           });
                           sheet.rows.push(grandTotalRow);
                       }
                   },
                   height: 500,
                   columns: columns,
                   filterable: {
                       mode: "row",
                       multi: true,
                       search: true,
                       extra: false
                   },
                   sortable: true,
                   reorderable: true,
                   editable: false,
                   resizable: true,
                   pageable: {
                       pageSizes: [10, 20, 50],
                       buttonCount: 5,
                       refresh: true
                   },
                   dataBound: function () {
                       const treeList = $("#grid").data("kendoTreeList");
                       // Clean any custom grand total rows to prevent duplication growth
                       $("#grid .k-grid-content-locked tbody tr.grand-total-row, #grid .k-grid-content tbody tr.grand-total-row").remove();
                       if (grandRowData && !grandTotalAppendedFlag && !searchingActive) {
                           const $lockedRow = $("<tr>").addClass("grand-total-row").append(
                               $("<td>").attr("colspan", 1).html("<b>Grand Total</b>")
                           );
                           $("#grid .k-grid-content-locked tbody").append($lockedRow);

                           const $unlockedRow = $("<tr>").addClass("grand-total-row");
                           columns.slice(1).forEach(col => {
                               const val = grandRowData[col.field];
                               const formatted = col.format ? kendo.format(col.format, val || 0) : (val || "");
                               $unlockedRow.append(
                                   $("<td>").css("text-align", "right").text(formatted)
                               );
                           });
                           $("#grid .k-grid-content tbody").append($unlockedRow);
                           grandTotalAppendedFlag = true;
                       }
                   }
               });

               // Scoped, debounced search binding
               const treeList = $("#grid").data("kendoTreeList");
               const $toolbar = $("#grid").closest(".k-grid").find(".k-grid-toolbar");
               let searchTimeoutId;
               $toolbar.find("#treelist-global-search").off("input.monthwiseCP").on("input.monthwiseCP", function () {
                   clearTimeout(searchTimeoutId);
                   const term = ($(this).val() || '').toLowerCase();
                   searchTimeoutId = setTimeout(() => {
                       if (!term.trim()) {
                           // Restore full data
                           treeList.dataSource.data(transformedData.map(r => ({ ...r, expanded: true })));
                           grandTotalAppendedFlag = false;
                           searchingActive = false;
                           return;
                       }
                       if (isFiltering) return;
                       isFiltering = true;
                       searchingActive = true;
                       requestAnimationFrame(() => {
                           let filtered = filterTreeWithParents(transformedData, term);
                           filtered = filtered.map(r => ({ ...r, expanded: true }));
                           treeList.dataSource.data(filtered);
                           grandTotalAppendedFlag = false;
                           isFiltering = false;
                           // Keep searchingActive true while filtered view is applied
                       });
                   }, 300);
               });

               // Manual Excel export based on current TreeList view
               function exportMonthwiseManually(treeListInstance) {
                   const ds = treeListInstance.dataSource;
                   const cols = columns;

                   // Get current report key
                   const reportKey = $("#reportSelector").val();

                   // Generate headers using the helper function
                   const headerRows = generateManualExcelHeaders(
                       companyName,
                       branchname,
                       reportKey,
                       fromADdate,
                       fromBSdate,
                       toADdate,
                       toBSdate
                   );

                   const columnHeader = cols.map(c => ({ value: c.title || c.field, bold: true }));

                   const rows = [];
                   const addItemRows = (item, level) => {
                       const rowCells = cols.map((c, idx) => {
                           let val = item[c.field];
                           if (c.template && typeof c.template === 'function') {
                               const html = c.template(item) || '';
                               const tmp = document.createElement('div');
                               tmp.innerHTML = html;
                               val = tmp.textContent || tmp.innerText || '';
                           }
                           const cell = { value: val == null ? '' : val };
                           if (c.format && typeof val === 'number') cell.format = c.format;
                           if (idx === 0 && level > 0) cell.indent = level * 2;
                           return cell;
                       });
                       rows.push(rowCells);
                       const children = ds.childNodes(item);
                       if (children && children.length) children.forEach(ch => addItemRows(ch, level + 1));
                   };
                   ds.view().forEach(root => addItemRows(root, 0));

                   const workbook = new kendo.ooxml.Workbook({
                       sheets: [{
                           name: 'Monthwise Customer Product',
                           columns: cols.map(() => ({ width: 22 })),
                           rows: [
                               ...headerRows.map(r => ({ cells: r })),
                               { cells: columnHeader },
                               ...rows.map(r => ({ cells: r }))
                           ]
                       }]
                   });

                   kendo.saveAs({ dataURI: workbook.toDataURL(), fileName: 'MonthwiseCustomerProductNetSales.xlsx' });
               }

               const $excelBtn = $toolbar.find('.k-grid-excel');
               $excelBtn.off('click.monthwiseCP').on('click.monthwiseCP', function (e) {
                   e.preventDefault();
                   e.stopPropagation();
                   const $btn = $(this);
                   if ($btn.data('exporting')) return;
                   $btn.data('exporting', true).prop('disabled', true).addClass('k-state-disabled').text('Exporting...');
                   setTimeout(() => {
                       try {
                           exportMonthwiseManually(treeList);
                       } finally {
                           $btn.data('exporting', false).prop('disabled', false).removeClass('k-state-disabled').text('Export to Excel');
                       }
                   }, 0);
               });
           },
           error: function (err) {
               console.error("Failed to load data:", err);
               alert("Failed to load data. Please check console for details.");
           }
       });
        }

