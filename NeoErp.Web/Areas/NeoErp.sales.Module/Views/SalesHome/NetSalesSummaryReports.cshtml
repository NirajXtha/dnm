                    setTimeout(function () {
                        $(".k-grid-excel").off("click").on("click", function () {
                            const treeList = $("#grid").data("kendoTreeList");
                            if (treeList) {
                                $(".k-grid-excel").prop("disabled", true).text("Exporting...");
                                treeList.one("excelExport", function () {
                                    $(".k-grid-excel").prop("disabled", false).text("Export to Excel");
                                });
                                treeList.saveAsExcel();
                            }
                        });
                    }, 200);

                    // for Graand Total
                    rowTemplate: kendo.template(function (dataItem) {
                        const isGrandTotal = dataItem.ITEM_EDESC && dataItem.ITEM_EDESC.toLowerCase().includes("grand total");
                        const rowClass = isGrandTotal ? "grand-total-row" : "";
                        return `<tr class="${rowClass}" data-uid="${dataItem.uid}"></tr>`;
                    });

                    // Function to filter tree data while maintaining parent-child relationships
                    function filterTreeWithParents(data, searchTerm) {
                        if (!searchTerm.trim()) return data;

                        const filteredData = [];
                        const addedIds = new Set();

                        data.forEach(item => {
                            if (item.ITEM_EDESC && item.ITEM_EDESC.toLowerCase().includes('grand total')) {
                                return;
                            }

                            const matchesSearch =
                                (item.ITEM_EDESC && item.ITEM_EDESC.toLowerCase().includes(searchTerm)) ||
                                (item.ITEM_CODE && item.ITEM_CODE.toLowerCase().includes(searchTerm)) ||
                                (item.INDEX_MU_CODE && item.INDEX_MU_CODE.toLowerCase().includes(searchTerm));

                            if (matchesSearch) {
                                // Add parent chain if exists
                                let currentItem = item;
                                const itemsToAdd = [currentItem];

                                // Find parent chain
                                while (currentItem.PRE_ITEM_CODE) {
                                    const parent = data.find(d => d.MASTER_ITEM_CODE === currentItem.PRE_ITEM_CODE);
                                    if (parent && !parent.ITEM_EDESC.toLowerCase().includes('grand total')) {
                                        itemsToAdd.unshift(parent);
                                        currentItem = parent;
                                    } else {
                                        break;
                                    }
                                }

                                // Add all items in chain
                                itemsToAdd.forEach(itemToAdd => {
                                    if (!addedIds.has(itemToAdd.MASTER_ITEM_CODE)) {
                                        filteredData.push(itemToAdd);
                                        addedIds.add(itemToAdd.MASTER_ITEM_CODE);
                                    }
                                });

                                // If this is a parent, add all children
                                if (!item.PRE_ITEM_CODE) {
                                    const children = data.filter(d => d.PRE_ITEM_CODE === item.MASTER_ITEM_CODE);
                                    children.forEach(child => {
                                        if (!child.ITEM_EDESC.toLowerCase().includes('grand total') && !addedIds.has(child.MASTER_ITEM_CODE)) {
                                            filteredData.push(child);
                                            addedIds.add(child.MASTER_ITEM_CODE);
                                        }
                                    });
                                }
                            }
                        });

                        return filteredData;
                    }

                    // Debounced search to prevent page hanging
                    let searchTimeout;
                    $("#treelist-global-search").off("input").on("input", function () {
                        const searchValue = $(this).val().toLowerCase();
                        const treeList = $("#grid").data("kendoTreeList");

                        clearTimeout(searchTimeout);

                        searchTimeout = setTimeout(function () {
                            if (treeList) {
                                // Reset flag before filtering to allow grand total to be added again
                                grandTotalAppendedFlag = false;

                                if (!searchValue.trim()) {
                                    treeList.dataSource.data(response);
                                } else {
                                    const filteredData = filterTreeWithParents(response, searchValue);
                                    treeList.dataSource.data(filteredData);
                                }
                            }
                        }, 300);
                    });

                },
                error: function (err) {
                    console.error("Failed to load data:", err);
                    alert("Failed to load data. Please check console for details.");
                }
            });
        }
