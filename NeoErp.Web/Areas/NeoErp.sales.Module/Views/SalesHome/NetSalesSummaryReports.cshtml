                    // Then add current item
                    if (!addedIds.has(itemId)) {
                        filteredData.push(item);
                        addedIds.add(itemId);
                    }
                }

                // Helper function to add all children of a parent
                function addAllChildren(parentId, data) {
                    const children = data.filter(d => d.PRE_CUSTOMER_CODE === parentId);
                    children.forEach(child => {
                        if (!child.CUSTOMER_EDESC || !child.CUSTOMER_EDESC.toLowerCase().includes('grand total')) {
                            if (!addedIds.has(child.MASTER_CUSTOMER_CODE)) {
                                filteredData.push(child);
                                addedIds.add(child.MASTER_CUSTOMER_CODE);
                            }
                            // Recursively add children of children
                            addAllChildren(child.MASTER_CUSTOMER_CODE, data);
                        }
                    });
                }

                // First pass: find all matching items (both parents and children)
                const matchingItems = [];
                data.forEach(item => {
                    // Skip any grand total items
                    if (item.CUSTOMER_EDESC && item.CUSTOMER_EDESC.toLowerCase().includes('grand total')) {
                        return;
                    }

                    const matchesSearch =
                        (item.CUSTOMER_EDESC && item.CUSTOMER_EDESC.toLowerCase().includes(searchTerm)) ||
                        (item.CUSTOMER_CODE && item.CUSTOMER_CODE.toLowerCase().includes(searchTerm)) ||
                        (item.ITEM_EDESC && item.ITEM_EDESC.toLowerCase().includes(searchTerm)) ||
                        (item.ITEM_CODE && item.ITEM_CODE.toLowerCase().includes(searchTerm)) ||
                        (item.GROUP_SKU_FLAG && item.GROUP_SKU_FLAG.toLowerCase().includes(searchTerm));

                    if (matchesSearch) {
                        matchingItems.push(item);
                    }
                });

                // Second pass: add matching items and their parent chains
                matchingItems.forEach(item => {
                    // Add the item and its parent chain
                    addParentChain(item.MASTER_CUSTOMER_CODE, data);

                    // If this is a parent node (no PRE_CUSTOMER_CODE), also add all its children
                    if (!item.PRE_CUSTOMER_CODE) {
                        addAllChildren(item.MASTER_CUSTOMER_CODE, data);
                    }
                });

                // Sort to maintain proper parent-child order
                return filteredData.sort((a, b) => {
                    // Parents first (no PRE_CUSTOMER_CODE)
                    if (!a.PRE_CUSTOMER_CODE && b.PRE_CUSTOMER_CODE) return -1;
                    if (a.PRE_CUSTOMER_CODE && !b.PRE_CUSTOMER_CODE) return 1;

                    // Within same level, maintain original order
                    const aIndex = data.findIndex(d => d.MASTER_CUSTOMER_CODE === a.MASTER_CUSTOMER_CODE);
                    const bIndex = data.findIndex(d => d.MASTER_CUSTOMER_CODE === b.MASTER_CUSTOMER_CODE);
                    return aIndex - bIndex;
                });
            }

            // Debounced search to prevent page hanging
            let searchTimeout;
            $("#treelist-global-search").off("input").on("input", function () {
                const searchValue = $(this).val().toLowerCase();
                const treeList = $("#grid").data("kendoTreeList");

                // Clear previous timeout
                clearTimeout(searchTimeout);

                // Debounce search by 300ms to prevent excessive calls
                searchTimeout = setTimeout(function() {
                    if (treeList) {
                        if (!searchValue.trim()) {
                            // If search is empty, show all data
                            treeList.dataSource.data(response);
                        } else {
                            // Filter data with the implemented function
                            const filteredData = filterTreeWithParents(response, searchValue);
                            treeList.dataSource.data(filteredData);

                            // Expand all parent nodes after filtering to show children
                            setTimeout(function() {
                                const dataSource = treeList.dataSource;
                                const view = dataSource.view();

                                // Find all parent nodes (items without PRE_CUSTOMER_CODE) and expand them
                                view.forEach(function(item) {
                                    if (!item.PRE_CUSTOMER_CODE) {
                                        treeList.expand(treeList.tbody.find("tr[data-uid='" + item.uid + "']"));
                                    }
                                });
                            }, 50); // Small delay to ensure data is loaded
                        }
                        // No need for flag anymore since we handle duplicates in dataBound
                    }
                }, 300);
            });

        },
        error: function (err) {
            console.error("Failed to load data:", err);
            alert("Failed to load data. Please check console for details.");
        }
    });
        }

        function BindBranchwiseCustomerProductNetSalesGrid(readurl, currentFilters = {}) {
    const companyName = '@workingContent.CurrentUserinformation.company_name';
    const fromADdate = $("#FromDateVoucher").val();
    const toADdate = $("#ToDateVoucher").val();
    const fromBSdate = $("#fromInputDateVoucher").val();
    const toBSdate = $("#toInputDateVoucher").val();
    var branchname = '@workingContent.CurrentUserinformation.branch_name';
    let grandTotalAppendedFlag = false;
    let originalData = "";
    let grandRowData = null;
    let searchingActive = false;
            const {
                FormCodeFilter = [],
            } = currentFilters;
    const requestData = {
        company_name: companyName,
        fromADdate,
        toADdate,
        fromBSdate,
        toBSdate,
        branches: branchname,
        FormCodeFilter,
    };

    // Optimized depth calculation with caching
    const depthCache = new Map();
    const getItemDepth = (dataItem, allTransformedData, parentMap) => {
        if (depthCache.has(dataItem.MASTER_CUSTOMER_CODE)) {
            return depthCache.get(dataItem.MASTER_CUSTOMER_CODE);
        }

        let depth = 0;
        let currentItem = dataItem;
        while (currentItem && currentItem.PRE_CUSTOMER_CODE) {
            const parent = parentMap.get(currentItem.PRE_CUSTOMER_CODE);
            if (parent) {
                depth++;
                currentItem = parent;
            } else {
                break;
            }
        }
        depthCache.set(dataItem.MASTER_CUSTOMER_CODE, depth);
        return depth;
    };

    // Optimized hierarchical filter with Map-based lookups
    let byIdCache = null;
    let childrenByParentCache = null;

    const filterTreeWithParents = (data, searchValue) => {
        const term = String(searchValue || '').toLowerCase().trim();
        if (!term || term.length < 2) return data;

        // Build caches once
        if (!byIdCache || !childrenByParentCache) {
            byIdCache = new Map();
            childrenByParentCache = new Map();
            for (const row of data) {
                byIdCache.set(row.MASTER_CUSTOMER_CODE, row);
                const pid = row.PRE_CUSTOMER_CODE || null;
                if (!childrenByParentCache.has(pid)) childrenByParentCache.set(pid, []);
                childrenByParentCache.get(pid).push(row);
            }
        }

        const filtered = [];
        const added = new Set();

        const addWithAncestors = (row) => {
            const stack = [];
            let current = row;
            while (current) {
                stack.unshift(current);
                if (!current.PRE_CUSTOMER_CODE) break;
                current = byIdCache.get(current.PRE_CUSTOMER_CODE);
            }
            for (const x of stack) {
                if (!added.has(x.MASTER_CUSTOMER_CODE)) {
                    filtered.push(x);
                    added.add(x.MASTER_CUSTOMER_CODE);
                }
            }
        };

        const addDescendants = (parentId) => {
            const kids = childrenByParentCache.get(parentId) || [];
            for (const k of kids) {
                if (!added.has(k.MASTER_CUSTOMER_CODE)) {
                    filtered.push(k);
                    added.add(k.MASTER_CUSTOMER_CODE);
                }
                addDescendants(k.MASTER_CUSTOMER_CODE);
            }
        };

        const MAX_RESULTS = 6000;
        for (const item of data) {
            // Skip any grand total-like rows
            if (item.CUSTOMER_EDESC && item.CUSTOMER_EDESC.toLowerCase().includes('grand total')) continue;

            const hay = item.__search != null ? item.__search : ((item.CUSTOMER_EDESC || '') + ' ' + (item.ITEM_EDESC || '') + ' ' + (item.ITEM_CODE || '') + ' ' + (item.CUSTOMER_CODE || '')).toLowerCase();
            if (hay.includes(term)) {
                addWithAncestors(item);
                // Only include subtree when item is a group/root
                if (!item.PRE_CUSTOMER_CODE || item.GROUP_SKU_FLAG === 'G' || item.hasChildren) {
                    addDescendants(item.MASTER_CUSTOMER_CODE);
                }
            }
            if (filtered.length > MAX_RESULTS) break;
        }

        return filtered;
    };

    $.ajax({
        url: readurl,
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify(requestData),
        success: function (response) {
            console.log("Original TreeList Data:", response);

            grandRowData = response.find(x => x.CUSTOMER_CODE && x.CUSTOMER_EDESC.toLowerCase().includes("grand total"));
            const rawData = response.filter(x => !(x.CUSTOMER_CODE && x.CUSTOMER_EDESC.toLowerCase().includes("grand total")));

            const transformData = (data) => {
                // Build lookup maps for performance optimization
                const childrenByCusCode = new Map();
                const itemsByMasterCode = new Map();

                // Pre-build maps in a single pass
                data.forEach(item => {
                    itemsByMasterCode.set(item.MASTER_CUSTOMER_CODE, item);
                    if (item.CUS_CODE) {
                        if (!childrenByCusCode.has(item.CUS_CODE)) {
                            childrenByCusCode.set(item.CUS_CODE, []);
                        }
                        childrenByCusCode.get(item.CUS_CODE).push(item);
                    }
                });

                const arBrothersLookup = {};
                const tempTransformedData = [];

                // First pass: Identify groups using Map lookup
                data.forEach(item => {
                    const children = childrenByCusCode.get(item.CUSTOMER_CODE) || [];
                    const hasChildrenMatchingCusCode = children.some(child =>
                        child.MASTER_CUSTOMER_CODE !== item.MASTER_CUSTOMER_CODE
                    );

                    if (item.GROUP_SKU_FLAG === "I" && hasChildrenMatchingCusCode) {
                        tempTransformedData.push({ ...item, hasChildren: true });
                        arBrothersLookup[item.CUSTOMER_CODE] = item.MASTER_CUSTOMER_CODE;
                    } else if (item.GROUP_SKU_FLAG === "G") {
                        tempTransformedData.push({ ...item, hasChildren: true });
                    } else {
                        tempTransformedData.push({ ...item, hasChildren: false });
                    }
                });

                // Second pass: Re-parent items
                const reParentedData = tempTransformedData.map(item => {
                    const isItemToReparent = item.GROUP_SKU_FLAG === "I" && item.CUS_CODE && arBrothersLookup[item.CUS_CODE];
                    const isNotSelfParent = isItemToReparent && item.MASTER_CUSTOMER_CODE !== arBrothersLookup[item.CUS_CODE];
                    if (isItemToReparent && isNotSelfParent) {
                        return { ...item, PRE_CUSTOMER_CODE: arBrothersLookup[item.CUS_CODE] };
                    }
                    return item;
                });

                // Third pass: Create subgroups with Map for O(1) lookups
                const finalTransformedData = [];
                const newGroups = new Map();
                const processedItems = new Map();

                reParentedData.forEach(item => {
                    const parent = processedItems.get(item.PRE_CUSTOMER_CODE);

                    const shouldSkipSubgroup = !parent
                        || item.GROUP_SKU_FLAG === 'G'
                        || item.hasChildren
                        || item.CUSTOMER_CODE === parent.CUSTOMER_CODE
                        || item.CUSTOMER_EDESC === parent.CUSTOMER_EDESC
                        || !item.ITEM_EDESC;

                    if (!shouldSkipSubgroup) {
                        const groupKey = `${item.PRE_CUSTOMER_CODE}-${item.CUSTOMER_CODE}`;
                        if (!newGroups.has(groupKey)) {
                            const newGroupId = `group_${item.PRE_CUSTOMER_CODE}_${item.CUSTOMER_CODE}`;
                            const newGroup = {
                                MASTER_CUSTOMER_CODE: newGroupId,
                                PRE_CUSTOMER_CODE: item.PRE_CUSTOMER_CODE,
                                CUSTOMER_CODE: item.CUSTOMER_CODE,
                                CUSTOMER_EDESC: item.CUSTOMER_EDESC,
                                GROUP_SKU_FLAG: "G",
                                hasChildren: true,
                            };
                            finalTransformedData.push(newGroup);
                            processedItems.set(newGroupId, newGroup);
                            newGroups.set(groupKey, newGroupId);
                        }
                        const updatedItem = {
                            ...item,
                            PRE_CUSTOMER_CODE: newGroups.get(groupKey),
                            hasChildren: false
                        };
                        finalTransformedData.push(updatedItem);
                        processedItems.set(updatedItem.MASTER_CUSTOMER_CODE, updatedItem);
                    } else {
                        finalTransformedData.push(item);
                        processedItems.set(item.MASTER_CUSTOMER_CODE, item);
                    }
                });
                return finalTransformedData;
            };

            originalData = transformData(rawData).map(it => ({
                ...it,
                __search: ((it.CUSTOMER_EDESC || '') + ' ' + (it.ITEM_EDESC || '') + ' ' + (it.ITEM_CODE || '') + ' ' + (it.CUSTOMER_CODE || '')).toLowerCase()
            }));

            // Build parent map for optimized depth calculation
            const parentMap = new Map();
            originalData.forEach(item => {
                parentMap.set(item.MASTER_CUSTOMER_CODE, item);
            });

            const getCustomerProductTemplate = (dataItem) => {
                const depth = getItemDepth(dataItem, originalData, parentMap);
                let content;
                const paddingLeft = depth * 20;

                if (dataItem.GROUP_SKU_FLAG === "G" || (dataItem.GROUP_SKU_FLAG === "I" && dataItem.hasChildren && !dataItem.ITEM_EDESC)) {
                    content = `<b>${dataItem.CUSTOMER_EDESC}</b>`;
                } else {
                    content = dataItem.ITEM_EDESC || "";
                }
                return `<span style="padding-left: ${paddingLeft}px;">${content}</span>`;
            };

            const columns = [{
                field: "CUSTOMER_EDESC",
                title: "Customer >>> Product",
                template: getCustomerProductTemplate,
                width: 400,
                locked: true
            }, {
                field: "ITEM_CODE",
                title: "Code",
                width: 80
            }, {
                field: "INDEX_MU_CODE",
                title: "Unit",
                width: 80,
                template: dataItem => dataItem.INDEX_MU_CODE && dataItem.INDEX_MU_CODE !== "None" ? dataItem.INDEX_MU_CODE : ""
            }, {
                field: "BRANCH_QTY",
                title: " Branch Quantity",
                width: 130,
                format: "{0:N2}",
                attributes: { style: "text-align:right;" }
            }, {
                field: "BRANCH_VALUE",
                title: "Branch Value",
                width: 130,
                format: "{0:N2}",
                attributes: { style: "text-align:right;" }
            }, {
                field: "BRANCH_QTY",
                title: "Total Quantity",
                width: 130,
                format: "{0:N2}",
                attributes: { style: "text-align:right;" }
            }, {
                field: "BRANCH_VALUE",
                title: "Total Value",
                width: 130,
                format: "{0:N2}",
                attributes: { style: "text-align:right;" }
            }];

            const $grid = $("#grid");
            const existingTreeList = $grid.data("kendoTreeList");
            if (existingTreeList) {
                existingTreeList.destroy();
                $grid.empty();
            }

            $grid.kendoTreeList({
                dataSource: new kendo.data.TreeListDataSource({
                    data: originalData,
                    schema: {
                        model: {
                            id: "MASTER_CUSTOMER_CODE",
                            parentId: "PRE_CUSTOMER_CODE",
                            fields: {
                                CUSTOMER_CODE: { type: "string" },
                                ITEM_CODE: { type: "string" },
                                ITEM_EDESC: { type: "string" },
                                CUSTOMER_EDESC: { type: "string" },
                                MASTER_CUSTOMER_CODE: { type: "string" },
                                PRE_CUSTOMER_CODE: { type: "string" },
                                GROUP_SKU_FLAG: { type: "string" },
                                hasChildren: { type: "boolean" }
                            }
                        }
                    }
                }),
                toolbar: kendo.template($("#toolbar-template1").html()),
                excel: {
                    fileName: "BranchwiseCustomerProductSales.xlsx",
                    allPages: true,
                    filterable: true
                },
                excelExport: function (e) {
                    const sheet = e.workbook.sheets[0];

                    // Get current report key
                    const reportKey = $("#reportSelector").val();

                    // Generate headers using the helper function
                    const customRows = generateExcelHeaders(
                        companyName,
                        branchname,
                        reportKey,
                        fromADdate,
                        fromBSdate,
                        toADdate,
                        toBSdate,
                        sheet.columns.length
                    );

                    Array.prototype.unshift.apply(sheet.rows, customRows);

                    if (grandRowData) {
                        const grandTotalRow = { cells: [] };
                        grandTotalRow.cells.push({ value: "Grand Total", bold: true });
                        grandTotalRow.cells.push(...Array(2).fill({}));

                        columns.slice(3).forEach(col => {
                            const rawValue = grandRowData[col.field];
                            grandTotalRow.cells.push({ value: rawValue, type: "number", format: col.format, bold: true });
                        });
                        sheet.rows.push(grandTotalRow);
                    }
                },
                height: 500,
                columns: columns,
                filterable: {
                    mode: "row",
                    multi: true,
                    search: true,
                    extra: false
                },
                sortable: true,
                reorderable: true,
                editable: false,
                resizable: true,
                pageable: {
                    pageSizes: [10, 20, 50],
                    buttonCount: 5,
                    refresh: true
                },
                dataBound: function () {
                    const treeList = $("#grid").data("kendoTreeList");
                    // Clean any custom grand total rows to prevent duplication
                    $("#grid .k-grid-content-locked tbody tr.grand-total-row, #grid .k-grid-content tbody tr.grand-total-row").remove();

                    if (grandRowData && !searchingActive) {
                        const $lockedRow = $("<tr>").addClass("grand-total-row").append(
                            $("<td>").attr("colspan", 1).html("<b>Grand Total</b>")
                        );
                        $("#grid .k-grid-content-locked tbody").append($lockedRow);

                        const $unlockedRow = $("<tr>").addClass("grand-total-row");
                        columns.slice(1).forEach(col => {
                            const val = grandRowData[col.field];
                            const formatted = col.format ? kendo.format(col.format, val || 0) : (val || "");
                            $unlockedRow.append(
                                $("<td>").css("text-align", "right").text(formatted)
                            );
                        });
                        $("#grid .k-grid-content tbody").append($unlockedRow);
                        grandTotalAppendedFlag = true;
                    }
                }
            });

            // Manual Excel export function
            function exportBranchwiseManually(treeListInstance) {
                const ds = treeListInstance.dataSource;
                const cols = columns;

                // Get branch names
               // const branchNames = (branches || []).map(b => b.Branches.join(', ')).join(', ');

                // Get current report key
                const reportKey = $("#reportSelector").val();

                // Generate headers using the helper function
                const headerRows = generateManualExcelHeaders(
                    companyName,
                    branchname,
                    reportKey,
                    fromADdate,
                    fromBSdate,
                    toADdate,
                    toBSdate
                );

                const columnHeader = cols.map(c => ({ value: c.title || c.field, bold: true }));

                const rows = [];
                const addItemRows = (item, level) => {
                    const rowCells = cols.map((c, idx) => {
                        let val = item[c.field];
                        if (c.template && typeof c.template === 'function') {
                            const html = c.template(item) || '';
                            const tmp = document.createElement('div');
                            tmp.innerHTML = html;
                            val = tmp.textContent || tmp.innerText || '';
                        }
                        const cell = { value: val == null ? '' : val };
                        if (c.format && typeof val === 'number') cell.format = c.format;
                        if (idx === 0 && level > 0) cell.indent = level * 2;
                        return cell;
                    });
                    rows.push(rowCells);
                    const children = ds.childNodes(item);
                    if (children && children.length) children.forEach(ch => addItemRows(ch, level + 1));
                };
                ds.view().forEach(root => addItemRows(root, 0));

                // Add grand total row
                if (grandRowData) {
                    const grandTotalCells = [];
                    grandTotalCells.push({ value: "Grand Total", bold: true });
                    grandTotalCells.push({ value: "" });
                    grandTotalCells.push({ value: "" });
                    cols.slice(3).forEach(col => {
                        const rawValue = grandRowData[col.field];
                        grandTotalCells.push({ value: rawValue || 0, type: "number", format: col.format, bold: true });
                    });
                    rows.push(grandTotalCells);
                }

                const workbook = new kendo.ooxml.Workbook({
                    sheets: [{
                        name: 'Branchwise Customer Product',
                        columns: cols.map(() => ({ width: 22 })),
                        rows: [
                            ...headerRows.map(r => ({ cells: r })),
                            { cells: columnHeader },
                            ...rows.map(r => ({ cells: r }))
                        ]
                    }]
                });

                kendo.saveAs({ dataURI: workbook.toDataURL(), fileName: 'BranchwiseCustomerProductNetSales.xlsx' });
            }

            // Re-apply the event handlers after the TreeList is initialized
            const treeList = $("#grid").data("kendoTreeList");

            // Use setTimeout to ensure toolbar is rendered
            setTimeout(() => {
                const $toolbar = $("#grid").closest(".k-grid").find(".k-grid-toolbar");
                let searchTimeoutId;
                let isFiltering = false;

                console.log("Attaching Branchwise event handlers...");
                console.log("Grand Row Data:", grandRowData);

                // Search handler
                $toolbar.find("#treelist-global-search").off("input.branchwiseCP").on("input.branchwiseCP", function () {
                    clearTimeout(searchTimeoutId);
                    const term = ($(this).val() || '').toLowerCase();
                    searchTimeoutId = setTimeout(() => {
                        if (!term.trim()) {
                            // Restore full data
                            treeList.dataSource.data(originalData.map(r => ({ ...r, expanded: true })));
                            grandTotalAppendedFlag = false;
                            searchingActive = false;
                            return;
                        }
                        if (isFiltering) return;
                        isFiltering = true;
                        searchingActive = true;
                        requestAnimationFrame(() => {
                            let filtered = filterTreeWithParents(originalData, term);
                            filtered = filtered.map(r => ({ ...r, expanded: true }));
                            treeList.dataSource.data(filtered);
                            grandTotalAppendedFlag = false;
                            isFiltering = false;
                            // Keep searchingActive true while filtered view is applied
                        });
                    }, 300);
                });

                // Excel export handler
                const $excelBtn = $toolbar.find('.k-grid-excel');
                $excelBtn.off('click.branchwiseCP').on('click.branchwiseCP', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const $btn = $(this);
                    if ($btn.data('exporting')) return;
                    $btn.data('exporting', true).prop('disabled', true).addClass('k-state-disabled').text('Exporting...');
                    setTimeout(() => {
                        try {
                            exportBranchwiseManually(treeList);
                        } finally {
                            $btn.data('exporting', false).prop('disabled', false).removeClass('k-state-disabled').text('Export to Excel');
                        }
                    }, 0);
                });
            }, 100);
        },
        error: function (err) {
            console.error("Failed to load data:", err);
            alert("Failed to load data. Please check console for details.");
        }
    });
}

        function clearGrid() {
            var gridElement = $("#grid");

            // Check if a Kendo Grid exists and destroy it
            var kendoGrid = gridElement.data("kendoGrid");
            if (kendoGrid) {
                kendoGrid.destroy();
            }

            // Check if a Kendo TreeList exists and destroy it
            var kendoTreeList = gridElement.data("kendoTreeList");
            if (kendoTreeList) {
                kendoTreeList.destroy();
            }

            // Finally, empty the grid container
            gridElement.empty();
        }
        // Initialize Universal Grid Print
        var companyName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.company_name));
        var branchName = @Html.Raw(Json.Encode(workingContent.CurrentUserinformation.branch_name));

        const REPORT_DISPLAY_NAMES = {
            "BranchwiseNetSalesReport": "Branchwise NetSales Report",
            "BranchwiseEmployeeNetSales": "Branchwise Employee NetSales",
            "MonthwiseProductNetSales": "Monthwise Product NetSales",
            "BranchwiseCustomerProductNetSales": "Branchwise Customer Product NetSales",
            "MonthwiseCustomerProductNetSales": "Monthwise Customer Product NetSales",
			"MonthwiseCustomerSalesCollection": "Monthwise Customer Sales Collection",
            "MonthwiseEmployeeCustomerNetSales": "Monthwise Employee Customer NetSales",
            "MonthwiseEmployeeProductNetSales": "Monthwise Employee Product NetSales",
            "MonthwiseRegionProductNetSales": "Monthwise Region Product NetSales",
            "MonthwiseRegionEmployeeNetSales": "Monthwise Region Employee NetSales"
        };

        UniversalGridPrint.init({
            reportName: function() {
                const value = $("#reportSelector").val();
                return REPORT_DISPLAY_NAMES[value] || value;
            },
            companyName: companyName,
            branchName: branchName
        });

    });




</script>
