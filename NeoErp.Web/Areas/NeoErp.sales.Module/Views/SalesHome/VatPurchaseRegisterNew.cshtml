            dataSource: dataSource,
            toolbar: kendo.template($("#toolbar-template").html()),
            excel: {
                fileName: "Vat Sales Register",
                //proxyURL: "//demos.telerik.com/kendo-ui/service/export",
                allPages: true
            },
            excelExport: function (e) {
                e.preventDefault();
                var workbook = e.workbook;
                var sheet = workbook.sheets[0];

                // Step 1: Clean the footer (Grand Total) values by removing any HTML tags
                for (var i = 0; i < sheet.rows.length; i++) {
                    var row = sheet.rows[i];

                    if (row.type === "footer") { // Only for footer rows
                        for (var j = 0; j < row.cells.length; j++) {
                            var cell = row.cells[j];

                            if (cell && cell.value && typeof cell.value === "string") {
                                // Remove HTML tags and extra spaces
                                cell.value = cell.value.replace(/<[^>]*>/g, '').trim();

                                // Optional: if cell is numeric after cleanup, convert it to number
                                if (!isNaN(cell.value.replace(/,/g, ""))) {
                                    cell.value = parseFloat(cell.value.replace(/,/g, ""));
                                }
                            }
                        }
                    }
                }
                // Step 2: Add custom headers before the data rows
                sheet.rows.unshift({
                    cells: [{ value: "Vat Purchase Register".split('').join(' '), colSpan: 18 }]
                });
                var filterText = $("#AdvanceFilter").attr('data-original-title');
                if (filterText.indexOf('|') < 0) {
                    filterText = $((filterText).replace(/<strong>/g, "|")).text().replace('|', '').split('|').reverse();
                    $.each(filterText, function (k, item) {
                        sheet.rows.unshift({
                            cells: [{ value: item, colSpan: 18 }]
                        });
                    });
                }
                if (filterText.toString().indexOf('Date Range') < 0) {
                    sheet.rows.unshift({
                        cells: [{ value: "From :- " + fromADdate + "(" + fromBSdate + ")" + "\t To :- " + toADdate + "(" + toBSdate + ")", colSpan: 18 }]
                    });
                }
                for (var companyCount = 0; companyCount < branches.length; companyCount++) {
                    sheet.rows.unshift({
                        cells: [{ value: branches[companyCount].Company + " :- " + branches[companyCount].Branches.join(','), colSpan: 18 }]
                    });
                }
                sheet.rows.unshift({
                    cells: [{ value: companyName.split('').join(' '), colSpan: 18 }]
                });
                // Step 3: Create a final Workbook object
                var WorkbookFinal = new kendo.ooxml.Workbook({
                    sheets: [{
                        columns: [
                            { width: 110 } // Optional: you can set widths properly if you want
                        ],
                        rows: sheet.rows
                    }]
                });
                // Step 4: Save the final Excel file
                kendo.saveAs({
                    dataURI: WorkbookFinal.toDataURL(),
                    fileName: "Vat Purchase Register.xlsx"
                });
            },
