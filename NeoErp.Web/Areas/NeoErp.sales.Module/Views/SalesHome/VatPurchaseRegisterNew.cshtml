            type: "json",
            transport: {
                read: {
                    url: readurl, // <-- Get data from here.
                    dataType: "json", // <-- The default was "jsonp".
                    type: "POST",
                    contentType: "application/json; charset=utf-8"
                },
                parameterMap: function (options, type) {
                    var paramMap = JSON.stringify($.extend(options, ReportFilter.filterAdditionalData()));
                    //  paramMap.formDate = $("#FromDateVoucher").val();
                    delete paramMap.$inlinecount; // <-- remove inlinecount parameter.
                    delete paramMap.$format; // <-- remove format parameter.
                    return paramMap;
                }

            },
            error: function (e) {
                displayPopupNotification("Sorry error occured while processing data", "error");
            },
            serverFiltering: true,
            serverAggregates: true,
            schema: {
                data: "VatPurchaseNew", // records are returned in the "data" field of the response
                total: function (response) {
                    // Ensure we get the total count of ALL records (not just current page)
                    return response.Total || response.total || (response.VatPurchaseNew ? response.VatPurchaseNew.length : 0);
                },
                aggregates: "AggregationResult",
                model: {
                    fields: {
                        INVOICE_DATE: { type: "string" },
                        MITI: { type: "string" },
                        INVOICE_NO: { type: "string" },
                        SUPPLIER_INV_NO: { type: "string" },
                        SUPPLIER_INV_DATE: { type: "string" },
                        PP_NO: { type: "string" },
                        SUPPLIER_CODE: { type: "string" },
                        SUPPLIER_EDESC: { type: "string" },
                        TPIN_VAT_NO: { type: "string" },
                        P_TYPE: { type: "string" },
                        FORM_CODE: { type: "string" },
                        ACC_IN_VOUCHER: { type: "string" },
                        INVOICE_TOTAL_PRICE: { type: "number" },
                        VAT_TOTAL_PRICE: { type: "number" },
                        TAXFREE_PURCHASE: { type: "number" },
                        TAXABLE_PURCHASE: { type: "number" },
                        TAXABLE_VAT: { type: "number" },
                        TAXABLE_PURCHASE_IMPORT: { type: "number" },
