		function isColumnAllNullOrZero(columnIndex, rows) {
			for (let i = 1; i < rows.length; i++) {
				const cell = rows[i].cells[columnIndex];
				const cellValue = cell ? cell.value : null;
				if (cellValue !== null && cellValue !== 0 && cellValue !== '0') {
					return false; // If any cell in the column has a non-null, non-zero value, return false
				}
			}
			return true; // If all cells in the column are either null or 0, return true
		}

		function removeColumn(columnIndex, rows) {
			// Remove data cells in each row
			for (let i = 0; i < rows.length; i++) {
