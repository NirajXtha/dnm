	function HideAllBlank(checkAllBlank, columnName) {
		
		if (checkAllBlank.dataSource.data().length > 0) {
			var hasNull = checkAllBlank.dataSource.data().every(function (item) {
				return item[columnName] === null || item[columnName] == '' || item[columnName] == '0' || item[columnName] == 0;
			});
			if (hasNull) {
