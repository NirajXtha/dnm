<div class="print">

    <!-- ================= HEADER ================= -->
    <div class="print-header">
        <div style="text-align:center;font-weight:700;">
            <p>{{COMPANY_NAME}} | {{COMPANY_ADDRESS}}</p>
            <p style="margin-top:6px;">COMPARATIVE REPORT</p>
        </div>

        <table class="print_table" style="margin-top:10px; width: 100%;">
            <tr>
                <td>Tender No</td>
                <td>{{master.TENDER_NO}}</td>
                <td>Issue Date</td>
                <td>{{master.ISSUE_DATE | date:'yyyy-MM-dd'}}</td>
                <td>Valid Date</td>
                <td>{{master.VALID_DATE | date:'yyyy-MM-dd'}}</td>
            </tr>
            <tr>
                <td>Nepali Date</td>
                <td>{{master.NEPALI_DATE}}</td>
                <td>Delivery BS</td>
                <td>{{master.DELIVERY_DT_BS}}</td>
                <td>Created By</td>
                <td>{{master.CREATED_BY}}</td>
            </tr>
        </table>
    </div>

    <!-- ================= VENDOR LOOP ================= -->
    <div class="print-page" ng-repeat="vendor in vendors track by vendor.QUOTATION_NO">

        <div class="vendor-section">

            <!-- Vendor Header -->
            <div class="vendor-title" style="width: 100%; font-weight: 900;">
                Vendor: {{vendor.PARTY_NAME}}
                @*<span style="float:right;">Status : {{vendor.STATUS}}</span>*@
            </div>

            <!-- Vendor Info -->
            <table class="print_table" style="margin-bottom: 10px; width: 100%;">
                <tr>
                    <td>PAN No</td>
                    <td>{{vendor.PAN_NO}}</td>
                    <td>Contact</td>
                    <td>{{vendor.CONTACT_NO}}</td>
                </tr>
                <tr>
                    <td>Address</td>
                    <td>{{vendor.ADDRESS}}</td>
                    <td>Email</td>
                    <td>{{vendor.EMAIL}}</td>
                </tr>
                <tr>
                    <td>Quotation No</td>
                    <td>{{vendor.QUOTATION_NO}}</td>
                    <td>Delivery Date</td>
                    <td>{{vendor.DELIVERY_DATE | date:'yyyy-MM-dd'}}</td>
                </tr>
            </table>

            <!-- ================= ITEM TABLE ================= -->
            <table class="print_table fnce">
                <thead>
                    <tr>
                        <th style="width:20%;">Item</th>
                        <th style="width:4%;">Unit</th>
                        <th style="width:6%;">Qty</th>
                        <th style="width:8%;">Rate</th>
                        <th style="width:8%;">Amount</th>
                        <th style="width:6%;">Discount</th>
                        <th style="width:8%;">VAT</th>
                        <th style="width:10%;">Net</th>
                        <th style="width:30%;">Digital Signature</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="item in vendor.Item_Detail">
                        <td>{{item.ITEM_CODE}}</td>
                        <td>{{item.UNIT}}</td>
                        <td style="text-align:center;">{{item.QUANTITY}}</td>
                        <td style="text-align:right;">{{item.RATE}}</td>
                        <td style="text-align:right;">{{item.AMOUNT}}</td>
                        <td style="text-align:right;">{{item.DISCOUNT_AMOUNT}}</td>
                        <td style="text-align:right;">{{item.VAT_AMOUNT}}</td>
                        <td style="text-align:right;">{{item.NET_AMOUNT}}</td>

                        <!-- ITEM APPROVAL -->
                        <td style="font-size:8px;">
                            <div>Checked : {{item.CHECKED_BY || '-'}}</div>
                            <div>Verified : {{item.VERIFIED_BY || '-'}}</div>
                            <div>Recommended : {{item.RECOMMEND_BY || '-'}}</div>
                            <div>Approved : {{item.APPROVED_BY || '-'}}</div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- ================= TOTALS ================= -->
            <!--<table class="print_table" style="width:100%;float:right;margin-top:10px;">
        <tr><td>Total</td><td>{{vendor.TOTAL_AMOUNT}}</td>
        <td>Discount</td><td>{{vendor.TOTAL_DISCOUNT}}</td>
        <td>Excise</td><td>{{vendor.TOTAL_EXCISE}}</td>
        <td>Taxable</td><td>{{vendor.TOTAL_TAXABLE_AMOUNT}}</td>
        <td>VAT</td><td>{{vendor.TOTAL_VAT}}</td>-->
            @*<tr >*@
            <!--<td style="font-weight:700;">Grand Total</td>
            <td style="font-weight:700;">{{vendor.TOTAL_NET_AMOUNT}}</td>
        </tr>
    </table>-->
            <table class="print_table"
                   style="margin-top: 10px; width: 100%; margin-bottom: 10px;"
                   ng-init="
            vendorTotal        = vendor.TOTAL_AMOUNT;
            vendorDiscount     = vendor.TOTAL_DISCOUNT;
            vendorExcise       = vendor.TOTAL_EXCISE;
            vendorTaxable      = vendor.TOTAL_TAXABLE_AMOUNT;
            vendorVat          = vendor.TOTAL_VAT;
            vendorGrandTotal   = vendor.TOTAL_NET_AMOUNT;
       ">

                <tr>
                    <td>Total: {{ vendorTotal }}</td>

                    <td>Discount: {{ vendorDiscount }}</td>

                    <td>Excise: {{ vendorExcise }}</td>

                    <td>Taxable: {{ vendorTaxable }}</td>

                    <td>VAT: {{ vendorVat }}</td>

                    <td style="font-weight:700;">Grand Total: {{ vendorGrandTotal }}</td>
                </tr>
            </table>

            <!-- ================= TERMS ================= -->
            @*<div ng-if="vendor.TermsCondition.length" style="margin-top:15px;">
            <p style="font-weight:700;">Terms & Conditions</p>
            <ul>
                <li ng-repeat="t in vendor.TermsCondition">
                    {{t.TERM_CONDITION}}
                </li>
            </ul>
        </div>*@

        </div>
    </div>
</div>