@using NeoErp.Core.Models
@using NeoErp.Core
@using NeoErp.Core.Infrastructure
@{
    ViewBag.Title = "QR Popup Generator";
    //Layout = "~/Views/Shared/_Layout.cshtml";
}
<!--form-->


<div class="container">
    <h2 class="mb-4">QR Coupon Generator</h2>

    <div>
        <div class="form-group mb-3">
            <label for="itemSelect">Item:</label>
            <select id="itemSelect" class="form-control">
                <option value="">-- Select an Item --</option>
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Points:</label>
            <input type="number" id="points" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Valid From:</label>
            <input type="date" id="validFrom" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label>Valid To:</label>
            <input type="date" id="validTo" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Number of QR:</label>
            <input type="number" id="numQr" class="form-control" min="1" />
        </div>

        <div class="form-group mb-3">
            <label>Logo for QR (optional):</label>
            <input type="file" id="logoUpload" class="form-control" accept="image/*" />
            <small class="text-muted">Upload a logo to embed in QR codes. If not selected, default logo will be used.</small>
        </div>

        <button type="button" id="showPopupBtn" class="btn btn-primary mt-3">
            Generate Coupons
        </button>
    </div>
</div>
<!--popup content-->
<div id="popupContainer"
     style="display:none;
     position:fixed;
     top:0;left:0;
     width:100%;
     height:100%;
     background-color:rgba(0,0,0,0.9);
     justify-content:center;
     align-items:center;
     z-index:9999;">

    <div id="popupContent"
         style="background:#fff;
          border-radius:0;
          padding:10px;
          max-width:98%;
          width:98%;
          height:98%;
          position:relative;
          text-align:center;
          overflow-y:auto;
          display:flex;
          flex-direction:column;">
        <!--pdf export-->
        <div style="padding:10px; background:#f4f4f4; border-bottom:1px solid #ccc; display:flex; justify-content:space-between; align-items:center; flex-shrink: 0;">
            <div style="font-weight: bold; font-size: 1.1rem;">Generated Coupons (<span id="couponCount">0</span>)</div>
            <div>
                <span id="closePopup"
                      style="cursor:pointer;
                            font-size:26px;
                            font-weight:bold;
                            color:#333;">&times;</span>
            </div>
        </div>

        <div id="pdfContent"
             style="flex-grow:1;
                     padding: 10px;
                     background: #fff;
                     overflow-y: auto;">

            <div id="popupQrContainer"
                 style="display:flex;
                         flex-wrap:wrap;
                         justify-content:center;
                         align-items: flex-start;
                         max-width: 780px;
                         margin: 0 auto;
                         gap: 0;">
            </div>
        </div>
    </div>
</div>
<!--toast message-->
<div id="toast"
     style="position:fixed;
     top:20px;right:20px;
     min-width:200px;
     padding:12px 20px;
     background-color:#28a745;'h'
     color:white;
     border-radius:5px;
     display:none;
     z-index:99999;">
    QR Codes generated successfully!
</div>


<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.3/html2pdf.bundle.min.js"></script>

<script>
    $(document).ready(function () {
        debugger;

        $("#wrapper").attr("id", "");
        $(".navbar-header").hide();

        const popup = $("#popupContainer");
        const popupQrContainer = $("#popupQrContainer");
        const toast = $("#toast");
        const couponCountSpan = $("#couponCount");

        let uploadedImageUrl = "/images/qr.jpg";
        let logoImageUrl = "/images/qr_logo.png"; // Logo to be embedded in QR codes
        let customLogoUrl = null; // For uploaded custom logo

        // Test logo path on page load
        console.log('Testing logo path:', logoImageUrl);
        const testImg = new Image();
        testImg.onload = function () {
            console.log('✅ Logo path is valid and accessible');
        };
        testImg.onerror = function () {
            console.error('❌ Logo path failed to load, trying alternatives...');
            // Try alternative paths
            const alternatives = ['/Content/images/logo.png', '/images/hulasLogo.png', '/images/logo1old.png'];
            alternatives.forEach(alt => {
                const altImg = new Image();
                altImg.onload = function () {
                    console.log('✅ Alternative logo found:', alt);
                    logoImageUrl = alt;
                };
                altImg.src = alt;
            });
        };
        testImg.src = logoImageUrl;

        // Handle logo file upload
        $("#logoUpload").change(function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    customLogoUrl = e.target.result;
                    toast.css('background-color', '#28a745')
                        .text('Logo uploaded successfully!')
                        .fadeIn(400).delay(1500).fadeOut(400);
                };
                reader.readAsDataURL(file);
            }
        });

        // Function to add logo to QR code
        function addLogoToQR(qrContainer, logoUrl, qrSize) {
            console.log("qrContainer", qrContainer.children);

            qrContainer.children[1].remove();

           
            $(".helloid").css({
                "display": "flex",
                "justify-content": "center",
                "align-items": "center",
                "height": 65,
                "width": 65,
            });


            console.log('Adding logo to QR:', logoUrl);
            const canvas = qrContainer.querySelector('canvas');
            
            if (!canvas) {
                console.error('Canvas not found in QR container');
                return;
            }

            const ctx = canvas.getContext('2d');


            const logoImg = new Image();

            logoImg.onload = function () {
                console.log('Logo loaded successfully, drawing on canvas');
                console.log('Canvas dimensions:', canvas.width, 'x', canvas.height);
                console.log('Logo image dimensions:', logoImg.width, 'x', logoImg.height);
                try {

                   
                    // Make logo bigger and more visible for testing

                    const logoSize = qrSize * 1.2; // Increased from 0.2 to 0.3
                    const x = (canvas.width - logoSize) / 2;
                    const y = (canvas.height - logoSize) / 2;
                    debugger;

                    console.log('Drawing logo at position:', x, y, 'with size:', logoSize);
                    debugger;

                    // Create white background circle for logo
                    const bgSize = logoSize * 1.3;

                    ctx.fillStyle = '#ffffff';
                    ctx.beginPath();
                    ctx.arc(canvas.width / 2, canvas.height / 2, bgSize / 2, 0, 2 * Math.PI);
                    ctx.fill();

                    debugger;
                    // Draw logo
                    ctx.drawImage(logoImg, x, y, logoSize, logoSize);
                    console.log('✅ Logo drawn successfully at:', x, y);
                    debugger;

                    // Force canvas refresh
                    canvas.style.display = 'none';
                    canvas.offsetHeight; // Trigger reflow
                    canvas.style.display = '';
                    canvas.style.height = "65px";
                    canvas.style.width = "65px";
                    debugger;

                } catch (error) {
                    console.error('❌ Error drawing logo:', error);
                }
            };

            logoImg.onerror = function () {
                console.error('Logo image failed to load:', logoUrl);
                // Try alternative logo path
                if (logoUrl.includes('/images/qr_logo.png')) {
                    console.log('Trying alternative logo path...');
                    logoImg.src = '/Content/images/logo.png';
                } else {
                    // Fallback: Draw a simple colored rectangle logo
                    console.log('Drawing fallback colored rectangle logo');
                    const logoSize = qrSize * 0.3;
                    const bgSize = logoSize * 1.3;

                    // Create white background circle
                    ctx.fillStyle = '#ffffff';
                    ctx.beginPath();
                    ctx.arc(canvas.width / 2, canvas.height / 2, bgSize / 2, 0, 2 * Math.PI);
                    ctx.fill();


                    // Draw colored rectangle as logo
                    const rectSize = logoSize * 0.8;
                    const rectX = (canvas.width - rectSize) / 2;
                    const rectY = (canvas.height - rectSize) / 2;

                    ctx.fillStyle = '#007bff'; // Blue rectangle
                    ctx.fillRect(rectX, rectY, rectSize, rectSize);

                    // Draw text on rectangle
                    ctx.fillStyle = '#ffffff';
                    ctx.font = `${logoSize * 0.2}px Arial`;
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.fillText('LOGO', canvas.width / 2, canvas.height / 2);

                    console.log('✅ Fallback logo drawn successfully');
                }
            };

            // Remove crossOrigin to avoid CORS issues with local files
            logoImg.src = logoUrl;
        }

        // Function to generate QR coupons from real data
        function generateQrCoupons(qrDataArray) {

            popupQrContainer.html("");
            popupQrContainer.html("");

            // Get the user-requested number of QR codes
            const requestedCount = parseInt($("#numQr").val()) || 1;
            console.log('User requested:', requestedCount, 'QR codes');
            console.log('API returned:', qrDataArray.length, 'QR codes');

            // Limit to user-requested count
            const limitedArray = qrDataArray.slice(0, requestedCount);
            console.log('Generating:', limitedArray.length, 'QR codes');

            couponCountSpan.text(limitedArray.length);

            const COUPON_WIDTH = 300;
            const COUPON_HEIGHT = 200;
            const QR_CONTAINER_SIZE = 75;

            limitedArray.forEach((qrItem, i) => {
                const wrapper = $("<div></div>")
                    .addClass('coupon-container')
                    .css({
                        position: "relative",
                        width: `${COUPON_WIDTH}px`,
                        height: `${COUPON_HEIGHT}px`,
                        margin: "30px",
                        display: "flex",
                        justifyContent: "center",
                        alignItems: "center",
                        overflow: "hidden",
                        flexShrink: 0,
                        flexGrow: 0,
                        boxSizing: "border-box",
                        background: "#fff",
                        border: "none",
                        outline: "none",
                        boxShadow: "none"
                    });

                // Coupon background image
                const logo = $("<img>")
                    .attr("src", uploadedImageUrl)
                    .attr("alt", "coupon image")
                    .css({
                        width: "100%",
                        height: "100%",
                        objectFit: "contain",
                        display: "block",
                        border: "none",
                        outline: "none"
                    });

                // QR code container
                const qrDiv = $("<div></div>").css({
                    width: `${QR_CONTAINER_SIZE}px`,
                    height: `${QR_CONTAINER_SIZE}px`,
                    position: "absolute",
                    right: "26px",
                    top: "80px",
                    background: "#fff",
                    display: "flex",
                    justifyContent: "center",
                    alignItems: "center",
                    border: "1.5px solid orange",
                    borderRadius: "2px",
                    boxSizing: "border-box",
                    outline: "none",
                    boxShadow: "0 0 5px rgba(230, 80, 10,0.4)"
                });

                const qrCanvasDiv = $('<div class="helloid"></div>').css({
                    border: "none",
                    outline: "none"
                });
                qrDiv.append(qrCanvasDiv);

                // Coupon number label
                //const numberLabel = $("<div></div>")
                //    .text(`${i + 1}`)
                //    .css({
                //        position: "absolute",
                //        top: "2px",
                //        left: "15px",
                //        background: "rgba(255,140,0,0.9)",
                //        color: "white",
                //        fontWeight: "bold",
                //        fontSize: "14px",
                //        padding: "3px 8px",
                //        borderRadius: "6px",
                //    });

                wrapper.append(logo).append(qrDiv);


                popupQrContainer.append(wrapper);

                // Generate QR code with real data from API - use ENCODED_DATA from backend
                const qrData = qrItem.ENCODED_DATA;
                const qrCode = new QRCode(qrCanvasDiv[0], {
                    text: qrData,
                    width:4*(QR_CONTAINER_SIZE - 10),
                    height:4*(QR_CONTAINER_SIZE - 10),
                    correctLevel: QRCode.CorrectLevel.H,
                    colorDark: "#e6500a",
                    colorLight: "#ffffff"
                });

                 setTimeout(() => {
                     const logoToUse = customLogoUrl || logoImageUrl;
                     console.log('Using logo:', logoToUse);

                     // Double-check canvas exists and is ready
                     const canvas = qrCanvasDiv[0].querySelector('canvas');
                     debugger;
                     if (canvas && canvas.width > 0 && canvas.height > 0) {
                         console.log('Canvas ready, adding logo...');
                         addLogoToQR(qrCanvasDiv[0], logoToUse, QR_CONTAINER_SIZE - 10);
                        
                         debugger;
                     } else {
                         console.warn('Canvas not ready, retrying in 500ms...');
                         setTimeout(() => {

                             addLogoToQR(qrCanvasDiv[0], logoToUse, QR_CONTAINER_SIZE - 10);
                         }, 500);
                     }
                 }, 1000);
                debugger;// Increased from 500ms to 1000ms
            });

            // Show popup
            popup.css("display", "flex");

            // Auto-generate PDF after a short delay to ensure QR codes and logos are rendered
            setTimeout(() => {
                generatePdf();
            }, 2500);
        }

        $("#showPopupBtn").click(function () {
            // Validate inputs - no defaults allowed
            const itemCode = $("#itemSelect").val();
            const points = $("#points").val();
            const validFrom = $("#validFrom").val();
            const validTo = $("#validTo").val();
            const numQr = parseInt($("#numQr").val());

            if (!itemCode) {
                alert("⚠️ Please select an item.");
                return;
            }
            if (!points || points <= 0) {
                alert("⚠️ Please enter valid points.");
                return;
            }
            if (!validFrom) {
                alert("⚠️ Please select a valid from date.");
                return;
            }
            if (!validTo) {
                alert("⚠️ Please select a valid to date.");
                return;
            }
            if (!numQr || numQr <= 0 || isNaN(numQr)) {
                alert("⚠️ Please enter a valid number of QR codes (1 or more).");
                return;
            }

            // Show loading toast
            toast.css('background-color', '#007bff')
                .text('Generating QR codes...')
                .fadeIn(400);

            // Call API to insert data and get real QR codes
            generateQrApi(itemCode, points, validFrom, validTo, numQr);
        });
        // PDF Generation Function
        function generatePdf() {
            const element = document.getElementById('pdfContent');

            $(".page-break").remove();
            $(".coupon-container").each(function (i) {
                if ((i + 1) % 8 === 0 && (i + 1) < $(".coupon-container").length) {
                    $(this).after('<div class="page-break"></div>');
                }
            });

            const options = {
                margin: [10, 0, 10, 0],
                filename: `coupons_${new Date().toISOString().slice(0, 10)}.pdf`,
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 3, useCORS: true, backgroundColor: "#ffffff" },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            toast.css('background-color', '#007bff')
                .text('Preparing PDF...')
                .fadeIn(400);

            html2pdf().from(element).set(options).save().then(() => {
                $(".page-break").remove();
                toast.css('background-color', '#28a745')
                    .text('PDF Downloaded Successfully!')
                    .delay(2000).fadeOut(400);
            });
        }

        $("#closePopup").click(() => popup.hide());
        $(window).click(e => { if (e.target.id === "popupContainer") popup.hide(); });




        /// FETCH ITMES

        const apiUrl = window.location.protocol + "//" + window.location.host + "/api/mobileDistribution/SchemeApi/";
        function fetchItems() {
            $.ajax({
                url: apiUrl,
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    action: "getItems",
                    data: {}
                }),
                success: function (response) {
                    if (response.response && response.result.Data) {
                        $('#itemSelect').empty();
                        $.each(response.result.Data, function (i, item) {
                            $('#itemSelect').append(`<option value="${item.ITEM_CODE}">${item.ITEM_EDESC}</option>`);
                        });
                    }
                },
                error: function (xhr) {
                    console.error('Failed to fetch items:', xhr.responseText);
                }
            });
        }
        fetchItems();





        // GENERATE QR API - Insert data and get real QR codes
        function generateQrApi(itemCode, points, validFrom, validTo, numQr) {
            const url = window.location.protocol + "//" + window.location.host + "/api/mobileDistribution/SchemeApi/";

            const requestData = {
                "action": "generateQr",
                "data": {
                    "data": {
                        "count": parseInt(numQr),
                        "item_code": itemCode,
                        "points": parseFloat(points),
                        "from_date": validFrom,
                        "to_date": validTo
                    }
                }
            };

            $.ajax({
                method: 'POST',
                url: url,
                contentType: 'application/json',
                data: JSON.stringify(requestData),
                dataType: 'json',

                success: function (response) {
                    if (response.response) {
                        console.log("QR codes inserted successfully:", response.result);

                        toast.css('background-color', '#28a745')
                            .text('QR codes generated successfully!')
                            .delay(1000).fadeOut(400);

                        // Check if API returns the inserted QR data
                        if (response.result && response.result.Data && Array.isArray(response.result.Data)) {
                            // API returned the QR data directly
                            generateQrCoupons(response.result.Data);
                        } else {
                            // API didn't return data - this shouldn't happen with updated backend
                            console.warn("API did not return QR data");
                            toast.css('background-color', '#ffc107')
                                .text('Warning: QR codes inserted but data not returned!')
                                .fadeIn(400).delay(2000).fadeOut(400);
                        }
                    } else {
                        console.warn("API returned failed response:", response);
                        toast.css('background-color', '#dc3545')
                            .text('Failed to generate QR codes!')
                            .fadeIn(400).delay(2000).fadeOut(400);
                    }
                },

                error: function (xhr, status, error) {
                    console.error("AJAX Error:", status, error, xhr.responseText);
                    toast.css('background-color', '#dc3545')
                        .text('Error: ' + error)
                        .fadeIn(400).delay(3000).fadeOut(400);
                }
            });
        }



    });
</script>

<style>
    .page-break {
        page-break-after: always;
        height: 0;
    }

    .container {
        page-break-after: always;
        height: 0;
        width: 500px;
    }

    #popupQrContainer {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: flex-start;
        max-width: 780px;
        margin: 25px auto;
        gap: 25px;
        background: #fff;
    }

    .coupon-container {
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
        background: #fff !important;
    }

    #pdfContent {
        background: #fff !important;
    }

    @@media print {
        .coupon-container {
            page-break-inside: avoid;
        }
    }
</style>

