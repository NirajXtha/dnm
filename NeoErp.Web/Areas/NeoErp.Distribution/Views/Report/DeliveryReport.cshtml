                            if (dataItem.LATITUDE) {
                                var AtnLocation = [Number(dataItem.LATITUDE), Number(dataItem.LONGITUDE)];
                                markerAtn = L.marker(AtnLocation, {
                                    icon: L.icon({
                                        iconUrl: "http://maps.google.com/mapfiles/ms/icons/green-dot.png",
                                        iconSize: [25, 41],
                                        iconAnchor: [12, 20]
                                    }),
                                    title: 'Delivered Here'
                                }).addTo(map);
                            } else {
                                console.log("No ATN_LOCATION found");
                            }

                            

                            // Center the map on the ATN marker or EOD marker if ATN is not available
                            if (dataItem.ATN_LOCATION) {
                                map.setView(AtnLocation, 12);
                            } else if (dataItem.EOD_LOCATION) {
                                map.setView(EodLocation, 12);
                            }

                            $("#mapModal").modal('show');
                        },
                    },
                    title: "Actions",
                },
            ]
        });
    };

