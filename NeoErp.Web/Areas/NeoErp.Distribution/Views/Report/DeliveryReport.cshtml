    function loadStatusFilter() {
        $.ajax({
            url: window.location.protocol + "//" + window.location.host + "/api/Report/GetAllDeliveryStatusFilter",
            type: "GET",
            success: function (res) {

                $("#statusFilter").empty();
                $("#statusFilter").append('<option value="ALL">All Status</option>');
                $("#statusFilter").append('<option value="">Pending</option>');
                console.log(res);
                $.each(res, function (i, v) {
                    $("#statusFilter").append(
                        `<option value="${v.status_code}">${v.status_name}</option>`
                    );
                });
            }
        });
    }

    function BindGrid(readurl) {
        var branches = ReportFilter.getBranchs();
        reportConfig = GetReportSetting("AttendanceReport");
        var grid = $("#grid").kendoGrid({
            dataSource: new kendo.data.DataSource({
                type: "json",
                transport: {
                    read: {
                        url: readurl + "?Type=" + encodeURIComponent($("#typeFilter").val()) + "&status=" + encodeURIComponent($("#statusFilter").val()),
                        dataType: "json",
                        type: "POST",
                        contentType: "application/json; charset=utf-8"
                    },
                    parameterMap: function (options, type) {
                        var paramMap = JSON.stringify($.extend(options, ReportFilter.filterAdditionalData()));
                        delete paramMap.$inlinecount; // <-- remove inlinecount parameter.
                        delete paramMap.$format; // <-- remove format parameter.
                        return paramMap;
                    }
                },

                error: function (e) {
                    displayPopupNotification("Sorry error occured while processing data", "error");
                },
                model: {
                    fields: {
                        REFERENCE_NO: { type: "string" },
                        DRIVER_MOBILE_NO: { type: "number" },
                        RECEIVER_NUMBER: { type: "number" },
                    }
                },
                pageSize: reportConfig.defaultPageSize,
            }),
            toolbar: kendo.template($("#toolbar-template").html()),
            excel: {
                fileName: "Delivery Report",
                allPages: true,
            },
            excelExport: function (e) {
                var sheet = e.workbook.sheets[0];

                // Fields to ignore
                var ignoreCols = ["SIGNATURE", "IMG0", "IMG1", "IMG2", "IMG3"];

                // Get visible grid columns
                var gridColumns = e.sender.columns;

                sheet.rows.forEach(function (row) {
                    if (row.type === "header") {
                        // Keep only headers whose corresponding field is NOT in ignoreCols
                        row.cells = row.cells.filter(function (cell, idx) {
                            var field = gridColumns[idx] ? gridColumns[idx].field : null;
                            return ignoreCols.indexOf(field) === -1;
                        });
                    }
                    if (row.type === "data") {
                        // Keep only data cells that map to non-ignored fields
                        row.cells = row.cells.filter(function (cell, idx) {
                            var field = gridColumns[idx] ? gridColumns[idx].field : null;
                            return ignoreCols.indexOf(field) === -1;
                        });
                    }
                });

                // Format DeliveredDate (CREATED_DATE)
                sheet.rows.forEach(function (row) {
                    if (row.type === "data") {
                        if (row.cells[0] && row.cells[0].value) {
                            row.cells[0].value = kendo.toString(new Date(row.cells[0].value), "yyyy-MM-dd HH:mm:ss");
                        }
                        //[6, 8].forEach(function (colIndex) {
                        //    if (row.cells[colIndex] && row.cells[colIndex].value) {
                        //        row.cells[colIndex].value = kendo.toString(new Date(row.cells[colIndex].value), "hh:mm tt");
                        //    }
                        //});
                    }
                });
            },
