@using NeoErp.Core.Models;
@using NeoErp.Core;
@using NeoErp.Core.Infrastructure;

@{
    ViewBag.Title = "Claim Report";
    var workingContent = EngineContext.Current.Resolve<IWorkContext>();
}

<style>
    .k-grid-header th.k-header,
    tr.k-filter-row > th {
        text-align: center;
    }

    .k-grid td {
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .k-grid-content,
    .k-grid-header {
        font-size: 11px;
    }
</style>

<div class="content">
    <div class="page-bar">
        <ul class="page-breadcrumb">
            <li><i class="fa fa-home"></i><a href="/Home">Home</a><i class="fa fa-angle-right"></i></li>
            <li><a href="/Distribution/Home/Dashboard#">Report</a><i class="fa fa-angle-right"></i></li>
            <li><a href="">Claim Report</a></li>
        </ul>
        <div class="page-toolbar">
            <div class="btn-group pull-right">
                <div class="actions">
                    <input type="text" id="claimSearch" class="k-textbox" placeholder="Search..." style="margin-bottom:10px; width:300px;" />
                    <div class="btn-group">
                        @Html.Partial("~/Views/Shared/Controls/DateField.cshtml", false)
                    </div>
                    <a class="btn btn-circle btn-icon-only btn-default" id="RunQuery" href="#">
                        <i class="icon-control-play"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- BEGIN PAGE CONTENT -->
    <div class="row collapse in" id="demo">
        <div class="col-md-12">
            <div class="portlet light bordered">
                <div class="portlet-body form">
                    <div id="grid"></div>
                    @Html.Partial("~/Views/Shared/Controls/_GridToolbar.cshtml")
                </div>
            </div>
        </div>
    </div>
</div>
<script src="@Scripts.Url("~/JS/reportFilter.js")"></script>
<script src="@Scripts.Url("~/JS/DateFilter.js")" type="text/javascript"></script>
<script>
    var urlClaimReport = window.location.protocol + "//" + window.location.host + "/api/Report/GetClaimReport";
    $(document).ready(function () {
        DateFilter.init(function () {
            consolidate.init(function () {
                $("#grid").data("kendoGrid").dataSource.read();
            });
        });
        var branches = ReportFilter.getBranchs();
        reportConfig = GetReportSetting("AttendanceReport");
        var grid = $("#grid").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: urlClaimReport,
                        dataType: "json",
                        type: "POST",
                        contentType: "application/json; charset=utf-8"
                    },
                    parameterMap: function (options, type) {
                        var paramMap = JSON.stringify($.extend(options, ReportFilter.filterAdditionalData()));
                        delete paramMap.$inlinecount;
                        delete paramMap.$format;
                        return paramMap;
                    }
                },
                schema: {
                    data: "data",
                    model: {
                        fields: {
                            CLAIM_ID: { type: "number" },
                            USERNAME: { type: "string" },
                            CLAIM: { type: "string" },
                            TRAVEL_MODE: { type: "string" },
                            TRAVEL_PURPOSE: { type: "string" },
                            VEHICLE_MILEAGE: { type: "number" },
                            FUEL_PRICE: { type: "number" },
                            START_KM_READING: { type: "number" },
                            END_KM_READING: { type: "number" },
                            CHECK_IN: { type: "date", parse: function (value) { return value ? new Date(value) : null; } },
                            CHECK_OUT: { type: "date", parse: function (value) { return value ? new Date(value) : null; } },
                            TOTAL_EXPENSE: { type: "number" },
                            IN_REMARKS: { type: "string" },
                            OUT_REMARKS: { type: "string" },
                            CHECK_IN_IMAGE: { type: "string" },
                            CHECK_OUT_IMAGE: { type: "string" }
                        }
                    }
                },
                pageSize: 20
            },
            pageable: true,
            sortable: true,
            filterable: true,
            resizable: true,
            toolbar: ["excel"],
            excel: {
                fileName: "ClaimReport.xlsx",
                allPages: true,
                filterable: true
            },
            excelExport: function (e) {
                var sheet = e.workbook.sheets[0];
                var checkInDateIndex = -1;
                var checkInTimeIndex = -1;
                var checkOutDateIndex = -1;
                var checkOutTimeIndex = -1;
                var checkInImgIndex = -1;
                var checkOutImgIndex = -1;
                var billImgIndex = -1;

                e.sender.columns.forEach(function (col, idx) {
                    if (col.title === "CheckIn Date") checkInDateIndex = idx;
                    if (col.title === "CheckIn Time") checkInTimeIndex = idx;
                    if (col.title === "CheckOut Date") checkOutDateIndex = idx;
                    if (col.title === "CheckOut Time") checkOutTimeIndex = idx;
                    if (col.field === "CHECK_IN_IMAGE") checkInImgIndex = idx;
                    if (col.field === "CHECK_OUT_IMAGE") checkOutImgIndex = idx;
                    if (col.field === "BILL_IMG") billImgIndex = idx;
                });

                sheet.rows.forEach(function (row, rowIndex) {
                    if (row.type === "data") {
                        if (checkInDateIndex > -1 && row.cells[checkInDateIndex].value) {
                            var dateObj = new Date(row.cells[checkInDateIndex].value);
                            row.cells[checkInDateIndex].value =
                                kendo.toString(dateObj, "yyyy-MM-dd");
                        }
                        if (checkInTimeIndex > -1 && row.cells[checkInTimeIndex].value) {
                            var dateObj = new Date(row.cells[checkInTimeIndex].value);
                            row.cells[checkInTimeIndex].value =
                                kendo.toString(dateObj, "hh:mm tt");
                        }
                        if (checkOutDateIndex > -1 && row.cells[checkOutDateIndex].value) {
                            var dateObj = new Date(row.cells[checkOutDateIndex].value);
                            row.cells[checkOutDateIndex].value =
                                kendo.toString(dateObj, "yyyy-MM-dd");
                        }
                        if (checkOutTimeIndex > -1 && row.cells[checkOutTimeIndex].value) {
                            var dateObj = new Date(row.cells[checkOutTimeIndex].value);
                            row.cells[checkOutTimeIndex].value =
                                kendo.toString(dateObj, "hh:mm tt");
                        }
                    }
                    [billImgIndex, checkOutImgIndex, checkInImgIndex]
                        .sort(function (a, b) { return b - a; })
                        .forEach(function (index) {
                            if (index > -1) {
                                row.cells.splice(index, 1);
                            }
                        });
                });
            },
            columns: [
                { field: "CLAIM_ID", title: "ClaimID", width: 80 },
                { field: "USERNAME", title: "Employee", width: 120 },
                { field: "CLAIM", title: "ClaimName", width: 150 },
                { field: "TRAVEL_MODE", title: "TravelMode", width: 100 },
                { field: "TRAVEL_PURPOSE", title: "Purpose", width: 150 },
                { field: "MILEAGE", title: "Mileage", width: 80 },
                { field: "FUEL_PRICE", title: "FuelPrice", width: 100 },
                { field: "START_KM_READING", title: "StartKM", width: 80 },
                { field: "END_KM_READING", title: "EndKM", width: 80 },
                //{ field: "CHECK_IN", title: "CheckIn", format: "{0:yyyy-MM-dd HH:mm}", width: 130 },
                //{ field: "CHECK_OUT", title: "CheckOut", format: "{0:yyyy-MM-dd HH:mm}", width: 130 },
                {
                    field: "CHECK_IN",
                    title: "CheckIn Date",
                    template: "#= CHECK_IN ? kendo.toString(CHECK_IN, 'yyyy-MM-dd') : '' #",
                    width: 120
                },
                {
                    field: "CHECK_IN",
                    title: "CheckIn Time",
                    template: "#= CHECK_IN ? kendo.toString(CHECK_IN, 'hh:mm tt') : '' #",
                    width: 110
                },
                {
                    field: "CHECK_OUT",
                    title: "CheckOut Date",
                    template: "#= CHECK_OUT ? kendo.toString(CHECK_OUT, 'yyyy-MM-dd') : '' #",
                    width: 120
                },
                {
                    field: "CHECK_OUT",
                    title: "CheckOut Time",
                    template: "#= CHECK_OUT ? kendo.toString(CHECK_OUT, 'hh:mm tt') : '' #",
                    width: 110
                },
                { field: "TOTAL_EXPENSE", title: "TotalExpense", width: 100 },
                { field: "IN_REMARKS", title: "InRemarks", width: 150 },
                { field: "OUT_REMARKS", title: "OutRemarks", width: 150 },
                {
                    field: "CHECK_IN_IMAGE",
                    title: "CheckInImage",
                    template: `
                        # var img = CHECK_IN_IMAGE && CHECK_IN_IMAGE.trim() !== ""
                            ? "/" + CHECK_IN_IMAGE
                            : "/Areas/NeoErp.Distribution/Images/EntityImages/noimage.png"; #
                        <a href="#= img #" target="_blank">
                            <img src="#= img #" height="60" />
                        </a>
                    `,
                    width: 120,
                    exportable: false
                },
                {
                    field: "CHECK_OUT_IMAGE",
                    title: "CheckOutImage",
                    template: `
                        # var img = CHECK_OUT_IMAGE && CHECK_OUT_IMAGE.trim() !== ""
                            ? "/" + CHECK_OUT_IMAGE
                            : "/Areas/NeoErp.Distribution/Images/EntityImages/noimage.png"; #
                        <a href="#= img #" target="_blank">
                            <img src="#= img #" height="60" />
                        </a>
                    `,
                    width: 120,
                    exportable: false
                },
                {
                    field: "BILL_IMG",
                    title: "Bill Image",
                    template: `
                        # var img = BILL_IMG && BILL_IMG.trim() !== ""
                            ? "/" + BILL_IMG
                            : "/Areas/NeoErp.Distribution/Images/EntityImages/noimage.png"; #
                        <a href="#= img #" target="_blank">
                            <img src="#= img #" height="60" />
                        </a>
                    `,
                    width: 120,
                    exportable: false
                }
            ]
        }).data("kendoGrid");
        var debounceTimer;
        $("#claimSearch").on("keyup", function () {
            var value = $(this).val();
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function () {
                if (value) {
                    grid.dataSource.filter({
                        logic: "or",
                        filters: [
                            { field: "USERNAME", operator: "contains", value: value },
                            { field: "CLAIM", operator: "contains", value: value },
                            { field: "TRAVEL_MODE", operator: "contains", value: value },
                            { field: "TRAVEL_PURPOSE", operator: "contains", value: value },
                            { field: "IN_REMARKS", operator: "contains", value: value },
                            { field: "OUT_REMARKS", operator: "contains", value: value }
                        ]
                    });
                } else {
                    grid.dataSource.filter({});
                }
            }, 250);
        });

        $("#RunQuery").on("click", function (e) {
            e.preventDefault();
            grid.dataSource.read();
        });

        $(".applydp").on("click", function (evt) {
            evt.preventDefault();
            $("#RunQuery").trigger("click");
            $(this).closest("#applydp").modal('hide');
        });
    });
</script>