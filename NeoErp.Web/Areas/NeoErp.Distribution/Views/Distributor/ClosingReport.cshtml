<script type="text/javascript">
    var a = location.hash;
    var b = location.pathname;
    var url = (b + a);
    $(".active").removeClass();
    $("a[href='" + url + "']").parent().addClass("active");
    $("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>

<script type="text/javascript">
    $(".applydp").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
        $(this).closest("#applydp").modal('hide');
    });

    $("#loadAdvancedFilters").on("click", function (evt) {
        evt.preventDefault();
        $("#RunQuery").trigger("click");
    });

    $("#RunQuery").click(function (evt) {
        evt.preventDefault();
        var urltest = window.location.protocol + "//" + window.location.host + "/api/Distributor/GetClosingReport";
        KendoGridRefresh(urltest);
    });
    var searchTimeout = null;

    function GridSearch() {
        var grid = $("#grid").data("kendoGrid");
        if (!grid) return;

        var searchValue = $(".grid-search").val().trim();

        if (searchTimeout) {
            clearTimeout(searchTimeout);
        }

        searchTimeout = setTimeout(function () {
            if (searchValue === "") {
                grid.dataSource.filter({});
                return;
            }

            var searchFields = [
                "CUSTOMER_EDESC",
                "ITEM_EDESC",
                "GROUP_EDESC"
            ];

            var filterConditions = [];
            for (var i = 0; i < searchFields.length; i++) {
                filterConditions.push({
                    field: searchFields[i],
                    operator: "contains",
                    value: searchValue
                });
            }

            grid.dataSource.filter({
                logic: "or",
                filters: filterConditions
            });
        }, 300);
    }

    $(document).on("click", ".search-btn", function (e) {
        e.preventDefault();
        if (searchTimeout) {
            clearTimeout(searchTimeout);
        }
        GridSearch();
    });

    $(document).on("keydown", ".grid-search", function (e) {
        if (e.key === "Escape" || e.keyCode === 27) {
            $(this).val("");
            GridSearch();
        }
    });
    function BindGrid(readurl) {
        var companyName = ('@workingContent.CurrentUserinformation.company_name');
        var fromADdate = $("#FromDateVoucher").val();
        var toADdate = $("#ToDateVoucher").val();
        var fromBSdate = $("#fromInputDateVoucher").val();
        var toBSdate = $("#toInputDateVoucher").val();
        var branches = ReportFilter.getBranchs();
        reportConfig = GetReportSetting("ClosingStockReport");

        var dataSource = new kendo.data.DataSource({
            type: "json",
            transport: {
                read: {
                    url: readurl, // <-- Get data from here.
                    dataType: "json", // <-- The default was "jsonp".
                    type: "POST",
                    contentType: "application/json; charset=utf-8"
                },
                parameterMap: function (options, type) {

                    var paramMap = JSON.stringify($.extend(options, ReportFilter.filterAdditionalData()));
                    delete paramMap.$inlinecount; // <-- remove inlinecount parameter.
                    delete paramMap.$format; // <-- remove format parameter.
                    return paramMap;
                }
            },
            error: function (e) {
                displayPopupNotification("Sorry error occured while processing data", "error");
            },
            model: {
                fields: {
                    ASSIGN_DATE: { type: "date" },
                    Visit_Date: { type: "date" },
                    GROUP_EDESC: {type: "string"}
                }
            },
            //group: {
            //    field: "CUSTOMER_EDESC", dir: "desc", aggregates: [

            //        { field: "OPENING_QTY", aggregate: "sum" },
            //        { field: "PURCHASE_QTY", aggregate: "sum" },
            //        { field: "TOTAL", aggregate: "sum" },
            //        { field: "SECONDARY_SALES", aggregate: "sum" },
            //        { field:"CLOSING_QTY",aggregate:"sum"}
            //    ]
            //},
            group: [
                {
                    field: "GROUP_EDESC", dir: "asc", aggregates: [
                        { field: "OPENING_QTY", aggregate: "sum" },
                        { field: "PURCHASE_QTY", aggregate: "sum" },
                        { field: "TOTAL", aggregate: "sum" },
                        { field: "SECONDARY_SALES", aggregate: "sum" },
                        { field: "CLOSING_QTY", aggregate: "sum" }
                    ]
                },
                {
                    field: "CUSTOMER_EDESC", dir: "asc", aggregates: [
                        { field: "OPENING_QTY", aggregate: "sum" },
                        { field: "PURCHASE_QTY", aggregate: "sum" },
                        { field: "TOTAL", aggregate: "sum" },
                        { field: "SECONDARY_SALES", aggregate: "sum" },
                        { field: "CLOSING_QTY", aggregate: "sum" }
                    ]
                },
                {
                    field: "BRAND_NAME", dir: "asc", aggregates: [
                        { field: "OPENING_QTY", aggregate: "sum" },
                        { field: "PURCHASE_QTY", aggregate: "sum" },
                        { field: "TOTAL", aggregate: "sum" },
                        { field: "SECONDARY_SALES", aggregate: "sum" },
                        { field: "CLOSING_QTY", aggregate: "sum" }
                    ]
                }
            ],


            pageSize: 100,
        });

        var grid = $("#grid").kendoGrid({
            dataSource: dataSource,
            toolbar: kendo.template($("#toolbar-template").html()),
            excel: {
                fileName: "Closing Stock Report",
                allPages: true,
            },
            excelExport: function (e) {
                var sheet = e.workbook.sheets[0];
                if (!sheet || !sheet.rows || !sheet.columns) return;

                var columnCount = sheet.columns.length;
                var openingDateCol, closingDateCol;

                if (sheet.rows[0]?.cells) {
                    sheet.rows[0].cells.forEach((cell, idx) => {
                        if (cell.value === "Opening Date") openingDateCol = idx;
                        if (cell.value === "Closing Date") closingDateCol = idx;
                    });
                }
                sheet.rows.forEach(row => {
                    if (!row?.cells) return;
                    if (row.type === "group-header") {
                        let titleCell = null;
                        let titleIndex = 0;

                        for (let i = 0; i < row.cells.length; i++) {
                            if (row.cells[i]?.value && row.cells[i].value !== "") {
                                titleCell = row.cells[i];
                                titleIndex = i;
                                break;
                            }
                        }

                        if (!titleCell) {
                            titleCell = row.cells[0] || {};
                            titleIndex = 0;
                        }

                        const originalTitle = titleCell.value ?? "";
                        const level = row.level ?? 0;

                        row.cells = Array.from({ length: columnCount }, (_, colIdx) => {
                            const cell = {
                                bold: true,
                                background: titleCell.background,
                                color: titleCell.color
                            };

                            if (colIdx === 0) {
                                cell.value = originalTitle;
                                const indentLevel = row.level ?? 0;
                                if (indentLevel > 0) {
                                    cell.marginLeft = (indentLevel * 10) + "px";
                                }
                            } else {
                                cell.value = "";
                            }

                            return cell;
                        });
                        return;
                    }
                    if (row.type === "data") {
                        if (openingDateCol !== undefined && row.cells[openingDateCol]) {
                            const od = row.cells[openingDateCol].value;
                            row.cells[openingDateCol].value = od
                                ? (od instanceof Date ? kendo.toString(od, "MMM dd, yyyy") : "-")
                                : "-";
                            row.cells[openingDateCol].textAlign = "center";
                        }
                        if (closingDateCol !== undefined && row.cells[closingDateCol]) {
                            const cd = row.cells[closingDateCol].value;
                            row.cells[closingDateCol].value = cd
                                ? (cd instanceof Date ? kendo.toString(cd, "MMM dd, yyyy") : "-")
                                : "-";
                            row.cells[closingDateCol].textAlign = "center";
                        }
                    }
                });
                const headerStack = [];
                const pairedHeaders = new Set();

                sheet.rows.forEach(row => {
                    if (!row?.cells) return;

                    if (row.type === "group-header") {
                        headerStack.push({
                            headerRow: row,
                            level: row.level ?? 0,
                            paired: false
                        });
                    }
                    else if (row.type === "group-footer") {
                        const footerLevel = row.level ?? 0;
                        for (let i = headerStack.length - 1; i >= 0; i--) {
                            const headerInfo = headerStack[i];

                            if (!headerInfo.paired && headerInfo.level === footerLevel) {
                                for (let colIdx = 2; colIdx < columnCount; colIdx++) {
                                    const ftrCell = row.cells[colIdx];
                                    if (!ftrCell || ftrCell.value == null || ftrCell.value === "") continue;

                                    headerInfo.headerRow.cells[colIdx].value = ftrCell.value;
                                    if (ftrCell.format) headerInfo.headerRow.cells[colIdx].format = ftrCell.format;
                                }

                                headerInfo.paired = true;
                                pairedHeaders.add(headerInfo.headerRow);
                                break;
                            }
                        }
                    }
                });
                sheet.rows = sheet.rows.filter(row => row.type !== "group-footer");
                sheet.columns.forEach((col, idx) => {
                    col.autoWidth = true;
                    if (idx > 1) col.width = 8;
                });
            },
            pdf: {
                //fileName: "Received Schedule",
                allPages: true,
                avoidLinks: true,
                pageSize: "auto",
                margin: {
                    top: "2m",
                    right: "1m",
                    left: "1m",
                    buttom: "1m",
                },

                landscape: true,
                repeatHeaders: true,
                scale: 0.8,
            },
            height: window.innerHeight - 50,
            sortable: true,
            reorderable: true,
            groupable: true,
            resizable: true,
            filterable: {
                extra: false,
                operators: {
                    number: {
                        eq: "Is equal to",
                        neq: "Is not equal to",
                        gte: "is greater than or equal to	",
                        gt: "is greater than",
                        lte: "is less than or equal",
                        lt: "is less than",
                    },
                    string: {

                        eq: "Is equal to",
                        neq: "Is not equal to",
                        startswith: "Starts with	",
                        contains: "Contains",
                        doesnotcontain: "Does not contain",
                        endswith: "Ends with",
                    },
                    date: {
                        eq: "Is equal to",
                        neq: "Is not equal to",
                        gte: "Is after or equal to",
                        gt: "Is after",
                        lte: "Is before or equal to",
                        lt: "Is before",
                    }
                }
            },
            columnMenu: true,
            columnMenuInit: function (e) {
                wordwrapmenu(e);
                checkboxItem = $(e.container).find('input[type="checkbox"]');
            },
            pageable: {
                refresh: true,
                pageSizes: ["50", "100", "500", "1000", "All"],
                buttonCount: 5
            },
            expand: function (e) {
                var grid = this;
                console.log("hello?");
                $("tr.k-group-footer:not(:last-child)").each(function () {
                    console.log("hello2");
                    var nextRow = $(this).next();
                    if (nextRow.hasClass('k-group-footer')) {
                        console.log("hello3");
                        $(this).hide();
                    }
                });
                $('div').removeClass('.k-group-footer');
            },
            dataBound: function (o) {
                GetSetupSetting("ClosingStockReport");
                var grid = this;
                if ($("#grid").data("kendoGrid").dataItems().length == 0) {
                    var colCount = grid.columns.length;
                    $(o.sender.wrapper)
                        .find('tbody')
                        .append('<tr class="kendo-data-row" style="font-size:12px;"><td colspan="' + colCount + '" class="alert alert-danger">Sorry, no data :(</td></tr>');
                    displayPopupNotification("No Data Found.", "info");
                }
                else {
                    grid.tbody.find("tr").dblclick(function (e) {
                        if (e.srcElement.className == "k-icon k-i-expand" || e.srcElement.className == "k-hierarchy-cell" || e.srcElement.className == "k-icon k-i-collapse")
                            return;
                        e.preventDefault();

                        updateEvent(grid.dataItem(this));

                    });


                    $("tr.k-group-footer:not(:last-child)").each(function () {
                        var nextRow = $(this).next();
                        if (nextRow.hasClass('k-group-footer')) {
                            $(this).hide();
                        }
                    });

            }

                $('div').removeClass('.k-header k-grid-toolbar');
                $("#allItems").parent().hide();


            },
            columns: [{
                field: "CUSTOMER_EDESC",
                title: "Customer Name",
                width: "20%",
                groupFooterTemplate:"Total"
            },{
                field: "BRAND_NAME",
                title: "Brand Name",
                width: "20%",
            }, {
                field: "ITEM_EDESC",
                title: "Item",
                width: "20%",
            }, {
                field: "OPENING_QTY",
                title: "Opening qty",
                width: "15%",
                attributes: {
                    style: "text-align: right;"
                },
                aggregates: ["sum"],
                groupFooterTemplate: "#= kendo.toString(sum, 'n')#",
                headerAttributes: {
                    title: "Stock quantity from the last stock update prior to the current closing stock date."
                    },
                },
                {
                    field: "OPENING_DATE",
                    title: "Opening Date",
                    width: "15%",
                    attributes: {
                        style: "text-align: right;"
                    },
                    headerAttributes: {
                        title: "Date of the previous stock update immediately before the closing stock update."
                    },
                    template: "#= OPENING_DATE ? kendo.toString(new Date(OPENING_DATE), 'MMM dd, yyyy') : '-' #"
                },
                {
                    field: "PURCHASE_QTY",
                    title: "Sales",
                    width: "15%",
                    attributes: {
                        style: "text-align: right;"
                    },
                    aggregates: ["sum"],
                    headerAttributes: {
                        title: "Total quantity sold to the distributor between the previous stock update date and the closing stock date."
                    },
                    groupFooterTemplate: "#= kendo.toString(sum, 'n')#",
                }, {
                field: "TOTAL",
                title: "Total",
                width: "15%",
                attributes: {
                    style: "text-align: right;"
                },
                aggregates: ["sum"],
                groupFooterTemplate: "#= kendo.toString(sum, 'n')#",
                },  {
                field: "SECONDARY_SALES",
                title: "Secondary Sales",
                width: "15%",
                attributes: {
                    style: "text-align: right;"
                },
                    aggregates: ["sum"],
                    headerAttributes: {
                        title: "Calculated consumption between two stock updates using the formula: Previous Stock + Primary Sales − Closing Stock"
                    },
                groupFooterTemplate: "#= kendo.toString(sum, 'n')#",
            }, {
                field: "CLOSING_QTY",
                title: "Closing Qty",
                width: "15%",
                attributes: {
                    style: "text-align: right;"
                },
                    aggregates: ["sum"],
                    headerAttributes: {
                        title: "Latest stock quantity updated  on or before the selected As On Date."
                    },
                groupFooterTemplate: "#= kendo.toString(sum, 'n')#",
                },
                {
                    field: "CLOSING_DATE",
                    title: "Closing Date",
                    width: "15%",
                    attributes: {
                        style: "text-align: right;"
                    },
                    headerAttributes: {
                        title: "Date on which the distributor last updated stock on or before the selected As On Date."
                    },
                    template: "#= CLOSING_DATE ? kendo.toString(new Date(CLOSING_DATE), 'MMM dd, yyyy') : '-' #"

                },{
                    field: "UPDATE_DAYS",
                    title: "Days since update",
                    width: "15%",
                    attributes: {
                        style: "text-align: right;"
                    },
                    headerAttributes: {
                        title: "Number of days since the distributor last updated stock, calculated up to the selected As On Date."
                    },

                },]
        });


    }

    function KendoGridRefresh(readUrl) {
        $('#grid').val('');
        $('#grid').html('');
        BindGrid(readUrl);
    }

    $(document).ready(function () {
        var urltest = window.location.protocol + "//" + window.location.host + "/api/Distributor/GetClosingReport";
        DateFilter.init(function () {
            BindGrid(urltest);
            //var dateFilterForm = $("#form_modal2").find(".form-horizontal").find(".form-group");
            //console.log(dateFilterForm);
            //$(dateFilterForm[0]).hide(); //hiding the date range drop down selector
