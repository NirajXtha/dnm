            //$(dateFilterForm[2]).find("span").hide();
            //$("#toInputDateVoucher").hide();
            //$("#ToDateVoucher").hide();
        });
        var $formGroups = $("#form_modal2 .form-horizontal .form-group");

        var $firstLabel = $formGroups.eq(0).find("label");
        $firstLabel.css("width", "100%");
        $firstLabel.text("Stock As On Date ");
        var $infoIcon = $('<i class="fa fa-info-circle" style="margin-left:5px;" title="Shows stock level exactly as of the selected date. The report considers the latest stock update on or before this date for each distributor."></i>');

        // Append the icon to the label
        $firstLabel.append($infoIcon);
    });
</script>
