            SQL_COMPANY_ENTITY: SQL_COMPANY_ENTITY,
            LO_BG_TRACK: LO_BG_TRACK,
            PO_RATE_TABLE: $("#RateTableSetup").val(),
            PO_RATE_COLUMN: $("#RateColumnSetup").val(),
            SO_REPO_RATE_TABLE: $("#SORateTableSetup").val(),
            SO_REPO_RATE_COLUMN: $("#SORateColumnSetup").val(),
            PO_DIST_RATE_COLUMN: $("#RateColumnSetupDist").val(),
            LO_BG_TIME: $("#bgTime").val(),
            SQL_PEV_DAYS: $("#prevDays").val(),
            SQL_FOL_DAYS: $("#folDays").val(),
            SALES_RATE_DISCOUNT: SALES_RATE_DISCOUNT,
            SALES_FLAT_DISCOUNT: SALES_FLAT_DISCOUNT,
            SALES_PERCENTAGE_DISCOUNT: SALES_PERCENTAGE_DISCOUNT,
            SO_DISCOUNT_TABLE: '',
            SO_DISCOUNT_COLUMN: '',
            RESELLER_DEFAULT_RATE: RESELLER_DEFAULT_RATE,
            RESELLER_CUSTOM_RATE: RESELLER_CUSTOM_RATE,
        }

        $.ajax({
            type: 'POST',
            data: data,
            dataType: "json",
            //contentType: false,
            //processData: false,
            url: window.location.protocol + "//" + window.location.host + "/api/UserSetup/UpdatePreferenceSetup",
            success: function (data) {
                // $("#grid").data("kendoGrid").dataSource.read();
                //update grid data
                // clear();
                setTimeout(function () {
                    location.reload();
                }, 1000)
                displayPopupNotification("Update success", "success");


            },
            error: function(data) {
                setTimeout(function () {
                    location.reload();
                }, 1000)
                displayPopupNotification(data.responseJSON.ExceptionMessage, "error");
            }

        });

    });
</script>
