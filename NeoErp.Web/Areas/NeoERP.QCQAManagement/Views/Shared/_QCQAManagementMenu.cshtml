<style>
	.form_tree {
		margin-top: 30px;
	}

		.form_tree .k-group.k-treeview-lines, .form_tree #formTreeView {
			max-height: 1500px !important;
			height: auto !important;
			overflow-x: hidden;
		}

	.page-sidebar.navbar-collapse {
		margin-top: 2px;
	}

	.page-sidebar .form_tree .k-treeview-lines li span {
		font-size: 12px !important;
	}


	.container-2 {
		width: 300px;
		vertical-align: middle;
		white-space: nowrap;
		position: relative;
	}

		.container-2 input.Tree_search {
			width: 17px;
			height: 24px;
			border: none;
			font-size: 12px;
			float: left;
			color: #262626;
			padding-left: 26px;
			-webkit-border-radius: 5px;
			-moz-border-radius: 5px;
			border-radius: 5px;
			color: #fff;
			border: solid #ddd 1px;
			margin-left: 10px;
			color: #2e2e2e;
			-webkit-transition: width .55s ease;
			-moz-transition: width .55s ease;
			-ms-transition: width .55s ease;
			-o-transition: width .55s ease;
			transition: width .55s ease;
		}

			.container-2 input.Tree_search::-webkit-input-placeholder {
				color: #65737e;
			}

			.container-2 input.Tree_search:-moz-placeholder { /* Firefox 18- */
				color: #65737e;
			}

			.container-2 input.Tree_search::-moz-placeholder { /* Firefox 19+ */
				color: #65737e;
			}

			.container-2 input.Tree_search:-ms-input-placeholder {
				color: #65737e;
			}

		.container-2 .icon {
			position: absolute;
			top: 50%;
			margin-left: 18px;
			margin-top: 7px;
			z-index: 1;
			color: #999;
		}

		.container-2 input.Tree_search:focus, .container-2 input.Tree_search:active {
			outline: none;
			width: 300px;
		}

		.container-2:hover input.Tree_search {
			width: 222px;
		}

		.container-2:hover .icon {
			color: #93a2ad;
		}

	#formContextMenu {
		font-size: 11px !important;
	}
</style>

