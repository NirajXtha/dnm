	<script>
		(function () {
			var $sidebar = $('.page-sidebar-menu');

			function disableHoverBehavior() {
				// remove title attributes (save them)
				$sidebar.find('[title]').each(function () {
					var $el = $(this);
					if (!$el.data('savedTitle')) $el.data('savedTitle', $el.attr('title'));
					$el.removeAttr('title');
				});
				// hide any existing tooltip/popover elements that might be present
				$('.sidebar-hover, .page-sidebar-hover, .menu-tooltip, .menu-popover, .tooltip, [role="tooltip"]').hide();
			}

			function enableHoverBehavior() {
				// restore titles
				$sidebar.find('[data-savedTitle]').each(function () {
					var $el = $(this);
					$el.attr('title', $el.data('savedTitle'));
					$el.removeData('savedTitle');
				});
			}

			function update() {
				if ($sidebar.hasClass('page-sidebar-menu-closed') || $sidebar.closest('.page-sidebar').hasClass('page-sidebar-closed')) {
					disableHoverBehavior();
				} else {
					enableHoverBehavior();
				}
			}

			// run once on ready
			$(document).ready(function () {
				setTimeout(update, 50); // small delay to allow initial classes to settle
			});

			// watch clicks on common toggler(s) and re-run after toggle
			$(document).on('click', '.sidebar-toggler, .sidebar-collapse, .menu-toggler, .page-header .menu-toggler', function () {
				setTimeout(update, 50);
			});

			// MutationObserver to detect class changes on the sidebar element (robust)
			var sidebarNode = $sidebar.get(0);
			if (sidebarNode && window.MutationObserver) {
				var obs = new MutationObserver(function (mutations) {
					mutations.forEach(function (m) {
						if (m.attributeName === 'class') update();
					});
				});
				obs.observe(sidebarNode, { attributes: true, attributeFilter: ['class'] });
			}
		})();
	</script>*@