<style>
	.header, .header-space,
	.footers, .footer-spaces {
		height: 105px;
	}

	.header {
		position: relative;
		top: 0;
	}

	.footer {
		/*position: fixed;*/
		position: relative;
		bottom: 0;
	}

	.companylogo img {
		max-width: 100% !important;
		max-height: 50px !important;
		margin-right: 20px !important;
	}

	.incoming-material-tr {
		border-top: 1px solid #333;
	}

	.incoming-material-td {
		border-right: 1px solid #333;
	}




	.p_header {
		min-height: 80px;
	}

	.p_header {
		min-height: 80px;
	}


	user agent stylesheet
	thead {
		display: table-header-group;
		vertical-align: middle;
		unicode-bidi: isolate;
		border-color: inherit;
	}

	.printable-modal > table {
		border: none !important;
		border-collapse: collapse;
		width: 100%;
	}

	table {
		border-spacing: 0;
		border-collapse: collapse;
	}

	user agent stylesheet
	table {
		border-collapse: separate;
		text-indent: initial;
		border-spacing: 2px;
	}

	body {
		font-family: sans-serif, 'Open Sans';
	}

	body {
		font-family: Arial, sans-serif;
		font-size: 9px;
		margin: 0;
		padding: 0;
	}

	body {
		color: #333333;
		font-family: "Open Sans", sans-serif;
		padding: 0px !important;
		margin: 0px !important;
		font-size: 13px;
		direction: ltr;
	}

	body {
		font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
		font-size: 14px;
		line-height: 1.42857143;
		color: #333;
		background-color: #fff;
	}

	html {
		font-size: 10px;
		-webkit-tap-highlight-color: rgba(0, 0, 0, 0);
	}

	html {
		font-family: sans-serif;
		-webkit-text-size-adjust: 100%;
		-ms-text-size-adjust: 100%;
	}

	:after, :before {
		-webkit-box-sizing: border-box;
		-moz-box-sizing: border-box;
		box-sizing: border-box;
	}

	:after, :before {
		-webkit-box-sizing: border-box;
		-moz-box-sizing: border-box;
		box-sizing: border-box;
	}
	.info{
		margin-right:200px !important;
	}

</style>

<div class="printable-modal">
	<table>
		<thead class="p_header">
			<tr>
				<td>
					<div class="header-space">
						<div class="companylogo" style="width:20%;">
							<img alt="" src="~/Images/Birat.Jpeg" style="max-width: 115% !important; max-height: 70px !important;">
						</div>

						<div class="info">
							<h4> {{printCompanyInfo.companyName}}<br>{{printCompanyInfo.form_edesc}}</h4>
							<p>{{printCompanyInfo.address}}</p>
							<p>Ph.No. : {{printComnayInfo.TELEPHONE}}</p>

						</div>
						<div class="print_document_title">
							<h3 style="text-decoration-line:underline">OnSite Inspection</h3>
						</div>

						<div class="left-side" style="padding-top: 0px !important">
							<table class="print_table consignee">
								<tr>
									<td style="width:15%;text-align:left;" id="IncomingMaterialTes">Inspection No</td>
									<td style="width:20%;text-align:left;">: {{Inspection_No}}</td>
								</tr>
								<tr>
									<td style="width:15%; text-align:left;" id="IncomingMaterialTes">Plant</td>
									<td style="width:20%;text-align:left;">: {{ITEM_CODE}}</td>
								</tr>
								<tr>
									<td style="width:15%; text-align:left;" id="IncomingMaterialTes">Product</td>
									<td style="width:20%;text-align:left;">: {{ITEM_EDESC}}</td>
								</tr>
								<tr>
									<td style="width:15%;text-align:left;" id="IncomingMaterialTes">Shift</td>
									<td style="width:20%;text-align:left;">: {{Shift}}</td>
								</tr>
							</table>
						</div>
						<div class="right-side" style="padding-top: 0px !important;">
							<table class="print_table consignee" style="width:100%;margin-bottom:5px;">
								<tr>
									<td style="width:40%;text-align:right;">Date/Miti</td>
									<td style="width:20%;text-align:left;">: {{ CREATED_DATE | date:'dd-MMM-yyyy' }}</td>
								</tr>
								<tr>
									<td style="width:40%;text-align:right;">Batch No</td>
									<td style="width:20%;text-align:left;">: {{Batch_No}}</td>
								</tr>
								<tr>
									<td style="width: 40%; text-align: right; ">
										Ref.No
									</td>
									<td style="text-align:left; width:50%;">
										: {{REFERENCE_NO}}
									</td>
								</tr>
							</table>
						</div>
					</div>
				</td>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>
					<table class="print_table fnce" style="width:100%;border:1px solid black;">
						<thead>
							<tr>
								<th style="width:5%;" class="abc" rowspan="2"><b>S.No.</b></th>
								<th style="width:38.5%;" class="abc" rowspan="2"><b>Parameters</b></th>
								<th style="width:18.5%;" class="abc" rowspan="2"><b>Target</b></th>
								<th class="abc" style="width:18%;" rowspan="2"><b>Tolerence(±)</b></th>
								<th class="abc" style="width:18%;" rowspan="2"><b>Results</b></th>
								<th class="abc" style="width:18%;" rowspan="2"><b>Variance</b></th>
							</tr>
						</thead>
						<tbody>
							<tr class="grid-tr" ng-repeat="(key1,row) in childModels">
								<td style="border: 1px solid #000 !important;">
									<span>{{key1 + 1}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['PARAMETERS']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['TARGET']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['TOLERENCE']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['RESULTS']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['VARIANCE']}}</span>
									</div>
								</td>
						</tbody>
					</table>
				</td>
			</tr>


		</tbody>
		<tfoot>
			<tr>
				<td>
					<div style="display: flex; justify-content: space-between; text-align: center; padding-top: 10px !important;">
						<div style="width: 25%;">
							<p>{{CHECKED_BY}}</p>
							<p>Checked By</p>
						</div>
						<div style="width: 25%;">
							<p>{{CHECKED_BY}}</p>
							<p>QC Assistant</p>
						</div>
						<div style="width: 25%;">
							<p>{{AUTHORISED_BY}}</p>
							<p>Verified By</p>
						</div>
						<div style="width: 25%;">
							<p>{{POSTED_BY}}</p>
							<p>QC Head</p>
						</div>
					</div>
				</td>
			</tr>
		</tfoot>
	</table>
</div>
