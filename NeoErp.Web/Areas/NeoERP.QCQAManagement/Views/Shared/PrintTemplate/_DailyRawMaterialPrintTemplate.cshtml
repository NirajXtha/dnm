@using NeoErp.Core;
@using NeoErp.Core.Infrastructure;
@{
	var workingContent = EngineContext.Current.Resolve<IWorkContext>();
}

<link href="@Styles.Url(" ~/Areas/NeoERP.DocumentTemplate/Content/saleschalanpra.css")" rel="stylesheet" media="print" />
<link href="@Styles.Url(" ~/Areas/NeoERP.DocumentTemplate/Content/saleschalanpra.css")" rel="stylesheet" />
<style>
	.header, .header-space,
	.footers, .footer-spaces {
		height: 105px;
	}

	.header {
		position: relative;
		top: 0;
	}

	.footer {
		/*position: fixed;*/
		position: relative;
		bottom: 0;
	}
	.companylogo img {
		max-width: 100% !important;
		max-height: 50px !important;
		margin-right: 20px !important;
	}

	.incoming-material-tr {
		border-top: 1px solid #333;
	}

	.incoming-material-td {
		border-right: 1px solid #333;
	}
</style>

<div class="printable-modal">
	<table>
		<thead class="p_header">
			<tr>
				<td>
					<div class="header-space">
						<div class="companylogo" style="width:20%;">
							<img alt="" src="~/Images/Birat.Jpeg" style="max-width: 115% !important; max-height: 70px !important;">
						</div>

						<div class="info">
							<h4> {{printCompanyInfo.companyName}}<br>{{printCompanyInfo.form_edesc}}</h4>
							<p>{{printCompanyInfo.address}}</p>
							<p>Ph.No. : {{printComnayInfo.TELEPHONE}}</p>

						</div>
						<div class="print_document_title">
							<h3 style="text-decoration-line:underline">Daily Raw Material</h3>
						</div>


						<div class="left-side" style="padding-top: 0px !important">
							<table class="print_table consignee">
								<tr>
									<td style="width:15%;text-align:left;" id="IncomingMaterialTes">Product Type</td>
									<td style="width:20%;text-align:left;">: {{ITEM_CODE}}</td>
								</tr>
								<tr>
									<td style="width:15%;text-align:left;" id="IncomingMaterialTes">QC No</td>
									<td style="width:20%;text-align:left;">: {{QC_NO}}</td>
								</tr>								
								<tr>
									<td style="width:15%;text-align:left;">QC Date</td>
									<td style="width:20%;text-align:left;">: {{ CREATED_DATE | date:'dd-MMM-yyyy' }}</td>
								</tr>
							</table>
						</div>
						<div class="right-side" style="padding-top: 0px !important;">
							<table class="print_table consignee" style="width:100%;margin-bottom:5px;">
								<tr>
									<td style="width:40%;text-align:right;">Production Batch No  </td>
									<td style="width:20%;text-align:left;">: {{BATCH_NO}}</td>
								</tr>
								<tr>
									<td style="width: 40%; text-align: right; ">
										Manual No
									</td>
									<td style="text-align:left; width:50%;">
										: {{MANUAL_NO}}
									</td>
								</tr>

								<tr>
									<td style="width:40%;text-align:right;">Remarks </td>
									<td style="width:20%;text-align:left;">: {{REMARKS}}</td>
								</tr>
							</table>
						</div>
					</div>
				</td>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>
					<table class="print_table fnce" style="width:100%;border:1px solid black;">
						<thead>
							<tr>
								<th style="width:5%;" class="abc" rowspan="2"><b>S.No.</b></th>
								<th style="width:38.5%;" class="abc" rowspan="2"><b>Raw Material Name</b></th>
								<th style="width:18.5%;" class="abc" rowspan="2"><b>Vendor Name</b></th>
								<th class="abc"  style="width:18%;" rowspan="2"><b>Batch No</b></th>
								<th style="width:20%;" class="abc" rowspan="2" ><b>Roll No</b></th>
								<th style="width:39%;" class="abc" colspan="5"><b>Standard</b></th>
								<th class="abc"  style="width:39%;" colspan="5"><b>Actual</b></th>
								<th style="width:20%;" class="abc" rowspan="2"><b>Remarks</b></th>
							</tr>
							<tr style="border-top: 1px solid #333;">
								<th style="width:13%;" class="abc"><b>GSM</b></th>
								<th style="width:13%;" class="abc"><b>Width</b></th>
								<th style="width:13%;" class="abc"><b>MD S</b></th>
								<th style="width:13%;" class="abc"><b>CD S</b></th>
								<th style="width:13%;" class="abc"><b>Thickness</b></th>
								<th style="width:13%;" class="abc"><b>GSM</b></th>
								<th style="width:13%;" class="abc"><b>Width</b></th>
								<th style="width:13%;" class="abc"><b>MD S</b></th>
								<th style="width:13%;" class="abc"><b>CD S</b></th>
								<th style="width:13%;" class="abc"><b>Thickness</b></th>
							</tr>
						</thead>
						<tbody>
							<tr class="grid-tr" ng-repeat="(key1,row) in RawMaterialList">
								<td style="border: 1px solid #000 !important;">
									<span>{{key1 + 1}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['ITEM_EDESC']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['SUPPLIER_EDESC']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['BATCH_NO']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['ROLL_NO']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['GSM']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['WIDTH']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['STRENGTH_MD']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['STRENGTH']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['THICKNESS']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<span>{{childModels[key1]['ACTUAL_GSM']}}</span>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['ACTUAL_WIDTH']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['ACTUAL_STRENGTH_MD']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['ACTUAL_STRENGTH']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['ACTUAL_THICKNESS']}}</span>
									</div>
								</td>
								<td style="border: 1px solid #000 !important;">
									<div>
										<span>{{childModels[key1]['REMARKS']}}</span>
									</div>
								</td>

						</tbody>

					</table>
				</td>
			</tr>


		</tbody>
		<tfoot>
			<tr>
				<td>
					<div style="display: flex; justify-content: space-between; text-align: center; padding-top: 10px !important;">
						<div style="width: 25%;">
							<p>-----------------------------</p>
							<p>Checked By</p>
						</div>
						<div style="width: 25%;">
							<p>-----------------------------</p>
							<p>QC Assistant</p>
						</div>
						<div style="width: 25%;">
							<p>-----------------------------</p>
							<p>Verified By</p>
						</div>
						<div style="width: 25%;">
							<p>-----------------------------</p>
							<p>QC Head</p>
						</div>
					</div>
				</td>
			</tr>
		</tfoot>
	</table>
</div>
