
@{
	ViewBag.Title = "OutLetSetup";
	Layout = null;
}
<style>
	#OutletsForm h4 {
		margin-top: 0px !important;
	}

	#outletSetup .k-auto-scrollable {
		overflow-y: auto !important;
		/*overflow: hidden !important;*/
	}

	.k-splitter {
		min-height: 404px;
	}

	.form-control {
		width: 97% !important;
	}

	.custom-panel-body {
		padding: 7px 30px 0px 10px !important;
		height: 182px;
	}


		.custom-panel-body .caption {
			font-size: 12px !important;
			padding: 5px 0 6px 0 !important;
		}

		.custom-panel-body .portlet-title {
			min-height: auto !important;
		}

	/*.control-label {
		font-size: 12px !important;
	}*/

	.tblresponsive {
		border: 1px solid #e1e1e1 !important;
	}

	.table thead tr th {
		font-size: 12px;
		font-weight: 600;
	}

	/*button#cancelOutlet {
		padding-bottom: 3px !important;
		margin-right: 12px !important
	}*/

	input#outletCode {
		font-size: 12px;
	}

	input#outletName {
		font-size: 12px;
	}

	#outletSetup .k-grid-header {
		padding-right: 0px !important
	}

	.titleheading {
		padding: 5px 0px 5px !important
	}
	.row-margin{
		margin-bottom:15px;
	}
</style>

<body>

	<div id="splitter" ng-controller="ParameterSetupList">
		<div id="pane1">
			<div id="outletSetup">
				<kendo-grid options="grid" id="grid"></kendo-grid>
			</div>
		</div>
		<div>
			<div id="OutletsForm" name="OutletsForm" novalidate>
				<div class="panel-body custom-panel-body clearfix">
					<div class="portlet box box-green">
						<div class="portlet-title">
							<div class="caption">
								<i class="icon-equalizer font-green-haze"></i>
								<span class="caption-subject font-green-haze bold uppercase text-center" style="text-align: center">
									PARAMETER SETUP
								</span>
							</div>

						</div>
						<div class="portlet-body form">
						</div>
					</div>
					<div class="main">
						<div class="tblresponsive">
							<table class="table table-striped  table-hover ctable" id="items">

								<thead style="background-color:#eee">

									<tr>
										<th width="5%">SN.</th>
										<th width="30%">
											Item ID <small style="opacity:0.6"></small>
										</th>
										<th width="30%">Description</th>
										<th width="30%">Category</th>
									</tr>
								</thead>
								<tbody>
									<tr style="font-size:10px;" ng-if="Outlets.length==0">
										<td colspan="8">No Items To Display..</td>
									</tr>
									<tr ng-repeat="out in Outlets track by out.ITEM_CODE">
										<td hidden>{{out.ITEM_CODE}}</td>
										<td>{{$index+1}}</td>

										<td>
											@*<input class="form-control" type="text" name="userName" ng-model="out.PRODUCT_CODE" placeholder="Code (S,M,B)" style="font-weight:normal !important">*@
											{{out.PRODUCT_CODE}}
										</td>
										<td>
											@*<input class="form-control" type="text" name="userName" ng-model="out.ITEM_EDESC" placeholder="Name (Small, Medium, Big)" style="font-weight:normal !important">*@
											{{out.ITEM_EDESC}}
										</td>
										<td>
											@*<input class="form-control" type="text" name="userName" ng-model="out.CATEGORY_EDESC" placeholder="Name (Small, Medium, Big)" style="font-weight:normal !important">*@
											{{out.CATEGORY_EDESC}}
										</td>
										<td>
											<a href="javascript:void(0)" ng-show="out.ITEM_CODE" ng-click="AddParameterModal(out.ITEM_CODE,out.ITEM_EDESC)" class="btn btn-xs btn-success pull-right">
												[<i class="fa fa-plus"></i>]
											</a>

										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>



					<div class="modal fade-out" id="ParameterModal" data-backdrop="static" tabindex="-1" data-width="800">
						<div class="modal-dialog modal-dialog-centered">
							<div class="modal-content">
								<div class="modal-header">
									<button type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</button>
									<h4 class="modal-title">
										<span class="fa fa-file"></span>
										Specification
									</h4>
								</div>
								<div class="k-grid-content  k-auto-scrollable" style="height: 400px; padding-top: 10px;">
									<form name="projectForm" class="form" method="post" ng-submit="submitQCSetup()" enctype="multipart/form-data" id="projectForm" novalidate>
										<input type="hidden" name="qcqaId" id="qcqaId" ng-model="item_code">
										<div class="form-group row">
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Description</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="item_edesc">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Apply on/Plant</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="ITEM_APPLY_ON">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Brand Name</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="BRAND_NAME">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Part Number/Model</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="PART_NUMBER">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Specification</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="ITEM_SPECIFICATION">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Thickness</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="thickness">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Equipment</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="INTERFACE">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Color</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="COLOR">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Lamination</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="LAMINATION">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Grade/Range</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="GRADE">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Type</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="TYPE">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Item Size</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="ITEM_SIZE">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">GSM</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="GSM">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">KG Weight</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="REEM_WEIGHT_KG">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Length</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="SIZE_LENGHT">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Width</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="SIZE_WIDTH">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Roll Diameter</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="RollDiameter">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">pH</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="PH">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Unpleseant smell and odour</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="UNPLEASANT_SMELL_ODOUR">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Dust and dirt</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Dust_Dirt">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Damaging of Material</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Damaging_Material">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Core Damaging</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Core_Damaging">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Tensile CD</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Tensile_CD">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Tensile MD</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Tensile_MD">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Strength CD</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Strength">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Strength MD</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Strength_MD">
												</div>
											</div>
											<div class="col-sm-12 row-margin">
												<label for="projectName" class="col-sm-1 col-form-label">Visual Inspection</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="Visual_Inspection">
												</div>
												<label for="projectName" class="col-sm-2 col-form-label">Remarks</label>
												<div class="col-sm-3">
													<input type="text" class="form-control" ng-model="REMARKS">
												</div>
											</div>

										</div>

											<input type="submit" class="hidden" id="btnProject" value="submit">
							</form>
								</div>

								<div class="modal-footer">
									<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveParameterSetup()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
										<i class="fa fa-floppy-o"></i> Save
									</button>
									<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
										<i class="fa-solid fa-xmark"></i> Cancel
									</button>
								</div>
							</div>
						</div>
					</div>




				</div>



			</div>
		</div>
	</div>
</body>

<script>
	var a = location.hash;
	var b = location.pathname;
	var url = (b + a);
	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
<script>
	$("#splitter").kendoSplitter();
	var splitter = $("#splitter").data("kendoSplitter");
	splitter.size(".k-pane:first", "19%");
	//new
	splitter.max("#pane1", "200px");
	//old
	// splitter.max("#pane1", "550px");
	// splitter.min("#pane1", "200px");

	$('.tblresponsive').slimScroll({
		height: '320px',
	});

</script>
@*<script src="@Scripts.Url("~/Areas/NeoErp.QCQAManagement/js/MenuNavigation.js?V2")"></script>*@
