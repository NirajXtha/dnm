					</div>
					<div class="tab-content d-tab-content">
						<div class="tab-pane active" id="tab_15_1">
							<div class="table-responsive">
								<div class="col-md-12 col-sm-12">
									<label for="element" class="label-font">Weight Details (KG)</label>

									<table class="document_child_table dynamic-table table-fixed dynamic_child_table dynamic_child_table6 table-border">

										<thead class="child-table-head">
											<tr>
												<th class="SNo header">S/No</th>
