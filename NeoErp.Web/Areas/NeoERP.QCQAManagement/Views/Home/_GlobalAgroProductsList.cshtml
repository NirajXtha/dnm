<style>
	.input-text {
		width: 200px;
	}

	.form-text {
		width: 200px !important;
		margin-right: 16px !important;
	}

	.input-6 {
		width: 370px;
	}

	.input-3 {
		width: 220px;
	}

	.inner-line {
		width: 100%;
		height: 2px;
		background-color: black; /* solid line */
		position: absolute;
		top: 50%; /* position the line halfway vertically */
		left: 0;
	}

	.third-grid {
		height: 52px;
		border-style: solid;
		border-width: 2px;
		/*color: #333333;*/
		border: 1px solid #e1e1e1 !important;
		min-height: 1px;
	}

	.fourth-grid {
		height: 52px;
		border-style: solid;
		border-width: 2px;
		/*color: #333333;*/
		border: 1px solid #e1e1e1 !important;
		min-height: 1px;
	}

	.fifth-grid {
		height: 52px;
		border-style: solid;
		border-width: 2px;
		/*color: #333333;*/
		border: 1px solid #e1e1e1 !important;
		min-height: 1px;
	}

	.label-font {
		margin: 0px 0px 5px 370px;
		font-weight: bold;
	}

	.stamp-details {
		height: 100px;
		border-style: solid;
		border-width: 2px;
		border: 1px solid #e1e1e1 !important;
		min-height: 1px;
		margin-left: 770px;
		width: 91px;
	}

	.div-margin-top {
		margin-top: 15px;
	}

	.div-second-margin-top {
		margin-top: 5px;
	}

	.margin-dust {
		margin-left: 50px;
	}

	.div-margin {
		margin-right: 90px !important;
	}

	.div-margin-master {
		margin-right: 78px !important;
	}

	.div-margin-master-textbox {
		margin-right: 127px !important;
		width: 24% !important;
	}

	.div-margin-master-second-textbox {
		width: 23% !important;
	}

	.div-margin-master-third-textbox {
		width: 22% !important;
		padding-left: 0px !important;
	}

	.div-margin-master-date {
		display: flex;
		margin-top: 16px;
		margin-right: 60px !important;
	}

	.ddlMaterials {
		width: 200px !important;
	}

	.table-border {
		border: 1px solid #e1e1e1 !important;
	}

	.td-border {
		border-right: none !important;
	}

	.large-button {
		padding: 8px 24px;
		/*font-size: 18px;*/
		border-radius: 6px;
		background-color: #28a745;
		color: white;
		border: none;
		cursor: pointer;
		display: block; /* Ensures proper centering */
		margin: auto; /* Centers horizontally */
	}

	.k-window {
		position: fixed !important;
		top: 50% !important;
		left: 50% !important;
		transform: translate(-50%, -50%) !important;
	}

	.textpadding {
		padding-left: 5px;
	}

	.material-font {
		font-size: 11px;
		width: 200px;
	}

	.kendo-row {
		border: 1px solid #ddd;
	}

	.header {
		text-align: center !important;
		font-weight: bold !important;
	}

	td.SNo_child {
		text-align: right !important;
	}

	.page-sidebar-closed.page-sidebar-fixed .page-sidebar:hover .page-sidebar-menu.page-sidebar-menu-light > li.active > a, .page-sidebar-closed.page-sidebar-fixed .page-sidebar:hover .page-sidebar-menu.page-sidebar-menu-light > li.active.open > a, .page-sidebar .page-sidebar-menu.page-sidebar-menu-light > li.active > a, .page-sidebar .page-sidebar-menu.page-sidebar-menu-light > li.active.open > a {
		background: rgb(67, 163, 46) !important;
		border-left: 4px solid #008000 !important;
		color: #ffffff;
	}

	/* Normalize layout across medium/large screens */
	.input-text,
	.form-text,
	.ddlMaterials {
		width: 100% !important;
		max-width: 100%;
	}
	/* Harmonize excessive custom margins within Bootstrap grid */
	.div-margin,
	.div-margin-master,
	.div-margin-master-textbox {
		margin-right: 16px !important;
	}
	/* Align label used as section heading without arbitrary left offset */
	.label-font {
		margin: 0 0 8px 0 !important;
	}
	/* Reflow Date/Miti cluster and remove negative offsets */
	.div-margin-master-date {
		display: flex;
		align-items: flex-end;
		gap: 12px;
		margin-right: 16px !important;
	}

		.div-margin-master-date > label {
			margin: 0 !important;
		}

		.div-margin-master-date .col-xs-12,
		.div-margin-master-date .col-sm-12,
		.div-margin-master-date .col-md-12 {
			margin-left: 0 !important;
			padding-left: 0;
			padding-right: 0;
		}

	/* Tidy slider labels spacing on wide screens as well */
	.slider-container {
		display: flex;
		align-items: center;
		/*gap: 12px;*/
		flex-wrap: wrap;
	}

	label#idGRNNo {
		margin-left: 0 !important;
	}

	/* Tables: ensure predictable sizing and scrolling when needed */
	.table-responsive {
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.document_child_table {
		width: 100%;
		table-layout: auto;
	}

		.document_child_table th,
		.document_child_table td {
			white-space: nowrap;
		}

		.document_child_table input.form-control {
			width: 100% !important;
		}

	/* Constrain overall content width on very large screens for visual balance */
	@@media (min-width: 1400px) {
		.portlet.box.green-box.main {
			max-width: 1320px;
			margin-left: auto;
			margin-right: auto;
		}
	}

	/* Ensure consistent sizing inside this view */
	.bodyController input,
	.bodyController select,
	.bodyController textarea {
		box-sizing: border-box;
	}

	/* Responsive adjustments: keep changes scoped to this view only */
	@@media (max-width: 991.98px) {
		/* Make text inputs and dropdowns fluid on smaller screens */
		.input-text,
		.form-text,
		.input-6,
		.input-3,
		.ddlMaterials {
			width: 100% !important;
		}
		/* Remove large right-margins that cause overflow on small screens */
		.div-margin,
		.div-margin-master,
		.div-margin-master-textbox {
			margin-right: 0 !important;
		}
		/* Tidy header label spacing */
		.label-font {
			margin: 0 0 5px 0 !important;
			text-align: left;
		}
		/* Prevent off-canvas stamp section */
		.stamp-details {
			margin-left: 0 !important;
			width: auto !important;
		}
		/* Reflow Date/Miti block */
		#registeredVehicle .div-margin-master-date {
			display: block;
			margin-right: 0 !important;
		}

			#registeredVehicle .div-margin-master-date > label {
				margin: 0 0 6px 0 !important;
			}

			#registeredVehicle .div-margin-master-date .col-xs-12,
			#registeredVehicle .div-margin-master-date .col-sm-12,
			#registeredVehicle .div-margin-master-date .col-md-12 {
				margin-left: 0 !important;
				padding-left: 0;
				padding-right: 0;
			}
		/* Improve slider layout */
		.slider-container {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 8px;
		}

			.slider-container label {
				margin: 0 !important;
			}
		/* Ensure table inputs fit their cells */
		.document_child_table input.form-control {
			width: 100% !important;
		}
		/* Guarantee horizontal scroll for wide tables */
		.table-responsive {
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
		}
	}
</style>
<link href="@Styles.Url("~/Areas/NeoERP.QCQAManagement/Content/QCQASetup.css")" rel="stylesheet" />
<div class="col-md-12 bodyController" ng-controller="GlobalAgroProductsList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Global Agro Products (Pvt) Ltd.</span>
				</div>
			</div>

			<div class="row" style="margin-top: 10px;">
				<form id="registeredVehicle" name="registeredVehicle">
					<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
						<div class="form-group col-md-3 col-sm-3 div-margin-master">
							<label for="element">PON No:</label>
							<div>
								<input type="text" ng-model="TRANSACTION_NO" ng-init="TRANSACTION_NO='@ViewBag.QCNO'" disabled>
								<span type="hidden" class="hidTRANSACTION_NO" style="visibility:hidden">'@ViewBag.QCNO'</span>
								<span type="hidden" id="idFormCode" style="visibility:hidden">@ViewBag.formCode</span>
							</div>
						</div>
						<div class="form-group col-md-4 div-margin-master-date" style="margin-top: 0px !important;margin-left:38px;">
							@*<label style="margin: -18px 0px 0px 50px;" for="element">Date/Miti</label>*@
							<div class="col-xs-12 col-sm-12 col-md-12">
								<label style="margin-bottom: 5px !important;" for="element">Date/Miti</label>
								<input style="width: 55% !important;" id="englishdatedocument" autocomplete="off" class="englishdate" kendo-date-picker
									   ng-model="CREATED_DATE"
									   k-options="monthSelectorOptions" />
							</div>
							<div class="col-xs-12 col-sm-12 col-md-12">
								<input type="text" style="width: 60% !important; margin-left:-33px !important;" id="nepaliDate5" data-checkfor="englishdatedocument" autocomplete="off" onchange="ConvertNepToEng(this)" class="nepali-calendar" next-on-tab />
								<i class="fa fa-calendar form-control-feedback calendar-icon-2" style="padding-right:93px;"></i>
							</div>
						</div>
						<div class="form-group col-md-3 col-sm-3" style="margin-left:-86px;">
							<div class="slider-container">
								<label id="idGateNo">Gate No</label>
								<label id="idGRNNo" style="margin-left: 55px !important; ">GRN No</label>
								<input type="range" ng-model="SLIDER_VALUE" id="gate-grn-Slider" min="0" max="1" step="1" value="0">

							</div>
						</div>
					</div>
					<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
						<div class="form-group col-md-3 col-sm-3 div-margin-master-textbox">
							<label for="element">Select Items</label>
							<div class="row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.3rem;">
								<div class="col-md-6" style="flex: 1; margin-bottom:6px;">
									<div class="topsearch" style="display: block;">
										<select id="ddlMaterials" k-ng-model="item_code" kendo-drop-down-list
												k-options="ddlMaterials"
												class="ddlMaterials">
										</select>
									</div>
								</div>
							</div>
						</div>
						<div class="form-group col-md-3 col-sm-3 div-margin-master-second-textbox">
							<label for="element">Gate/GRN No</label>
							<input type="text" id="idGateOrGrnNo" ng-model="GATE_OR_GRN_NO" class="input-text" autocomplete="off">
						</div>
						<div class="form-group col-md-1 col-sm-1 div-margin-master-third-textbox">
							<label for="element">Vehicle No</label>
							<input type="text" id="idVehicleNo" ng-model="VEHICLE_NO" class="input-text" autocomplete="off">
						</div>
					</div>
					<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
						<div class="form-group col-md-3 col-sm-3 div-margin-master-textbox">
							<label for="element">Party Name</label>
							<input type="text" id="idPartyName" ng-model="PARTY_NAME" class="input-text" autocomplete="off">
						</div>
						<div class="form-group col-md-3 col-sm-3 div-margin-master-second-textbox">
							<label for="element">Address</label>
							<input type="text" id="idAddress" ng-model="ADDRESS" class="input-text" autocomplete="off">
						</div>
						<div class="form-group col-md-3 col-sm-3 div-margin-master-third-textbox">
							<label for="element">Bill No</label>
							<input type="text" id="idBillNo" ng-model="BILL_NO" class="input-text" autocomplete="off">
						</div>
					</div>
				</form>
			</div>
			<div class="portlet-body light bg-inverse">
				<div id="ItemGrid" data-role="grid" class="k-grid k-widget k-display-block">

					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="" name="registeredVehicle">
