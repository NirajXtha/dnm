<div class="col-md-12 bodyController" ng-controller="DailyWastageList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Daily Wastage Report</span>
				</div>
			</div>
			<div class="portlet-body light bg-inverse">
				<div id="ItemGrid">
					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="registeredVehicle" name="registeredVehicle">
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Wastage No:</label>
									<div>
										<label class="clsFormType" hidden ng-init="FormType='@ViewBag.FormType'">@ViewBag.FormType</label>
										<input type="text" ng-model="DAILYWASTAGE_NO" ng-init="DAILYWASTAGE_NO='@ViewBag.QCNO'" disabled>
									</div>
								</div>
								<div class="form-group col-md-4 date-container">
									<label class="date-label">Date / Miti</label>
									<div class="date-row">
										<input id="englishdatedocument"
											   autocomplete="off"
											   class="englishdate"
											   kendo-date-picker
											   ng-model="CREATED_DATE"
											   k-options="monthSelectorOptions" />
										<div class="nepali-wrapper nopadding-left pl-1">
											<input type="text"
												   id="nepaliDate5"
												   class="nepali-calendar"
												   data-checkfor="englishdatedocument"
												   autocomplete="off"
												   onchange="ConvertNepToEng(this)"
												   next-on-tab />
											<i class="fa fa-calendar calendar-icon-2"></i>
										</div>
									</div>
								</div>
							</div>
						        <div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
							        <div class="form-group col-md-3 col-sm-3">
								        <label for="element">Product Type</label>
								        <div class="topsearch" style="display: block;">

									        <select id="ddlProductType" k-ng-model="selectedProductType" kendo-drop-down-list
											        k-options="ddlProductType"
											        class="ddlProductType">
									        </select>
								        </div>
							        </div>
							        <div class="form-group col-md-3 col-sm-3">
								        <label for="element">Production Batch No:</label>
								        <div>
									        <input type="text" autocomplete="off" class="material-font" ng-model="BATCH_NO" name="BATCH_NO" id="txtBatch_No" />
								        </div>
							        </div>
						        </div>
								<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
									<div class="form-group col-md-10 col-sm-19">
										<label for="element">Product</label>
										<select id="productList"
												style="width: 100%;"
												multiple="multiple"
												kendo-multi-select
												k-data-text-field="'ITEM_EDESC'"
												k-data-value-field="'ITEM_CODE'"
												k-data-source="products"
												k-ng-model="productMapping"
												k-change="onProductChange1()">
										</select>
									</div>
								</div>
						</form>
					</div>
					<div class="tab-content d-tab-content">

						<div class="tab-pane active" id="tab_15_1">
							<div class="table-responsive">
								<table class="document_child_table dynamic-table table-fixed dynamic_child_table dynamic_child_table6">

									<thead class="child-table-head">
										<tr>
											<th class="SNo">S/No</th>
											<th class="dailyWastageReport">Daily Wastage Report</th>
											<th class="day">Unit</th>
											<th class="day">Qty</th>
											<!-- Action column -->
											<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>
										</tr>
									</thead>
									<tbody class="table_body">

										<tr ng-repeat="(key,row) in childModels" id="idDailyWastage">
											<td class="SNo">
												<div>
													<input type="text" style="text-align: right;" value="{{key + 1}}" class="form-control SNo" disabled />
												</div>
											</td>
											<td class="ParamID_{{key}}" hidden>{{ row.PARAMETER_ID }}</td>
											<td class="Item_{{key}}" hidden>{{ row.ITEM_CODE }}</td>
											<td class="Serial_{{key}}" hidden>{{ row.SERIAL_NO }}</td>
											<td class="Param_{{key}}" hidden>{{ row.PARAM_CODE }}</td>
											<td class="text-align dailyWastageReport Parameters Parameters_{{key}}">{{ row.PARAMETERS }}</td>
											<td class="text-align day Unit Unit_{{key}}">{{ row.UNIT }}</td>
											<td class="text-align day Variance {{key}}"><input type="text" id="item.COLUMN_NAME" placeholder="Enter" name="item.COLUMN_NAME" autocomplete="off" ng-model="childModels[key].QTY" class="form-control input-width Qty_{{key}} textbox" /></td>
											<td class="btn-action">
												<a href="" id="remove_child_element" name="remove_child_element" class="buttondelete" ng-click="remove_child_element($index)"><i class="fa fa-trash" data-toggle="tooltip" title="Delete row"></i></a>
											</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
			</div>

		</div>
		<div class="modal-footer">
			<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveDailyWastage()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
				<i class="fa fa-floppy-o"></i> Save
			</button>
			<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
				<i class="fa-solid fa-xmark"></i> Cancel
			</button>
		</div>
	</div>
</div>
<script>
	var a = location.hash;
	var b = location.pathname;
	var url = (b + a);
	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
<script>
	function dateSet(date) {
		var month = date.getMonth() + 1;
		var day = date.getDate();
		date = date.getFullYear() + '/' +
			(('' + month).length < 2 ? '0' : '') + month + '/' +
			(('' + day).length < 2 ? '0' : '') + day;
		return date;
	}

	function setNepaliDateFromEnglish() {
		var engDate = $("#englishdatedocument").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#englishdatedocument").val(formattedDate);
		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#issueNep").val(nepaliDate);
	}

	function NepaliDateFromEnglish() {
		var engDate = $("#validDt").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#validDt").val(formattedDate);

		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#nepaliDate").val(nepaliDate);

		var issueDt = moment($("#englishdatedocument").val(), 'DD-MMM-YYYY');
		var validUntilDt = moment(engDate, 'M/D/YYYY');

		if (validUntilDt.isBefore(issueDt)) {
			displayPopupNotification("To be Deliver Date cannot be greater than Date/Miti date.", "error");
		}
	}

	function ConvertNepToEng(e) {
		var date = BS2AD($("#issueNep").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#englishdatedocument").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepaliDate = $("#issueNep").val(); // Get the Nepali date value
			var engDate = BS2AD(nepaliDate); // Convert Nepali date to English date
			var formattedEngDate = moment(engDate).format('DD-MMM-YYYY'); // Format the English date
			$("#englishdatedocument").val(formattedEngDate); // Update the English date input field
		}
	});

	function NepToEng(e) {
		var date = BS2AD($("#nepaliDate").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#validDt").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepalidate = $("#nepaliDate5").val();
			var Engdate = BS2AD(nepalidate);
			var cmpEngDate = moment(Engdate).format('YYYY/MM/DD');
			var FormattedEngDate = moment(Engdate).format('DD-MMM-YYYY');
			var date = new Date();
			var formBackDays = $('#hdnformBackDays').val();
			date.setDate(date.getDate() - formBackDays);
			var minDate = dateSet(date);
			var maxDate = dateSet(new Date());
			$("#englishdatedocument").val(FormattedEngDate);
		}
	});
</script>
<script type="text/javascript">
	$(document).ready(function () {
		var ddlUrl = window.location.protocol + "//" + window.location.host + "/api/HandOverInspectionAPI/GetPackingUnit"
		var defaultValue = "QC_Master_Setup";
		var ddlPackingUnit = $("#ddlPackingUnit").kendoDropDownList({
			optionLabel: "-- Select Unit--",
			dataTextField: "MU_EDESC", // Field name for the dropdown text
			dataValueField: "MU_CODE", // Field name for the dropdown value
			autoBind: false, // Prevent auto-binding until we load the data
			filter: "contains",
			dataSource: {
				transport: {
					read: {
						url: ddlUrl,
						dataType: "json",
						success: function (data) {
							data.forEach(item => {
							});
							ddlMaterials.data("kendoDropDownList").setDataSource(new kendo.data.DataSource({
								data: data
							}));
							ddlMaterials.data("kendoDropDownList").enable(true); // Enable dropdown after loading data
						},
						error: function (xhr, status, error) {
							console.error("Error loading dropdown data:", error);
						}
					}
				}
			},
			dataBound: function () {
				var dropdown = this;
				var items = dropdown.dataSource.data();
				var exists = items.some(function (item) {
					return item.TABLE_NAME === defaultValue;
				});

				if (exists) {
					dropdown.value(defaultValue);  // Set default value
				}
			},
			change: function (e) {
				var dropdown = e.sender;
				var selectedValue = dropdown.value();
				var scope = angular.element($("#ddlPackingUnit")).scope();
				scope.$apply(function () {
					scope.tableName = selectedValue;
				});
			}, height: 200
		}).data("kendoDropDownList");
	});
</script>

