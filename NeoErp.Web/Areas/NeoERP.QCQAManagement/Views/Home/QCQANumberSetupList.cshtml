@{
	Layout = null;
}

<link href="@Styles.Url("~/Areas/NeoERP.QCQAManagement/Content/QCQASetup.css")" rel="stylesheet" />
<div class="col-md-12 bodyController" ng-controller="QCQANumberSetupList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">QC Number Setup</span>
				</div>
			</div>

			<div class="portlet-body light bg-inverse">
				<div class="row" style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; margin-bottom: 0.3rem;">
					<div class="col-md-3" style="flex: 1;">
						<div class="topsearch" style="display: block;">
							<input class="k-textbox txtSearchString" type="text" id="itemtxtSearchString" ng-model="txtSearchString" name="search" placeholder="Search...." style="width: 35%;" />
						</div>
					</div>
					<div class="col-md-4" style="flex: none;">
						<div class="actions text-right">
							<a class="btn dark-green btn-sm addcolor" id="createbtn" ng-disabled="treenodeselected" ng-click="AddQCQASetup()" data-loading-text="<i class='fa fa-spinner fa-spin'></i> Processing..." href="javascript:;" style="margin-left: 0;">
								<i class="fa fa-plus"></i> NEW
							</a>
						</div>
					</div>
				</div>
				<div id="NumberSetupGrid"></div>
			</div>
			<div class="modal fade-out" id="QCQANumberModal" data-backdrop="static" tabindex="-1" data-width="760">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content">
						<div class="modal-header">
							<button type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</button>
							<h4 class="modal-title">
								<span class="fa fa-file"></span>
								QC Number Setup
							</h4>

						</div>

						<div class="modal-body">
							<form name="projectForm" class="form" method="post" ng-submit="submitQCSetup()" enctype="multipart/form-data" id="projectForm" novalidate>
								<input type="hidden" name="qcqaId" id="qcqaId" ng-model="FORM_CODE">
								<div class="form-group row">
									<label for="projectName" class="col-sm-3 col-form-label">Prefix Text</label>
									<div class="col-sm-5">
										<input type="text" style="width:250px;" class="form-control clsPrefixText" ng-model="CUSTOM_PREFIX_TEXT" ng-readonly="panelMode === 'view'" required>
									</div>
									<div class="col-sm-2" style="width:10rem;padding-left:50px;">
										<input type="number" style="width:70px;" class="form-control clsPrefixLength" ng-model="PREFIX_LENGTH" ng-readonly="true">
									</div>
								</div>
								<div class="form-group row">
									<label for="startDate" class="col-sm-3 col-form-label">Suffix Text</label>
									<div class="col-sm-5">
										<input type="text" style="width:250px;" class="form-control clsSuffixText" ng-model="CUSTOM_SUFFIX_TEXT" ng-readonly="panelMode === 'view'" required>
									</div>
									<div class="col-sm-2" style="width:10rem;padding-left:50px;">
										<input type="number" style="width:70px;" class="form-control clsSuffixLength" ng-model="SUFFIX_LENGTH" ng-readonly="true">
									</div>
								</div>
								<div class="form-group row">
									<label for="endDate" class="col-sm-3 col-form-label">Body Length</label>
									<div class="col-sm-7">
										<input type="number" class="form-control" ng-readonly="panelMode === 'view'" ng-model="BODY_LENGTH">
									</div>
								</div>
								<div class="form-group row">
									<label for="startDate" class="col-sm-3 col-form-label">Start No.</label>
									<div class="col-sm-3">
										<input type="number" style="width:130px;" class="form-control clsStartNo" ng-model="START_NO" ng-readonly="panelMode === 'view'" required>
									</div>
									<label for="startDate" class="col-sm-3 col-form-label">End No.</label>
									<div class="col-sm-2">
										<input type="number" style="width:130px;" class="form-control clsLastNo" ng-model="LAST_NO" ng-readonly="panelMode === 'view'">
									</div>
								</div>
								<div class="form-group row">
									<label for="startDate" class="col-sm-3 col-form-label">Start Date</label>
									<div class="col-sm-3">
										<input id="idStartDate" class="englishdate" ng-model="START_DATE" kendo-date-picker
											   k-options="start_datePickerOptions" />
									</div>
									<label for="startDate" class="col-sm-3 col-form-label">End Date</label>
									<div class="col-sm-3">
										<input id="idEndDate" class="englishdate" ng-model="LAST_DATE" kendo-date-picker
											   k-options="last_datePickerOptions" />
										@*<input type="text" style="width:130px;" class="form-control clsEndDate" ng-model="LAST_DATE" ng-readonly="panelMode === 'view'">*@
									</div>
								</div>
								<input type="submit" class="hidden" id="btnProject" value="submit">
							</form>
						</div>

						<div class="modal-footer">
							<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveQCSetup()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
								<i class="fa fa-floppy-o"></i> Save
							</button>
							<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
								<i class="fa-solid fa-xmark"></i> Cancel
							</button>
						</div>
					</div>
				</div>
			</div>

		</div>
	</div>
</div>
<script>
	var a = location.hash;
	var b = location.pathname;
	var url = (b + a);
	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
