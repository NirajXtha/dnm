@{
	Layout = null;

}
<style>
	/* ====== GLOBAL RESET ====== */
	html, body {
		overflow-x: hidden !important;
		max-width: 100%;
	}

	/* sensible default so widths include padding/border */
	*, *::before, *::after {
		box-sizing: border-box;
	}

	/* override bootstrap .table-responsive which adds overflow auto */
	.table-responsive {
		overflow-x: hidden !important; /* hide scrollbars on the wrapper */
	}

	/* ====== MAIN TABLE STYLING ====== */
	.dynamic_child_table6 {
		table-layout: fixed;
		width: 100%;
		min-width: 0; /* lets table shrink inside parent */
		border-collapse: collapse;
		overflow-x: hidden;
	}

		/* allow cells to wrap instead of expanding table */
		.dynamic_child_table6 th,
		.dynamic_child_table6 td {
			white-space: normal !important;
			word-break: break-word;
			overflow-wrap: anywhere;
		}

		/* inputs/widgets inside table: allow them to shrink */
		.dynamic_child_table6 .form-control,
		.dynamic_child_table6 input,
		.dynamic_child_table6 select,
		.dynamic_child_table6 textarea,
		.dynamic_child_table6 .input-group,
		.dynamic_child_table6 .k-widget, /* kendo widgets */
		.dynamic_child_table6 .k-combobox,
		.dynamic_child_table6 .clsParametersValue {
			max-width: 100% !important;
			min-width: 0 !important; /* critical for flexbox children */
			box-sizing: border-box;
		}

	/* fix flex children that cause overflow */
	.input-group, .btn-action, .addon-iconbox {
		min-width: 0 !important;
	}

	/* images/svg/iframes shouldn't blow out container */
	img, svg, iframe {
		max-width: 100%;
		height: auto;
	}

	/* fallback: if anything still uses 100vw (common cause), force it to 100% */
	*[style*="100vw"], *[style*="width:100vw"] {
		width: 100% !important;
		max-width: 100% !important;
	}

	/* ====== COLUMN-SPECIFIC WIDTHS ====== */
	.material-font {
		font-size: 11px;
		width: 200px;
	}

	.SNo {
		width: 36px;
	}

	.SNo_div {
		width: 36px;
	}

	/*.Department {
		width: 170px;
	}*/

	.Standard,
	.Actual,
	.GAP {
		width: 140px;
	}

	.material-align {
		margin-left: 50px;
	}

	/* ====== ALIGNMENT FIX (MOST IMPORTANT PART) ====== */
	.dynamic_child_table6 {
		border-collapse: collapse;
	}

		/* Make header and data cells behave identically */
		.dynamic_child_table6 th,
		.dynamic_child_table6 td {
			vertical-align: middle !important;
			padding: 2px 6px !important;
			text-align: left;
			font-weight: normal !important;
			height: 30px;
			box-sizing: border-box;
		}

			/* Ensure flex inside <td> doesn't add offset */
			.dynamic_child_table6 td > div {
				display: flex;
				align-items: center;
				justify-content: center;
				height: 100%;
			}

		/* Compact the input box to align visually with header text */
		.dynamic_child_table6 input.form-control,
		.dynamic_child_table6 .textbox {
			height: 24px !important;
			line-height: 1.2 !important;
			padding: 2px 4px !important;
			text-align: left;
			margin: 0 !important;
			border-radius: 2px;
		}

		/* Match column widths between th and td */
		.dynamic_child_table6 th.SNo,
		.dynamic_child_table6 td.SNo_div {
			width: 36px;
		}

		.dynamic_child_table6 th.Department,
		.dynamic_child_table6 td.Department {
			width: 170px;
		}

		.dynamic_child_table6 th.Standard,
		.dynamic_child_table6 td.Standard {
			width: 140px;
		}

		.dynamic_child_table6 th.Actual,
		.dynamic_child_table6 td.Actual {
			width: 140px;
		}

		.dynamic_child_table6 th.GAP,
		.dynamic_child_table6 td.GAP {
			width: 140px;
		}

		.dynamic_child_table6 th.btn-action,
		.dynamic_child_table6 td.btn-action {
			width: 8%;
		}
	.date-width {
		width: 87px !important;
	}

	.dept-wrapper {
		display: flex;
		align-items: center;
		gap: 8px; /* space between + icon and text */
	}

		.dept-wrapper i {
			cursor: pointer;
			font-size: 16px;
			flex-shrink: 0;
		}
	.dept-child-wrapper {
		align-items: initial;
	}
	.table_body{
		overflow:visible !important;
	}
	/*document_child_table tbody.table_body {
		overflow: hidden !important;
	}*/
</style>
<link href="@Styles.Url("~/Areas/NeoERP.QCQAManagement/Content/QCQASetup.css")" rel="stylesheet" />
<div class="col-md-12 bodyController" ng-controller="SanitationHygieneList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Sanitation Hygiene</span>
				</div>
			</div>
			<div class="portlet-body light bg-inverse">
				<div id="ItemGrid">
					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="registeredVehicle" name="registeredVehicle">
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Inspection No:</label>
									<div>
										<input type="text" ng-model="SANITATION_NO" ng-init="SANITATION_NO='@ViewBag.QCNO'" disabled>
									</div>
								</div>
								<div style="display: flex; margin: 16px -5px 0px -4px;" class="form-group col-md-4">
									<label style="margin: -18px 0px 0px 50px;" for="element">Date/Miti</label>
									<div class="col-xs-12 col-sm-12 col-md-12" style="margin: 0px 5px 0px -56px;">
										<input id="englishdatedocument" autocomplete="off" class="englishdate date-width" kendo-date-picker
											   ng-model="CREATED_DATE"
											   k-options="monthSelectorOptions" />
									</div>
									<div class="col-xs-12 col-sm-12 col-md-12 nopadding-left pl-1">
										<input type="text" id="nepaliDate5" data-checkfor="englishdatedocument" autocomplete="off" onchange="ConvertNepToEng(this)" class="nepali-calendar" next-on-tab />
										<i class="fa fa-calendar form-control-feedback calendar-icon-2"></i>
									</div>
								</div>
							</div>
						</form>
					</div>
					<div class="tab-content d-tab-content">

						<div class="tab-pane active" id="tab_15_1">
							<div class="table-responsive">
								<table class="document_child_table dynamic-table table-fixed dynamic_child_table6">

									<thead class="child-table-head">
										<tr>
											<th class="text-center Department">Department Name</th>
											<th class="text-center Standard">Standard %</th>
											<th class="text-center Actual">Actual</th>
											<th class="text-center GAP">GAP</th>
											<th class="btn-action">&nbsp;</th>
										</tr>
									</thead>

									<tbody class="table_body">

										<tr ng-repeat-start="(key,row) in SanitationHygieneData" id="idSanitationHygiene">
											<td class="Department">
												<div class="dept-wrapper">
													<i class="fa"
													   ng-class="row.isExpanded ? 'fa-minus-square' : 'fa-plus-square'"
													   ng-click="toggleRow(row)"></i>
													<span class="clsDepartmentCode_{{key}}" hidden>{{childModels[key]['DEPARTMENT_CODE']}}</span>
													<input type="text"
														   ng-model="row.DEPARTMENT_EDESC"
														   class="form-control"
														   disabled />
												</div>
											</td>


											<td class="Standard">
												<input type="text" id="row.STANDARD" autocomplete="off" placeholder="Enter STANDARD" name="row.STANDARD" ng-model="row.STANDARD" class="form-control STANDARD_{{key}} textbox" ng-keypress="blockIfExceeds($event, key, 100)" ng-change="enforceMaxValue(key, 100)" ng-keyup="updateGAP(key)" />
											</td>

											<td class="Actual">
												<input type="text" id="row.ACTUAL" autocomplete="off" placeholder="Enter ACTUAL" name="row.ACTUAL" ng-model="row.ACTUAL" class="form-control ACTUAL_{{key}} textbox" ng-keypress="blockIfExceeds_Actual($event, key, 100)" ng-change="enforceMaxValue(key, 100)" ng-keyup="updateGAP(key)" />
											</td>

											<td class="GAP">
												<input type="text" id="row.GAP" placeholder="Enter GAP" name="row.GAP" ng-model="row.GAP" class="form-control GAP_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="updateGAP(key)" disabled />
											</td>

											<td class="btn-action">
												<a href="" ng-click="remove_child_element(key,SanitationHygieneData,row,'',SanitationHygieneData)">
													<i class="fa fa-trash"></i>
												</a>
											</td>

										</tr>

										<!-- CHILD ROW -->
										<tr ng-repeat="(key,child) in  row.children"
											ng-if="row.isExpanded"
											class="child-row" id="idSanitationHygiene">
											<td class="Department">
												<div class="dept-wrapper">
													<i></i>
													<i></i>
													<i class="fa"
													   ng-class="child.isExpanded == 1 ? '' : 'fa-plus-square'"
													   ng-click="toggleRow(child)">
													</i>
													<span class="clsDepartmentCode_{{key}}" hidden>{{childModels[key]['DEPARTMENT_CODE']}}</span>
													<input type="text" id="child.DEPARTMENT_EDESC" placeholder="Enter Department" name="child.DEPARTMENT_EDESC" ng-model="child.DEPARTMENT_EDESC" class="form-control DEPARTMENT_{{key}} textbox" disabled />
												</div>
											</td>
											<td class="Standard"><input type="text" autocomplete="off" id="child.STANDARD" placeholder="Enter STANDARD" name="child.STANDARD" ng-model="child.STANDARD" class="form-control STANDARD_{{key}} textbox" ng-keypress="blockIfExceedschild($event, key, 100,row.children)" ng-change="syncChild(child)"  ng-keyup="updateChildGAP(key,row.children)" /></td>
											<td class="Actual"><input type="text" id="child.ACTUAL" autocomplete="off" placeholder="Enter ACTUAL" name="child.ACTUAL" ng-model="child.ACTUAL" class="form-control ACTUAL_{{key}} textbox" ng-keypress="blockIfExceedschild_Actual($event, key, 100,row.children)" ng-change="syncChild(child)"  ng-keyup="updateChildGAP(key,row.children)" /></td>
											<td class="GAP">				<input type="text" id="child.GAP" placeholder="Enter GAP" name="child.GAP" ng-model="child.GAP" class="form-control GAP_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-change="syncChild(child)"  ng-keyup="updateChildGAP(key,row.children)" disabled /></td>
											<td class="btn-action">
												<a href="" ng-click="remove_child_element(key,row,child,row.children,'AllSanitationHygieneChildData')">
													<i class="fa fa-trash"></i>
												</a>
											</td>
										</tr>
							<tr ng-repeat-end></tr>


							</tbody>


							</table>
						</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="modal-footer">
			<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveSanitationHygiene()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
				<i class="fa fa-floppy-o"></i> Save
			</button>
			<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
				<i class="fa-solid fa-xmark"></i> Cancel
			</button>
		</div>
	</div>
</div>
<script>
	var a = location.hash;
	var b = location.pathname;
	var url = (b + a);
	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
<script>
	function dateSet(date) {
		var month = date.getMonth() + 1;
		var day = date.getDate();
		date = date.getFullYear() + '/' +
			(('' + month).length < 2 ? '0' : '') + month + '/' +
			(('' + day).length < 2 ? '0' : '') + day;
		return date;
	}

	function setNepaliDateFromEnglish() {
		var engDate = $("#englishdatedocument").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#englishdatedocument").val(formattedDate);
		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#issueNep").val(nepaliDate);
	}

	function NepaliDateFromEnglish() {
		var engDate = $("#validDt").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#validDt").val(formattedDate);

		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#nepaliDate").val(nepaliDate);

		var issueDt = moment($("#englishdatedocument").val(), 'DD-MMM-YYYY');
		var validUntilDt = moment(engDate, 'M/D/YYYY');

		if (validUntilDt.isBefore(issueDt)) {
			displayPopupNotification("To be Deliver Date cannot be greater than Date/Miti date.", "error");
		}
	}

	function ConvertNepToEng(e) {
		var date = BS2AD($("#issueNep").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#englishdatedocument").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		//  ndpEnglishInput: 'englishdatedocument',
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepaliDate = $("#issueNep").val(); // Get the Nepali date value
			var engDate = BS2AD(nepaliDate); // Convert Nepali date to English date
			var formattedEngDate = moment(engDate).format('DD-MMM-YYYY'); // Format the English date
			$("#englishdatedocument").val(formattedEngDate); // Update the English date input field
		}
	});

	function NepToEng(e) {
		var date = BS2AD($("#nepaliDate").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#validDt").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepalidate = $("#nepaliDate5").val();
			var Engdate = BS2AD(nepalidate);
			var cmpEngDate = moment(Engdate).format('YYYY/MM/DD');
			var FormattedEngDate = moment(Engdate).format('DD-MMM-YYYY');
			var date = new Date();
			var formBackDays = $('#hdnformBackDays').val();
			date.setDate(date.getDate() - formBackDays);
			var minDate = dateSet(date);
			var maxDate = dateSet(new Date());
			$("#englishdatedocument").val(FormattedEngDate);
		}
	});
</script>

