	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
<script>
	function dateSet(date) {
		var month = date.getMonth() + 1;
		var day = date.getDate();
		date = date.getFullYear() + '/' +
			(('' + month).length < 2 ? '0' : '') + month + '/' +
			(('' + day).length < 2 ? '0' : '') + day;
		return date;
	}

	function setNepaliDateFromEnglish() {
		var engDate = $("#englishdatedocument").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#englishdatedocument").val(formattedDate);
		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#issueNep").val(nepaliDate);
	}

	function NepaliDateFromEnglish() {
		var engDate = $("#validDt").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#validDt").val(formattedDate);

		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#nepaliDate").val(nepaliDate);

		var issueDt = moment($("#englishdatedocument").val(), 'DD-MMM-YYYY');
		var validUntilDt = moment(engDate, 'M/D/YYYY');

		if (validUntilDt.isBefore(issueDt)) {
			displayPopupNotification("To be Deliver Date cannot be greater than Date/Miti date.", "error");
		}
	}

	function ConvertNepToEng(e) {
		var date = BS2AD($("#issueNep").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#englishdatedocument").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		//  ndpEnglishInput: 'englishdatedocument',
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepaliDate = $("#issueNep").val(); // Get the Nepali date value
			var engDate = BS2AD(nepaliDate); // Convert Nepali date to English date
			var formattedEngDate = moment(engDate).format('DD-MMM-YYYY'); // Format the English date
			$("#englishdatedocument").val(formattedEngDate); // Update the English date input field
		}
	});

	function NepToEng(e) {
		var date = BS2AD($("#nepaliDate").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#validDt").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		//  ndpEnglishInput: 'englishdatedocument',
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			//evt.stopPropagation();

			var nepalidate = $("#nepaliDate5").val();
			var Engdate = BS2AD(nepalidate);
			var cmpEngDate = moment(Engdate).format('YYYY/MM/DD');
			var FormattedEngDate = moment(Engdate).format('DD-MMM-YYYY');
			var date = new Date();
			var formBackDays = $('#hdnformBackDays').val();
			date.setDate(date.getDate() - formBackDays);
			var minDate = dateSet(date);
			var maxDate = dateSet(new Date());
			$("#englishdatedocument").val(FormattedEngDate);
		}
	});

</script>
<script type="text/javascript">

	$(document).ready(function () {
		var preventPopup = false;
        var ddlShift = $("#ddlShift").kendoDropDownList({
            optionLabel: "Select Shift...",
            dataTextField: "text",
            dataValueField: "value",
            dataSource: [
                { text: "Day", value: "D" },
                { text: "Night", value: "N" }
            ]
        });


		var ddlUrl = window.location.protocol + "//" + window.location.host + "/api/IncomingMaterialAPI/MaterialListsByCategory?CategoryCode=FG"
		var defaultValue = "QC_Master_Setup";
		var ddlProductType = $("#ddlProductType").kendoDropDownList({
			optionLabel: "-- Select Product--",
			dataTextField: "item_edesc", // Field name for the dropdown text
			dataValueField: "item_code", // Field name for the dropdown value
			autoBind: false, // Prevent auto-binding until we load the data
			filter: "contains",
			dataSource: {
				transport: {
					read: {
						url: ddlUrl,
						dataType: "json",
						success: function (data) {
							data.forEach(item => {
							});
							// Populate the dropdown
							ddlProductType.data("kendoDropDownList").setDataSource(new kendo.data.DataSource({
								data: data
							}));
							ddlProductType.data("kendoDropDownList").enable(true); // Enable dropdown after loading data
						},
						error: function (xhr, status, error) {
							console.error("Error loading dropdown data:", error);
						}
					}
				}
			},
			dataBound: function () {
				var dropdown = this;
				var items = dropdown.dataSource.data();

				// Check if the default value exists in the data
				var exists = items.some(function (item) {
					return item.TABLE_NAME === defaultValue;
				});

				if (exists) {
					dropdown.value(defaultValue);  // Set default value
					//callNeewFieldAPI(defaultValue);
				}
			},
			change: function (e) {
				var dropdown = e.sender;
				var selectedValue = dropdown.value();
				// Update AngularJS scope
				var scope = angular.element($("#ddlProductType")).scope();
				scope.$apply(function () {
					scope.tableName = selectedValue;
				});
			}, height: 200
		}).data("kendoDropDownList");
		var grid = $("#ItemGrid").data("kendoGrid");

		function parseCustomDate(dateStr) {
			var parts = dateStr.split("/");
			if (parts.length === 3) {
				return new Date(parts[2], parts[0] - 1, parts[1]); // Month is zero-based
			}
			return null;
		}
		$(document).on('click', '.clsParameters', function (e) {
			e.preventDefault();
			var productIndex = $(this).closest('.input-group').find('input[product-index]').attr('product-index');
			var selectedVal = $("#ddlProductType").val(); // Get value from input
			if (selectedVal) {
				ShowPopupList(selectedVal, productIndex, "Parameter"); // Show popup with details For Raw Materials
			}
		});

		$("#ddlProductType").on('change', function (e) {
			e.preventDefault;
			var selectedVal = $(this).val(); // Get selected value
		});

		$("#productList").on('change', function (e) {
			e.preventDefault;
			var selectedVal = $(this).val(); // Get selected value
			//if (preventPopup) {
			//	// user closed the popup → stop reopening
			//	return;
			//}
			if (selectedVal) {
				ShowPopupList(selectedVal, 0, "Batch"); // Show popup with details For Finished Goods
			}
		});
		//$(document).on("click", ".k-i-close", function () {
		//	console.log("Close clicked");
		//	alert("Close icon was clicked!");
		//});

		function ShowPopupList(itemCode, index, ItemName) {
			// Example: Fetch details from an API
            if (ItemName === "Batch") {
				$.get("/api/OnSiteInspectionAPI/GetBatchNoByItemCode?ItemCode=" + itemCode, function (response) {
					if ($("#popupWindow").length === 0) {
						$("body").append('<div id="popupWindow"></div>');
					}
					$("#popupWindow").kendoWindow({
						width: "800px",
						height: "300px",
						title: "Select Parameter",
						visible: false,
						modal: true,
						actions: ["Close"]
						//close: function () {
						//	preventPopup = true;   // mark that popup was closed by user
						//}
					});
					var popupWindow = $("#popupWindow").data("kendoWindow");

					$.each(response, function (index, value) {

						let contentHtml =
							`<input type="text" id="searchInputText" placeholder="Search..." style="width: 35%;position: inherit; margin-bottom: 10px;margin-top: 4px; border: 1px solid #ccc;height: 25px;" />
							<table id=voucherList class=voucher-list  border='1' style='border-collapse: collapse; width: 100%;'>
						<tr style="padding:5px; border-bottom:1px solid #ccc; font-size: 14px;height: 25px;">
						<td class=textpadding><b>REFERENCE NO</b></td>
						<td class=textpadding><b>BATCH NO</b></td>
						<td class=textpadding><b>QUANTITY</b></td>
						<td class=textpadding><b>UNIT PRICE</b></td>
					</tr>`
						$.each(response, function (index, value) {
							contentHtml += `<tr id='voucherList' data-transaction="${value.TRANSACTION_NO}" data-batch="${value.BATCH_NO}" style="padding:5px; border-bottom:1px solid #ccc; font-size: 14px;">
						<td class=textpadding>${value.REFERENCE_NO}</td>
						<td class=textpadding>${value.BATCH_NO}</td>

						<td class=textpadding>${value.QUANTITY}</td>
						<td class=textpadding>${value.UNIT_PRICE}</td>
						<td><button class="btnClass batch-no large-button  data-batch=${value.BATCH_NO} type ="button">Ref</button></td>
					</tr>`;
						});
						contentHtml += "</table>"; // Closing the table tag
						popupWindow.content(contentHtml);
						popupWindow.center().open();
						$("#searchInputText").on("keyup", function () {
							var searchText = $(this).val().toLowerCase();
							$("#voucherList tbody tr").each(function () {
								var rowText = $(this).find("td").map(function () {
