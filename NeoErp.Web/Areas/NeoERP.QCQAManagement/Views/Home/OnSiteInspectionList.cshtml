@{
	Layout = null;

}
<style>
	html, body {
		overflow-x: hidden !important;
		max-width: 100%;
	}

	/* sensible default so widths include padding/border */
	*, *::before, *::after {
		box-sizing: border-box;
	}

	/* override bootstrap .table-responsive which adds overflow auto */
	.table-responsive {
		overflow-x: hidden !important; /* hide scrollbars on the wrapper */
	}

	/* the table */
	.dynamic_child_table6 {
		table-layout: fixed;
		width: 100%;
		min-width: 0; /* lets table shrink inside parent */
		border-collapse: collapse;
		overflow-x: hidden;
	}

		/* allow cells to wrap instead of expanding table */
		.dynamic_child_table6 th,
		.dynamic_child_table6 td {
			white-space: normal !important;
			word-break: break-word;
			overflow-wrap: anywhere;
		}

		/* inputs/widgets inside table: allow them to shrink */
		.dynamic_child_table6 .form-control,
		.dynamic_child_table6 input,
		.dynamic_child_table6 select,
		.dynamic_child_table6 textarea,
		.dynamic_child_table6 .input-group,
		.dynamic_child_table6 .k-widget, /* kendo widgets */
		.dynamic_child_table6 .k-combobox,
		.dynamic_child_table6 .clsParametersValue {
			max-width: 100% !important;
			min-width: 0 !important; /* critical for flexbox children */
			box-sizing: border-box;
		}

	/* fix flex children that cause overflow */
	.input-group, .btn-action, .addon-iconbox {
		min-width: 0 !important;
	}

	/* images/svg/iframes shouldn't blow out container */
	img, svg, iframe {
		max-width: 100%;
		height: auto;
	}

	/* fallback: if anything still uses 100vw (common cause), force it to 100% */
	*[style*="100vw"], *[style*="width:100vw"] {
		width: 100% !important;
		max-width: 100% !important;
	}


	.material-font {
		font-size: 11px;
		width: 200px;
	}
	
	.SNo {
		width: 36px;
	}
	.SNo_div {
		width: 36px;
	}
	.Parameters {
		width: 170px;
	}
	.PARAMETERS_div {
		width: 170px;
	}
	.clsParametersValue{
		width:157px;
	}
	.Target, .Tolerence, .Results, .Variance {
		width: 140px;
	}

	.TARGET_div, .TOLERENCE_div, .RESULTS_div, .VARIANCE_div {
		width: 140px;
	}

	/*.kendo-row {
		border: 1px solid #ddd;
	}*/

	.material-align {
		margin-left: 50px;
	}
	.large-button {
		padding: 8px 24px;
		/*font-size: 18px;*/
		border-radius: 6px;
		background-color: #28a745;
		color: white;
		border: none;
		cursor: pointer;
		display: block; /* Ensures proper centering */
		margin: auto; /* Centers horizontally */
	}
	.textpadding {
		padding-left: 5px;
	}
	#search {
		position: fixed;
		top: 0px;
		left: 0px width: 100%;
		height: 100%;
		background-color: rgba(0, 0, 0, 0.7);
		-webkit-transition: all 0.5s ease-in-out;
		-moz-transition: all 0.5s ease-in-out;
		-o-transition: all 0.5s ease-in-out;
		-ms-transition: all 0.5s ease-in-out;
		transition: all 0.5s ease-in-out;
		-webkit-transform: translate(0px, -100%) scale(0, 0);
		-moz-transform: translate(0px, -100%) scale(0, 0);
		-o-transform: translate(0px, -100%) scale(0, 0);
		-ms-transform: translate(0px, -100%) scale(0, 0);
		transform: translate(0px, -100%) scale(0, 0);
		opacity: 0;
	}

		#search.open {
			-webkit-transform: translate(0px, 0px) scale(1, 1);
			-moz-transform: translate(0px, 0px) scale(1, 1);
			-o-transform: translate(0px, 0px) scale(1, 1);
			-ms-transform: translate(0px, 0px) scale(1, 1);
			transform: translate(0px, 0px) scale(1, 1);
			opacity: 1;
			z-index: 5000 !important;
		}

		#search input[type="search"] {
			position: absolute;
			top: 50%;
			width: 100%;
			color: rgb(255, 255, 255);
			background: rgba(0, 0, 0, 0);
			font-size: 40px;
			font-weight: 300;
			text-align: center;
			border: 0px;
			margin: 0px auto;
			margin-top: -51px;
			padding-left: 30px;
			padding-right: 30px;
			outline: none;
		}

		#search .btn {
			position: absolute;
			top: 50%;
			left: 50%;
			margin-top: 61px;
			margin-left: -45px;
		}

		#search .search-close {
			background-color: green;
			border-color: green;
			font-size: 21px;
			opacity: 1;
			padding: 0px 8px;
			position: fixed;
			right: 15px;
			top: 54px;
			color: #fff;
			border: solid green;
		}

	.search-input a {
		display: inline-table;
	}

	.search-icon {
		color: #555555;
	}

		.search-icon i:hover {
			color: forestgreen;
		}
	/*.date-width {
		width: 87px !important;
	}*/
	.date-container {
		display: flex;
		flex-direction: column; /* label on top */
	}

	.date-label {
		margin-bottom: 6px; /* space below label */
		font-weight: 500;
	}

	.date-row {
		display: flex;
		gap: 12px; /* 👈 constant distance */
		align-items: center;
	}

	.nepali-wrapper {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.nepali-calendar {
		padding-right: 30px; /* space for icon */
		height: 34px; /* match Kendo input height */
	}


	.calendar-icon-2 {
		position: absolute;
		right: 8px;
		top: 50%;
		transform: translateY(-50%);
		font-size: 14px;
		color: #555;
		right: 9px !important;
		top: 10px !important;
		pointer-events: none;
	}

	.k-widget.k-datepicker {
		width: 50% !important;
	}
</style>
<div class="col-md-12 bodyController" ng-controller="OnSiteInspectionList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Onsite Inspection Form</span>
				</div>
			</div>

			<div class="portlet-body light bg-inverse">
				<div id="ItemGrid">

					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="registeredVehicle" name="registeredVehicle">
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Inspection No:</label>
									<div>
										<label class="clsFormType" hidden ng-init="FormType='@ViewBag.FormType'">@ViewBag.FormType</label>
										<input type="text" ng-model="Inspection_No" ng-init="Inspection_No='@ViewBag.QCNO'" disabled>
									</div>
								</div>
								<div class="form-group col-md-4 date-container">
									<label class="date-label">Date / Miti</label>

									<div class="date-row">
										<input id="englishdatedocument"
											   autocomplete="off"
											   class="englishdate"
											   kendo-date-picker
											   ng-model="CREATED_DATE"
											   k-options="monthSelectorOptions" />

										<div class="nepali-wrapper nopadding-left pl-1">
											<input type="text"
												   id="nepaliDate5"
												   class="nepali-calendar"
												   data-checkfor="englishdatedocument"
												   autocomplete="off"
												   onchange="ConvertNepToEng(this)"
												   next-on-tab />
											<i class="fa fa-calendar calendar-icon-2"></i>
										</div>
									</div>
								</div>
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Shift</label>
									<div class="topsearch" style="display: block;">
										<select id="ddlShift" k-ng-model="Shift" kendo-drop-down-list
												k-options="ddlShift"
												class="ddlShift">
										</select>
									</div>
								</div>
							</div>
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Plant</label>
									<div class="topsearch" style="display: block;">
										<select id="ddlProductType" k-ng-model="selectedProductType" kendo-drop-down-list
												k-options="ddlProductType"
												class="ddlProductType">
										</select>
									</div>
								</div>
								<div class="form-group col-md-4 col-sm-3">
									<label for="element">Batch No:</label>
									<div>
										<input type="text" class="material-font" autocomplete="off" ng-model="Batch_No" name="Batch_No" id="idBatch_No" />
									</div>
								</div>
								<div class="form-group  col-md-3 col-sm-3">
									<label for="element">Ref.No:</label>
									<div>
										<input type="text" ng-model="REFERENCE_NO" autocomplete="off" class="material-font" name="WB_SLIP_NO" id="txtRemarks" />
									</div>
								</div>
							</div>
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-10 col-sm-19">
									<label for="element">Product</label>
									<select id="productList"
											style="width: 100%;"
											multiple="multiple"
											kendo-multi-select
											k-data-text-field="'ITEM_EDESC'"
											k-data-value-field="'ITEM_CODE'"
											k-data-source="products"
											k-ng-model="productMapping">
									</select>
								</div>
							</div>
						</form>
					</div>
					<div class="tab-content d-tab-content">
						<div class="tab-pane active" id="tab_15_1">
							<div class="table-responsive">
								<table class="document_child_table dynamic-table table-fixed dynamic_child_table dynamic_child_table6">
									<thead class="child-table-head">
										<tr>
											<th class="SNo">S/No</th>
											<th colspan="4" class="text-center Parameters">Parameters</th>
											<th colspan="4" class="text-center Target">Target</th>
											<th colspan="4" class="text-center Tolerence">Tolerence(±)</th>
											<th colspan="4" class="text-center Results">Results</th>
											<th colspan="4" class="text-center Variance">Variance</th>
											<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>
										</tr>										
									</thead>
									<tbody class="table_body">
										<tr ng-repeat="(key,row) in childModels" id="idOnSiteInspection">
											<td class="SNo">
												<div>
													<input type="text" style="text-align: right;" value="{{key + 1}}" class="form-control SNo" disabled />
												</div>
											</td>
											<td class="ParamID_{{key}}" hidden>{{ row.PARAMETER_ID }}</td>
											<td class="Item_{{key}}" hidden>{{ row.ITEM_CODE }}</td>
											<td class="Serial_{{key}}" hidden>{{ row.SERIAL_NO }}</td>
											<td class="Param_{{key}}" hidden>{{ row.PARAM_CODE }}</td>
											<td class="text-align Parameters Parameters_{{key}}">{{ row.PARAMETERS }}</td>
											<td class="text-align Target Target_{{key}}">{{ row.TARGET }}</td>
											<td class="text-align Tolerence Tolerence_{{key}}">{{ row.TOLERENCE }}</td>
											@*<td class="text-align Results Results_{{key}}">{{ row.RESULTS }}</td>*@
											<td class="text-align Results"><input type="text" autocomplete="off" class="RESULTS_{{key}}" ng-model="childModels[key].RESULTS" name="RESULTS" id="txtRESULTS" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateVariance(key)"/></td>
											<td class="text-align Variance Variance_{{key}}">{{ row.VARIANCE }}</td>
											<td class="btn-action">
												<a href="" id="remove_child_element" name="remove_child_element" class="buttondelete" ng-click="remove_child_element($index)"><i class="fa fa-trash" data-toggle="tooltip" title="Delete row"></i></a>
											</td>
										</tr>										
									</tbody>
								</table>
							</div>
						</div>
					</div>					
				</div>
			</div>
		</div>
		<div class="modal-footer">
			<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveOnSiteInspection()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
				<i class="fa fa-floppy-o"></i> Save
			</button>
			<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
				<i class="fa-solid fa-xmark"></i> Cancel
			</button>
		</div>
	</div>
</div>
<script>
	var a = location.hash;
	var b = location.pathname;
