<div class="col-md-12 bodyController" ng-controller="RawMaterialList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Daily Raw Material Testing Report</span>
				</div>
			</div>
			<div class="portlet-body light bg-inverse">				
				<div id="ItemGrid">
					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="registeredVehicle" name="registeredVehicle">
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">

								<div class="form-group col-md-3 col-sm-3">
									<label for="element">QC No:</label>
									<div>
										<input type="text" ng-model="QC_NO" ng-init="QC_NO='@ViewBag.QCNO'" disabled>
									</div>
								</div>
								<div class="form-group col-md-4 date-container">
									<label class="date-label">Date / Miti</label>

									<div class="date-row">
										<input id="englishdatedocument"
											   autocomplete="off"
											   class="englishdate"
											   kendo-date-picker
											   ng-model="CREATED_DATE"
											   k-options="monthSelectorOptions" />

										<div class="nepali-wrapper nopadding-left pl-1">
											<input type="text"
												   id="nepaliDate5"
												   class="nepali-calendar"
												   autocomplete="off"
                                                   data-checkfor="englishdatedocument"
												   onchange="ConvertNepToEng(this)"
												   next-on-tab />
											<i class="fa fa-calendar calendar-icon-2"></i>
										</div>
									</div>
								</div>
								<div class="form-group col-md-3 col-sm-3 material-align">
									<label for="element">Manual No</label>
									<div>
										<input type="text" ng-model="MANUAL_NO" class="material-font" autocomplete="off" name="WB_SLIP_NO" id="txtManualNo" />
									</div>
								</div>
							</div>
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Product Type</label>
									<div class="topsearch" style="display: block;">

										<select id="ddlProductType" k-ng-model="selectedProductType" kendo-drop-down-list
												k-options="ddlProductType"
												class="ddlProductType" style="width: 178px;">
										</select>
									</div>
								</div>
								<div class="form-group col-md-4 col-sm-3">
									<label for="element">Production Batch No:</label>
									<div>
										<input type="text" ng-model="BATCH_NO" class="material-font" autocomplete="off" name="WB_SLIP_NO1" id="txtBatchNo" />
									</div>
								</div>
								<div class="form-group  col-md-3 col-sm-3 material-align">
									<label for="element">Remarks:</label>
									<div>
										<input type="text" ng-model="REMARKS" class="material-font" autocomplete="off" name="WB_SLIP_NO" id="txtRemarks" />
									</div>
								</div>
							</div>
						</form>
					</div>
					<div class="tab-content d-tab-content">

						<div class="tab-pane active" id="tab_15_1">
							<div class="document_child_table_wrapper">
								<div class="table-responsive">
									<table class="document_child_table dynamic-table table-fixed dynamic_child_table dynamic_child_table6">

										<thead class="child-table-head">
											<tr>
												<th class="SNo">S/No</th>
												<!-- First 4 headers -->

												<th rowspan="2" ng-repeat="item in RawMaterialData[0].element.slice(0, 4) | orderBy: 'SERIAL_NO'"
													class="{{item.COLUMN_NAME}} {{item.COLUMN_NAME}}-child">
													{{item.COLUMN_HEADER}}
												</th>

												<!-- Super header -->
												<th colspan="5" class="text-center">Standard</th>

												<th colspan="5" class="text-center">Actual</th>
												<th rowspan="2" ng-repeat="item in RawMaterialData[0].element.slice(14, 15) | orderBy: 'SERIAL_NO'"
													class="{{item.COLUMN_NAME}} {{item.COLUMN_NAME}}-child">
													{{item.COLUMN_HEADER}}
												</th>

												<!-- Action column -->
												<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>
											</tr>

											<!-- Second row: Empty ths for alignment + subheaders -->
											<tr>
												<!-- 4 empty cells to align under the first 4 headers -->
												@*<th ng-repeat="n in [1,2,3,4]"></th>*@
												<th class="SNo"></th>
												<th class="item_edesc"></th>
												<th class="SUPPLIER_EDESC"></th>
												<th class="BATCH_NO"></th>
												<th class="ROLL_NO"></th>
												<!-- Actual subheaders -->
												<th ng-repeat="item in RawMaterialData[0].element.slice(4, 14) | orderBy: 'SERIAL_NO'"
													class="{{item.COLUMN_NAME}} {{item.COLUMN_NAME}}-child">
													{{item.COLUMN_HEADER}}
												</th>
												<th class="REMARKS-child"></th>
												<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>

											</tr>
										</thead>
										<tbody class="table_body" style="overflow-x: hidden;">

											<tr ng-repeat="(key,row) in childModels" id="idRawMaterial">
												<td class="SNo">
													<div>
														<input type="text" style="text-align: right;" value="{{key + 1}}" class="form-control SNo" disabled />
													</div>
												</td>
												<td class="text-align Parameters itemCode_{{key}}" value="{{row.ITEM_CODE}}">{{ row.ITEM_EDESC }}</td>
												<td class="text-align Specification Specification_{{key}}">
													<div class="input-group">
														<input type="hidden" ng-model="row.ITEM_CODE" value="{{row.ITEM_CODE}}" class="hidItemCode itemCode_{{key}}" />
														<input type="hidden" id="supplierCode_{{key}}" ng-model="row.SUPPLIER_CODE" class="hidSupplierCode" />
														<input id="vendor_{{key}}"
															   kendo-combo-box
															   k-options="ItemCodeOption"
															   k-on-data-bound="onComboBound(key)"
															   k-ng-model="row.SUPPLIER_CODE"
															   name="products"
															   k-data-text-field="'SUPPLIER_EDESC'"
															   k-data-value-field="'SUPPLIER_CODE'"
															   k-placeholder="'Select Material'"
															   k-filter="'contains'"
															   k-auto-bind="false"
															   k-suggest="false"
															   product-index="{{key}}" />
														<span class="input-group-addon addon-iconbox itemCode_{{key}} clsSupplier {{item.COLUMN_NAME}}_{{key}}" style="cursor: pointer; text-align: right;">
															<i class="fa fa-search" data-toggle="tooltip" title="Search product"></i>
														</span>
													</div>
												</td>

												<td class="text-align Unit Unit_{{key}}">
													<div class="input-group">
														<input type="hidden" ng-model="row.ITEM_CODE" value="{{row.ITEM_CODE}}" class="hidItemCode {{row.ITEM_CODE}}_{{key}}" />
														<input type="hidden" id="transactionNo_{{key}}" ng-model="TRANSACTION_NO" class="hidTransacitonNo" />
														<input id="batch_{{key}}" autocomplete="off"
															   kendo-combo-box
															   k-options="BatchOptions"
															   k-on-data-bound="onComboBound(key)"
															   k-ng-model="row.BATCH_NO"
															   name="products"
															   k-data-text-field="'BATCH_NO'"
															   k-data-value-field="'BATCH_NO'"
															   k-placeholder="'Select Material'"
															   k-filter="'contains'"
															   k-auto-bind="false"
															   k-suggest="false"
															   product-batch-index="{{key}}" />
														<span class="input-group-addon addon-iconbox itemCode_{{key}} clsBatch {{row.ITEM_CODE}}_{{key}}" style="cursor: pointer; text-align: right;">
															<i class="fa fa-search" data-toggle="tooltip" title="Search product"></i>
														</span>
													</div>
												</td>
												<td class="text-align ROLL_NO_WIDTH ROLL_NO_{{key}}"><input ng-model="childModels[key]['ROLL_NO']" ng-value="childModels[key]['ROLL_NO']" placeholder="Enter" autocomplete="off" class="ROLL_NO ROLL_NO_{{key}}" /></td>
												<td class="text-align GSM_WIDTH GSM_{{key}}">{{ row.GSM }}</td>
												<td class="text-align SIZE_WIDTH_WIDTH SIZE_WIDTH_{{key}}">{{ row.WIDTH }}</td>
												<td class="text-align MD_STRENGTH_WIDTH STRENGTH_MD_{{key}}">{{ row.STRENGTH_MD }}</td>
												<td class="text-align CD_STRENGTH_WIDTH STRENGTH_{{key}}">{{ row.STRENGTH }}</td>
												<td class="text-align THICKNESS_WIDTH THICKNESS_{{key}}">{{ row.THICKNESS }}</td>
												<td class="text-align GSM_WIDTH ACTUAL_GSM_{{key}}"><input ng-model="childModels[key]['ACTUAL_GSM']" ng-value="childModels[key]['ACTUAL_GSM']" placeholder="Enter" autocomplete="off" class="GSM ACTUAL_GSM_{{key}}" /></td>
												<td class="text-align SIZE_WIDTH_WIDTH ACTUAL_WIDTH_{{key}}"><input ng-model="childModels[key]['ACTUAL_WIDTH']" placeholder="Enter" autocomplete="off" class="SIZE_WIDTH ACTUAL_WIDTH_{{key}}" /></td>
												<td class="text-align MD_STRENGTH_WIDTH Results_{{key}}"><input ng-model="childModels[key]['ACTUAL_STRENGTH_MD']" placeholder="Enter" autocomplete="off" class="MD_STRENGTH ACTUAL_STRENGTH_MD_{{key}}" /></td>
												<td class="text-align CD_STRENGTH_WIDTH STRENGTH_{{key}}"><input ng-model="childModels[key]['ACTUAL_STRENGTH']" placeholder="Enter" autocomplete="off" class="CD_STRENGTH ACTUAL_STRENGTH_{{key}}" /></td>
												<td class="text-align THICKNESS_WIDTH THICKNESS_{{key}}"><input ng-model="childModels[key]['ACTUAL_THICKNESS']" placeholder="Enter" autocomplete="off" class="THICKNESS ACTUAL_THICKNESS_{{key}}" /></td>
												<td class="text-align REMARKS-child REMARKS_{{key}}"><input ng-model="childModels[key]['REMARKS']" placeholder="Enter" autocomplete="off" class="REMARKS_{{key}}" /></td>
												<td class="btn-action">
													<a href="" id="remove_child_element" name="remove_child_element" class="buttondelete" ng-click="remove_child_element($index)"><i class="fa fa-trash" data-toggle="tooltip" title="Delete row"></i></a>
												</td>
											</tr>
										</tbody>
									</table>
								</div>
                                </div>
							</div>
						</div>
				</div>
			</div>

		</div>
		<div class="modal-footer">
			<button type="button" class="btn btn-sm btn-green" ng-hide="panelMode === 'view'" id="savedocumentformdata" ng-click="saveRawMaterial()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
				<i class="fa fa-floppy-o"></i> Save
			</button>
			<button type="button" class="btn btn-sm btn-danger" ng-click="ItemCancel()" data-dismiss="modal">
				<i class="fa-solid fa-xmark"></i> Cancel
			</button>
		</div>
	</div>
</div>
<script>
	var a = location.hash;
	var b = location.pathname;
	var url = (b + a);
	$(".active").removeClass();
	$("a[href='" + url + "']").parent().addClass("active");
	$("a[href='" + url + "']").parent().parent().slideDown("slow");
</script>
<script>
	function dateSet(date) {
		var month = date.getMonth() + 1;
		var day = date.getDate();
		date = date.getFullYear() + '/' +
			(('' + month).length < 2 ? '0' : '') + month + '/' +
			(('' + day).length < 2 ? '0' : '') + day;
		return date;
	}

    function setNepaliDateFromEnglish() {
		var engDate = $("#englishdatedocument").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#englishdatedocument").val(formattedDate);
        var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
        $("#issueNep").val(nepaliDate);
	}

	function NepaliDateFromEnglish() {
		var engDate = $("#validDt").val();
		var formattedDate = moment(engDate, 'M/D/YYYY').format('DD-MMM-YYYY');
		$("#validDt").val(formattedDate);

		var formattedEngDate = moment(engDate, 'M/D/YYYY').format('YYYY-MM-DD');
		var nepaliDate = AD2BS(formattedEngDate);
		$("#nepaliDate").val(nepaliDate);

		var issueDt = moment($("#englishdatedocument").val(), 'DD-MMM-YYYY');
		var validUntilDt = moment(engDate, 'M/D/YYYY');

		if (validUntilDt.isBefore(issueDt)) {
			displayPopupNotification("To be Deliver Date cannot be greater than Date/Miti date.", "error");
		}
	}

	function ConvertNepToEng(e) {
		var date = BS2AD($("#issueNep").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#englishdatedocument").val(FormattedEngDate);
	}

	$(".nepali-calendar").nepaliDatePicker({
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
		altFormat: "dd-MMM-YYYY",
		dateFormat: "dd-MMM-YYYY",
		onChange: function (evt) {
			var nepaliDate = $("#issueNep").val(); // Get the Nepali date value
            var engDate = BS2AD(nepaliDate); // Convert Nepali date to English date
			var formattedEngDate = moment(engDate).format('DD-MMM-YYYY'); // Format the English date
			$("#englishdatedocument").val(formattedEngDate); // Update the English date input field
		}
	});

	function NepToEng(e) {
		var date = BS2AD($("#nepaliDate").val());
		var FormattedEngDate = moment(date).format('DD-MMM-YYYY');
		$("#validDt").val(FormattedEngDate);
    }

	$(".nepali-calendar").nepaliDatePicker({
		npdMonth: true,
		onFocus: true,
		npdYear: true,
		npdYearCount: 10,
