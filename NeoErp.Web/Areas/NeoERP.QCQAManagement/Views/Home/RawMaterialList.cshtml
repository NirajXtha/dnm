.document_child_table {
    border-collapse: collapse;
    table-layout: fixed;

    min-width: 1844px; /* ensure all columns, including REMARKS, fit */
    width: 100%;
    font-size: 10px;
}

/* Table headers */
.document_child_table thead.child-table-head th {
    border: 1px solid #ddd;
    padding: 5px;
    text-align: center;
    vertical-align: middle;
    background-color: #f5f5f5;
    position: sticky;
    top: 0;
    z-index: 10;
    white-space: nowrap; /* prevent wrapping */
}

