	<script src="@Scripts.Url("~/Areas/NeoERP.QCQAManagement/js/controller/InternalInspectionSetup.js")"></script>
	<script src="@Scripts.Url("~/Areas/NeoERP.QCQAManagement/js/controller/OnSiteInspection.js")"></script>
	<script src="@Scripts.Url("~/Areas/NeoERP.QCQAManagement/js/controller/InternalInspection.js")"></script>
	<script src="@Scripts.Url("~/Areas/NeoERP.QCQAManagement/js/controller/SanitationHygiene.js")"></script>
	<script src="@Scripts.Url("~/Areas/NeoERP.QCQAManagement/js/controller/SanitationHygieneReport.js")"></script>
