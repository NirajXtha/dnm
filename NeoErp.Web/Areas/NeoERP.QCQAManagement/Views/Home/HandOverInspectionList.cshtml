						<td class=textpadding><b>GATE ENTRY NO</b></td>
						<td class=textpadding><b>GATE ENTRY MITI</b></td>
						<td class=textpadding><b>SUPPLIER NAME</b></td>
						<td class=textpadding><b>INVOICE NO</b></td>
					</tr>`
							$.each(response, function (index, value) {
								grn_ContentHtml += `<tr id='voucherList' data-supplier="${value.SUPPLIER_CODE}" data-voucher="${value.Voucher_No}" style="padding:5px; border-bottom:1px solid #ccc; font-size: 14px;">
						<td class=textpadding>${value.Voucher_No}</td>
						<td class=textpadding>${value.MITI}</td>

						<td class=textpadding>${value.supplier_edesc}</td>
						<td class=textpadding>${value.invoice_no}</td>
						<td><button class="btnClass voucher-item large-button data-supplier="${value.SUPPLIER_CODE}"  data-voucher=${value.Voucher_No} " type ="button">Ref</button></td>
					</tr>`;
							});
							grn_ContentHtml += "</table>"; // Closing the table tag
							popupWindow.content(grn_ContentHtml);
							popupWindow.center().open();
							$("#searchInputText").on("keyup", function () {
								var searchText = $(this).val().toLowerCase();
								$("#voucherList tbody tr").each(function () {
									var rowText = $(this).find("td").map(function () {
										return $(this).text().toLowerCase();
									}).get().join(" "); // Join all cell values for a full-row search
									$(this).toggle(rowText.includes(searchText));
								});
							});
						}
					});

					$("#voucherList").on("click", "tr", function (e) {
						var selectedVoucher = $(this).attr("data-voucher");
						var selectedSupplier = $(this).attr("data-supplier");
						$('#idGRNNo').val(selectedVoucher);
						$.get("/api/IncomingMaterialAPI/MaterialDetailLists?VoucherNo=" + selectedVoucher, function (response_MatDetails) {
							if (ItemName === "RM") {
								$('#vendor_' + index).val(response_MatDetails[0].supplier_edesc);
								$('#supplierCode_' + index).val(response_MatDetails[0].SUPPLIER_CODE);
							}
							else {
								$('#txtInvoiceNo').val(response_MatDetails[0].invoice_no);
								$('#txtMaterialName').val(response_MatDetails[0].item_edesc);
								$('#txtVendorName').val(response_MatDetails[0].supplier_edesc);
								$('#txtLCNo').val(response_MatDetails[0].to_location_code);
								$('#txtReceivedQty').val(response_MatDetails[0].quantity);
								$('#txtQCAssistant').text(response_MatDetails[0].CreatedBy);
								$('#txtQCHead').text(response_MatDetails[0].CreatedBy);
								$('#txtManualNo').val(response_MatDetails[0].MANUAL_NO);
								$('#txtRemarks').val(response_MatDetails[0].Remarks);
							}

						});

						var inputSelector = `.ccustomer_${key}`;
						$(inputSelector).val(selectedVoucher).trigger("input"); // Trigger input event for Angular binding
						popupWindow.close(); // Close popup after selection
					});
					$(document).on("click", ".btnClass", function () {
						var classes = this.classList;
						var selectedVoucher = null;
						var selectedSupplier = null;
						classes.forEach(function (token) {
							if (token.indexOf("data-voucher=") === 0) {
								selectedVoucher = token.substring("data-voucher=".length);
								selectedSupplier = token.substring("data-supplier=".length);
							}
						});
						$('#idGRNNo').val(selectedVoucher);
						$.get("/api/IncomingMaterialAPI/MaterialDetailLists?VoucherNo=" + selectedVoucher, function (response_MatDetails) {
							if (ItemName === "RM") {
								$('#vendor_' + index).val(response_MatDetails[0].supplier_edesc);
								$('#supplierCode_' + index).val(response_MatDetails[0].SUPPLIER_CODE);
							}
							else {
								$('#txtInvoiceNo').val(response_MatDetails[0].invoice_no);
								$('#txtMaterialName').val(response_MatDetails[0].item_edesc);
								$('#txtVendorName').val(response_MatDetails[0].supplier_edesc);
								$('#txtLCNo').val(response_MatDetails[0].to_location_code);
								$('#txtReceivedQty').val(response_MatDetails[0].quantity);
								$('#txtQCAssistant').text(response_MatDetails[0].CreatedBy);
								$('#txtQCHead').text(response_MatDetails[0].CreatedBy);
								$('#txtManualNo').val(response_MatDetails[0].MANUAL_NO);
								$('#txtRemarks').val(response_MatDetails[0].Remarks);
							}
						});
						var inputSelector = `.ccustomer_${key}`;
						$(inputSelector).val(selectedVoucher).trigger("input"); // Trigger input event for Angular binding
						popupWindow.close(); // Close popup after selection
					});
				});
			}
		}
		var grid = $("#ItemGrid").data("kendoGrid");
	});
</script>


