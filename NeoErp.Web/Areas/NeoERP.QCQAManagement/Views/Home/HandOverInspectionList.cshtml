	Layout = null;
}


<style>

	.custom-alert {
		display: none;
		position: fixed;
		top: 20px;
		right: 20px;
		background: #f8d7da;
		color: #721c24;
		padding: 12px 20px;
		border-radius: 4px;
		font-weight: 600;
		z-index: 99999;
	}



	.large-button {
		padding: 8px 24px;
		/*font-size: 18px;*/
		border-radius: 6px;
		background-color: #28a745;
		color: white;
		border: none;
		cursor: pointer;
		display: block; /* Ensures proper centering */
		margin: auto; /* Centers horizontally */
	}

	.textpadding {
		padding-left: 5px;
	}

	.material-font {
		font-size: 11px;
		width: 200px;
	}

	.kendo-row {
		border: 1px solid #ddd;
	}

	.material-align {
		margin-left: 50px;
	}

	.document_child_table .table_body, .document_child_table .child-table-head tr {
		display: table !important;
		width: 100% !important;
		table-layout: fixed !important;
	}
	.document_child_table td.btn-action {
		width: 8%;
	}
	th.remarks-label {
		width: 10%;
		white-space: nowrap;
	}

	td.remarks-value {
		width: 90%;
	}

		td.remarks-value input {
			width: 100%;
			box-sizing: border-box;
		}

	.responsive_tab_content .input-group-addon {
		padding: 4px 12px !important;
	}

	.table_body tr {
		display: table;
		table-layout: fixed;
	}

	.SNo,
	.SNo_child {
		width: 57px;
		min-width: 57px;
		max-width: 57px;
		text-align: right;
	}

	.TimePeriod {
		width: 96.27px !important;
	}

	.TIME_PERIOD_div {
		width: 96.27px !important;
	}

	.PRODUCT_TYPE, .PRODUCT_TYPE_div {
		width: 159px !important;
	}

	.ProductName, .ProductType, .ProductType_div, .ITEM_CODE_div, .ProductName_div, .ITEM_EDESC, .ITEM_EDESC_div {
		width: 159px !important;
	}

	.TotalQty {
		display: table-cell !important;
		width: 581px !important;
		white-space: nowrap;
	}

	.BatchNo,  .BATCH_NO_div {
		width: 110px !important;
	}
	.LooseProduct, .UnsealedPacket, .SealedPacket, .CartonBag, .WrapperInPrinter{
		width:110px !important;
	}

	.clsSupplierValue {
		width: 86px;
	}

	.LooseProduct_Sample, .LooseProduct_Defect, .UnsealedPacket_Sample, .UnsealedPacket_Defect, .SealedPacket_Sample, .SealedPacket_Defect, .CartonBag_Sample, .CartonBag_Defect, .WrapperInPrinter_Sample, .WrapperInPrinter_Defect, .LooseProduct_Sample_div, .LooseProduct_Defect_div, .UnsealedPacket_Sample_div, .UnsealedPacket_Defect_div, .SealedPacket_Sample_div, .SealedPacket_Defect_div, .CartonBag_Sample_div, .CartonBag_Defect_div, .WrapperInPrinter_Sample_div, .WrapperInPrinter_Defect_div, .LOOSE_PRODUCT_SAMPLE_div, .LOOSE_PRODUCT_DEFECT_div, .UNSEALED_PACKET_SAMPLE_div, .UNSEALED_PACKET_DEFECT_div, .SEALED_PACKET_SAMPLE_div, .SEALED_PACKET_DEFECT_div, .BAG_SAMPLE_div, .BAG_DEFECT_div, .WRAPPER_SAMPLE_div, .WRAPPER_DEFECT_div {
		width: 55px !important;
	}

	.LooseProduct_SampleTotal, .LooseProduct_DefectTotal, .UnsealedPacket_SampleTotal, .UnsealedPacket_DefectTotal, .SealedPacket_SampleTotal, .SealedPacket_DefectTotal, .CartonBag_SampleTotal, .CartonBag_DefectTotal, .WrapperInPrinter_SampleTotal, .WrapperInPrinter_DefectTotal {
		width: 55px !important;
		padding: 0px 4px !important;
	}

	.LooseProductTotal, .UnsealedPacketTotal, .SealedPacketTotal, .CartonBagTotal, .WrapperInPrinterTotal {
		width: 110px !important;
		padding: 0px 4px !important;
	}

	.REMARKS-child, .REMARKS_div {
		width: 190px !important;
	}

	@@media screen and (max-width: 1400px) {
		.SNo,
		.SNo_child {
			width: 57px;
			min-width: 57px;
			max-width: 57px;
			text-align: right;
		}

		.TimePeriod {
			width: 96.27px !important;
		}

		.TIME_PERIOD_div {
			width: 96.27px !important;
		}

		.PRODUCT_TYPE, .PRODUCT_TYPE_div {
			width: 159px !important;
		}

		.ProductName, .ProductType, .ProductType_div, .ITEM_CODE_div, .ProductName_div {
			width: 159px !important;
		}

		.TotalQty {
			display: table-cell !important;
			width: 581px !important;
			white-space: nowrap;
		}

		.BatchNo, .LooseProduct, .UnsealedPacket, .SealedPacket, .CartonBag, .WrapperInPrinter, .BATCH_NO_div {
			width: 110px !important;
		}

		.clsSupplierValue {
			width: 86px;
		}

		.LooseProduct_Sample, .LooseProduct_Defect, .UnsealedPacket_Sample, .UnsealedPacket_Defect, .SealedPacket_Sample, .SealedPacket_Defect, .CartonBag_Sample, .CartonBag_Defect, .WrapperInPrinter_Sample, .WrapperInPrinter_Defect, .LooseProduct_Sample_div, .LooseProduct_Defect_div, .UnsealedPacket_Sample_div, .UnsealedPacket_Defect_div, .SealedPacket_Sample_div, .SealedPacket_Defect_div, .CartonBag_Sample_div, .CartonBag_Defect_div, .WrapperInPrinter_Sample_div, .WrapperInPrinter_Defect_div, .LOOSE_PRODUCT_SAMPLE_div, .LOOSE_PRODUCT_DEFECT_div, .UNSEALED_PACKET_SAMPLE_div, .UNSEALED_PACKET_DEFECT_div, .SEALED_PACKET_SAMPLE_div, .SEALED_PACKET_DEFECT_div, .BAG_SAMPLE_div, .BAG_DEFECT_div, .WRAPPER_SAMPLE_div, .WRAPPER_DEFECT_div {
			width: 55px !important;
		}

		.LooseProduct_SampleTotal, .LooseProduct_DefectTotal, .UnsealedPacket_SampleTotal, .UnsealedPacket_DefectTotal, .SealedPacket_SampleTotal, .SealedPacket_DefectTotal, .CartonBag_SampleTotal, .CartonBag_DefectTotal, .WrapperInPrinter_SampleTotal, .WrapperInPrinter_DefectTotal {
			width: 55px !important;
			padding: 0px 4px !important;
		}

		.LooseProductTotal, .UnsealedPacketTotal, .SealedPacketTotal, .CartonBagTotal, .WrapperInPrinterTotal {
			width: 110px !important;
			padding: 0px 4px !important;
		}

		.REMARKS-child, .REMARKS_div {
			width: 190px !important;
		}
	}

	.btn-action a, .buttonadd, .buttondelete {
		border: solid #ddd 1px !important;
		background-color: #ddd !important;
		padding: 0px 3px 0px 3px !important;
		display: inline-block;
		font-size: 11px !important;
		margin-left: 2px !important;
		vertical-align: middle !important;
		vertical-align: -webkit-baseline-middle;
	}

	.btn-action {
		width: 100px !important;
	}

	.input-group .addon-iconbox {
		min-width: 23px;
		padding: 0px;
	}

	/*.date-width {
		width: 87px !important;
	}*/

	div.clsRemarks input{
		width: 90% !important;
	}

	.date-container {
		display: flex;
		flex-direction: column; /* label on top */
	}

	.date-label {
		margin-bottom: 6px; /* space below label */
		font-weight: 500;
	}

	.date-row {
		display: flex;
		gap: 12px; /* 👈 constant distance */
		align-items: center;
	}

	.nepali-wrapper {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.nepali-calendar {
		padding-right: 30px; /* space for icon */
		height: 34px; /* match Kendo input height */
	}


	.calendar-icon-2 {
		position: absolute;
		right: 8px;
		top: 50%;
		transform: translateY(-50%);
		font-size: 14px;
		color: #555;
		right: 9px !important;
		top: 10px !important;
		pointer-events: none;
	}

	.k-widget.k-datepicker {
		width: 50% !important;
	}

</style>

@*<link href="@Styles.Url("~/Areas/NeoERP.QCQAManagement/Content/QCQASetup.css")" rel="stylesheet" />*@
<div class="col-md-12 bodyController" ng-controller="HandOverInspectionList">
	<div class="portlet light form-fit bordered bottomspance">
		<div class="portlet box green-box main">
			<div class="portlet-title">
				<div class="caption">
					<a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/QuotationManagement/Home/Dashboard">
						<i class="fa fa-arrow-circle-left"></i>
					</a>
					<i class="fa fa-gift font-white-haze"></i>
					<span class="caption-subject font-white-haze bold uppercase">Handover Inspection Report</span>
				</div>
			</div>
			<div class="portlet-body light bg-inverse">
				<div id="ItemGrid">
					<div class="row" style="margin-bottom: 10px; margin-top: 10px;">
						<form id="registeredVehicle" name="registeredVehicle">
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group col-md-3 col-sm-3">
									<label for="element">Dispatch No:</label>
									<div>
										<input type="text" ng-model="DISPATCH_NO" ng-init="DISPATCH_NO='@ViewBag.QCNO'" disabled>
									</div>
								</div>
								<div class="form-group col-md-4 date-container">
									<label class="date-label">Date / Miti</label>
									<div class="date-row">
										<input id="englishdatedocument"
											   autocomplete="off"
											   class="englishdate"
											   kendo-date-picker
											   ng-model="CREATED_DATE"
											   k-options="monthSelectorOptions" />
										<div class="nepali-wrapper nopadding-left pl-1">
											<input type="text"
												   id="nepaliDate5"
												   class="nepali-calendar"
												   data-checkfor="englishdatedocument"
												   autocomplete="off"
												   onchange="ConvertNepToEng(this)"
												   next-on-tab />
											<i class="fa fa-calendar calendar-icon-2"></i>
										</div>
									</div>
								</div>
								<div class="form-group col-md-2 col-sm-2">
									<label for="element">Packing Unit</label>
									<div class="topsearch" style="display: block;">

										<select id="ddlPackingUnit" k-ng-model="PACKING_UNIT" kendo-drop-down-list
												k-options="ddlPackingUnit"
												class="ddlPackingUnit">
										</select>
									</div>
								</div>
								<div class="form-group col-md-1 col-sm-1">
									<label for="element">Manual No</label>
									<div>
										<input type="text" ng-model="MANUAL_NO" autocomplete="off" class="" name="WB_SLIP_NO" id="txtManualNo" />
									</div>
								</div>
								
							</div>
							<div class="col-md-12 col-sm-12 form-group nopadding-right dynamicform">
								<div class="form-group  col-md-12 col-sm-12">
									<label for="element">Remarks:</label>
									<div class="clsRemarks">
										<input type="text" ng-model="REMARKS" autocomplete="off" class="" name="WB_SLIP_NO" id="txtRemarks" />
									</div>
								</div>
							</div>
						</form>
					</div>
					<div class="tab-content d-tab-content">
						<div class="tab-pane active" id="tab_15_1">
							<div class="table-responsive">
								<table class="document_child_table dynamic-table table-fixed dynamic_child_table dynamic_child_table6">
									<thead class="child-table-head">
										<tr>
											<th class="SNo">S/No</th>
											<th class="TIME_PERIOD_div">Time Period</th>
											<th class="ProductType_div">Product Type</th>
											<th class="ProductName">Product Name</th>
											<th class="BatchNo">Batch No</th>
											<th class="LooseProduct">Loose Product</th>
											<th class="UnsealedPacket">Unsealed Packet</th>
											<th class="SealedPacket">Sealed Packet</th>
											<th class="CartonBag">Carton/Bag</th>
											<th class="WrapperInPrinter">Wrapper in printer</th>
											<th class="Remarks-child">Remarks</th>

											<!-- Action column -->
											<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>
										</tr>

										<!-- Second row: Empty ths for alignment + subheaders -->
										<tr>
											<th class="SNo_child"></th>
											<th class="TIME_PERIOD_div"></th>
											<th class="ProductType"></th>
											<th class="ProductName"></th>
											<th class="BatchNo"></th>
											<th class="LooseProduct_Sample">Sample</th>
											<th class="LooseProduct_Defect">Defect</th>
											<th class="UnsealedPacket_Sample">Sample</th>
											<th class="UnsealedPacket_Defect">Defect</th>
											<th class="SealedPacket_Sample">Sample</th>
											<th class="SealedPacket_Defect">Defect</th>
											<th class="CartonBag_Sample">Sample</th>
											<th class="CartonBag_Defect">Defect</th>
											<th class="WrapperInPrinter_Sample">Sample</th>
											<th class="WrapperInPrinter_Defect">Defect</th>
											<th class="Remarks-child"></th>
											<th rowspan="2" class="btn-action" style="width:8%;">&nbsp;</th>
										</tr>
									</thead>
									<tbody class="table_body">

										<tr ng-repeat="(key,row) in HandOverItemsData" id="idDispatchItems">
											<td class="SNo_child" style="background-color: #eeeeee;">
												<div>
													<input type="text" style="text-align: right;" value="{{key + 1}}" class="form-control SNo_child TIME_PERIOD1" disabled />
												</div>
											</td>
											<td ng-repeat="item in row.element | orderBy: 'SERIAL_NO'" class="{{item.COLUMN_NAME| uppercase}}_div">
												<div ng-if="item.COLUMN_NAME ==='TIME_PERIOD'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" />
												</div>
												<div class="input-group" ng-if="item.COLUMN_NAME ==='PRODUCT_TYPE'">
													<input id="productType_{{key}}" ng-model="PRODUCT_TYPE"
														   autocomplete="off"
														   class="clsProductType" kendo-combo-box
														   product-index="{{key}}"
														   k-options="ItemCodeOption1"
														   k-min-length="3" />
													<span class="input-group-addon addon-iconbox PRODUCT_TYPE_{{key}} clsProductType PRODUCT_TYPE_{{key}}" style="cursor: pointer; text-align: right;">
														<i class="fa fa-search" data-toggle="tooltip" title="Search product"></i>
													</span>
												</div>
												<div class="input-group" ng-if="item.COLUMN_NAME ==='ITEM_EDESC'">
													<label type="hidden" ng-model="ITEM_CODE" class="hidProductNameCode_{{key}} productNameCode_{{key}}">{{ITEM_CODE}}</label>
													<input id="productName_{{key}}" ng-model="ITEM_CODE"
														   autocomplete="off"
														   class="clsSupplierValue" kendo-combo-box
														   product-name-index="{{key}}"
														   k-options="ItemCodeOption"
														   k-min-length="3" />
													<span class="input-group-addon addon-iconbox itemCode_{{key}} clsProductName ITEM_EDESC_{{key}}" style="cursor: pointer; text-align: right;">
														<i class="fa fa-search" data-toggle="tooltip" title="Search product"></i>
													</span>
												</div>
												<div class="input-group" ng-if="item.COLUMN_NAME === 'BATCH_NO'">
													<input type="hidden" ng-model="FORM_CODE" class="hidItemCode itemCode_{{key}}" />
													<input type="hidden" id="transactionNo_{{key}}" ng-model="TRANSACTION_NO" class="hidTransacitonNo" />
													<input id="batch_{{key}}" ng-model="BATCH_NO"
														   autocomplete="off"
														   class="clsSupplierValue" kendo-combo-box
														   batch-name-index="{{key}}"
														   k-options="ItemCodeBatchOption"
														   k-min-length="3" />
													<span class="input-group-addon addon-iconbox itemCode_{{key}} clsBatch {{item.COLUMN_NAME}}_{{key}}" style="cursor: pointer; text-align: right;">
														<i class="fa fa-search" data-toggle="tooltip" title="Search product"></i>
													</span>
												</div>
												<div ng-if="item.COLUMN_NAME ==='LOOSE_PRODUCT_SAMPLE'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='LOOSE_PRODUCT_DEFECT'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='UNSEALED_PACKET_SAMPLE'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='UNSEALED_PACKET_DEFECT'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='SEALED_PACKET_SAMPLE'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='SEALED_PACKET_DEFECT'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='BAG_SAMPLE'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='BAG_DEFECT'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='WRAPPER_SAMPLE'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='WRAPPER_DEFECT'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" onkeypress="return event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57) || event.charCode == 46" ng-keyup="CalculateTotal(key)" />
												</div>
												<div ng-if="item.COLUMN_NAME ==='REMARKS'">
													<input type="text" id="item.COLUMN_NAME" placeholder="Enter" autocomplete="off" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" />
												</div>
											</td>
											<td class="btn-action">
												<a href="" id="add_child_element" name="add_child_element" class="buttonadd" ng-click="add_child_element($index)"><i class="fa fa-plus" data-toggle="tooltip" title="Add row"></i></a>
												<a href="" id="remove_child_element" name="remove_child_element" class="buttondelete" ng-click="remove_child_element($index)"><i class="fa fa-trash" data-toggle="tooltip" title="Delete row"></i></a>
											</td>
										</tr>
										<tr><th class="TotalQty">Total Qty</th><td class="LooseProduct_SampleTotal"></td><td class="LooseProduct_DefectTotal"></td><td class="UnsealedPacket_SampleTotal"></td><td class="UnsealedPacket_DefectTotal"></td><td class="SealedPacket_SampleTotal"></td><td class="SealedPacket_DefectTotal"></td><td class="CartonBag_SampleTotal"></td><td class="CartonBag_DefectTotal"></td><td class="WrapperInPrinter_SampleTotal"></td><td class="WrapperInPrinter_DefectTotal"></td><td class="Remarks-child"></td><td class="btn-action"></td></tr>
										<tr><th class="TotalQty">Total Defect Rate:</th><td class="LooseProductTotal" colspan="2"><td class="UnsealedPacketTotal" colspan="2"></td><td class="SealedPacketTotal" colspan="2"></td><td class="CartonBagTotal" colspan="2"></td><td class="WrapperInPrinterTotal" colspan="2"></td><td class="Remarks-child" colspan="2"></td><td class="btn-action"></td></tr>
										<tr><th class="remarks-label">Overall Remarks</th><td class="remarks-value"><input id="txtOverAllRemarks" ng-model="OVERALL_REMARKS" autocomplete="off"  type="text"></td></tr>
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
