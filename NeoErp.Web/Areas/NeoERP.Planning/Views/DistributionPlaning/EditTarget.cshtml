@{
    ViewBag.Title = "Edit Target Setup";
    //Layout = "~/Areas/NeoERP.Planning/Views/Shared/_Layout.cshtml";
}
<style>
    #generateplan input.form-control, #planSetupForm .k-dropdown-wrap, .common input.form-control, .customdesign select.dateFilterSelect {
        padding: 0px 0px !important;
    }

    .k-splitter {
        height: 460px !important;
    }

    .k-dropdown {
        position: relative; /* Ensure the Kendo dropdown is positioned */
        z-index: 1000; /* Set the desired z-index value */
    }

    #external-events {
        /*float: left !important;*/
        padding: 0 10px;
        border: 1px solid #ccc;
    }

    .target-type-container {
        display: flex;
        flex-wrap: wrap;
    }

    .radio-option {
        display: flex;
        align-items: center;
        margin-right: 15px;
    }

        .radio-option label {
            margin-left: 5px;
        }

    #external-events h4 {
        font-size: 16px;
        margin-top: 0;
        padding-top: 1em;
    }

    #external-events .fc-event {
        margin: 10px 0;
        cursor: pointer;
    }

    #external-events p {
        margin: 1.5em 0;
        font-size: 11px;
        /*color: #666;*/
    }

    .calendar-sliim {
        /*max-height:900px;
        overflow-y:auto;*/
    }


    #external-events p input {
        margin: 0;
        vertical-align: middle;
    }

    #calendar {
        float: left;
        width: 81%;
        padding-left: 1%;
        position: absolute;
        left: 15%;
    }

    .md-radio-inline div {
        display: inline-block;
    }

    input[type=checkbox], input[type=radio] {
        margin: -5px 0 0;
        line-height: normal;
    }

    .md-radio-inline .has-error {
        margin-right: 10px;
    }

    .TriSea-technologies-Switch > input[type="checkbox"] {
        display: none;
    }

    .TriSea-technologies-Switch > label {
        cursor: pointer;
        height: 0px;
        position: relative;
        width: 40px;
    }

        .TriSea-technologies-Switch > label::before {
            background: rgb(0, 0, 0);
            box-shadow: inset 0px 0px 10px rgba(0, 0, 0, 0.5);
            border-radius: 8px;
            content: '';
            height: 16px;
            margin-top: -8px;
            position: absolute;
            opacity: 0.3;
            transition: all 0.4s ease-in-out;
            width: 40px;
        }

        .TriSea-technologies-Switch > label::after {
            background: rgb(255, 255, 255);
            border-radius: 16px;
            box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.3);
            content: '';
            height: 24px;
            left: -4px;
            margin-top: -8px;
            position: absolute;
            top: -4px;
            transition: all 0.3s ease-in-out;
            width: 24px;
        }

    .TriSea-technologies-Switch > input[type="checkbox"]:checked + label::before {
        background: inherit;
        opacity: 0.5;
    }

    .TriSea-technologies-Switch > input[type="checkbox"]:checked + label::after {
        background: inherit;
        left: 20px;
    }

    .dateFilterSelect.form-control {
        font-size: 11px !important;
        height: 24px !important;
        padding: 0 5px !important;
    }

    .form-horizontal .control-label {
        padding-top: 3px !important;
    }

    .slimScrollDiv {
        width: 14%;
    }

    .sidebar-route {
        max-height: 500px;
        overflow-y: auto;
    }


    #external-events1 {
        /*max-height: 450px;*/
        overflow: hidden;
    }

    input.input_search {
        width: 130px !important;
        font-size: 11px !important;
        margin-top: 5px;
        margin-left: -5px;
    }

    .fc-today {
        background: #FFBF00 !important;
    }
</style>
<div class="row" ng-controller="EditTarget">
    <div class="col-md-12 common">
        <div class="portlet light bordered">
            <div class="portlet-title">
                <div class="caption">
                    <i class="fa fa-calendar font-green-haze"></i>
                    <span class="caption-subject font-green-haze bold uppercase">
                        {{add_edit_option == "New" ? "Edit" : "New"}} Target Setup
                    </span>
                </div>
                <div class="caption" style="margin-left: 5rem;display:flex">
                    <div class="radio-option" ng-repeat="type in Types">
                        <input type="radio" id="selectedType_{{type.value}}" name="selectedType" ng-model="selectedType" ng-value="type.value" ng-click="onTypeChange(type)" />
                        <label for="selectedType_{{type.value}}">{{type.text}}</label>
                    </div>
                </div>

                <div class="actions pull-right">
                    @*<div class="btn-group" style="margin-top:10px;">
                        <input id="avatar" type="file" name="avatar" style="width:185px;" />
                    </div>
                    <div class="btn-group">
                        <a href="javascript:void(0)" id="uploadExcel" class="pull-right btn btn-circle btn-icon-only btn-default">
                            <i class="fa fa-upload"></i>
                        </a>
                    </div>

                    <a href="~/PlanExcell/CalendarRouteSetup/RouteSetupTemplate.xlsx" download>
                        <i class="fa fa-file-excel-o"></i>
                    </a>*@
                    <button type="button" ng-click="cancelClick()" class="btn btn-circle btn-default btn-sm"><i class="fa fa-times"></i> Cancel</button>
                    <button type="submit" ng-click="assignTargets()" class="btn btn-circle btn-green btn-sm"><i class="fa fa-save"></i> Save</button>
                    @*<button type="submit" ng-click="AddEditOption()" class="btn btn-circle btn-green-light btn-sm"><i class="fa fa-edit"></i> Go To {{add_edit_option}}</button>*@
                </div>
            </div>
            <div class="portlet-body clearfix">
                <div class="route_plan">
                    <form id="targetForm" name="targetForm">
                        <div class="row">

                            <div class="col-md-8">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label">Target Type</label>
                                            <div class="target-type-container">
                                                <div class="radio-option" ng-repeat="type in targetTypes">
                                                    <input type="radio" id="targetType_{{type.value}}" name="targetType" ng-model="selectedTarget" ng-value="type" ng-click="onTargetTypeChange(type)" />
                                                    <label for="targetType_{{type.value}}">{{type.text}}</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label">Target Name</label>
                                            <input type="text" name="targetName" class="form-control input-sm" ng-model="targetName" />
                                        </div>
                                    </div>
                                    <div class="col-md-6" ng-show="shouldShowSubTargetType">
                                        <div class="form-group">
                                            <label class="control-label">Sub Target Type<span style="color:red" ng-show="targetForm.subTarget.$invalid">*</span></label>
                                            <select id="subTargetType" k-ng-model="selectedSubTarget" kendo-drop-down-list k-options="subTargetTypeOptions" style="width: 100%"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label">Employee Group<span style="color:red" ng-show="targetForm.group.$invalid">*</span></label>
                                            <select id="empGroup" k-ng-model="selectedEmpGroup" k-options="employeeGroupOptions" kendo-multi-select style="width: 100%"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label">Employees List</label>
                                            <select id="employees" name="employee" k-ng-model="selectedEmployees" kendo-multi-select k-options="employeeOptions" style="width: 100%"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-6" ng-show="showIndividualType">
                                        <div class="form-group">
                                            <label class="control-label">Item Group<span style="color:red" ng-show="targetForm.group.$invalid">*</span></label>
                                            <select id="itemGroup" k-ng-model="selectedItmGroup" kendo-multi-select k-options="itemGroupOptions" style="width: 100%"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-6" ng-show="showIndividualType">
                                        <div class="form-group">
                                            <label class="control-label">Items<span style="color:red" ng-show="targetForm.individual.$invalid">*</span></label>
                                            <select id="individual" k-ng-model="selectedIndividual" kendo-multi-select k-options="individualOptions" style="width: 100%"></select>
                                        </div>
                                    </div>
                                    <div class="col-md-6" ng-show="showCustomerType">
                                        <div class="form-group">
                                            <label class="control-label">Customer Group<span style="color:red" ng-show="targetForm.group.$invalid">*</span></label>
                                            <select id="customerGroup" k-ng-model="selectedCusGroup" kendo-multi-select k-options="customerGroupOptions" style="width: 100%"></select>
                                        </div>
                                    </div>
                                    @*<div class="col-md-6" ng-show="showCustomerType">
                                        <div class="form-group">
                                            <label class="control-label">Customer<span style="color:red" ng-show="targetForm.individual.$invalid">*</span></label>
                                            <select id="customerList" k-ng-model="selectedCustomer" kendo-multi-select k-options="customerOptions" style="width: 100%"></select>
                                        </div>
                                    </div>*@
                                    <div class="col-md-6" ng-show="showCustomerType">
                                        <div class="form-group">
                                            <label class="control-label">
                                                Customer
                                                <span style="color:red" ng-show="targetForm.individual.$invalid">*</span>
                                            </label>

                                            <!-- Button to open popup -->
                                            <button type="button" class="btn btn-outline-primary w-100" ng-click="openCustomerPopup()">
                                                Select Customers
                                            </button>

                                            <textarea class="form-control mt-2"
                                                      rows="3"
                                                      style="resize: vertical; overflow-y: auto;"
                                                      ng-model="selectedCustomerText"
                                                      readonly></textarea>
                                        </div>
                                    </div>


                                    <!-- KENDO WINDOW POPUP -->
                                    <div kendo-window="customerPopup"
                                         k-visible="false"
                                         k-title="'Select Customers'"
                                         k-modal="true"
                                         k-width="600"
                                         k-height="400"
                                         class="p-3">

                                        <!-- Search box -->
                                        <div class="form-group mb-2">
                                            <input type="text"
                                                   class="form-control"
                                                   placeholder="Search Customer"
                                                   ng-model="customerPopupSearch"
                                                   ng-change="reloadCustomerPopup()" />
                                        </div>

                                        <!-- Buttons -->
                                        <div class="mb-2 d-flex justify-content-between">
                                            <button type="button" class="btn btn-sm btn-primary" ng-click="selectAllCustomers()">
                                                Select All
                                            </button>

                                            <button type="button" class="btn btn-sm btn-warning" ng-click="unselectAllCustomers()">
                                                Unselect All
                                            </button>

                                            <button type="button" class="btn btn-sm btn-success" ng-click="applyCustomerSelection()">
                                                Apply
                                            </button>
                                        </div>

                                        <!-- Grid -->
                                        <div id="customerPopupGrid"
                                             kendo-grid
                                             k-options="customerPopupGridOptions"
                                             style="height:300px; overflow:auto;">
                                        </div>
                                    </div>


                                    <div class="col-sm-6 col-md-3" ng-show="shouldShowSubTargetType">
                                        <div class="form-group">
                                            <label for="customQty">Quantity</label>
                                            <input type="number" id="customQty" name="customQty" min="1" ng-model="customQty" class="form-control input-sm" />
                                        </div>
                                    </div>
                                    <div class="col-sm-6 col-md-3">
                                        <div class="form-group">
                                            <label for="customAmt">Amount</label>
                                            <input type="number" id="customAmt" name="customAmt" min="1" ng-model="customAmt" class="form-control input-sm" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div ng-show="!IsEdit" class="col-md-4">
                                <div class="form-group">
                                    <div class="btn-group">
                                        @Html.Partial("~/Areas/NeoERP.Planning/Views/Shared/Controls/DateField.cshtml", true)
                                    </div>
                                </div>
                                <div class="form-group text-right mb-3">
                                    <button id="searchEmployeesBtn" ng-click="searchClick()" class="btn btn-default btn-sm pull-right">
                                        Search
                                        <i class="fa fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div class="row" ng-if="employeeTreeListOptions">
                        <div class="col-md-12">
                            <div id="employeeTreeList"
                                 kendo-treelist
                                 k-options="employeeTreeListOptions">
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<script src="@Scripts.Url("~/Areas/NeoERP.Planning/js/controller/DateFilter.js")" type="text/javascript"></script>
<script src="@Scripts.Url("~/JS/ReportFilter.js")" type="text/javascript"></script>

<script>
    $(document).ready(function () {
        DateFilter.init(function () {
            var dateFilterForm = $("#form_modal2 .form-horizontal .form-group");
            var dateFilterSelect = $("#ddlDateFilterVoucher");
            dateFilterSelect.find("option").filter(function () {
                var text = $(this).text().trim();
                return ![
                    "This Month",
                    "This Year",
                    "First Quarter",
                    "Second Quarter",
                    "Third Quarter",
                    "Fourth Quarter"
                ].includes(text);
            }).remove();
            $("#fromInputDateVoucher, #toInputDateVoucher").removeAttr("onfocus");
            $("#fromDateVoucher, #toDateVoucher").removeAttr("onfocus");

            $("#fromDateVoucher, #toDateVoucher").on("click", function (e) {
                e.preventDefault();
                $(this).blur();
            });
            const items = [
                { value: "monthly", text: "This Month" },
                { value: "thisyear", text: "This Year" },
                { value: "q1", text: "First Quarter" },
                { value: "q2", text: "Second Quarter" },
                { value: "q3", text: "Third Quarter" },
                { value: "q4", text: "Fourth Quarter" }
            ];

            var dateFilterSelect = $("#ddlDateFilterVoucher");
            dateFilterSelect.find("option").each(function () {
                var optionText = $(this).text().trim();
                var match = items.find(x => x.text === optionText);

                if (!match) {
                    $(this).remove();
                } else {
                    $(this).val(match.value);
                }
            });

        });
    });
</script>


