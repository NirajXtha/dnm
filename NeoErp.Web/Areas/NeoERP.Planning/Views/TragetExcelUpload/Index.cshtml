@{
    ViewBag.Title = "Home Page";
    Layout = null;    
    }

    <style>
        .upload-area {
            border: 2px dashed #43A32E;
            border-radius: 8px;
            text-align: center;
            background: #f8f9fa;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

            .upload-area:hover {
                background: #e9ecef;
                border-color: #246f14;
            }

        .upload-icon {
            font-size: 48px;
            color: #43A32E;
            margin-bottom: 15px;
        }

        .file-input-wrapper {
            position: relative;
            display: inline-block;
            margin: 5px 0;
        }

            .file-input-wrapper input[type=file] {
                position: absolute;
                opacity: 0;
                width: 100%;
                height: 100%;
                cursor: pointer;
            }

        .btn-choose-file {
            padding: 5px 10px;
            background: #43A32E;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            transition: background 0.3s ease;
        }

            .btn-choose-file:hover {
                background: #67B755;
            }

        .preview-section {
            display: none;
            margin-top: 20px;
        }

        .summary-cards {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .summary-card {
            flex: 1;
            min-width: 150px;
            padding: 0px 5px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .summary-card.total {
                background: linear-gradient(135deg, #5C8D89 0%, #43A32E 100%);
                color: white;
            }

            .summary-card.valid {
                background: linear-gradient(135deg, #43A32E 0%, #67B755 100%);
                color: white;
            }

            .summary-card.invalid {
                background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);
                color: white;
            }

            .summary-card h3 {
                margin: 0;
                font-size: 17px;
                font-weight: bold;
            }

            .summary-card p {
                margin: 0;
                font-size: 10px;
                opacity: 0.95;
                font-weight: 500;
            }

        .table-responsive-custom {
            max-height: 500px;
            overflow-y: auto;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .data-table thead {
                background: #43A32E;
                color: white;
                position: sticky;
                top: 0;
                z-index: 10;
            }

            .data-table th {
                padding: 12px 8px;
                text-align: left;
                font-weight: 600;
                border-bottom: 2px solid #dee2e6;
            }

            .data-table td {
                padding: 2px 3px;
                border-bottom: 1px solid #dee2e6;
            }

            .data-table tr.valid {
                background: #d4edda;
            }

            .data-table tr.invalid {
                background: #f8d7da;
            }

            .data-table tr:hover {
                background: #e9ecef;
            }

        .status-icon {
            font-size: 18px;
            margin-right: 5px;
        }

            .status-icon.valid {
                color: #43A32E;
            }

            .status-icon.invalid {
                color: #dc3545;
            }

        .validation-errors {
            color: #dc3545;
            font-size: 12px;
            margin-top: 5px;
        }

            .validation-errors ul {
                margin: 0;
                padding-left: 20px;
            }

        .field-invalid {
            background-color: #ffe6e6 !important;
            font-weight: bold;
        }

        .field-valid {
            background-color: #e6ffe6 !important;
        }

        .loader-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }

            .loader-overlay.active {
                display: flex;
            }

        .loader-content {
            background: white;
            padding: 40px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #43A32E;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .loader-text {
            font-size: 18px;
            color: #333;
            font-weight: 500;
        }

        /* Tab Styles */
        .nav-tabs {
            border-bottom: 2px solid #43A32E;
            margin-bottom: 20px;
            display: flex;
            flex-direction: row;
            list-style: none;
            padding-left: 0;
        }

            .nav-tabs > li {
                margin-bottom: -2px;
                display: inline-block;
                float: none;
            }

                .nav-tabs > li > a {
                    border: 1px solid transparent;
                    border-radius: 4px 4px 0 0;
                    color: #555;
                    padding: 10px 20px;
                    font-weight: 500;
                    display: block;
                    cursor: pointer;
                    text-decoration: none;
                }

                    .nav-tabs > li > a:hover {
                        border-color: #e9ecef #e9ecef #43A32E;
                        background-color: #f8f9fa;
                        color: #43A32E;
                    }

                .nav-tabs > li.active > a,
                .nav-tabs > li.active > a:hover,
                .nav-tabs > li.active > a:focus {
                    color: #fff;
                    background-color: #43A32E;
                    border: 1px solid #43A32E;
                    border-bottom-color: transparent;
                }

        .tab-content {
            padding: 0;
        }

        .tab-pane {
            display: none;
        }

            .tab-pane.active {
                display: block;
            }
    </style>

    <div class="content">
        <div class="page-bar">
            <ul class="page-breadcrumb">
            </ul>
        </div>
    </div>

    @*<i class="fa fa-file-excel-o font-green-haze"></i>*@

