                        <div class="tab-pane" id="viewTab">
                            <!-- Search Section -->
                            <div class="upload-section">
                                <div class="upload-area">
                                    <div class="row">
                                        <div class="col-md-8" style="padding:20px;">
                                            <p style="color: #6c757d; margin-bottom: 15px;">
                                                Search and view target data by employee code
                                            </p>

                                            <div class="form-group">
                                                <label for="empCodeDropdown">Select Employee:</label>
                                                <select class="form-control" id="empCodeDropdown" style="max-width: 400px; display: inline-block; margin-right: 10px;">
                                                    <option value="">-- Select Employee --</option>
                                                </select>
                                                <button type="button" class="btn btn-green btn-sm" id="btnLoadTargets" style="margin-left: 10px;">
                                                    <i class="fa fa-search"></i> Load Targets
