    <!-- Loader Overlay -->
    <div class="loader-overlay" id="loaderOverlay">
        <div class="loader-content">
            <div class="spinner"></div>
            <div class="loader-text" id="loaderText">Processing...</div>
        </div>
    </div>

    <script>
        let uploadedData = [];

        // Helper function to format ISO 8601 date strings
        function formatDate(dateString) {
            if (!dateString) return '';

            // Parse the ISO 8601 date string (e.g., "2026-07-12T00:00:00")
            const date = new Date(dateString);

            // Check if date is valid
            if (isNaN(date.getTime())) return '';

            // Format as MM/DD/YYYY or use your preferred format
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const year = date.getFullYear();

            return `${month}/${day}/${year}`;
        }

        // Notification helper function with fallback
        function showNotification(message, type) {
            if (typeof displayPopupNotification === 'function') {
                displayPopupNotification(message, type);
            } else {
                alert(message);
            }
        }

        $(document).ready(function () {
            // Button click to trigger file input
            $('.btn-choose-file').on('click', function () {
                $('#excelFile').click();
            });

            // File input change event
            $('#excelFile').on('change', function (e) {
                const file = e.target.files[0];
                if (file) {
                    $('#fileName').text('Selected: ' + file.name);
                    uploadFile(file);
                }
            });

            // Reset button
            $('#btnReset').on('click', function () {
                resetForm();
            });

            // View button - triggers validation
            $('#btnView').on('click', function () {
                if (uploadedData.length > 0) {
                    validateData(uploadedData);
                }
            });

            // Save button
            $('#btnSave').on('click', function () {
                saveData();
            });
        });

        function showLoader(text) {
            $('#loaderText').text(text);
            $('#loaderOverlay').addClass('active');
        }

        function hideLoader() {
            $('#loaderOverlay').removeClass('active');
        }

        function uploadFile(file) {
            showLoader('Uploading and reading Excel file...');

            const formData = new FormData();
            formData.append('file', file);

            $.ajax({
                url: '/Planning/TragetExcelUpload/UploadExcel',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    hideLoader();
                    if (response.success) {
                        uploadedData = response.data;
                        console.log("uploadedData", uploadedData);
                        // Show action buttons after upload
                        $('#btnView').show().prop('disabled', false);
                        $('#btnReset').show();
                        showNotification('File uploaded successfully! Click "View" to validate data.', 'success');
                    } else {
                        showNotification('Error: ' + response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showNotification('Upload failed: ' + error, 'error');
                }
            });
        }

        function validateData(data) {
            showLoader('Validating data against database...');

            $.ajax({
                url: '/Planning/TragetExcelUpload/ValidateData',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (response) {
                    hideLoader();
                    if (response.success) {
                        uploadedData = response.data;
                        displayData(response.data, response.summary);
                    } else {
                        showNotification('Validation Error: ' + response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showNotification('Validation failed: ' + error, 'error');
                }
            });
        }

        function displayData(data, summary) {
            // Update summary
            $('#totalRows').text(summary.total);
            $('#validRows').text(summary.valid);
            $('#invalidRows').text(summary.invalid);

            // Show/enable action buttons
            $('#btnReset').show();
            $('#btnSave').show();

            // Enable save button if there are valid rows
            if (summary.valid > 0) {
                $('#btnSave').prop('disabled', false);
            } else {
                $('#btnSave').prop('disabled', true);
            }

            // Populate table
            const tbody = $('#dataTableBody');
            tbody.empty();

            data.forEach(function (row, index) {
                // Debug: Log the first row to see actual property names
                if (index === 0) {
                    console.log('First row data:', row);
                    console.log('FROM_DATE:', row.FROM_DATE);
                    console.log('TO_DATE:', row.TO_DATE);
                    console.log('All keys:', Object.keys(row));
                }

                const tr = $('<tr>').addClass(row.IsValid ? 'valid' : 'invalid');

                // Row number
                tr.append($('<td>').text(index + 1));

                // Status
                const statusIcon = row.IsValid
                    ? '<i class="fa fa-check-circle status-icon valid"></i>'
                    : '<i class="fa fa-times-circle status-icon invalid"></i>';
                tr.append($('<td>').html(statusIcon));

                // From Date - try different property name variations
                const fromDate = row.FROM_DATE || row.from_DATE || row.fromDate || row.From_Date;
                console.log('From Date value for row', index + 1, ':', fromDate);
                tr.append($('<td>').text(formatDate(fromDate)));

                // To Date - try different property name variations
                const toDate = row.TO_DATE || row.to_DATE || row.toDate || row.To_Date;
                console.log('To Date value for row', index + 1, ':', toDate);
                tr.append($('<td>').text(formatDate(toDate)));

                // Employee
                const empClass = row.IsEmployeeValid ? 'field-valid' : 'field-invalid';
                const empText = row.EMP_NAME ? row.EMP_CODE + ' - ' + row.EMP_NAME : row.EMP_CODE || '';
                tr.append($('<td>').addClass(empClass).text(empText));

                // Distributor
                const distClass = row.IsDistributorValid ? 'field-valid' : 'field-invalid';
                const distText = row.DISTRIBUTOR_NAME ? row.DISTRIBUTOR_CODE + ' - ' + row.DISTRIBUTOR_NAME : row.DISTRIBUTOR_CODE || '';
                tr.append($('<td>').addClass(distClass).text(distText));

                // Item
                const itemClass = row.IsItemValid ? 'field-valid' : 'field-invalid';
                const itemText = row.ITEM_NAME ? row.ITEM_CODE + ' - ' + row.ITEM_NAME : row.ITEM_CODE || '';
                tr.append($('<td>').addClass(itemClass).text(itemText));

                // Qty
                tr.append($('<td>').text(row.QTY || ''));

                // Price
                tr.append($('<td>').text(row.PRICE || ''));

                // Branch
                const branchClass = row.IsBranchValid ? 'field-valid' : 'field-invalid';
                const branchText = row.BRANCH_NAME ? row.BRANCH_CODE + ' - ' + row.BRANCH_NAME : row.BRANCH_CODE || '';
                tr.append($('<td>').addClass(branchClass).text(branchText));

                // Errors
                const errorsTd = $('<td>');
                if (row.ValidationErrors && row.ValidationErrors.length > 0) {
                    const errorsList = $('<ul>').addClass('validation-errors');
                    row.ValidationErrors.forEach(function (error) {
                        errorsList.append($('<li>').text(error));
                    });
                    errorsTd.append(errorsList);
                }
                tr.append(errorsTd);

                tbody.append(tr);
            });

            // Show preview section
            $('#previewSection').slideDown();
        }

        function saveData() {
            const validRows = uploadedData.filter(r => r.IsValid);

            if (validRows.length === 0) {
                showNotification('No valid rows to save!', 'warning');
                return;
            }

            if (!confirm('Are you sure you want to save ' + validRows.length + ' valid records?')) {
                return;
            }

            showLoader('Saving valid records to database...');

            $.ajax({
                url: '/Planning/TragetExcelUpload/SaveData',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(validRows),
                success: function (response) {
                    hideLoader();
                    if (response.success) {
                        showNotification(response.message, 'success');
                        resetForm();
                    } else {
                        showNotification('Save Error: ' + response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showNotification('Save failed: ' + error, 'error');
                }
            });
        }

        function resetForm() {
            uploadedData = [];
            $('#excelFile').val('');
            $('#fileName').text('');
            $('#previewSection').slideUp();
            $('#dataTableBody').empty();
            $('#totalRows').text('0');
            $('#validRows').text('0');
            $('#invalidRows').text('0');
            $('#btnView').prop('disabled', true).hide();
            $('#btnSave').prop('disabled', true).hide();
            $('#btnReset').hide();
        }

        // ==================== TAB SWITCHING (PREVENT REDIRECT) ====================

        $('.nav-tabs a').click(function (e) {
            e.preventDefault();
            
            // Remove active from all tabs
            $('.nav-tabs li').removeClass('active');
            $('.tab-pane').removeClass('active');
            
            // Add active to clicked tab
            $(this).parent('li').addClass('active');
            
            // Show corresponding tab content
            var target = $(this).attr('href');
            $(target).addClass('active');

            // Load employee list when View Targets tab is opened
            if (target === '#viewTab') {
                loadEmployeeDropdown();
            }
        });

        // ==================== VIEW TAB FUNCTIONS ====================

        var employeeListLoaded = false;
        var selectedEmployeeCode = '';

        // Load employee dropdown when View Targets tab is opened
        if ($('#viewTab').hasClass('active')) {
            loadEmployeeDropdown();
        }

        // Populate employee dropdown
        function loadEmployeeDropdown() {
            if (employeeListLoaded) return;

            $.ajax({
                url: '/Planning/TragetExcelUpload/GetEmployeeFilterList',
                type: 'GET',
                data: { limit: 50 },
                success: function (response) {
                    if (response.success && response.data) {
                        var $dropdown = $('#empCodeDropdown');
                        $dropdown.empty();
                        $dropdown.append('<option value="">-- Select Employee --</option>');
                        
                        response.data.forEach(function (emp) {
                            var optionText = emp.EMPLOYEE_CODE + ' - ' + emp.EMPLOYEE_NAME;
                            var $option = $('<option></option>')
                                .val(emp.EMPLOYEE_CODE)
                                .text(optionText)
                                .data('name', emp.EMPLOYEE_NAME);
                            $dropdown.append($option);
                        });
                        
                        employeeListLoaded = true;
                    }
                },
                error: function (xhr, status, error) {
                    showNotification('Failed to load employee list: ' + error, 'error');
                }
            });
        }

        // Handle dropdown selection
        $('#empCodeDropdown').change(function () {
            selectedEmployeeCode = $(this).val();
        });

        // Load Targets Button Click
        $('#btnLoadTargets').click(function () {
            var empCode = selectedEmployeeCode || $('#empCodeDropdown').val();
            if (!empCode) {
                showNotification('Please select an employee', 'error');
                return;
            }
            loadEmployeeTargets(empCode);
        });

        // Enter key on employee search
        $('#empCodeDropdown').keypress(function (e) {
            if (e.which === 13) {
                $('#btnLoadTargets').click();
            }
        });

        function loadEmployeeTargets(empCode) {
            showLoader('Loading target data...');

            $.ajax({
                url: '/Planning/TragetExcelUpload/GetEmployeeData',
                type: 'GET',
                data: { empCode: empCode },
                success: function (response) {
                    hideLoader();
                    if (response.success) {
                        displayViewData(response.data, response.summary);
                        showNotification('Target data loaded successfully', 'success');
                    } else {
                        showNotification('Error: ' + response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showNotification('Failed to load target data: ' + error, 'error');
                }
            });
        }

        function displayViewData(data, summary) {
            // Update summary
            $('#viewTotalRows').text(summary.total);

            // Clear existing data
            $('#viewDataTableBody').empty();

            if (data.length === 0) {
                $('#viewResultsSection').slideDown();
                $('#viewDataTableBody').html('<tr><td colspan="11" style="text-align:center;padding:20px;color:#999;">No target data found for this employee</td></tr>');
                return;
            }

            // Populate table
            data.forEach(function (row, index) {
                var fromDate = row.FROM_DATE ? new Date(row.FROM_DATE).toLocaleDateString() : '';
                var toDate = row.TO_DATE ? new Date(row.TO_DATE).toLocaleDateString() : '';

                var tr = $('<tr></tr>');
                tr.append('<td>' + (index + 1) + '</td>');
                tr.append('<td>' + (row.TARGETID || '') + '</td>');
                tr.append('<td>' + fromDate + '</td>');
                tr.append('<td>' + toDate + '</td>');
                tr.append('<td>' + (row.EMP_CODE || '') + ' - ' + (row.EMP_NAME || '') + '</td>');
                tr.append('<td>' + (row.DISTRIBUTOR_CODE || '') + ' - ' + (row.DISTRIBUTOR_NAME || '') + '</td>');
                tr.append('<td>' + (row.ITEM_CODE || '') + ' - ' + (row.ITEM_NAME || '') + '</td>');
                tr.append('<td>' + (row.QTY || '') + '</td>');
                tr.append('<td>' + (row.PRICE || '') + '</td>');
                tr.append('<td>' + (row.BRANCH_CODE || '') + ' - ' + (row.BRANCH_NAME || '') + '</td>');
                tr.append('<td><button class="btn btn-danger btn-xs btn-delete-target" data-targetid="' + row.TARGETID + '"><i class="fa fa-trash"></i></button></td>');

                $('#viewDataTableBody').append(tr);
            });

            $('#viewResultsSection').slideDown();
        }

        // Delete button click handler (delegated)
        $(document).on('click', '.btn-delete-target', function () {
            var targetId = $(this).data('targetid');
            var $row = $(this).closest('tr');

            if (confirm('Are you sure you want to delete this target record (ID: ' + targetId + ')?')) {
                deleteTarget(targetId, $row);
            }
        });

        function deleteTarget(targetId, $row) {
            showLoader('Deleting target...');

            $.ajax({
                url: '/Planning/TragetExcelUpload/DeleteByTargetId',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ targetId: targetId }),
                success: function (response) {
                    hideLoader();
                    if (response.success) {
                        // Remove row from table
                        $row.fadeOut(300, function () {
                            $(this).remove();
                            // Update total count
                            var currentTotal = parseInt($('#viewTotalRows').text());
                            $('#viewTotalRows').text(currentTotal - 1);

                            // Check if table is empty
                            if ($('#viewDataTableBody tr').length === 0) {
                                $('#viewDataTableBody').html('<tr><td colspan="11" style="text-align:center;padding:20px;color:#999;">No target data found</td></tr>');
                            } else {
                                // Re-number rows
                                $('#viewDataTableBody tr').each(function (index) {
                                    $(this).find('td:first').text(index + 1);
                                });
                            }
                        });
                        showNotification('Target deleted successfully', 'success');
                    } else {
                        showNotification('Error: ' + response.message, 'error');
                    }
                },
                error: function (xhr, status, error) {
                    hideLoader();
                    showNotification('Delete failed: ' + error, 'error');
                }
            });
        }
    </script>
