                    <!-- Tab Content -->
                    <div class="tab-content">
                        <!-- Upload Tab -->
                        <div class="tab-pane active" id="uploadTab">
                            <!-- Upload Section -->
                            <div class="upload-section">
                                <div class="upload-area">
                                    <div class="row">
                                        <div class="col-md-8" style="padding:20px;">
                                            <p style="color: #6c757d; margin-bottom: 5px;">
                               Required columns: From Date , To Date, Employee, Distributor, Item Code, Quantity, Price , Branch
                                            </p>

                                            <div style="float:left;">
                                                <button type="button" class="btn btns-circle btn-default btn-sm " id="btnReset" style="display: none;">
                                                    <i class="fa fa-refresh"></i> Reset
                                                </button>
