                <style>
                    .btns-circle {
                        /* width: 30px; */
                        /* height: 30px; */
                        /* padding: 6px 0; */
                        border-radius: 15px;
                        text-align: center;
                        font-size: 12px;
                        line-height: 1.428571429;
