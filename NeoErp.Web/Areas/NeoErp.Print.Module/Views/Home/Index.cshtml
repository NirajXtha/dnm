            bindPatternFormEvents: function(patternId) {
                var self = this;
                var container = $('#pattern_' + patternId);
                
                // Add head field
                container.find('.add-head-field-btn').off('click').on('click', function() {
                    var tbody = container.find('.head-fields-table tbody');
                    tbody.find('.no-data-row').remove();
                    
                    var newRow = '<tr>';
                    newRow += '<td><input type="text" class="form-control head-label" placeholder="Label"></td>';
                    newRow += '<td><input type="text" class="form-control head-field" placeholder="Field"></td>';
                    newRow += '<td><input type="text" class="form-control head-default" placeholder="Default"></td>';
                    newRow += '<td><button type="button" class="btn btn-danger btn-sm remove-head-field-btn"><i class="fa fa-trash"></i></button></td>';
                    newRow += '</tr>';
                    tbody.append(newRow);
                    
                    // Rebind remove event
                    self.bindPatternFormEvents(patternId);
                });
                
                // Remove head field
                container.find('.remove-head-field-btn').off('click').on('click', function() {
                    var row = $(this).closest('tr');
                    row.remove();
                    
                    var tbody = container.find('.head-fields-table tbody');
                    if (tbody.find('tr').length === 0) {
                        tbody.html('<tr class="no-data-row"><td colspan="4" class="text-center text-muted" style="padding: 8px;">No head fields. Click "Add" to add.</td></tr>');
                    }
                });
                
                // Add footer field
                container.find('.add-footer-field-btn').off('click').on('click', function() {
                    var tbody = container.find('.footer-fields-table tbody');
                    tbody.find('.no-data-row').remove();
                    
                    var newRow = '<tr>';
                    newRow += '<td><input type="text" class="form-control footer-label" placeholder="Label"></td>';
                    newRow += '<td><input type="text" class="form-control footer-field" placeholder="Field"></td>';
                    newRow += '<td><textarea class="form-control footer-default" rows="2" placeholder="Default" style="resize: vertical;"></textarea></td>';
                    newRow += '<td><button type="button" class="btn btn-danger btn-sm remove-footer-field-btn"><i class="fa fa-trash"></i></button></td>';
                    newRow += '</tr>';
                    tbody.append(newRow);
                    
                    // Rebind remove event
                    self.bindPatternFormEvents(patternId);
                });
                
                // Remove footer field
                container.find('.remove-footer-field-btn').off('click').on('click', function() {
                    var row = $(this).closest('tr');
                    var tbody = row.closest('tbody');
                    row.remove();
                    
                    // If no more rows, add "no data" message
                    if (tbody.find('tr').length === 0) {
                        tbody.append('<tr class="no-data-row"><td colspan="4" class="text-center text-muted">No footer fields</td></tr>');
                    }
                });
                
                // Allow Enter key in footer textarea for line breaks
                container.find('.footer-default').off('keydown').on('keydown', function(e) {
                    // Allow Enter key to create new lines (prevent form submission)
                    if (e.keyCode === 13 || e.which === 13) {
                        e.stopPropagation();
                        // Don't prevent default - let the textarea handle the newline naturally
                    }
                });
                
                // Remove footer field - using event delegation on container (pattern-specific)
                container.on('click.deleteFooter', '.remove-footer-field', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    $(this).closest('tr').remove();
                    
                    // Show "no data" row if table is empty
                    var tbody = container.find('.footer-fields-table tbody');
                    if (tbody.find('tr').length === 0) {
                        tbody.html('<tr class="no-data-row"><td colspan="4" class="text-center text-muted" style="padding: 8px;">No footer fields. Click "Add" to add.</td></tr>');
                    }
                });
                
                // Remove head field - using event delegation on container (pattern-specific)
                container.on('click.deleteHead', '.remove-head-field', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    $(this).closest('tr').remove();
                    
                    // Show "no data" row if table is empty
                    var tbody = container.find('.head-fields-table tbody');
                    if (tbody.find('tr').length === 0) {
                        tbody.html('<tr class="no-data-row"><td colspan="4" class="text-center text-muted" style="padding: 8px;">No head fields. Click "Add" to add.</td></tr>');
                    }
                });
                
                // Add column field
                container.find('.add-column-field-btn').off('click').on('click', function() {
                    var tbody = container.find('.column-fields-table tbody');
                    tbody.find('.no-data-row').remove();
                    
                    var newRow = '<tr>';
                    newRow += '<td style="padding: 3px;"><input type="number" class="form-control input-sm column-sn" value="0" style="font-size: 11px; height: 24px;"></td>';
                    newRow += '<td style="padding: 3px;"><select class="form-control input-sm column-mc-flag" style="font-size: 11px; height: 24px;"><option value="M">Master</option><option value="C" selected>Child</option></select></td>';
                    newRow += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-label" style="font-size: 11px; height: 24px;"></td>';
                    newRow += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-field" style="font-size: 11px; height: 24px;"></td>';
                    newRow += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-default" style="font-size: 11px; height: 24px;"></td>';
                    newRow += '<td style="padding: 3px;"><input type="number" class="form-control input-sm column-width" value="30" style="font-size: 11px; height: 24px;"></td>';
                    newRow += '<td style="padding: 3px;"><button type="button" class="btn btn-danger btn-xs remove-column-field-btn" style="font-size: 11px;"><i class="fa fa-trash"></i></button></td>';
                    newRow += '</tr>';
                    tbody.append(newRow);
                });
                
                // Remove column field - handle BOTH class names (remove-column-field and remove-column-field-btn)
                container.on('click.deleteColumn', '.remove-column-field-btn, .remove-column-field', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    $(this).closest('tr').remove();
                    
                    // Show "no data" row if table is empty
                    var tbody = container.find('.column-fields-table tbody');
                    if (tbody.find('tr').length === 0) {
                        tbody.html('<tr class="no-data-row"><td colspan="7" class="text-center text-muted" style="padding: 8px;">No column fields. Click "Add" to add.</td></tr>');
                    }
                });
                
                // Save button
                container.find('.save-pattern-btn').off('click').on('click', function() {
                    var patternId = $(this).data('pattern-id');
                    self.savePattern(patternId);
                });
                
                // Auto from Form Setup button
                container.find('.auto-from-form-btn').off('click').on('click', function() {
                    var patternId = $(this).data('pattern-id');
                    var formCode = self.currentFormData.FORM_CODE || self.currentFormData.form_code;
                    
                    if (confirm('Do you want to auto-fill this pattern from Form Setup?\n\nThis will populate fields automatically based on the form configuration.')) {
                        self.autoFillFromFormSetup(formCode, patternId);
                    }
                });
                
                // Generate SQL button
                container.find('.generate-sql-btn').off('click').on('click', function() {
                    var patternId = $(this).data('pattern-id');
                    var formCode = self.currentFormData.FORM_CODE || self.currentFormData.form_code;
                    
                    self.generateSqlQuery(formCode, patternId);
                });
                
                // Preview button
                container.find('.preview-pattern-btn').off('click').on('click', function() {
                    var mainFieldValue = container.find('.main-field-value').val();
                    var formCode = self.currentFormData.FORM_CODE || self.currentFormData.form_code;
                    var companyCode = self.getCompanyCode();
                    var patternId = $(this).data('pattern-id');
                    
                    // Build URL: if mainFieldValue is empty, use activePatternId instead
                    var url = '/Print/Home/PreviewPattern?formCode=' + formCode + '&companyCode=' + companyCode;
                    
                    if (mainFieldValue) {
                        // If mainFieldValue is provided, add it to URL
                        url += '&mainFieldValue=' + encodeURIComponent(mainFieldValue);
                    } else {
                        // If mainFieldValue is empty, add activePatternId instead
                        url += '&activePatternId=' + patternId;
                    }
                    
                    window.open(url, '_blank');
                });
                
                // ===== MAKE MENU EVENT HANDLERS =====
                
                // Load menu modules first, then load linked menu info (if exists)
                self.loadMenuModules(container, function() {
                    // After modules are loaded, load linked menu info
                    self.loadLinkedMenuInfo(container);
                });
                
                // Menu module change event
                container.find('.menu-module').off('change').on('change', function() {
                    var moduleCode = $(this).val();
                    if (moduleCode) {
                        self.loadMenuGroups(container, moduleCode);
                    } else {
                        container.find('.menu-group').prop('disabled', true).html('<option value="">-- Select Group --</option>');
                        container.find('.menu-next-code').val('');
                    }
                });
                
                // Menu group change event
                container.find('.menu-group').off('change').on('change', function() {
                    var groupMenuNo = $(this).val();
                    var moduleCode = container.find('.menu-module').val();
                    
                    if (groupMenuNo && moduleCode) {
                        self.generateNextMenuCode(container, moduleCode, groupMenuNo);
                    } else {
                        container.find('.menu-next-code').val('');
                    }
                });
                
                // Save menu button
                container.find('.save-menu-btn').off('click').on('click', function() {
                    var patternId = container.find('.pattern-id-for-menu').val();
                    self.saveNewMenu(container, patternId);
                });
            },

            // ===== MENU MANAGEMENT FUNCTIONS =====
            
            loadLinkedMenuInfo: function(container) {
                var self = this;
                var menuNo = container.find('.linked-menu-display').data('menu-no');
                
                if (!menuNo) {
                    return;
                }
                
                $.ajax({
                    url: '/Print/Home/GetMenuInfo',
                    type: 'POST',
                    data: { menuNo: menuNo },
                    success: function(response) {
                        if (response.success && response.data) {
                            var menuData = response.data;
                            
                            // Update the read-only display field
                            container.find('.linked-menu-display').val(menuData.MENU_NO + ' - ' + menuData.MENU_EDESC);
                            
                            // Populate the Make Menu section fields
                            if (menuData.MODULE_CODE) {
                                // Set module dropdown
                                container.find('.menu-module').val(menuData.MODULE_CODE);
                                
                                // Load groups for this module, then set the group
                                self.loadMenuGroups(container, menuData.MODULE_CODE, function() {
                                    if (menuData.PRE_MENU_NO) {
                                        container.find('.menu-group').val(menuData.PRE_MENU_NO);
                                        
                                        // Set the EXISTING menu number (not next code) since we're editing
                                        container.find('.menu-next-code').val(menuData.MENU_NO);
                                    }
                                });
                            }
                            
                            // Populate other fields
                            container.find('.menu-edesc').val(menuData.MENU_EDESC || '');
                            container.find('.menu-object-name').val(menuData.MENU_OBJECT_NAME || '');
                            container.find('.menu-full-path').val(menuData.FULL_PATH || '');
                            container.find('.menu-virtual-path').val(menuData.VIRTUAL_PATH || '');
                        } else {
                            container.find('.linked-menu-display').val(menuNo + ' - (Menu not found)');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error loading menu info:', error);
                        container.find('.linked-menu-display').val(menuNo + ' - (Error loading)');
                    }
                });
            },
            
            loadMenuModules: function(container, callback) {
                var self = this;
                
                $.ajax({
                    url: '/Print/Home/GetMenuModules',
                    type: 'GET',
                    success: function(response) {
                        if (response.success) {
                            var dropdown = container.find('.menu-module');
                            dropdown.empty().append('<option value="">-- Select Module --</option>');
                            
                            $.each(response.data, function(index, module) {
                                dropdown.append($('<option></option>')
                                    .val(module.MODULE_CODE)
                                    .text(module.MODULE_CODE + ' - ' + module.MODULE_EDESC));
                            });
                            
                            // Call callback after modules are loaded
                            if (typeof callback === 'function') {
                                callback();
                            }
                        } else {
                            alert('Error loading modules: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error loading menu modules:', error);
                        alert('Failed to load menu modules');
                    }
                });
            },
            
            loadMenuGroups: function(container, moduleCode, callback) {
                var self = this;
                
                container.find('.menu-group').prop('disabled', true).html('<option value="">Loading...</option>');
                
                $.ajax({
                    url: '/Print/Home/GetMenuGroups',
                    type: 'POST',
                    data: { moduleCode: moduleCode },
                    success: function(response) {
                        if (response.success) {
                            var dropdown = container.find('.menu-group');
                            dropdown.empty().append('<option value="">-- Select Group --</option>');
                            
                            $.each(response.data, function(index, group) {
                                dropdown.append($('<option></option>')
                                    .val(group.MENU_NO)
                                    .text(group.MENU_NO + ' - ' + group.MENU_EDESC));
                            });
                            
                            dropdown.prop('disabled', false);
                            
                            // Call callback if provided
                            if (typeof callback === 'function') {
                                callback();
                            }
                        } else {
                            alert('Error loading groups: ' + response.message);
                            container.find('.menu-group').html('<option value="">-- Select Group --</option>');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error loading menu groups:', error);
                        alert('Failed to load menu groups');
                        container.find('.menu-group').prop('disabled', false).html('<option value="">-- Select Group --</option>');
                    }
                });
            },
            
            generateNextMenuCode: function(container, moduleCode, groupMenuNo) {
                var self = this;
                
                container.find('.menu-next-code').val('Generating...');
                
                $.ajax({
                    url: '/Print/Home/GetNextMenuCode',
                    type: 'POST',
                    data: { 
                        moduleCode: moduleCode,
                        groupMenuNo: groupMenuNo
                    },
                    success: function(response) {
                        if (response.success) {
                            container.find('.menu-next-code').val(response.nextMenuCode);
                        } else {
                            alert('Error generating menu code: ' + response.message);
                            container.find('.menu-next-code').val('');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error generating menu code:', error);
                        alert('Failed to generate menu code');
                        container.find('.menu-next-code').val('');
                    }
                });
            },
            
            saveNewMenu: function(container, patternId) {
                var self = this;
                
                // Collect form data
                var moduleCode = container.find('.menu-module').val();
                var groupMenuNo = container.find('.menu-group').val();
                var menuEdesc = container.find('.menu-edesc').val();
                var menuObjectName = container.find('.menu-object-name').val();
                var fullPath = container.find('.menu-full-path').val();
                var virtualPath = container.find('.menu-virtual-path').val();
                
                // Validation
                if (!moduleCode || !groupMenuNo || !menuEdesc) {
                    alert('Please select Module, Group, and enter Menu Description');
                    return;
                }
                
                // Show saving indicator
                var saveBtn = container.find('.save-menu-btn');
                var originalText = saveBtn.html();
                saveBtn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Saving...');
                
                $.ajax({
                    url: '/Print/Home/SaveNewMenu',
                    type: 'POST',
                    data: {
                        ModuleCode: moduleCode,
                        GroupMenuNo: groupMenuNo,
                        MenuEdesc: menuEdesc,
                        MenuObjectName: menuObjectName || '',
                        FullPath: fullPath || '',
                        VirtualPath: virtualPath || '',
                        PatternId: patternId || ''  // Backend uses this to check for existing menu
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Menu saved successfully!');
                            
                            // Get the saved menu code from hidden field
                            var savedMenuCode = container.find('.menu-next-code').val();
                            
                            // Update linked menu display and data attribute
                            if (patternId && savedMenuCode) {
                                container.find('.linked-menu-display')
                                    .val(savedMenuCode + ' - ' + menuEdesc)
                                    .data('menu-no', savedMenuCode);
                                
                                // Reload the menu info to show saved data in the form
                                self.loadLinkedMenuInfo(container);
                            } else {
                                // If no pattern ID, just clear the form for creating another menu
                                container.find('.menu-edesc').val('');
                                container.find('.menu-object-name').val('');
                                container.find('.menu-full-path').val('');
                                container.find('.menu-virtual-path').val('');
                                
                                // Generate next code for subsequent entries
                                self.generateNextMenuCode(container, moduleCode, groupMenuNo);
                            }
                        } else {
                            alert('Error: ' + response.message);
                        }
                        
                        // Restore button
                        saveBtn.prop('disabled', false).html(originalText);
                    },
                    error: function(xhr, status, error) {
                        console.error('Error saving menu:', error);
                        alert('Failed to save menu: ' + error);
                        
                        // Restore button
                        saveBtn.prop('disabled', false).html(originalText);
                    }
                });
            },

            autoFillFromFormSetup: function(formCode, patternId) {
                var self = this;
                
                console.log('=== autoFillFromFormSetup ===');
                console.log('Form Code:', formCode);
                console.log('Pattern ID:', patternId);
                
                $.ajax({
                    url: '/Print/Home/AutoFillPattern',
                    type: 'POST',
                    data: {
                        formCode: formCode,
                        patternId: patternId
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Pattern data fetched successfully! Populating form...');
                            
                            var container = $('#pattern_' + patternId);
                            
                            // Clear existing head fields table
                            container.find('.head-fields-table tbody').empty();
                            
                            // Populate head fields
                            if (response.headFields && response.headFields.length > 0) {
                                $.each(response.headFields, function(i, field) {
                                    var row = '<tr>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm head-label" value="' + (field.LABEL || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm head-field" value="' + (field.FIELD || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm head-default" value="' + (field.DEFAULT_VAL || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><button type="button" class="btn btn-danger btn-xs remove-head-field" style="font-size: 11px;"><i class="fa fa-trash"></i></button></td>';
                                    row += '</tr>';
                                    container.find('.head-fields-table tbody').append(row);
                                });
                            }
                            
                            // Clear existing footer fields table
                            container.find('.footer-fields-table tbody').empty();
                            
                            // Populate footer fields
                            if (response.footerFields && response.footerFields.length > 0) {
                                $.each(response.footerFields, function(i, field) {
                                    var row = '<tr>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm footer-label" value="' + (field.LABEL || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm footer-field" value="' + (field.FIELD || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style=\"padding: 3px;\"><textarea class=\"form-control input-sm footer-default\" rows=\"2\" style=\"font-size: 11px; resize: vertical;\">' + (field.DEFAULT_VAL || '') + '</textarea></td>';
                                    row += '<td style="padding: 3px;"><button type="button" class="btn btn-danger btn-xs remove-footer-field" style="font-size: 11px;"><i class="fa fa-trash"></i></button></td>';
                                    row += '</tr>';
                                    container.find('.footer-fields-table tbody').append(row);
                                });
                            }
                            
                            // Clear existing column fields table
                            container.find('.column-fields-table tbody').empty();
                            
                            // Populate column fields
                            if (response.columnFields && response.columnFields.length > 0) {
                                $.each(response.columnFields, function(i, field) {
                                    var row = '<tr>';
                                    row += '<td style="padding: 3px;"><input type="number" class="form-control input-sm column-sn" value="' + (field.SN || 0) + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><select class="form-control input-sm column-mc-flag" style="font-size: 11px; height: 24px;">';
                                    row += '<option value="M" ' + (field.MASTER_CHILD_FLAG === 'M' ? 'selected' : '') + '>Master</option>';
                                    row += '<option value="C" ' + (field.MASTER_CHILD_FLAG === 'C' ? 'selected' : '') + '>Child</option>';
                                    row += '</select></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-label" value="' + (field.LABEL || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-field" value="' + (field.FIELD || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="text" class="form-control input-sm column-default" value="' + (field.DEFAULT_VAL || '') + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><input type="number" class="form-control input-sm column-width" value="' + (field.WIDTH || 30) + '" style="font-size: 11px; height: 24px;"></td>';
                                    row += '<td style="padding: 3px;"><button type="button" class="btn btn-danger btn-xs remove-column-field" style="font-size: 11px;"><i class="fa fa-trash"></i></button></td>';
                                    row += '</tr>';
                                    container.find('.column-fields-table tbody').append(row);
                                });
                            }
                            
                            // Re-bind events for the new rows
                            self.bindPatternFormEvents(patternId);
                            
                            // Fetch and update only MAIN_FIELD and FORM_TYPE without reloading everything
                            $.ajax({
                                url: '/Print/Home/GetAllPatterns',
                                type: 'POST',
                                data: { 
                                    formCode: formCode,
                                    patternId: patternId
                                },
                                success: function (resp) {
                                    if (resp.success && resp.data && resp.data.PatternDetail) {
                                        // Update only MAIN_FIELD, FORM_TYPE, and ITEM_COUNT inputs
                                        container.find('.main-field').val(resp.data.PatternDetail.MAIN_FIELD || '');
                                        container.find('.form-type').val(resp.data.PatternDetail.FORM_TYPE || '');
                                        container.find('.item-count').val(resp.data.PatternDetail.ITEM_COUNT || '');
                                    }
                                }
                            });
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Error auto-filling pattern: ' + error);
                    }
                });
            },

            savePattern: function(patternId) {
                var self = this;
                var container = $('#pattern_' + patternId);
                
                console.log('=== savePattern ===');
                console.log('Pattern ID:', patternId);
                
                // Collect pattern details (property names must match C# model)
                var patternData = {
                    PATTERN_ID: patternId,
                    PATTERN_NAME: container.find('.pattern-name').val(),
                    FORM_CODE: self.currentFormData.FORM_CODE || self.currentFormData.form_code,
                    COMPANY_CODE: self.getCompanyCode(),
                    CHARGE_EXIST: container.find('.charge-exist-cb').is(':checked') ? 1 : 0,
                    SQL_QUERY: container.find('.sql-query').val(),
                    FILE_NAME: container.find('.file-name').val(),
                    FORM_TYPE: container.find('.form-type').val(),
                    ACTIVE: container.find('.active-cb').is(':checked') ? 1 : 0,
                    MAIN_FIELD: container.find('.main-field').val(),
                    ITEM_COUNT: parseInt(container.find('.item-count').val()) || 0
                };
                
                // Collect head fields
                var headFields = [];
                container.find('.head-fields-table tbody tr:not(.no-data-row)').each(function() {
                    var row = $(this);
                    headFields.push({
                        LABEL: row.find('.head-label').val(),
                        FIELD: row.find('.head-field').val(),
                        DEFAULT_VAL: row.find('.head-default').val()
                    });
                });
                
                // Collect footer fields
                var footerFields = [];
                container.find('.footer-fields-table tbody tr:not(.no-data-row)').each(function() {
                    var row = $(this);
                    footerFields.push({
                        LABEL: row.find('.footer-label').val(),
                        FIELD: row.find('.footer-field').val(),
                        DEFAULT_VAL: row.find('.footer-default').val()
                    });
                });
                
                console.log('Footer Fields Count:', footerFields.length);
                console.log('Footer Fields Data:', footerFields);
                
                // Collect column fields
                var columnFields = [];
                container.find('.column-fields-table tbody tr').not('.no-data-row').each(function() {
                    var row = $(this);
                    columnFields.push({
                        SN: parseInt(row.find('.column-sn').val()) || 0,
                        MASTER_CHILD_FLAG: row.find('.column-mc-flag').val(),
                        LABEL: row.find('.column-label').val(),
                        FIELD: row.find('.column-field').val(),
                        DEFAULT_VAL: row.find('.column-default').val(),
                        WIDTH: parseInt(row.find('.column-width').val()) || 0
                    });
                });
                
                var saveData = {
                    PatternDetail: patternData,
                    HeadFields: headFields,
                    FooterFields: footerFields,
                    ColumnFields: columnFields
                };
                
                console.log('Save Data:', saveData);
                
                // Call backend API
                $.ajax({
                    url: '/Print/Home/SavePattern',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(saveData),
                    success: function(response) {
                        if (response.success) {
                            alert('Pattern saved successfully!');
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Error saving pattern: ' + error);
                    }
                });
            },
            
            generateSqlQuery: function(formCode, patternId) {
                var self = this;
                
                console.log('=== generateSqlQuery ===');
                console.log('Form Code:', formCode);
                console.log('Pattern ID:', patternId);
                
                $.ajax({
                    url: '/Print/Home/GenerateSqlQuery',
