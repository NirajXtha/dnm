@{
    ViewBag.Title = "Print Setup";
}

<link href="~/Areas/NeoErp.Print.Module/Content/print-setup.css" rel="stylesheet" />

<h5>Report Setup</h5>

<div class="print-setup-container">
    <!-- Left Block -->
    <div class="print-setup-left">
        <div class="module-filter">
            <label for="moduleDropdown">Select Module:</label>
            <select id="moduleDropdown" class="form-control">
                <option value="">-- Select Module --</option>
            </select>
        </div>

        <h4>Report Groups</h4>
        <div class="tree-container" id="treeContainer">
            <div class="no-data">Please select a module</div>
        </div>
    </div>

    <!-- Right Block -->
    <div class="print-setup-right">
        <h4>Report List</h4>
        <div id="reportTableContainer">
            <table class="report-table">
                <thead>
                    <tr>
                        <th style="width: 100px;">Report No</th>
                        <th>Report Description</th>
                    </tr>
                </thead>
                <tbody id="reportTableBody">
                    <tr>
                        <td colspan="2" class="no-data">Select a group to view reports</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Print Configuration Modal -->
<div class="modal fade" id="printConfigModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    <i class="fa fa-print"></i> Report Configuration - <span id="modalFormEdesc"></span>
                </h4>
            </div>

            <div class="modal-body">
                <!-- Form Info -->
                <div class="form-info-panel" style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <strong>Form Code:</strong> <span id="modalFormCode"></span> |
                        <strong>Form Type:</strong> <span id="modalFormType"></span>
                    </div>
                    <button type="button" class="btn btn-success btn-sm" id="addPatternBtn" style="background: #46a930; border-color: #46a930;">
                        <i class="fa fa-plus"></i> Add Pattern
                    </button>
                </div>

                <!-- Pattern Tabs -->
                <ul class="nav nav-tabs" id="patternTabs" role="tablist">
                    <!-- Tabs will be dynamically generated -->
                </ul>

                <!-- Tab Content -->
                <div class="tab-content pattern-tab-content" id="patternTabContent" style="min-height: 500px; padding: 15px; margin-top: 10px;">
                    <!-- Tab panes will be dynamically generated -->
                </div>
            </div>



            
        </div>
    </div>
</div>

<!-- Add Pattern Modal -->
<div class="modal fade" id="addPatternModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background: #46a930; color: #fff;">
                <button type="button" class="close" data-dismiss="modal" style="color: #fff;">&times;</button>
                <h4 class="modal-title" style="color: #fff; font-size: 14px;">
                    <i class="fa fa-plus"></i> Add New Pattern
                </h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label style="font-size: 12px;">Pattern Name</label>
                    <input type="text" class="form-control input-sm" id="newPatternName" placeholder="Enter pattern name" style="font-size: 12px;">
                </div>
                <input type="hidden" id="newPatternFormCode">
                <input type="hidden" id="newPatternCompanyCode">
            </div>
            <div class="modal-footer" style="padding: 10px;">
                <button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success btn-sm" id="saveNewPatternBtn" style="background: #46a930; border-color: #46a930;">
                    <i class="fa fa-save"></i> Create Pattern
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        var printSetup = {
            currentModuleCode: '',
            reportGroups: [],

            init: function () {
                this.loadModules();
                this.bindEvents();
            },

            bindEvents: function () {
                var self = this;

                // Module dropdown change event
                $('#moduleDropdown').on('change', function () {
                    var moduleCode = $(this).val();
                    if (moduleCode) {
                        self.currentModuleCode = moduleCode;
                        self.loadReportGroups(moduleCode);
                    } else {
                        $('#treeContainer').html('<div class="no-data">Please select a module</div>');
                        self.clearReportTable();
                    }
                });
            },

            loadModules: function () {
                var self = this;
                $.ajax({
                    url: '@Url.Action("GetModules", "Home")',
                    type: 'GET',
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            self.populateModuleDropdown(response.data);
                        } else {
                            alert('Error loading modules: ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error loading modules:', error);
                        alert('Failed to load modules');
                    }
                });
            },

            populateModuleDropdown: function (modules) {
                var dropdown = $('#moduleDropdown');
                dropdown.empty().append('<option value="">-- Select Module --</option>');

                $.each(modules, function (index, module) {
                    dropdown.append($('<option></option>')
                        .val(module.MODULE_CODE)
                        .text(module.MODULE_CODE + ' - ' + module.MODULE_EDESC));
                });
            },

            loadReportGroups: function (moduleCode) {
                var self = this;
                $('#treeContainer').html('<div class="loading-spinner">Loading...</div>');

                $.ajax({
                    url: '@Url.Action("GetReportGroups", "Home")',
                    type: 'POST',
                    data: JSON.stringify({ moduleCode: moduleCode }),
                    contentType: 'application/json',
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            self.reportGroups = response.data;
                            self.buildTreeView(response.data);
                        } else {
                            $('#treeContainer').html('<div class="no-data">Error: ' + response.message + '</div>');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error loading report groups:', error);
                        $('#treeContainer').html('<div class="no-data">Failed to load report groups</div>');
                    }
                });
            },

            buildTreeView: function (groups) {
                var self = this;
                var container = $('#treeContainer');
                container.empty();

                if (!groups || groups.length === 0) {
                    container.html('<div class="no-data">No report groups found</div>');
                    return;
                }

                // Build hierarchical structure
                var tree = self.buildTreeStructure(groups);
                var treeHtml = self.renderTreeNodes(tree);
                container.html(treeHtml);

                // Bind click events on tree labels
                $('.tree-label').on('click', function (e) {
                    e.stopPropagation();
                    $('.tree-node').removeClass('selected');
                    $(this).closest('.tree-node').addClass('selected');

                    var masterCode = $(this).closest('.tree-node').data('master-form-code');
                    self.loadReportItems(masterCode);
                });

                // Bind toggle events
                $('.tree-toggle').on('click', function (e) {
                    e.stopPropagation();
                    var toggle = $(this);
                    var treeItem = toggle.closest('.tree-item');
                    var children = treeItem.find('> .tree-children');
                    
                    if (children.is(':visible')) {
                        children.hide();
                        toggle.text('+');
                    } else {
                        children.show();
                        toggle.text('-');
                    }
                });
            },

            buildTreeStructure: function (groups) {
                var tree = [];
                var lookup = {};

                // Create lookup
                $.each(groups, function (index, item) {
                    lookup[item.MASTER_FORM_CODE] = {
                        data: item,
                        children: []
                    };
                });

                // Build tree
                $.each(groups, function (index, item) {
                    if (item.PRE_FORM_CODE === '00') {
                        tree.push(lookup[item.MASTER_FORM_CODE]);
                    } else {
                        var parent = lookup[item.PRE_FORM_CODE];
                        if (parent) {
                            parent.children.push(lookup[item.MASTER_FORM_CODE]);
                        }
                    }
                });

                return tree;
            },

            renderTreeNodes: function (nodes, level) {
                level = level || 0;
                var html = '';

                $.each(nodes, function (index, node) {
                    var hasChildren = node.children && node.children.length > 0;
                    var toggleIcon = hasChildren ? '-' : '&nbsp;&nbsp;';
                    var nodeClass = level === 0 ? 'tree-node-group' : 'tree-node-child';

                    html += '<div class="tree-item">';
                    html += '<div class="tree-node ' + nodeClass + '" data-master-form-code="' + node.data.MASTER_FORM_CODE + '">';
                    html += '<span class="tree-toggle">' + toggleIcon + '</span>';
                    html += '<span class="tree-label">';
                    html += node.data.FORM_EDESC;
                    html += '</span>';
                    html += '</div>';

                    if (hasChildren) {
                        html += '<div class="tree-children">';
                        html += printSetup.renderTreeNodes(node.children, level + 1);
                        html += '</div>';
                    }
                    html += '</div>';
                });

                return html;
            },

            loadReportItems: function (masterReportCode) {
                var self = this;
                var tbody = $('#reportTableBody');
                tbody.html('<tr><td colspan="2" class="loading-spinner">Loading...</td></tr>');

                console.log('=== loadReportItems ===');
                console.log('Master Form Code:', masterReportCode);
                console.log('Module Code:', self.currentModuleCode);

                $.ajax({
                    url: '@Url.Action("GetReportItems", "Home")',
                    type: 'POST',
                    data: JSON.stringify({
                        moduleCode: self.currentModuleCode,
                        masterFormCode: masterReportCode
                    }),
                    contentType: 'application/json',
                    dataType: 'json',
                    success: function (response) {
                        console.log('GetReportItems response:', response);
                        if (response.success) {
                            console.log('Report items count:', response.data ? response.data.length : 0);
                            self.populateReportTable(response.data);
                        } else {
                            console.error('GetReportItems failed:', response.message);
                            tbody.html('<tr><td colspan="2" class="no-data">Error: ' + response.message + '</td></tr>');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error loading report items:', error);
                        console.error('Response:', xhr.responseText);
                        tbody.html('<tr><td colspan="2" class="no-data">Failed to load reports</td></tr>');
                    }
                });
            },


            populateReportTable: function (reports) {
                var self = this;
                var tbody = $('#reportTableBody');
                tbody.empty();

                if (!reports || reports.length === 0) {
                    tbody.html('<tr><td colspan="2" class="no-data">No reports found</td></tr>');
                    return;
                }

                $.each(reports, function (index, report) {
                    var row = $('<tr></tr>');
                    row.append($('<td></td>').text(report.FORM_CODE));
                    row.append($('<td></td>').text(report.FORM_EDESC));

                    // Store report data on the row
                    row.data('reportData', report);

                    row.on('click', function () {
                        tbody.find('tr').removeClass('selected');
                        $(this).addClass('selected');
                        
                        // Open print configuration modal
                        self.openPrintConfigModal(report);
                    });

                    tbody.append(row);
                });
            },

            clearReportTable: function () {
                $('#reportTableBody').html('<tr><td colspan="2" class="no-data">Select a group to view reports</td></tr>');
            },

            // ===== PRINT CONFIGURATION FUNCTIONS =====
            openPrintConfigModal: function (formData) {
                var self = this;
                
                console.log('=== openPrintConfigModal ===');
                console.log('Form data:', formData);
                
                self.currentFormData = formData;
                
                // Set modal header info
                $('#modalFormEdesc').text(formData.FORM_EDESC || formData.form_edesc);
                $('#modalFormCode').text(formData.FORM_CODE || formData.form_code);
                
                var formTypeMap = {
                    'OT': 'Others',
                    'CH': 'Cash',
                    'JV': 'Journal',
                    'BK': 'Bank',
                    'PV': 'Post Journal'
                };
                $('#modalFormType').text(formTypeMap[formData.FORM_TYPE || formData.form_type] || formData.FORM_TYPE || formData.form_type || '-');

                // Load configuration from database
                self.loadFormConfiguration(formData.FORM_CODE || formData.form_code);

                // Show modal
                $('#printConfigModal').modal('show');
                
                // Bind Add Pattern button
                $('#addPatternBtn').off('click').on('click', function() {
                    $('#newPatternFormCode').val(formData.FORM_CODE || formData.form_code);
                    $('#newPatternCompanyCode').val(self.getCompanyCode());
                    $('#newPatternName').val('');
                    $('#addPatternModal').modal('show');
                });
                
                // Bind Create Pattern button
                $('#saveNewPatternBtn').off('click').on('click', function() {
                    var patternName = $('#newPatternName').val().trim();
                    var formCode = $('#newPatternFormCode').val();
                    var companyCode = $('#newPatternCompanyCode').val();
                    
                    if (!patternName) {
                        alert('Please enter pattern name');
                        return;
                    }
                    
                    self.createNewPattern(patternName, formCode, companyCode);
                });
            },

            getCompanyCode: function() {
                // You can adjust this to get company code from your context
                return '01'; // Default company code
            },

            createNewPattern: function(patternName, formCode, companyCode) {
                var self = this;
                
                console.log('=== createNewPattern ===');
                console.log('Pattern Name:', patternName);
                console.log('Form Code:', formCode);
                console.log('Company Code:', companyCode);
                
                $.ajax({
                    url: '/Print/Home/AddPattern',
                    type: 'POST',
                    data: {
                        patternName: patternName,
                        formCode: formCode,
                        companyCode: companyCode
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Pattern created successfully!');
                            $('#addPatternModal').modal('hide');
                            // Reload patterns
                            self.loadFormConfiguration(formCode);
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Error creating pattern: ' + error);
                    }
                });
            },

            loadFormConfiguration: function (formCode, patternId) {
                var self = this;
                
                console.log('=== loadFormConfiguration START ===');
                console.log('Form Code:', formCode);
                console.log('Pattern ID:', patternId || 'default (first pattern)');
                
                $.ajax({
                    url: '/Print/Home/GetAllPatterns',
                    type: 'POST',
                    data: { 
                        formCode: formCode,
                        patternId: patternId || null
                    },
                    success: function (response) {
                        console.log('=== GetAllPatterns RESPONSE ===');
                        console.log('Success:', response.success);
                        
                        if (response.success && response.data) {

                            console.log('--- PATTERNS LIST ---');
                            console.log(response.data.Patterns);                            
                            console.log('--- PATTERN DETAIL ---');
                            console.log(response.data.PatternDetail);                            
                            console.log('--- HEAD FIELDS ---');
                            console.log(response.data.HeadFields);                            
                            console.log('--- COLUMN FIELDS ---');
                            console.log(response.data.ColumnFields);
                            
                            // Store for future use
                            self.currentPatternConfig = response.data;
                            
                            // Render pattern tabs
                            self.renderPatternTabs(response.data.Patterns);
                        } else {
                            console.error('No data returned or error:', response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('=== GetAllPatterns ERROR ===');
                        console.error('Status:', status);
                        console.error('Error:', error);
                        console.error('Response:', xhr.responseText);
                    }
                });
            },

            renderPatternTabs: function(patterns) {
                var self = this;
                
                if (!patterns || patterns.length === 0) {
                    $('#patternTabs').html('<li><a href="#">No patterns found</a></li>');
                    $('#patternTabContent').html('<div class="alert alert-warning">No patterns configured for this form.</div>');
                    return;
                }
                
                console.log('=== renderPatternTabs ===');
                console.log('Number of patterns:', patterns.length);
                
                var tabsHtml = '';
                var contentHtml = '';
                
                // Loop through patterns and create tabs
                $.each(patterns, function(index, pattern) {
                    var isActive = index === 0 ? 'active' : '';
                    var patternId = pattern.PATTERN_ID;
                    var patternName = pattern.PATTERN_NAME;
                    
                    console.log('Creating tab for:', patternName, '(ID:', patternId + ')');
                    
                    // Create tab
                    tabsHtml += '<li class="' + isActive + '">';
                    tabsHtml += '<a href="#pattern_' + patternId + '" data-toggle="tab" data-pattern-id="' + patternId + '">';
                    tabsHtml += patternName;
                    tabsHtml += '</a>';
                    tabsHtml += '</li>';
                    
                    // Create tab content placeholder
                    contentHtml += '<div class="tab-pane ' + isActive + '" id="pattern_' + patternId + '">';
                    contentHtml += '<div class="pattern-content">';
                    contentHtml += '<p>Loading pattern details...</p>';
                    contentHtml += '</div>';
                    contentHtml += '</div>';
                });
                
                // Update DOM
                $('#patternTabs').html(tabsHtml);
                $('#patternTabContent').html(contentHtml);
                
                console.log('Pattern tabs rendered successfully');
                console.log('Tab content HTML updated');
                
                // Bind click event to tabs
                $('#patternTabs a[data-toggle="tab"]').on('shown.bs.tab', function(e) {
                    var patternId = $(e.target).data('pattern-id');
                    var formCode = self.currentFormData.FORM_CODE || self.currentFormData.form_code;
                    
                    console.log('=== Tab switched to pattern ID:', patternId);
                    
                    // Call API to load pattern details
                    self.loadPatternDetail(formCode, patternId);
                });
                
                // Load first pattern details immediately (with small delay to ensure DOM is ready)
                if (patterns.length > 0) {
                    setTimeout(function() {
                        var formCode = self.currentFormData.FORM_CODE || self.currentFormData.form_code;
                        console.log('Loading first pattern details...');
                        self.loadPatternDetail(formCode, patterns[0].PATTERN_ID);
                    }, 100);
                }
            },

            loadPatternDetail: function(formCode, patternId) {
                var self = this;
                
                console.log('=== loadPatternDetail ===');
                console.log('Form Code:', formCode);
                console.log('Pattern ID:', patternId);
                
                $.ajax({
                    url: '/Print/Home/GetAllPatterns',
                    type: 'POST',
                    data: { 
                        formCode: formCode,
                        patternId: patternId
                    },
                    success: function (response) {
                        console.log('=== Pattern Detail Response ===');
                        
                        if (response.success && response.data) {
                            console.log('Pattern Detail:', response.data.PatternDetail);
                            console.log('Head Fields:', response.data.HeadFields);
                            console.log('Column Fields:', response.data.ColumnFields);
                            
                            // Update current pattern config
                            self.currentPatternConfig = response.data;
                            
                            // Render pattern content
                            self.renderPatternContent(patternId, response.data);
                        } else {
                            console.error('Failed to load pattern detail');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error loading pattern detail:', error);
                    }
                });
            },

            renderPatternContent: function(patternId, data) {
                var self = this;
                
                console.log('=== renderPatternContent for pattern ID:', patternId);
                
                var pattern = data.PatternDetail || {};
                var headFields = data.HeadFields || [];
                var columnFields = data.ColumnFields || [];
                
                // Build editable form with compact styling
                var html = '<div class="pattern-detail-panel" style="padding: 10px; font-size: 12px;">';
                
                // === PATTERN DETAILS === (Single Row - No title)
                html += '<div class="row" style="margin-bottom: 10px;">';
                
                // Pattern Name (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Pattern Name</label>';
                html += '<input type="text" class="form-control input-sm pattern-name" value="' + (pattern.PATTERN_NAME || '') + '" style="font-size: 12px; height: 24px;">';
                html += '</div>';
                html += '</div>';
                
                // Form Code (col-md-2)
                html += '<div class="col-md-2">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Form Code</label>';
                html += '<input type="text" class="form-control input-sm" value="' + (pattern.FORM_CODE || '') + '" readonly style="font-size: 12px; height: 24px;">';
                html += '</div>';
                html += '</div>';
                
                // Charge Exist checkbox (col-md-2)
                html += '<div class="col-md-2">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px; display: block;">&nbsp;</label>'; // Spacer to align with inputs
                html += '<div class="checkbox" style="margin-top: 0; margin-bottom: 0;">';
                html += '<label style="font-size: 11px;">';
                html += '<input type="checkbox" class="charge-exist-cb" ' + (pattern.CHARGE_EXIST ? 'checked' : '') + '> Charge Exist';
                html += '</label>';
                html += '</div>';
                html += '</div>';
                html += '</div>';
                
                // Active checkbox (col-md-2)
                html += '<div class="col-md-2">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px; display: block;">&nbsp;</label>'; // Spacer to align with inputs
                html += '<div class="checkbox" style="margin-top: 0; margin-bottom: 0;">';
                html += '<label style="font-size: 11px;">';
                html += '<input type="checkbox" class="active-cb" ' + (pattern.ACTIVE ? 'checked' : '') + '> Active';
                html += '</label>';
                html += '</div>';
                html += '</div>';
                html += '</div>';
                
                // Auto from Form Setup - Button (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px; display: block;">&nbsp;</label>'; // Spacer to align with inputs
                html += '<button type="button" class="btn btn-sm auto-from-form-btn" data-pattern-id="' + patternId + '" style="background: #46a930; color: #fff; font-size: 11px; height: 24px; line-height: 12px; padding: 5px 10px; border: none;">';
                html += '<i class="fa fa-magic"></i> Auto from Form Setup';
                html += '</button>';
                html += '</div>';
                html += '</div>';
                
                html += '</div>'; // end row
                
                // === NEW ROW for FILE_NAME, FORM_TYPE, MAIN_FIELD, and ITEM_COUNT ===
                html += '<div class="row" style="margin-bottom: 10px;">';
                
                // File Name (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">File Name</label>';
                html += '<input type="text" class="form-control input-sm file-name" value="' + (pattern.FILE_NAME || '') + '" style="font-size: 12px; height: 24px;">';
                html += '</div>';
                html += '</div>';
                
                // Form Type (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Form Type</label>';
                html += '<select class="form-control input-sm form-type" style="font-size: 12px; height: 24px;">';
                html += '<option value="">-- Select --</option>';
                html += '<option value="OT" ' + (pattern.FORM_TYPE === 'OT' ? 'selected' : '') + '>Others</option>';
                html += '<option value="JV" ' + (pattern.FORM_TYPE === 'JV' ? 'selected' : '') + '>Journal</option>';
                html += '</select>';
                html += '</div>';
                html += '</div>';
                
                // Main Field (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Main Field</label>';
                html += '<input type="text" class="form-control input-sm main-field" value="' + (pattern.MAIN_FIELD || '') + '" style="font-size: 12px; height: 24px;">';
                html += '</div>';
                html += '</div>';
                
                // Item Count (col-md-3)
                html += '<div class="col-md-3">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Item Count</label>';
                html += '<input type="number" class="form-control input-sm item-count" value="' + (pattern.ITEM_COUNT || '') + '" style="font-size: 12px; height: 24px;">';
                html += '</div>';
                html += '</div>';
                
                html += '</div>'; // end row

                // === ROW for Linked Menu (Read-only display) ===
                html += '<div class="row" style="margin-bottom: 10px;">';
                html += '<div class="col-md-6">';
                html += '<div class="form-group" style="margin-bottom: 0;">';
                html += '<label style="font-size: 11px; margin-bottom: 3px;">Linked Menu</label>';
