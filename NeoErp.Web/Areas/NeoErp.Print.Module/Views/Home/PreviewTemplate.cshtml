@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.FileName</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
        }
        .header h2 {
            margin: 5px 0;
        }
        .master-data {
            margin: 20px 0;
        }
        .master-row {
            display: flex;
            margin-bottom: 8px;
        }
        .master-label {
            font-weight: bold;
            width: 200px;
        }
        .master-value {
            flex: 1;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th {
            background-color: #f5f5f5;
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            font-weight: bold;
        }
        td {
            border: 1px solid #ddd;
            padding: 8px;
        }
        .print-btn {
            margin: 20px 0;
            padding: 10px 20px;
            background: #4CAF50;
            color: white;
            border: none;
            cursor: pointer;
        }
        .loading {
            text-align: center;
            padding: 40px;
            font-size: 18px;
            color: #666;
        }
        .error {
            background-color: #ffebee;
            padding: 20px;
            border-left: 4px solid #f44336;
            margin: 20px 0;
        }
        @@media print {
            .print-btn {
                display: none;
            }
        }
    </style>
</head>
<body>
    <button class='print-btn' onclick='window.print()'>Print</button>
    
    <div id="loading" class="loading">Loading preview data...</div>
    <div id="content" style="display: none;"></div>
    <div id="error" class="error" style="display: none;"></div>

    <script>
        // Get parameters from ViewBag
        const formCode = '@ViewBag.FormCode';
        const companyCode = '@ViewBag.CompanyCode';
        const mainFieldValue = '@ViewBag.MainFieldValue';

        console.log('=== Preview Page Debug ===');
        console.log('Form Code:', formCode);
        console.log('Company Code:', companyCode);
        console.log('Main Field Value:', mainFieldValue);

        // Call API to get preview data
        const apiUrl = '/Print/Home/GetPreviewDataApi?formCode=' + encodeURIComponent(formCode) +
                       '&companyCode=' + encodeURIComponent(companyCode) +
                       '&mainFieldValue=' + encodeURIComponent(mainFieldValue);

        console.log('API URL:', apiUrl);

        fetch(apiUrl)
            .then(response => response.json())
            .then(result => {
                document.getElementById('loading').style.display = 'none';

                if (result.success) {
                    console.log('=== Preview Data Received ===');
                    console.log('Data:', result.data);
                    
                    renderPreview(result.data);
                } else {
                    throw new Error(result.message || 'Failed to load preview data');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('loading').style.display = 'none';
                document.getElementById('error').style.display = 'block';
                document.getElementById('error').innerHTML = '<h3>Error Loading Preview</h3><p>' + error.message + '</p>';
            });

        function renderPreview(data) {
            const contentDiv = document.getElementById('content');
            let html = '';

            // Header - Head fields (company name, address, etc.)
            html += '<div class="header">';
            html += '<h1>' + (data.FileName || 'Document Preview') + '</h1>';

            if (data.HeadFields && data.HeadFields.length > 0) {
                data.HeadFields.forEach(headField => {
                    let value = headField.DEFAULT_VAL || '';

                    // Try to get value from query data
                    if (data.QueryData && data.QueryData.length > 0) {
                        const firstRow = data.QueryData[0];
                        const fieldKey = headField.FIELD.toUpperCase();

                        if (firstRow[fieldKey]) {
                            value = firstRow[fieldKey];
                        }
                    }

                    if (value) {
                        html += '<h3>' + escapeHtml(value) + '</h3>';
                    }
                });
            }

            html += '</div>';

            // Master fields (Invoice No, Date, Party Name, etc.)
            if (data.MasterFields && data.MasterFields.length > 0) {
                html += '<div class="master-data">';

                data.MasterFields.forEach(masterField => {
                    let value = masterField.DEFAULT_VAL || '';

                    // Try to get value from query data
                    if (data.QueryData && data.QueryData.length > 0) {
                        const firstRow = data.QueryData[0];
                        const fieldKey = masterField.FIELD.toUpperCase();

                        // For CODE fields, look for EDESC version first
                        if (fieldKey.endsWith('_CODE')) {
                            const edescKey = fieldKey.replace('_CODE', '_EDESC');
                            if (firstRow[edescKey]) {
                                value = firstRow[edescKey];
                            }
                        }

                        // If still empty, get the actual field value
                        if (!value && firstRow[fieldKey]) {
                            value = firstRow[fieldKey];
                        }
                    }

                    // Always show the label, even if value is empty
                    html += '<div class="master-row">';
                    html += '<div class="master-label">' + escapeHtml(masterField.LABEL || masterField.FIELD) + ':</div>';
                    html += '<div class="master-value">' + (value ? escapeHtml(value) : '&nbsp;') + '</div>';
                    html += '</div>';
                });

                html += '</div>';
            }

            // Child fields table (items/products)
            if (data.ChildFields && data.ChildFields.length > 0) {
                html += '<table><thead><tr>';

                data.ChildFields.forEach(childField => {
                    html += '<th>' + escapeHtml(childField.LABEL || childField.FIELD) + '</th>';
                });

                html += '</tr></thead><tbody>';

                // Add data rows
                if (data.QueryData && data.QueryData.length > 0) {
                    data.QueryData.forEach(row => {
                        html += '<tr>';

                        data.ChildFields.forEach(childField => {
                            const fieldKey = childField.FIELD.toUpperCase();
                            let value = childField.DEFAULT_VAL || '';

                            // For CODE fields, look for EDESC version first
                            if (fieldKey.endsWith('_CODE')) {
                                const edescKey = fieldKey.replace('_CODE', '_EDESC');
                                if (row[edescKey]) {
                                    value = row[edescKey];
                                }
                            }

                            // If still empty, get the actual field value
                            if (!value && row[fieldKey]) {
                                value = row[fieldKey];
                            }

                            html += '<td>' + (value ? escapeHtml(value) : '&nbsp;') + '</td>';
                        });

                        html += '</tr>';
                    });
                } else {
                    // Show empty row with message if no data
                    html += '<tr><td colspan="' + data.ChildFields.length + '" style="text-align:center;color:#999;">No data available</td></tr>';
                }

                html += '</tbody></table>';
            }

            contentDiv.innerHTML = html;
            contentDiv.style.display = 'block';
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
</body>
</html>
