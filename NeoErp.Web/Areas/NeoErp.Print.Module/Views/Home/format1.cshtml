        // Convert number to words (for AMOUNT_IN_WORDS)
        function numberToWords(num) {
            if (num === 0 || num === null || num === undefined) return 'Zero';
            
            const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
            
            function convertLessThanThousand(n) {
                if (n === 0) return '';
                
                let result = '';
                
                if (n >= 100) {
                    result += ones[Math.floor(n / 100)] + ' Hundred ';
                    n %= 100;
                }
                
                if (n >= 10 && n <= 19) {
                    result += teens[n - 10] + ' ';
                } else if (n >= 20 || n > 0) {
                    result += tens[Math.floor(n / 10)] + ' ';
                    n %= 10;
                    result += ones[n] + ' ';
                }
                
                return result.trim();
            }
            
            // Handle negative numbers
            let isNegative = false;
            if (num < 0) {
                isNegative = true;
                num = Math.abs(num);
            }
            
            // Split into integer and decimal parts
            const integerPart = Math.floor(num);
            const decimalPart = Math.round((num - integerPart) * 100);
            
            let result = '';
            
            if (integerPart === 0) {
                result = 'Zero';
            } else {
                const billion = Math.floor(integerPart / 1000000000);
                const million = Math.floor((integerPart % 1000000000) / 1000000);
                const thousand = Math.floor((integerPart % 1000000) / 1000);
                const remainder = integerPart % 1000;
                
                if (billion > 0) {
                    result += convertLessThanThousand(billion) + ' Billion ';
                }
                if (million > 0) {
                    result += convertLessThanThousand(million) + ' Million ';
                }
                if (thousand > 0) {
                    result += convertLessThanThousand(thousand) + ' Thousand ';
                }
                if (remainder > 0) {
                    result += convertLessThanThousand(remainder);
                }
            }
            
            result = result.trim();
            
            // Add decimal part
            if (decimalPart > 0) {
                result += ' and ' + convertLessThanThousand(decimalPart) + ' Paisa';
            }
            
            if (isNegative) {
                result = 'Negative ' + result;
            }
            
            return result + ' Only';
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Convert English date to Nepali date (BS)
        function convertToNepaliDate(englishDateStr) {
            try {
                // Parse the English date
                const date = new Date(englishDateStr);
                if (isNaN(date.getTime())) {
                    return ''; // Invalid date
                }

                // Calculate approximate Nepali date (this is simplified)
                const year = date.getFullYear();
                const month = date.getMonth() + 1;
                const day = date.getDate();

                // Rough conversion: Add 56-57 years for Nepali year
                let nepYear = year + 56;
                let nepMonth = month + 8;
                let nepDay = day + 16;

                // Adjust for month overflow
                if (nepMonth > 12) {
                    nepMonth -= 12;
                    nepYear += 1;
                }

                // Adjust for day overflow (simplified - assumes 30 days per month)
                if (nepDay > 30) {
                    nepDay -= 30;
                    nepMonth += 1;
                    if (nepMonth > 12) {
                        nepMonth = 1;
                        nepYear += 1;
                    }
                }

                // Format as YYYY-MM-DD
                return nepYear + '-' + String(nepMonth).padStart(2, '0') + '-' + String(nepDay).padStart(2, '0');
            } catch (e) {
                return '';
            }
        }

        // Format number with commas and 2 decimal places
        function formatNumber(value) {
            if (value === undefined || value === null || value === '') return '';
            const num = parseFloat(value);
            if (isNaN(num)) return value;
            return num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // Check if a value is a date and format it with Nepali date
        function formatDateValue(value, fieldName) {
            // Check if this is likely a date field
            if (!fieldName || !fieldName.toUpperCase().includes('DATE')) {
                return escapeHtml(value);
            }

            try {
                // Try to parse as date
                const dateStr = String(value);
                const date = new Date(dateStr);

                if (isNaN(date.getTime())) {
                    return escapeHtml(value);
                }

                // Get Nepali date
                const nepDate = convertToNepaliDate(dateStr);

                if (nepDate) {
                    return escapeHtml(value) + '/' + escapeHtml(nepDate);
                }

                return escapeHtml(value);
            } catch (e) {
                return escapeHtml(value);
            }
        }


        // Load preview data immediately (always)
        console.log('📊 Loading preview data...');
        loadPreview();
        
        // Initialize filters in background (only if placeholders exist)
        console.log('🔧 Initializing filters in background...');
        initializeFilters();
        
        // Handle print with print count tracking
        async function handlePrint() {
            console.log('🖨️ Print button clicked');
            
            // Only call PrintCount API if print count flag is true
            if (printCountFlag) {
                console.log('✅ Print count tracking enabled');
                try {
                    // Call the PrintCount API
                    const printCountUrl = '/Print/Home/PrintCount?formCode=' + encodeURIComponent(formCode) +
                        '&mainFieldValue=' + encodeURIComponent(mainFieldValue);
                    
                    console.log('📡 Calling PrintCount API:', printCountUrl);
                    
                    const response = await fetch(printCountUrl);
                    const result = await response.json();
                    
                    if (result.success) {
                        console.log('✅ Print count updated successfully. New count:', result.printCount);
                    } else {
                        console.warn('⚠️ PrintCount API failed:', result.message);
                        // Continue with print even if count update fails
                    }
                } catch (error) {
                    console.error('❌ Error calling PrintCount API:', error);
                    // Continue with print even if API call fails
                }
                
                // Set up one-time event listener to refresh page after printing
                const afterPrintHandler = function() {
                    console.log('🔄 Printing completed - refreshing page to load updated count...');
                    window.removeEventListener('afterprint', afterPrintHandler);
                    window.location.reload();
                };
                
                window.addEventListener('afterprint', afterPrintHandler);
            } else {
                console.log('ℹ️ Print count tracking disabled - skipping API call');
            }
            
            // Always proceed with printing regardless of API result
            console.log('🖨️ Initiating print...');
            window.print();
        }
    </script>
</body>
</html>
