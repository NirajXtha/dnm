                        }
                        
                        const end = Math.min(currentIdx + chunkSize, totalItems);
                        pages.push({ start: currentIdx, end: end, isLast: false });
                        currentIdx = end;
                    }
                }
                
                // Edge case handling (if logic above failed to produce a last page for some reason)
                if (pages.length > 0 && !pages[pages.length - 1].isLast) {
                     // If we are here, it means we have items on previous pages but need a footer page.
