                        currentIdx = totalItems;
                    } else {
                        // Must be a Non-Last Page
                        let chunkSize = limitNonLast;
                        
                        // CRITICAL: Ensure we don't leave 0 items for the last page
                        // If the currently proposed chunk would consume ALL remaining items,
