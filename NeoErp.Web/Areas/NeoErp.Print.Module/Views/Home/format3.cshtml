@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.FileName</title>
    <style>
        /* [AWESOME PROFESSIONAL DESIGN - FORMAT 3] */
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&family=JetBrains+Mono:wght@400;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', 'Segoe UI', sans-serif; /* Modern font choice */
            font-size: 9pt;
            background: #f4f6f8; /* Light gray background for screen, white for print */
            color: #334155; /* Slate 700 text color */
            line-height: 1.4;
            display: flex;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* Filter Sidebar (Standard) */
        .filter-sidebar {
            width: 320px;
            background: #fff;
            border-right: 1px solid #e2e8f0;
            padding: 20px;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 100;
        }
        
         .filter-sidebar h4 { font-size: 14px; font-weight: 600; margin-bottom: 15px; color: #1e293b; }
         .filter-item { margin-bottom: 20px; }
         .filter-item label { display: block; font-size: 11px; font-weight: 500; color: #64748b; margin-bottom: 5px; }
         .filter-input { width: 100%; padding: 8px 10px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 12px; }
         .autocomplete-dropdown { position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #e2e8f0; max-height: 250px; overflow-y: auto; z-index: 1000; display: none; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-radius: 6px; margin-top: 4px; }
         .autocomplete-dropdown.show { display: block; }
         .autocomplete-item { padding: 8px 12px; cursor: pointer; font-size: 11px; border-bottom: 1px solid #f1f5f9; }
         .autocomplete-item:hover { background: #f8fafc; }
         .autocomplete-item.group { background: #e0f2fe; font-weight: 600; color: #0284c7; }
         .filter-btn { width: 100%; padding: 10px; background: #0f172a; color: white; border: none; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; margin-top: 10px; transition: all 0.2s; }
         .filter-btn:hover { background: #1e293b; }

        /* Main Wrapper */
        .content-wrapper {
            margin-left: 320px;
            flex: 1;
            padding: 10px; /* Reduced from 20px */
            display: flex;
            justify-content: center;
        }

        /* Page Container (The Invoice Sheet) */
        .page {
            width: 210mm;
            min-height: 297mm;
            background: white;
            padding: 8mm 15mm; /* Reduced padding (Top 8mm) */
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            position: relative;
            margin-bottom: 20px;
        }

        /* ----- AWESOME HEADER DESIGN ----- */
        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            border-bottom: 2px solid #0f172a; /* Strong dark border */
            padding-bottom: 15px;
        }

        .header-brand {
            flex: 1;
        }

        .brand-logo {
            height: 50px;
            object-fit: contain;
            margin-bottom: 8px;
            display: block;
        }

        .company-title {
            font-size: 16pt;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .company-details {
            font-size: 8pt;
            color: #64748b;
            line-height: 1.4;
        }

        .header-meta {
            text-align: right;
        }

        .invoice-tag {
            font-size: 24pt;
            font-weight: 800;
            color: #cbd5e1; /* Subtle "Watermark" style text */
            text-transform: uppercase;
            letter-spacing: 2px;
            line-height: 1;
        }

        .copy-badge {
            display: inline-block;
            background: #f1f5f9;
            color: #475569;
            font-size: 7.5pt;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 5px;
        }

        /* ----- INFO GRID (Master Data) ----- */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .info-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px;
        }

        .info-box-title {
            font-size: 7.5pt;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 4px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            font-size: 8.5pt;
            margin-bottom: 3px;
        }

        .info-label {
            color: #64748b;
            font-weight: 500;
        }

        .info-value {
            color: #0f172a; /* Dark bold text */
            font-weight: 600;
            text-align: right;
        }

        /* ----- TABLE AWESOMENESS ----- */
        .table-container {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: separate; /* Required for border-radius */
            border-spacing: 0;
        }

        th {
            background: #0f172a; /* Dark Header */
            color: white;
            font-size: 8pt;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 8px 10px;
            text-align: left;
        }
        
        /* Rounded corners for header */
        th:first-child { border-top-left-radius: 6px; }
        th:last-child { border-top-right-radius: 6px; }

        td {
            padding: 8px 10px;
            font-size: 8.5pt;
            color: #334155;
            border-bottom: 1px solid #e2e8f0;
        }
        
        tr:last-child td { border-bottom: 2px solid #0f172a; } /* Strong finish line */
        
        /* Alternating row color */
        tbody tr:nth-child(even) { background-color: #f8fafc; }
        
        td[style*="text-align:right"] {
            font-family: 'JetBrains Mono', monospace; /* Monospace for numbers */
            font-size: 8pt;
        }

        /* ----- FOOTER SUMMARY ----- */
        .footer-summary {
            display: flex;
            justify-content: flex-end;
            margin-top: 10px;
        }

        .summary-box {
            width: 40%;
            background: #fff;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 4px 10px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 8.5pt;
        }

        .summary-row.total {
            background: #0f172a;
            color: white;
            border-radius: 4px;
            padding: 8px 10px;
            margin-top: 5px;
            font-weight: 700;
        }

        /* Terms / Amount In Words */
        .bottom-meta {
            margin-top: 20px;
            font-size: 8pt;
            color: #64748b;
            border-top: 1px dashed #cbd5e1;
            padding-top: 10px;
        }

        .amount-words {
            font-style: italic;
            color: #0f172a;
            font-weight: 600;
        }

        /* Print Button */
        .print-btn {
            position: fixed; top: 20px; right: 20px; padding: 12px 24px;
            background: #0f172a; color: white; border: none; border-radius: 8px;
            font-weight: 600; cursor: pointer; z-index: 1000;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.2);
            font-family: 'Outfit', sans-serif;
        }
        .print-btn:hover { background: #1e293b; transform: translateY(-1px); }

        /* PRINT MEDIA QUERY */
        @@media print {
            .filter-sidebar, .print-btn { display: none !important; }
            .content-wrapper { display: block !important; margin: 0 !important; padding: 0 !important; }
            
            /* Remove fixed height to prevent overflow/extra pages */
            .page { 
                width: 100% !important; 
                box-shadow: none !important; 
                margin: 0 !important; 
                padding: 8mm 15mm !important; /* Keep padding for content spacing */
                min-height: 0 !important; 
                height: auto !important; 
                border: none !important;
            }
            
            body { 
                background: white !important; 
                display: block !important; /* Disable flex in print */
                margin: 0 !important;
                padding: 0 !important;
                min-height: 0 !important;
                height: auto !important;
                overflow: visible !important;
                -webkit-print-color-adjust: exact; 
                print-color-adjust: exact; 
            }
            
            /* Ensure page breaks work and don't create extra space */
            .page-break, div[style*="page-break-before:always"], div[style*="page-break-before: always"] {
                page-break-before: always !important;
                height: 0;
                margin: 0;
                padding: 0;
            }

            /* Ensure colors print correctly */
            th { background-color: #0f172a !important; color: white !important; }
            .info-box { background-color: #f8fafc !important; border: 1px solid #cbd5e1 !important; }
            tbody tr:nth-child(even) { background-color: #f8fafc !important; }
        }
    </style>
</head>
<body>
    <!-- Filter Sidebar -->
    <div class="filter-sidebar">
        <h4>Filters</h4>
        <div id="filterContainer"></div>
        <button class="filter-btn" onclick="applyFilters()">Apply Filters</button>
    </div>

    <!-- Main Content -->
    <div class="content-wrapper">
        <button class='print-btn' onclick='handlePrint()'>Print Invoice</button>

        <div class="page">
            <div id="loading" class="loading">Generating Awesome Invoice...</div>
            <div id="content" style="display: none;"></div>
            <div id="error" class="error" style="display: none;"></div>
        </div>
    </div>

    <script>
        // Use standard logic from Format1
        const formCode = '@ViewBag.FormCode';
        const companyCode = '@ViewBag.CompanyCode';
        const mainFieldValue = '@ViewBag.MainFieldValue';
        const activePatternId = parseInt('@ViewBag.ActivePatternId') || 0;

        let sqlQuery = '';
        let filterState = {};
        let debounceTimers = {};
        let printCountFlag = false;

        function debounce(func, delay) {
            return function(...args) {
                const context = this;
                clearTimeout(debounceTimers[args[0]]);
                debounceTimers[args[0]] = setTimeout(() => func.apply(context, args), delay);
            };
        }

        // Initialize (Standard)
        async function initializeFilters() {
             try {
                const patternResponse = await fetch(`/Print/Home/GetAllPatterns?formCode=${formCode}&patternId=${activePatternId || ''}`, { method: 'POST' });
                const patternData = await patternResponse.json();
                
                if (patternData.success && patternData.data && patternData.data.PatternDetail) {
                    sqlQuery = patternData.data.PatternDetail.SQL_QUERY || '';
                    const placeholderResponse = await fetch(`/Print/Home/GetQueryPlaceholders?sqlQuery=${encodeURIComponent(sqlQuery)}`);
                    const placeholderData = await placeholderResponse.json();
                    
                    if (placeholderData.success && placeholderData.placeholders && placeholderData.placeholders.length > 0) {
                        renderFilters(placeholderData.placeholders);
                    }
                }
            } catch (error) { console.error('Init Error', error); }
        }

        function renderFilters(placeholders) {
            const container = document.getElementById('filterContainer');
            container.innerHTML = '';
            placeholders.forEach(placeholder => {
                const filterItem = document.createElement('div');
                filterItem.className = 'filter-item';
                const label = document.createElement('label');
                label.textContent = placeholder.Field.replace(/_/g, ' ');
                
                const autocompleteContainer = document.createElement('div');
                autocompleteContainer.className = 'autocomplete-container';
                autocompleteContainer.style.position = 'relative';

                const input = document.createElement('input');
                input.className = 'filter-input';
                input.placeholder = 'Search...';
                input.dataset.field = placeholder.Field;
                input.dataset.entityType = placeholder.EntityType;

                const dropdown = document.createElement('div');
                dropdown.className = 'autocomplete-dropdown';
                dropdown.id = `dropdown-${placeholder.Field}`;

                input.addEventListener('input', debounce((e) => handleAutocomplete(e.target), 300));
                input.addEventListener('focus', (e) => { if (e.target.value) handleAutocomplete(e.target); });

                autocompleteContainer.append(input, dropdown);
                filterItem.append(label, autocompleteContainer);
                container.appendChild(filterItem);
            });
        }

        async function handleAutocomplete(input) {
            const dropdown = document.getElementById(`dropdown-${input.dataset.field}`);
            const searchTerm = input.value.trim();
            if (!searchTerm) { dropdown.classList.remove('show'); return; }
            
            dropdown.innerHTML = '<div class="autocomplete-loading">...</div>';
            dropdown.classList.add('show');
            
            try {
                const url = `/Print/Home/SearchEntity?entityType=${input.dataset.entityType}&searchTerm=${encodeURIComponent(searchTerm)}&pageNumber=1&pageSize=100`;
                const response = await fetch(url);
                const data = await response.json();
                
                if (data.success && data.data && data.data.length > 0) {
                    renderAutocompleteResults(dropdown, data.data, input.dataset.field);
                } else { dropdown.innerHTML = '<div class="autocomplete-item">No results</div>'; }
            } catch (e) { dropdown.innerHTML = '<div class="autocomplete-item">Error</div>'; }
        }

        function renderAutocompleteResults(dropdown, items, field) {
            dropdown.innerHTML = '';
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = 'autocomplete-item' + (item.IsGroup ? ' group' : '');
                div.textContent = `${item.Code} - ${item.Description}`;
                div.addEventListener('click', async () => {
                    const input = document.querySelector(`input[data-field="${field}"]`);
                    input.value = `${item.Code} - ${item.Description}`;
                     // Simplified Group logic restoration from original
                     if (item.IsGroup) {
                        try {
                            const resp = await fetch(`/Print/Home/GetEntityChildren?entityType=${input.dataset.entityType}&masterCode=${encodeURIComponent(item.MasterCode)}`);
                            const d = await resp.json();
                            if(d.success) filterState[field] = { code: '', codes: d.codes, isGroup: true };
                        } catch(e) {}
                     } else {
                         filterState[field] = { code: item.Code, codes: [], isGroup: false };
                     }
                    dropdown.classList.remove('show');
                });
                dropdown.appendChild(div);
            });
        }

        function applyFilters() { loadPreview(); }

        function loadPreview() {
            const filters = JSON.stringify(filterState);
            const apiUrl = `/Print/Home/GetPreviewDataApi?formCode=${encodeURIComponent(formCode)}&companyCode=${encodeURIComponent(companyCode)}&mainFieldValue=${encodeURIComponent(mainFieldValue)}&activePatternId=${encodeURIComponent(activePatternId)}&filters=${encodeURIComponent(filters)}`;

            fetch(apiUrl).then(r => r.json()).then(result => {
                document.getElementById('loading').style.display = 'none';
                if (result.success) renderPreview(result.data);
                else document.getElementById('error').textContent = result.message;
            }).catch(e => console.error(e));
        }

        // ==========================================
        //        AWESOME RENDER LOGIC
        // ==========================================
        
        function renderPreview(data) {
            const contentDiv = document.getElementById('content');
            printCountFlag = data.PRINT_COUNT_FLAG || false;
            const itemsPerPage = data.ITEM_COUNT || 15;
            const totalItems = (data.QueryData && data.QueryData.length) || 0;
            
            // Re-use logic for pages
            const pages = [];
            let currentIdx = 0;
            const limitLast = itemsPerPage; 
            const limitNonLast = itemsPerPage + 10; 

            if (totalItems === 0) pages.push({ start: 0, end: 0, isLast: true });
            else {
                while (currentIdx < totalItems) {
                    const remaining = totalItems - currentIdx;
                    if (remaining <= limitLast) {
                        pages.push({ start: currentIdx, end: totalItems, isLast: true });
                        currentIdx = totalItems;
                    } else {
                        let chunkSize = limitNonLast;
                        if (chunkSize >= remaining) chunkSize = remaining - 1;
                        const end = Math.min(currentIdx + chunkSize, totalItems);
                        pages.push({ start: currentIdx, end: end, isLast: false });
                        currentIdx = end;
                    }
                }
                 if (pages.length > 0 && !pages[pages.length - 1].isLast) pages.push({ start: totalItems, end: totalItems, isLast: true });
            }

            let html = '';
            
            // --- NEW RENDER HEADER (MODERN) ---
            const renderAwesomeHeader = (copyIndex) => {
                let h = '<div class="header-container">';
                
                // LEFT: Logo & Company
                h += '<div class="header-brand">';
                h += '<img src="/Areas/NeoErp.Print.Module/Content/logo.png" class="brand-logo" alt="Logo" />';
                
                if (data.HeadFields) {
                    data.HeadFields.forEach(f => {
                         let val = f.DEFAULT_VAL;
                         if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0][f.FIELD.toUpperCase()];
                         if (val) {
                             if (f.FIELD.toUpperCase() === 'COMPANY_CODE') 
                                h += `<div class="company-title">${formatDateValue(val, f.FIELD)}</div>`;
                             else 
                                h += `<div class="company-details">${formatDateValue(val, f.FIELD)}</div>`;
                         }
                    });
                }
                h += '</div>';

                // RIGHT: Invoice Meta & Label
                h += '<div class="header-meta">';
                
                let mainTitle = 'INVOICE';
                let subLabel = '';

                 // ORIGINAL LOGIC PRESERVED
                if (data.PRINT_COUNT_FLAG) {
                    const printCount = data.PRINT_COUNT || 0;
                    if (printCount === 1) {
                         // First print
                        if (copyIndex === 0) { mainTitle = 'TAX INVOICE'; subLabel = 'CUSTOMER COPY'; }
                        else { mainTitle = 'INVOICE'; subLabel = 'OFFICE COPY'; }
                    } else {
                        // Resubmission
                        const copyNum = (printCount > 1) ? (printCount - 1) : printCount; 
                        subLabel = `COPY OF ORIGINAL(${copyNum})`;
                    }
                }

                h += `<div class="invoice-tag">${mainTitle}</div>`;
                if (subLabel) h += `<div class="copy-badge">${subLabel}</div>`;
                h += '</div>'; // End Right

                h += '</div>'; // End Header Container
                return h;
            };

            // --- NEW INFO GRID ---
            const renderInfoGrid = () => {
                if (!data.MasterFields || data.MasterFields.length === 0) return '';
                
                // Split fields into Left Box and Right Box
                const mid = Math.ceil(data.MasterFields.length / 2);
                const leftFields = data.MasterFields.slice(0, mid);
                const rightFields = data.MasterFields.slice(mid);
                
                let h = '<div class="info-grid">';
                
                // Function to render a box
                const renderBox = (title, fields) => {
                    let b = `<div class="info-box"><div class="info-box-title">${title}</div>`;
                    fields.forEach(f => {
                        let val = f.DEFAULT_VAL;
                        if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0][f.FIELD.toUpperCase()];
                        b += `<div class="info-row"><span class="info-label">${escapeHtml(f.LABEL || f.FIELD)}</span><span class="info-value">${val ? formatDateValue(val, f.FIELD) : '-'}</span></div>`;
                    });
                    b += '</div>';
                    return b;
                };

                h += renderBox('BILL TO / DETAILS', leftFields);
                h += renderBox('ADDITIONAL INFO', rightFields);
                h += '</div>';
                return h;
            };

            const numCopies = (data.PRINT_COUNT == 1 && data.PRINT_COUNT_FLAG) ? 3 : 1;

            for (let copyIndex = 0; copyIndex < numCopies; copyIndex++) {
                if (copyIndex > 0) html += '<div style="page-break-before:always;"></div>';

                if (data.ChildFields && data.ChildFields.length > 0 && data.QueryData) {
                    for (let pageIdx = 0; pageIdx < pages.length; pageIdx++) {
                        const pageInfo = pages[pageIdx];
                        if (pageIdx > 0) html += '<div style="page-break-before:always;"></div>';
                        
                        // Header & Info
                        html += renderAwesomeHeader(copyIndex);
                        html += renderInfoGrid();

                        // Table
                        html += '<div class="table-container"><table><thead><tr>';
                        html += '<th style="width:40px;text-align:center;">#</th>';
                        data.ChildFields.forEach(f => {
                             // Clean headers: remove underscores
                             html += `<th>${escapeHtml((f.LABEL || f.FIELD).replace(/_/g, ' '))}</th>`;
                        });
                        html += '</tr></thead><tbody>';

                        // Rows
                        for (let i = pageInfo.start; i < pageInfo.end; i++) {
                            const row = data.QueryData[i];
                            html += `<tr><td style="text-align:center;">${i + 1}</td>`;
                            
                            data.ChildFields.forEach(f => {
                                const key = f.FIELD.toUpperCase();
                                let val = f.DEFAULT_VAL;
                                if (!val && row[key] !== undefined) val = row[key];
                                
                                const isNum = ['PRICE','AMOUNT','TOTAL','QTY','RATE'].some(k => key.includes(k));
                                const align = isNum ? 'text-align:right;' : '';
                                
                                html += `<td style="${align}">${isNum ? formatNumber(val) : formatDateValue(val, f.FIELD)}</td>`;
                            });
                            html += '</tr>';
                        }
                        
                         // Empty filler rows
                        if (pageInfo.isLast) {
                            const filled = pageInfo.end - pageInfo.start;
                            const needed = itemsPerPage - filled;
                            for(let k=0; k<needed; k++) {
                                html += '<tr><td>&nbsp;</td>';
                                data.ChildFields.forEach(() => html += '<td></td>');
                                html += '</tr>';
                            }
                        }

                        html += '</tbody></table></div>'; // Close Table

                        // Footer
                        if (pageInfo.isLast) {
                            html += '<div class="footer-summary">';
                            html += '<div class="summary-box">';
                            
                            // Calculate Totals logic (same as before)
                            const totalCols = [];
                             data.ChildFields.forEach((f, idx) => {
                                 if(['TOTAL','PRICE','AMOUNT'].some(k => f.FIELD.toUpperCase().includes(k))) totalCols.push(f.FIELD);
                             });
                            
                             if (totalCols.length > 0) {
                                 // Simple Total Sum
                                 let grandTotal = 0;
                                 data.QueryData.forEach(r => {
                                     // Assuming last calc field is Grand Total for simplicity in generic
                                     const k = totalCols[totalCols.length-1].toUpperCase();
                                     if(r[k]) grandTotal += parseFloat(r[k]) || 0;
                                 });

                                 // Charges
                                 if (data.ChargeData) {
                                     data.ChargeData.forEach(c => {
                                          html += `<div class="summary-row"><span>${c.CHARGE_EDESC}</span><span>${formatNumber(c.AMOUNT)}</span></div>`;
                                          if(c.CHARGE_TYPE_FLAG == 'D') grandTotal -= c.AMOUNT; else grandTotal += c.AMOUNT;
                                     });
                                 }
                                 
                                 html += `<div class="summary-row total"><span>GRAND TOTAL</span><span>${formatNumber(grandTotal)}</span></div>`;
                                 
                                 // Close Box
                                 html += '</div></div>';
                                 
                                 // Bottom Meta
                                 html += '<div class="bottom-meta">';
                                 html += `<div class="amount-words">In Words: ${numberToWords(grandTotal)}</div>`;
                                 
                                 // Terms
                                 if (data.FooterFields) {
                                     data.FooterFields.forEach(ff => {
                                         if (ff.FIELD.toUpperCase().includes('TERMS')) {
                                             let tVal = ff.DEFAULT_VAL || (data.QueryData[0] ? data.QueryData[0][ff.FIELD.toUpperCase()] : '');
                                             if(tVal) html += `<div style="margin-top:10px;"><strong>Terms:</strong><br>${escapeHtml(tVal)}</div>`;
                                         }
                                     });
                                 }
                                 html += '</div>';
                             } else {
                                 html += '</div></div>'; // Close empty
                             }
                        }
                    }
                }
            }
            contentDiv.innerHTML = html;
            contentDiv.style.display = 'block';
        }

        // --- UTILS ---
        function escapeHtml(text) { if (!text) return ''; const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
        
        function formatNumber(v) { 
            if (v === undefined || v === null || v === '') return ''; 
            const n = parseFloat(v); 
            return isNaN(n) ? v : n.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}); 
        }

        // Convert English date to Nepali date (BS) - Restored from Format1
        function convertToNepaliDate(englishDateStr) {
            try {
                const date = new Date(englishDateStr);
                if (isNaN(date.getTime())) return '';
                const year = date.getFullYear();
                const month = date.getMonth() + 1;
                const day = date.getDate();
                let nepYear = year + 56;
                let nepMonth = month + 8;
                let nepDay = day + 16;
                if (nepMonth > 12) { nepMonth -= 12; nepYear += 1; }
                if (nepDay > 30) { nepDay -= 30; nepMonth += 1; if (nepMonth > 12) { nepMonth = 1; nepYear += 1; } }
                return nepYear + '-' + String(nepMonth).padStart(2, '0') + '-' + String(nepDay).padStart(2, '0');
            } catch (e) { return ''; }
        }

        function formatDateValue(val, field) { 
             if (!field || !field.toUpperCase().includes('DATE')) return escapeHtml(val);
             try { 
                 const dateStr = String(val);
                 const date = new Date(dateStr);
                 if(isNaN(date.getTime())) return escapeHtml(val); 
                 const nepDate = convertToNepaliDate(dateStr);
                 if (nepDate) return escapeHtml(val) + '/' + escapeHtml(nepDate);
                 return escapeHtml(val);
             } catch(e) { return escapeHtml(val); } 
        }

        // Convert number to words - Restored from Format1
        function numberToWords(num) {
            if (num === 0 || num === null || num === undefined) return 'Zero';
            const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
            
            function convertLessThanThousand(n) {
                if (n === 0) return '';
                let result = '';
                if (n >= 100) { result += ones[Math.floor(n / 100)] + ' Hundred '; n %= 100; }
                if (n >= 10 && n <= 19) { result += teens[n - 10] + ' '; } 
                else if (n >= 20 || n > 0) { result += tens[Math.floor(n / 10)] + ' '; n %= 10; result += ones[n] + ' '; }
                return result.trim();
            }
            
            let isNegative = false;
            if (num < 0) { isNegative = true; num = Math.abs(num); }
            
            const integerPart = Math.floor(num);
            const decimalPart = Math.round((num - integerPart) * 100);
            let result = '';
            
            if (integerPart === 0) result = 'Zero';
            else {
                const billion = Math.floor(integerPart / 1000000000);
                const million = Math.floor((integerPart % 1000000000) / 1000000);
                const thousand = Math.floor((integerPart % 1000000) / 1000);
                const remainder = integerPart % 1000;
                
                if (billion > 0) result += convertLessThanThousand(billion) + ' Billion ';
                if (million > 0) result += convertLessThanThousand(million) + ' Million ';
                if (thousand > 0) result += convertLessThanThousand(thousand) + ' Thousand ';
                if (remainder > 0) result += convertLessThanThousand(remainder);
            }
            result = result.trim();
            if (decimalPart > 0) result += ' and ' + convertLessThanThousand(decimalPart) + ' Paisa';
            if (isNegative) result = 'Negative ' + result;
            return result + ' Only';
        }

        function handlePrint() { 
             // Logic to track print count (from Format1)
             if (printCountFlag) {
                 fetch(`/Print/Home/PrintCount?formCode=${encodeURIComponent(formCode)}&mainFieldValue=${encodeURIComponent(mainFieldValue)}`)
                     .then(r => r.json())
                     .then(() => { window.location.reload(); })
                     .catch(e => console.error(e));
                 
                 const afterPrintHandler = function() { window.removeEventListener('afterprint', afterPrintHandler); window.location.reload(); };
                 window.addEventListener('afterprint', afterPrintHandler);
             }
             window.print(); 
        }
        
        loadPreview();
        initializeFilters();
    </script>
</body>
