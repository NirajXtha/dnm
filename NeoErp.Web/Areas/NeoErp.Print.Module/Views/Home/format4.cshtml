@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.FileName</title>
    <style>
        /* [NEW PATTERN - CORPORATE MINIMALIST - FORMAT 4] */
        @@import url('https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Roboto+Mono:wght@400;500&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Lato', sans-serif;
            font-size: 9pt;
            background: #eef2f5;
            color: #2d3748;
            line-height: 1.5;
            display: flex;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* --- COLORS --- */
        :root {
            --primary: #003366; /* Deep Royal Blue */
            --secondary: #64748b;
            --accent: #f1f5f9;
            --border: #e2e8f0;
        }

        /* Filter Sidebar (Standard) */
        .filter-sidebar { width: 320px; background: #fff; border-right: 1px solid #ddd; padding: 20px; position: fixed; left: 0; top: 0; height: 100vh; overflow-y: auto; z-index: 100; }
        .filter-sidebar h4 { font-size: 14px; font-weight: 700; margin-bottom: 15px; color: var(--primary); }
        .filter-item { margin-bottom: 20px; }
        .filter-item label { display: block; font-size: 11px; font-weight: 600; color: var(--secondary); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
        .filter-input { width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 4px; font-size: 12px; }
        .filter-btn { width: 100%; padding: 12px; background: var(--primary); color: white; border: none; border-radius: 4px; font-size: 12px; font-weight: 700; cursor: pointer; margin-top: 10px; text-transform: uppercase; letter-spacing: 1px; }
        .filter-btn:hover { opacity: 0.9; }
        
        /* Autocomplete Standard Styles */
        .autocomplete-dropdown { position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid var(--border); max-height: 250px; overflow-y: auto; z-index: 1000; display: none; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .autocomplete-dropdown.show { display: block; }
        .autocomplete-item { padding: 8px 12px; cursor: pointer; font-size: 12px; border-bottom: 1px solid var(--accent); }
        .autocomplete-item:hover { background: var(--accent); }
        
        /* Main Wrapper */
        .content-wrapper {
            margin-left: 320px;
            flex: 1;
            padding: 10px;
            display: flex;
            justify-content: center;
        }

        /* Page Container */
        .page {
            width: 210mm;
            min-height: 297mm;
            background: white;
            padding: 0; /* Full bleed for header */
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            position: relative;
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
        }

        .page-inner {
            padding: 10mm 15mm;
            flex: 1;
        }

        /* --- COMPACT SPLIT HEADER DESIGN --- */
        .header-split {
            display: flex;
            border-bottom: 4px solid var(--primary);
            margin-bottom: 20px;
        }

        .split-left {
            width: 60%;
            padding: 15px 20px;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .split-right {
            width: 40%;
            background: var(--primary);
            color: white;
            padding: 15px 20px;
            text-align: right;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Logo & Company - Left */
        .logo-row {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 5px;
        }

        .logo-img {
            height: 50px;
            object-fit: contain;
        }

        .company-name {
            font-size: 14pt;
            font-weight: 900;
            color: var(--primary);
            line-height: 1.2;
            text-transform: uppercase;
        }

        .company-addr {
            font-size: 8.5pt;
            color: var(--secondary);
            margin-top: 5px;
            line-height: 1.4;
        }

        /* Invoice Details - Right */
        .invoice-title {
            font-size: 24pt;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            line-height: 1;
            margin-bottom: 5px;
        }

        .copy-label {
            font-size: 8pt;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.9;
            margin-bottom: 12px;
            background: rgba(255,255,255,0.1);
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            align-self: flex-end;
        }

        .meta-row {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            font-size: 9pt;
            margin-bottom: 2px;
        }

        .meta-key { opacity: 0.7; font-weight: 400; }
        .meta-val { font-weight: 700; }

        /* Client Section (Slim Bar below header) */
        .client-bar {
            background: #f8fafc;
            padding: 12px 20px;
            margin-bottom: 20px;
            border-left: 4px solid var(--secondary);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        
        .client-col {
            flex: 1;
        }

        .client-label {
            font-size: 7.5pt;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 700;
            margin-bottom: 4px;
        }
        
        .client-val {
             font-size: 9pt;
             font-weight: 600;
             color: #334155;
        }

        /* --- INFO TABLE (META) --- */
        .meta-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
            background: #f8fafc;
            padding: 15px;
            border-radius: 4px;
        }

        .meta-item {
            display: flex;
            flex-direction: column;
        }

        .meta-label {
            font-size: 7.5pt;
            text-transform: uppercase;
            color: var(--secondary);
            font-weight: 600;
        }

        .meta-value {
            font-size: 10pt;
            font-weight: 700;
            color: #1a202c;
        }

        /* --- CLEAN TABLE DESIGN --- */
        .table-wrap {
            margin-bottom: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            font-size: 8pt;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--secondary);
            border-bottom: 2px solid var(--primary);
            padding: 10px 5px;
            font-weight: 700;
        }

        td {
            padding: 6px 5px; /* Reduced from 12px for compact rows */
            border-bottom: 1px solid #f1f5f9;
            font-size: 9pt;
            color: #334155;
        }

        td[style*="text-align:right"] {
            font-family: 'Roboto Mono', monospace;
            font-size: 8.5pt;
        }

        /* --- TOTALS SECTION --- */
        .totals-section {
            display: flex;
            justify-content: flex-end;
        }

        .totals-list {
            width: 350px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dashed var(--border);
            font-size: 9pt;
        }

        .total-row.grand {
            border-bottom: none;
            border-top: 2px solid var(--primary);
            padding-top: 15px;
            margin-top: 5px;
            font-weight: 900;
            font-size: 12pt;
            color: var(--primary);
            align-items: center; /* Align items vertically */
        }
        
        .total-row.grand span:first-child {
             font-size: 10pt; /* Label slightly smaller */
             text-transform: uppercase;
             letter-spacing: 1px;
        }

        .bottom-footer {
            margin-top: auto; /* Push to bottom */
            border-top: 1px solid var(--border);
            padding-top: 20px;
            font-size: 8pt;
            color: var(--secondary);
            display: flex;
            justify-content: space-between;
        }

        .terms-box {
            max-width: 60%;
        }

        /* Print Button */
        .print-btn { position: fixed; top: 20px; right: 20px; padding: 12px 25px; background: var(--primary); color: white; border: none; border-radius: 50px; font-weight: 700; cursor: pointer; z-index: 1000; box-shadow: 0 4px 15px rgba(0,51,102,0.3); transition: transform 0.2s; }
        .print-btn:hover { transform: translateY(-2px); }

        /* Wrapper for non-full-bleed content */
        .content-body {
            padding: 0 15mm 10mm 15mm;
        }

        /* --- PRINT CSS --- */
        @@media print {
            @@page { margin: 0; size: auto; } /* Key fix: Remove browser margins */
            
            html, body {
                width: 100% !important;
                height: auto !important;
                margin: 0 !important;
                padding: 0 !important;
                overflow: visible !important;
                background: white !important;
            }

            .filter-sidebar, .print-btn { display: none !important; }
            .content-wrapper { 
                display: block !important; 
                margin: 0 !important; 
                padding: 0 !important; 
                width: 100% !important;
            }
            
            .page { 
                width: 100% !important; 
                box-shadow: none !important; 
                margin: 0 !important; 
                padding: 0 !important;
                min-height: 0 !important; 
                height: auto !important; 
                border: none !important;
                page-break-after: auto !important;
            }
            
            /* Banner Print Safety */
            .split-right { background-color: #003366 !important; color: white !important; -webkit-print-color-adjust: exact; }
            .header-split { border-bottom: 4px solid #003366 !important; }
            .client-bar { background-color: #f8fafc !important; }
            th { border-bottom: 2px solid #003366 !important; }
            
            .page-break { page-break-before: always !important; height: 1px; display: block; margin: 0; padding: 0; opacity: 0; }
            
            /* Hide anything else that might float */
            * { float: none !important; }
        }
    </style>
</head>
<body>
    <div class="filter-sidebar">
        <h4>Filters</h4>
        <div id="filterContainer"></div>
        <button class="filter-btn" onclick="applyFilters()">Apply Filters</button>
    </div>

    <div class="content-wrapper">
        <button class='print-btn' onclick='handlePrint()'>PRINT INVOICE</button>
        <div class="page">
            <div id="loading" style="padding:50px; text-align:center;">Loading Preview...</div>
            <div id="content" style="display:none; height: 100%; display: flex; flex-direction: column;"></div>
            <div id="error" style="color:red; padding:20px; display:none;"></div>
        </div>
    </div>

    <script>
        // LOGIC PRESERVATION (Standard from Format1/3)
        const formCode = '@ViewBag.FormCode';
        const companyCode = '@ViewBag.CompanyCode';
        const mainFieldValue = '@ViewBag.MainFieldValue';
        const activePatternId = parseInt('@ViewBag.ActivePatternId') || 0;
        
        let sqlQuery = '';
        let filterState = {};
        let debounceTimers = {};
        let printCountFlag = false;

        function debounce(func, delay) {
            return function(...args) {
                const context = this;
                clearTimeout(debounceTimers[args[0]]);
                debounceTimers[args[0]] = setTimeout(() => func.apply(context, args), delay);
            };
        }

        // --- FILTER & INIT LOGIC (Same as others) ---
        async function initializeFilters() {
             try {
                const patternResponse = await fetch(`/Print/Home/GetAllPatterns?formCode=${formCode}&patternId=${activePatternId || ''}`, { method: 'POST' });
                const patternData = await patternResponse.json();
                if (patternData.success && patternData.data && patternData.data.PatternDetail) {
                    sqlQuery = patternData.data.PatternDetail.SQL_QUERY || '';
                    const placeholderResponse = await fetch(`/Print/Home/GetQueryPlaceholders?sqlQuery=${encodeURIComponent(sqlQuery)}`);
                    const placeholderData = await placeholderResponse.json();
                    if (placeholderData.success && placeholderData.placeholders && placeholderData.placeholders.length > 0) {
                        renderFilters(placeholderData.placeholders);
                    }
                }
            } catch (error) { console.error('Init Error', error); }
        }

        function renderFilters(placeholders) {
            const container = document.getElementById('filterContainer');
            container.innerHTML = '';
            placeholders.forEach(placeholder => {
                const filterItem = document.createElement('div');
                filterItem.className = 'filter-item';
                const label = document.createElement('label');
                label.textContent = placeholder.Field.replace(/_/g, ' ');
                const autocompleteContainer = document.createElement('div');
                autocompleteContainer.className = 'autocomplete-container';
                autocompleteContainer.style.position = 'relative';
                const input = document.createElement('input');
                input.className = 'filter-input';
                input.placeholder = 'Search...';
                input.dataset.field = placeholder.Field;
                input.dataset.entityType = placeholder.EntityType;
                const dropdown = document.createElement('div');
                dropdown.className = 'autocomplete-dropdown';
                dropdown.id = `dropdown-${placeholder.Field}`;

                input.addEventListener('input', debounce((e) => handleAutocomplete(e.target), 300));
                input.addEventListener('focus', (e) => { if (e.target.value) handleAutocomplete(e.target); });

                autocompleteContainer.append(input, dropdown);
                filterItem.append(label, autocompleteContainer);
                container.appendChild(filterItem);
            });
        }

        async function handleAutocomplete(input) {
            const dropdown = document.getElementById(`dropdown-${input.dataset.field}`);
            const searchTerm = input.value.trim();
            if (!searchTerm) { dropdown.classList.remove('show'); return; }
            dropdown.innerHTML = '<div style="padding:10px;">Searching...</div>';
            dropdown.classList.add('show');
            try {
                const url = `/Print/Home/SearchEntity?entityType=${input.dataset.entityType}&searchTerm=${encodeURIComponent(searchTerm)}&pageNumber=1&pageSize=100`;
                const response = await fetch(url);
                const data = await response.json();
                if (data.success && data.data && data.data.length > 0) {
                    renderAutocompleteResults(dropdown, data.data, input.dataset.field);
                } else { dropdown.innerHTML = '<div class="autocomplete-item">No results</div>'; }
            } catch (e) { dropdown.innerHTML = '<div class="autocomplete-item">Error</div>'; }
        }

        function renderAutocompleteResults(dropdown, items, field) {
            dropdown.innerHTML = '';
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.textContent = `${item.Code} - ${item.Description}`;
                div.addEventListener('click', async () => {
                    const input = document.querySelector(`input[data-field="${field}"]`);
                    input.value = `${item.Code} - ${item.Description}`;
                     if (item.IsGroup) {
                        try {
                            const resp = await fetch(`/Print/Home/GetEntityChildren?entityType=${input.dataset.entityType}&masterCode=${encodeURIComponent(item.MasterCode)}`);
                            const d = await resp.json();
                            if(d.success) filterState[field] = { code: '', codes: d.codes, isGroup: true };
                        } catch(e) {}
                     } else {
                         filterState[field] = { code: item.Code, codes: [], isGroup: false };
                     }
                    dropdown.classList.remove('show');
                });
                dropdown.appendChild(div);
            });
        }

        function applyFilters() { loadPreview(); }
        function loadPreview() {
            const filters = JSON.stringify(filterState);
            const apiUrl = `/Print/Home/GetPreviewDataApi?formCode=${encodeURIComponent(formCode)}&companyCode=${encodeURIComponent(companyCode)}&mainFieldValue=${encodeURIComponent(mainFieldValue)}&activePatternId=${encodeURIComponent(activePatternId)}&filters=${encodeURIComponent(filters)}`;
            fetch(apiUrl).then(r => r.json()).then(result => {
                document.getElementById('loading').style.display = 'none';
                if (result.success) renderPreview(result.data);
                else document.getElementById('error').textContent = result.message;
            }).catch(e => console.error(e));
        }

        // ==========================================
        //        DISTINCT RENDER LOGIC (F4)
        // ==========================================
        function renderPreview(data) {
            const contentDiv = document.getElementById('content');
            printCountFlag = data.PRINT_COUNT_FLAG || false;
            const itemsPerPage = data.ITEM_COUNT || 15;
            const totalItems = (data.QueryData && data.QueryData.length) || 0;
            
            // Pagination Logic
            const pages = [];
            let currentIdx = 0;
            const limitLast = itemsPerPage; 
            const limitNonLast = itemsPerPage + 10; 

            if (totalItems === 0) pages.push({ start: 0, end: 0, isLast: true });
            else {
                while (currentIdx < totalItems) {
                    const remaining = totalItems - currentIdx;
                    if (remaining <= limitLast) {
                        pages.push({ start: currentIdx, end: totalItems, isLast: true });
                        currentIdx = totalItems;
                    } else {
                        let chunkSize = limitNonLast;
                        if (chunkSize >= remaining) chunkSize = remaining - 1;
                        const end = Math.min(currentIdx + chunkSize, totalItems);
                        pages.push({ start: currentIdx, end: end, isLast: false });
                        currentIdx = end;
                    }
                }
                 if (pages.length > 0 && !pages[pages.length - 1].isLast) pages.push({ start: totalItems, end: totalItems, isLast: true });
            }

            let html = '';
            const numCopies = (data.PRINT_COUNT == 1 && data.PRINT_COUNT_FLAG) ? 3 : 1;

            // --- RENDER FUNCTIONS (NEW DESIGN) ---
            
            // 1. BANNER & HEADER (Compact Split)
            const renderBanner = (copyIndex) => {
                let h = '<div class="header-split">';
                
                // --- SPLIT LEFT: Logo + Company ---
                h += '<div class="split-left">';
                h += '<div class="logo-row">';
                h += '<img src="/Areas/NeoErp.Print.Module/Content/logo.png" class="logo-img" alt="Logo" />';
                
                // Find Company Name
                let coName = '';
                if (data.HeadFields) {
                     const nameField = data.HeadFields.find(f => f.FIELD && f.FIELD.toUpperCase() === 'COMPANY_CODE');
                     if (nameField) {
                         let val = nameField.DEFAULT_VAL;
                         if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0]['COMPANY_CODE'];
                         if (val) coName = formatDateValue(val, nameField.FIELD);
                     }
                }
                if (coName) h += `<div class="company-name">${coName}</div>`;
                h += '</div>'; // End Logo Row

                // Company Address (Below or Beside? Below is cleaner)
                if (data.HeadFields) {
                    data.HeadFields.forEach(f => {
                         if (f.FIELD && f.FIELD.toUpperCase() !== 'COMPANY_CODE') {
                             let val = f.DEFAULT_VAL;
                             if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0][f.FIELD.toUpperCase()];
                             if (val) h += `<div class="company-addr">${formatDateValue(val, f.FIELD)}</div>`;
                         }
                    });
                }
                h += '</div>'; // End Split Left

                // --- SPLIT RIGHT: Invoice Title + Meta ---
                h += '<div class="split-right">';
                
                let mainTitle = 'INVOICE';
                let subLabel = '';
                if (data.PRINT_COUNT_FLAG) {
                    const printCount = data.PRINT_COUNT || 0;
                    if (printCount === 1) {
                        if (copyIndex === 0) { mainTitle = 'TAX INVOICE'; subLabel = 'CUSTOMER COPY'; }
                        else { mainTitle = 'INVOICE'; subLabel = 'OFFICE COPY'; }
                    } else {
                        const copyNum = (printCount > 1) ? (printCount - 1) : printCount; 
                        subLabel = `COPY OF ORIGINAL(${copyNum})`;
                    }
                }
                
                h += `<div class="invoice-title">${mainTitle}</div>`;
                if (subLabel) h += `<div class="copy-label">${subLabel}</div>`;
                
                // Meta Data (Invoice No, Date) - Moved here for compactness
                if (data.MasterFields) {
                    data.MasterFields.forEach(f => {
                        // Priority display for Invoice No and Date in blue area
                        if (f.FIELD) {
                            const k = f.FIELD.toUpperCase();
                            if (k.includes('INVOICE') || k.includes('DATE') || k.includes('MITI')) {
                                 let val = f.DEFAULT_VAL;
                                 if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0][k];
                                 if (val) h += `<div class="meta-row"><span class="meta-key">${escapeHtml(f.LABEL || f.FIELD)}:</span> <span class="meta-val">${formatDateValue(val, f.FIELD)}</span></div>`;
                            }
                        }
                    });
                }

                h += '</div>'; // End Split Right
                h += '</div>'; // End Header Split
                
                // --- CLIENT BAR (Slim) ---
                h += '<div class="client-bar">';
                h += '<div class="client-col">';
                h += '<div class="client-label">Bill To / Acc Details</div>';
                
                 if (data.MasterFields) {
                    data.MasterFields.forEach(f => {
                        if (f.FIELD) {
                            const k = f.FIELD.toUpperCase();
                             if (!k.includes('INVOICE') && !k.includes('DATE') && !k.includes('MITI')) {
                                 let val = f.DEFAULT_VAL;
                                 if (!val && data.QueryData && data.QueryData.length > 0) val = data.QueryData[0][k];
                                 if (val) h += `<div style="font-size:8.5pt; color:#334155;"><strong>${escapeHtml(f.LABEL || f.FIELD)}:</strong> ${formatDateValue(val, f.FIELD)}</div>`;
                             }
                        }
                    });
                }
                h += '</div>'; // End Client Col
                h += '</div>'; // End Client Bar
                
                return h;
            };

            for (let copyIndex = 0; copyIndex < numCopies; copyIndex++) {
                if (copyIndex > 0) html += '<div style="page-break-before:always;"></div>';

                if (data.ChildFields && data.ChildFields.length > 0 && data.QueryData) {
                    for (let pageIdx = 0; pageIdx < pages.length; pageIdx++) {
                        const pageInfo = pages[pageIdx];
                        if (pageIdx > 0) html += '<div style="page-break-before:always;"></div>';
                        
                        html += renderBanner(copyIndex);
                        
                        // Start Content Body (Below Header/ClientBar)
                        html += '<div class="content-body">';
                        
                        // Table
                        html += '<div class="table-wrap"><table><thead><tr>';
                        html += '<th style="width:40px;text-align:center;">SN</th>';
                        data.ChildFields.forEach(f => {
                             html += `<th>${escapeHtml((f.LABEL || f.FIELD).replace(/_/g, ' '))}</th>`;
                        });
                        html += '</tr></thead><tbody>';

                        // Rows
                        for (let i = pageInfo.start; i < pageInfo.end; i++) {
                            const row = data.QueryData[i];
                            html += `<tr><td style="text-align:center; color:#94a3b8;">${i + 1}</td>`;
                            
                            data.ChildFields.forEach(f => {
                                if (f.FIELD) {
                                    const key = f.FIELD.toUpperCase();
                                    let val = f.DEFAULT_VAL;
                                    if (!val && row[key] !== undefined) val = row[key];
                                    const isNum = ['PRICE','AMOUNT','TOTAL','QTY','RATE'].some(k => key.includes(k));
                                    const align = isNum ? 'text-align:right;' : '';
                                    html += `<td style="${align}">${isNum ? formatNumber(val) : formatDateValue(val, f.FIELD)}</td>`;
                                } else {
                                    html += '<td></td>';
                                }
                            });
                            html += '</tr>';
                        }
                        
                         // Filler
                        if (pageInfo.isLast) {
                            const filled = pageInfo.end - pageInfo.start;
                            const needed = itemsPerPage - filled;
                            for(let k=0; k<needed; k++) {
                                html += '<tr><td>&nbsp;</td>';
                                data.ChildFields.forEach(() => html += '<td></td>');
                                html += '</tr>';
                            }
                        }

                        html += '</tbody></table></div>'; 

                        // Footer (Totals & Words)
                        if (pageInfo.isLast) {
                            html += '<div class="totals-section"><div class="totals-list">';
                            
                            // Calc Logic
                            const totalCols = [];
                             data.ChildFields.forEach((f, idx) => {
                                 if(f.FIELD && ['TOTAL','PRICE','AMOUNT'].some(k => f.FIELD.toUpperCase().includes(k))) totalCols.push(f.FIELD);
                             });
                            
                             if (totalCols.length > 0) {
                                 let grandTotal = 0;
                                 data.QueryData.forEach(r => {
                                     const k = totalCols[totalCols.length-1].toUpperCase();
                                     if(r[k]) grandTotal += parseFloat(r[k]) || 0;
                                 });

                                 // Charges
                                 if (data.ChargeData) {
                                     data.ChargeData.forEach(c => {
                                          html += `<div class="total-row"><span>${c.CHARGE_EDESC}</span><span>${formatNumber(c.AMOUNT)}</span></div>`;
                                          if(c.CHARGE_TYPE_FLAG == 'D') grandTotal -= c.AMOUNT; else grandTotal += c.AMOUNT;
                                     });
                                 }
                                 
                                 html += `<div class="total-row grand"><span>Total Amount</span><span>${formatNumber(grandTotal)}</span></div>`;
                                 html += `<div style="font-size:8pt; color:#64748b; margin-top:5px; text-align:right; font-style:italic;">"${numberToWords(grandTotal)}"</div>`;
                                 
                             } 
                             html += '</div></div>'; // End Totals

                             // Bottom Footer (Terms)
                             html += '<div class="bottom-footer">';
                             html += '<div class="terms-box">';
                             // Terms
                             if (data.FooterFields) {
                                 data.FooterFields.forEach(ff => {
                                     if (ff.FIELD && ff.FIELD.toUpperCase().includes('TERMS')) {
                                         let tVal = ff.DEFAULT_VAL || (data.QueryData[0] ? data.QueryData[0][ff.FIELD.toUpperCase()] : '');
                                         if(tVal) html += `<strong>Terms & Conditions:</strong><br><span style="white-space:pre-wrap;">${escapeHtml(tVal)}</span>`;
                                     }
                                 });
                             }
                             html += '</div>'; // End Terms
                             html += '<div style="text-align:right; margin-top:30px; border-top:1px solid #ddd; padding-top:5px; width:200px;">Authorized Signature</div>';
                             html += '</div>'; // End Bottom Footer
                        }
                        
                        html += '</div>'; // Close Content Body
                        
                        html += '</div>'; // Close page-inner
                    }
                }
            }
            contentDiv.innerHTML = html;
            contentDiv.style.display = 'flex'; // Important in F4 for flex column layout of page
            document.getElementById('content').style.flexDirection = 'column';
        }

        // --- UTILS ---
        function escapeHtml(text) { if (!text) return ''; const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
        function formatNumber(v) { if (v === undefined || v === null || v === '') return ''; const n = parseFloat(v); return isNaN(n) ? v : n.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}); }
        function convertToNepaliDate(englishDateStr) {
            try { const date = new Date(englishDateStr); if (isNaN(date.getTime())) return ''; const year = date.getFullYear(); const month = date.getMonth() + 1; const day = date.getDate(); let nepYear = year + 56; let nepMonth = month + 8; let nepDay = day + 16; if (nepMonth > 12) { nepMonth -= 12; nepYear += 1; } if (nepDay > 30) { nepDay -= 30; nepMonth += 1; if (nepMonth > 12) { nepMonth = 1; nepYear += 1; } } return nepYear + '-' + String(nepMonth).padStart(2, '0') + '-' + String(nepDay).padStart(2, '0'); } catch (e) { return ''; }
        }
        function formatDateValue(val, field) { if (!field || !field.toUpperCase().includes('DATE')) return escapeHtml(val); try { const dateStr = String(val); const date = new Date(dateStr); if(isNaN(date.getTime())) return escapeHtml(val); const nepDate = convertToNepaliDate(dateStr); if (nepDate) return escapeHtml(val) + '/' + escapeHtml(nepDate); return escapeHtml(val); } catch(e) { return escapeHtml(val); } }
        function numberToWords(num) {
            if (num === 0 || num === null || num === undefined) return 'Zero'; const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine']; const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety']; const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
            function convertLessThanThousand(n) { if (n === 0) return ''; let result = ''; if (n >= 100) { result += ones[Math.floor(n / 100)] + ' Hundred '; n %= 100; } if (n >= 10 && n <= 19) { result += teens[n - 10] + ' '; } else if (n >= 20 || n > 0) { result += tens[Math.floor(n / 10)] + ' '; n %= 10; result += ones[n] + ' '; } return result.trim(); }
            let isNegative = false; if (num < 0) { isNegative = true; num = Math.abs(num); } const integerPart = Math.floor(num); const decimalPart = Math.round((num - integerPart) * 100); let result = '';
            if (integerPart === 0) result = 'Zero'; else { const billion = Math.floor(integerPart / 1000000000); const million = Math.floor((integerPart % 1000000000) / 1000000); const thousand = Math.floor((integerPart % 1000000) / 1000); const remainder = integerPart % 1000; if (billion > 0) result += convertLessThanThousand(billion) + ' Billion '; if (million > 0) result += convertLessThanThousand(million) + ' Million '; if (thousand > 0) result += convertLessThanThousand(thousand) + ' Thousand '; if (remainder > 0) result += convertLessThanThousand(remainder); }
            result = result.trim(); if (decimalPart > 0) result += ' and ' + convertLessThanThousand(decimalPart) + ' Paisa'; if (isNegative) result = 'Negative ' + result; return result + ' Only';
        }
        function handlePrint() { 
             if (printCountFlag) { fetch(`/Print/Home/PrintCount?formCode=${encodeURIComponent(formCode)}&mainFieldValue=${encodeURIComponent(mainFieldValue)}`).then(r => r.json()).then(() => { window.location.reload(); }).catch(e => console.error(e)); const afterPrintHandler = function() { window.removeEventListener('afterprint', afterPrintHandler); window.location.reload(); }; window.addEventListener('afterprint', afterPrintHandler); } window.print(); 
        }
        loadPreview(); initializeFilters();
    </script>
</body>
</html>
