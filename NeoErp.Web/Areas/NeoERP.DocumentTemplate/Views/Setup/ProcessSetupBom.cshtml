            height: 80px !important;
        }

        .fieldset-box {
            margin-bottom: 8px;
        }


        .document_child_table tbody.table_body {
            min-height: 86px !important;
        }

        div#ndp-nepali-box {
            z-index: 10076 !important;
        }

        div#ndp-nepali-box {
            font-family: 'Trebuchet MS', Tahoma, Verdana, Arial, sans-serif;
            border: 1px solid #CCC;
            background-color: #FFF;
            position: absolute;
            z-index: 9999;
            padding: 1px;
            margin-top: 1px;
        }

        .k-select {
            display: none;
        }

        .requiredAsterik {
            position: absolute;
            top: 0px;
            right: 5px;
        }

        .k-list-container {
            width: 250px !important;
        }

        table {
            table-layout: fixed;
        }

            table th, table td {
                overflow: hidden;
            }

        .k-grid-content {
            height: 367px !important;
        }


        .borderRed {
            border: solid red 1px !important;
        }

        .addcolor {
            color: #ffffff;
        }

        .k-animation-container, .k-widget, .k-widget *, .k-animation-container *, .k-widget ::before, .k-animation-container ::after, .k-block .k-header, .k-list-container {
            -webkit-box-sizing: border-box;
            -moz-box-sizing: border-box;
            box-sizing: border-box;
        }

        /*.k-grid-content .k-auto-scrollable, .k-auto-scrollable {
            height: auto !important;
        }*/

        .k-virtual-scrollable-wrap {
            height: 454px !important;
        }

        #createContractForm .k-multiselect-wrap ul li {
            font-size: 10px !important;
        }

        #createContractForm .k-multiselect-wrap .k-input {
            color: hsl(0, 0%, 80%);
        }

        #multiselect-wrap.k-floatwrap {
            max-height: 101px;
            overflow-y: auto;
        }



        /*Stype form Resource table*/


        /* Left panel containing the table and buttons */
        .left-panel {
            display: flex;
            flex-direction: column;
            height: 100%; /* Ensure it takes full height of its parent for button positioning */
        }

        /* Right panel for help text */
        .right-panel {
            background-color: #f9f9f9; /* Lighter gray background */
            border: 1px solid #e5e5e5; /* Light border */
            padding: 15px;
            border-radius: 5px;
            text-align: center;
            color: #777; /* Darker gray text */
            font-style: italic;
            display: flex; /* Use flex to center content vertically */
            align-items: center;
            justify-content: center;
            min-height: 100px; /* Minimum height for the help text box */
        }

        /* Table container with fixed height and scroll */
        .table-wrapper {
            border: 1px solid #ddd; /* Light gray border */
            border-radius: 4px; /* Slightly rounded corners */
            overflow: hidden; /* Hide overflow for rounded corners */
            margin-bottom: 20px; /* Space below the table */
            max-height: 400px; /* Max height for the table, enabling scroll */
            overflow-y: auto; /* Enable vertical scrolling */
        }

        /* Table styling */
        table {
            width: 100%;
            border-collapse: collapse; /* Collapse borders */
            margin-bottom: 0; /* Remove default table margin */
        }

        th, td {
            border: 1px solid #eee; /* Lighter border for cells */
            padding: 10px;
            text-align: left;
        }

        th {
            background-color: #f5f5f5; /* Light background for headers */
            font-weight: bold;
            color: #555; /* Darker text for headers */
            position: sticky; /* Sticky header for scrolling table */
            top: 0;
            z-index: 1; /* Ensure header is above scrolling content */
        }

        /* Styling for table rows, including hover effect */
        tbody tr:hover {
            background-color: #f0f8ff; /* Light blue on hover */
            transition: background-color 0.2s ease; /* Smooth transition */
        }

        /* Buttons container */
        .button-group {
            display: flex;
            justify-content: center;
            gap: 10px; /* Space between buttons */
            margin-top: auto; /* Pushes buttons to the bottom of the left panel */
            padding-top: 10px; /* Add some padding above buttons */
        }

        /* Bootstrap button base styles are used, with custom colors */
        .btn-new {
            background-color: #5cb85c; /* Green for New */
            border-color: #4cae4c;
            color: white;
        }

            .btn-new:hover {
                background-color: #4cae4c;
                border-color: #4cae4c;
                color: white;
            }

        .btn-edit {
            background-color: #337ab7; /* Blue for Edit */
            border-color: #2e6da4;
            color: white;
        }

            .btn-edit:hover {
                background-color: #2e6da4;
                border-color: #2e6da4;
                color: white;
            }



        /*    Resouce Assing Setup */

        <!-- Custom CSS for modal appearance to match the image -->
        /* Label styling */
        .form-group label {
            font-weight: normal; /* Labels are not bold in the image */
            color: #555; /* Slightly muted label color */
            margin-bottom: 5px; /* Space between label and input */
            display: block; /* Ensure label takes full width */
        }

        /* Input field styling */
        .form-control {
            border-radius: 4px; /* Slightly rounded input fields */
            border: 1px solid #ced4da; /* Slightly darker, modern border color */
            box-shadow: inset 0 1px 2px rgba(0,0,0,.075); /* More subtle inner shadow */
        }

            /* Read-only input specific styling */
            .form-control[readonly] {
                background-color: #e9ecef; /* Lighter background for read-only fields */
                cursor: not-allowed; /* Indicate it's not editable */
                border-color: #ced4da; /* Consistent border */
            }

        /* Input group button styling (for folder icons) */
        .input-group-btn .btn {
            background-color: #f8f9fa; /* Very light grey background for the folder buttons */
            border: 1px solid #ced4da; /* Match the input field border */
            border-left: 1px solid #ced4da; /* Ensure left border is present and matches input */
            border-radius: 0 4px 4px 0; /* Only right side rounded, matching input */
            padding: 2px 8px; /* Standard button padding */
            /* Adjust height to align perfectly with input */
            height: 24px; /* Default Bootstrap 3 input height */
            display: flex; /* Use flexbox for vertical centering of icon */
            align-items: center; /* Vertically center the icon */
            justify-content: center; /* Horizontally center the icon */
        }

            /* Icon styling within buttons */
            .input-group-btn .btn i.fa {
                color: #6c757d; /* Muted grey color for the folder icon */
                font-size: 16px; /* Adjust icon size if needed */
            }



        .selected-row-assigned {
            background-color: #d9edf7; /* light blue */
            cursor: pointer;
        }


        #outputMatGrid .k-grid-content {
            height: 100px !important;
        }

        #billOfMatGrid .k-grid-content {
            height: 100px !important;
        }
    </style>



</head>
<body>
    <div class="row">

        <div class="col-md-12 col-sm-12" id="processSetupBomCtrl">

            <div class="portlet light form-fit bordered bottomspance">

                <div class="portlet mingap">

                    <div class="portlet-title">

                        <div class="caption caption-title ng-binding">
                            <a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/DocumentTemplate/Home/Dashboard">
                                <i class="fa fa-arrow-circle-left"></i>
                            </a>
                            <i class="fa fa-gift font-green-haze"></i>
                            <span class="caption-subject font-green-haze bold uppercase">{{FormName}}</span>
                        </div>

                        <div class="actions">

                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" id="newProcessSetupBtn" title="(Alt + P)" ng-click="newProcessSetup()" href="javascript:;">
                                <i class="fa fa-plus-circle"></i> New
                            </a>
                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" id="editRoutine" title="(Alt + P)" ng-click="editProcessRoutineSetup()" href="javascript:;" disabled>
                                <i class="fa fa-check-circle"></i> Edit
                            </a>
                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" id="copyRoutine" title="(Alt + C)" ng-click="copyProcessRoutineSetup()" href="javascript:;" disabled>
                                <i class="fa fa-copy"></i> Copy
                            </a>
                            <a class="btn btn-danger" data-toggle="tooltip" data-placement="top" id="deleteRoutine" title="(Alt + D)" ng-click="deleteProcessRoutineSetup()" href="javascript:;" disabled>
                                <i class="fa fa-trash"></i> Delete
                            </a>

                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" title="(Alt + P)" href="/DocumentTemplate/Home/Dashboard">
                                <i class="fa fa-close"></i> Cancel
                            </a>

                            @*<a class="btn btn-success" data-toggle="tooltip" data-placement="top" title="(Alt + P)" ng-click="printProcessSetup()" href="javascript:;">
                                <i class="fa fa-print"></i> Print
                            </a>*@
                        </div>
                    </div>

                    <div class="portlet-body">
                        <div class="row">

                            <div id="splitter">
                                <div id="pane1">
                                    <div class="portlet box green-box">
                                        <div class="portlet-title">

                                            <div class="caption">
                                                <i class="icon-pin"></i>
                                                <span class="caption-subject bold uppercase">Process</span>
                                                <span style="margin-left:181px;"><i class="fa fa-refresh" title="Remove selection" ng-click="removeNodeSelection()"></i></span>
                                            </div>
                                        </div>
                                        <div class="portlet-body">
                                            <div class="row">

                                                <div class="topsearch">

                                                    @*<input class="k-textbox txtSearchString" type="text" id="processSearchString" ng-model="txtSearchString" name="search" placeholder="Enter Search Text Here..." />*@
                                                    <input class="k-textbox" placeholder="Search here..." id="processSearchString" />
                                                </div>

                                            </div>
                                            <div id="categoryTreeGrid" style="height:350px;"></div>
                                            <ul id="menu">
                                                <li>Add</li>
                                                <li>Update</li>
                                                <li>Delete</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <div class="portlet box green-box main">

                                        <div class="portlet-title">
                                            <div class="caption">
                                                <i class="fa fa-list-alt"></i>
                                                <span class="caption-subject  bold uppercase">
                                                    Routine
                                                </span>
                                            </div>
                                        </div>

                                        <div class="portlet-body">
                                            <div class="row" style="margin-top:-8px !important;">
                                                <div class="col-md-offset-8 col-md-4 search_box">
                                                    <div class="topsearch" style="display:block;">
                                                        <a class="btn-linkicon fa fa-search" style="margin-right: -13px;" ng-click="reloadRoutineGridOnSearchText()"></a>
                                                        <input class="k-textbox txtSearchString" type="text" id="custtxtSearchString" ng-model="searchText" name="search" placeholder="enter search text..." style="margin-left: 13px;" ng-enter="reloadRoutineGridOnSearchText()" />

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="tabbable">
                                                <kendo-grid id="routineResultGrid" options="routineResultOptions" k-rebind="routineResultOptions" class="kendo_gride_table" style="width:100%;">
                                                </kendo-grid>
                                            </div>


                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>

            <div class="modal fade-out" id="addNewProcessCategoryModel" data-backdrop="static" tabindex="-1" data-width="760">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div type="button" class="close" aria-hidden="true" ng-click="close()">&times;</div>
                            <h4 class="modal-title">
                                <span class="fa fa-file"></span>
                                Process Setup
                            </h4>

                        </div>

                        <div id="addNewProcessCategoryDiv" class="modal-body OperaPrintModal main">

                            <div class="portlet box green-box main">

                                <div class="portlet-body form-horizontal">

                                    <div class="row">

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Under:<span style="color:red" ng-show="processCategoryForm.processType.$invalid">
                                                        <span ng-show="processCategoryForm.processType.$error.required">*</span>
                                                    </span>
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <select id="processType" ng-model="selectedProcessForDDL" k-value-primitive="true" k-ng-model="selectedProcessForDDL" name="processTypeForDDL" kendo-drop-down-list
                                                            k-options="processTypeDDLOptions" ng-change="onDDLChange()"
                                                            style="width: 100%"></select>
                                                </div>
                                            </div>

                                        </div>
                                        <div ng-show="fillPrimaryProcessName">
                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                <div class="form-group">
                                                    <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                        Primary Process Name:<span style="color:red" ng-show="processCategoryForm.primaryProcessName.$invalid">
                                                            <span ng-show="processCategoryForm.primaryProcessName.$error.required">*</span>
                                                        </span>
                                                    </label>
                                                    <div class="col-sm-6 col-md-6 col-lg-6">
                                                        <input class="form-control" type="text" name="primaryProcessName" ng-model="processCategoryRoutineObj.PRIMARY_PROCESS_NAME" id="primaryProcessName" placeholder="Primary Process Name" required>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>


                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Process Code:<span style="color:red" ng-show="processCategoryForm.processCode.$invalid">
                                                        <span ng-show="processCategoryForm.processCode.$error.required">*</span>
                                                    </span>
                                                </label>
                                                <div class="col-sm-3 col-md-3 col-lg-3">
                                                    <input class="form-control" type="text" name="processCode" ng-model="processCategoryRoutineObj.PROCESS_CODE" id="processCode" placeholder="Process Code" required>
                                                </div>

                                                <div class="col-md-6 col-sm-6 col-lg-6" id="cprradio">
                                                    Category:<input type="radio" name="processFlag" id="catRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="CATEGORY" />
                                                    Process:<input type="radio" name="processFlag" id="proccessRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="PROCESS" />
                                                    Routine:<input type="radio" name="processFlag" id="routineRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="ROUTINE" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    In English:<span style="color:red">*</span>
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <input class="form-control" type="text" name="in_english" ng-model="processCategoryRoutineObj.IN_ENGLISH" id="in_english" placeholder="name in english" required>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    In Nepali:
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <input class="form-control" type="text" name="in_nepali" ng-model="processCategoryRoutineObj.IN_NEPALI" id="in_nepali" placeholder="name in nepali">
                                                </div>
                                            </div>

                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Process Type:<span style="color:red">*</span>
                                                </label>
                                                <div class="col-sm-3 col-md-3 col-lg-3">
                                                    <select id="processType" ng-model="selectedProcessType" k-value-primitive="true" k-ng-model="selectedProcessType" name="processType" kendo-drop-down-list
                                                            k-options="processTypeOptions"
                                                            style="width: 100%"></select>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Priority Number:<span style="color:red">*</span>
                                                </label>
                                                <div class="col-sm-6 col-md-6 col-lg-6">

                                                    <input class="form-control" type="text" name="priorityNumber" ng-model="processCategoryRoutineObj.PRIORITY_NUMBER" id="priorityNumber" placeholder="Priority Number" required>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Remarks:
                                                </label>
                                                <div class="col-sm-6 col-md-6 col-lg-6">
                                                    <textarea class="form-control" type="text" rows="4" name="remarks" ng-model="processCategoryRoutineObj.REMARKS" id="remarks" placeholder="remarks"></textarea>
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                </div>
                            </div>

                        </div>

                        <div class="modal-footer">

                            <a class="btn btn-sm btn-green" ng-click="close()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                                <i class="fa fa-floppy-o"></i> Cancel
                            </a>
                            <a class="btn btn-sm btn-green" ng-click="SaveProcessCategorySetup()">Finish</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade-out" id="addNewProcessModel" data-backdrop="static" tabindex="-1" data-width="760">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div type="button" class="close" aria-hidden="true" ng-click="closeProcessModel()">&times;</div>
                            <h4 class="modal-title">
                                <span class="fa fa-file"></span>
                                Process Setup
                            </h4>

                        </div>

                        <div id="addNewProcessDiv" class="modal-body OperaPrintModal main">

                            <div class="portlet box green-box main">

                                <div class="portlet-body form-horizontal">

                                    <div class="row">

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Under:<span style="color:red" ng-show="processCategoryForm.dropdowntree.$invalid">
                                                        <span ng-show="processCategoryForm.dropdowntree.$error.required">*</span>
                                                    </span>
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <select id="processType" ng-model="selectedProcessForDDL" k-value-primitive="true" k-ng-model="selectedProcessForDDL" name="processTypeForDDL" kendo-drop-down-list
                                                            k-options="processTypeDDLOptions" ng-change="onDDLChange()"
                                                            style="width: 100%" disabled></select>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    Process Code:<span style="color:red" ng-show="processCategoryForm.processCode.$invalid">
                                                        <span ng-show="processCategoryForm.processCode.$error.required">*</span>
                                                    </span>
                                                </label>
                                                <div class="col-sm-3 col-md-3 col-lg-3">
                                                    <input class="form-control" type="text" name="processCode" ng-model="processCategoryRoutineObj.PROCESS_CODE" id="processCode" placeholder="Process Code" required>
                                                </div>

                                                <div class="col-md-6 col-sm-6 col-lg-6">
                                                    Category:<input type="radio" name="processFlag" id="catRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="CATEGORY" />
                                                    Process:<input type="radio" name="processFlag" id="proccessRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="PROCESS" />
                                                    Routine:<input type="radio" name="processFlag" id="routineRadio" ng-model="selectedProcessFlag" ng-change='ChangeFlag(selectedProcessFlag)' value="ROUTINE" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    In English:<span style="color:red">*</span>
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <input class="form-control" type="text" name="in_english" ng-model="processCategoryRoutineObj.IN_ENGLISH" id="in_english" placeholder="name in english" required>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">
                                                    In Nepali:
                                                </label>
                                                <div class="col-sm-9 col-md-9 col-lg-9">
                                                    <input class="form-control" type="text" name="in_nepali" ng-model="processCategoryRoutineObj.IN_NEPALI" id="in_nepali" placeholder="name in nepali">
                                                </div>
                                            </div>

                                        </div>

                                        <div class="col-sm-12 col-md-12 col-lg-12">
