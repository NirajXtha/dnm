            var nepaliDateForEncash = $("#encashNepaliDate").val();
            var nepaliDateForInTransit = $("#inTransitNepaliDate").val();
            var nepaliDateForCreated = $("#createdNepaliDate").val();
            var nepaliDateForBounce = $("#bounceNepaliDate").val();
            var nepaliDateForReturn = $("#returnNepaliDate").val();
            var nepaliDateForPayment = $("#paymentNepaliDate").val();
            var nepaliDateForPaymentCheque = $("#paymentChequeNepaliDate").val();
            var paymentChequeReturnNepaliDate = $("#paymentChequeReturnNepaliDate").val();
            var paymentCreatedNepaliDate = $("#paymentChequeCreatedNepaliDate").val();
            var paymentChequeEncashNepaliDate = $("#paymentChequeEncashNepaliDate").val();
            var Engdate = BS2AD(nepalidate);
            var Engdate1 = BS2AD(nepalidate1);
            var EngReceipt = BS2AD(nepaliDateForReceipt);
            var EngCheque = BS2AD(nepaliDateForCheque)
            var EngEncash = BS2AD(nepaliDateForEncash)
            var EngInTransit = BS2AD(nepaliDateForInTransit)
            var EngCreated = BS2AD(nepaliDateForCreated)
            var EngBounce = BS2AD(nepaliDateForBounce)
            var EngReturn = BS2AD(nepaliDateForReturn)
            var EngPayment = BS2AD(nepaliDateForPayment)
            var EngPaymentCheque = BS2AD(nepaliDateForPaymentCheque)
            var EngPaymentReturnDate = BS2AD(paymentChequeReturnNepaliDate)
            var EngPaymentCreatedDate = BS2AD(paymentCreatedNepaliDate)
            var EngPaymentEncashDate = BS2AD(paymentChequeEncashNepaliDate)
            var FormattedEngDate = moment(Engdate).format('DD-MMM-YYYY');
            var FormattedEngDate1 = moment(Engdate1).format('DD-MMM-YYYY');
            var FormattedReceiptEngDate = moment(EngReceipt).format('DD-MMM-YYYY');
            var FormattedChequeEngDate = moment(EngCheque).format('DD-MMM-YYYY');
            var FormattedEncashEngDate = moment(EngEncash).format('DD-MMM-YYYY');
            var FormattedIntransitEngDate = moment(EngInTransit).format('DD-MMM-YYYY');
            var FormattedCreatedEngDate = moment(EngCreated).format('DD-MMM-YYYY');
            var FormattedBounceEngDate = moment(EngBounce).format('DD-MMM-YYYY');
            var FormattedReturnEngDate = moment(EngReturn).format('DD-MMM-YYYY');
            var FormattedPaymentEngDate = moment(EngPayment).format('DD-MMM-YYYY');
            var FormattedPaymentReturnEngDate = moment(EngPaymentReturnDate).format('DD-MMM-YYYY');
            var FormattedPaymentCreatedEngDate = moment(EngPaymentCreatedDate).format('DD-MMM-YYYY');
            var FormattedPaymentEncashEngDate = moment(EngPaymentEncashDate).format('DD-MMM-YYYY');
            var FormattedPaymentChequeEngDate = moment(EngPaymentCheque).format('DD-MMM-YYYY');
            $("#englishdatedocument").val(FormattedEngDate);
            $("#englishdatedocument1").val(FormattedEngDate1);
            $("#receiptEnglishDate").val(FormattedReceiptEngDate);
            $("#chequeEnglishDate").val(FormattedChequeEngDate);
            $("#encashEnglishDate").val(FormattedEncashEngDate);
            $("#inTransitEnglishDate").val(FormattedIntransitEngDate);
            $("#createdEnglishDate").val(FormattedCreatedEngDate);
            $("#bounceEnglishDate").val(FormattedBounceEngDate);
            $("#returnEnglishDate").val(FormattedReturnEngDate);
            $("#paymentEnglishDate").val(FormattedPaymentEngDate);
            $("#paymentChqueReturnEnglishDate").val(FormattedPaymentReturnEngDate);
            $("#paymentCreatedChequeEnglishDate").val(FormattedPaymentCreatedEngDate);
            $("#paymentEncashChequeEnglishDate").val(FormattedPaymentEncashEngDate);
            $("#paymentChequeEnglishDate").val(FormattedPaymentChequeEngDate);
        }
    });   
</script>
