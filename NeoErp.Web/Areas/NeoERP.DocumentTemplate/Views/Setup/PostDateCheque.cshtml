@{
    ViewBag.Title = "Post Date Cheque";
    Layout = null;
}

<style>
    .k-splitbar.k-splitbar-horizontal {
        width: 5px;
    }

    .k-calendar {
        width: 210px !important;
    }

    .k-splitter {
        height: 490px !important;
    }

    .portlet-title.mingap {
        min-height: auto !important;
    }

    .bottomspance {
        padding: 2px 15px !important;
    }

    .portlet-title.mingap {
        min-height: auto !important;
    }

    .bottomspance .portlet-body {
        padding-top: 2px !important;
    }

    .portlet {
        margin-top: 0px;
        margin-bottom: 7px !important;
    }

    .bodyController {
        margin-top: 4px;
    }

    .main .k-widget.k-dropdown.k-header {
        min-height: 22px !important;
    }

    .main .k-dropdown-wrap.k-state-default {
        min-height: 24px !important;
        font-size: 11px;
    }

    .k-splitter .k-scrollable {
        overflow-y: hidden !important;
    }

    .k-scrollable .k-widget.k-treeview {
        max-height: 444px;
        overflow: auto !important;
    }

    .k-i-calendar {
        margin-top: 0px;
    }

    span.k-icon.k-i-warning {
        display: none;
    }

    .calendar-icon-2 {
        top: 24px !important;
    }

    .k-widget.k-datepicker {
        background-color: transparent !important;
    }

    .k-grid td .k-checkbox-label {
        display: none !important;
    }

    div#ndp-nepali-box {
        z-index: 99999 !important;
    }

    .tab-content {
        border: 1px solid #ddd;
        border-top: none;
        padding: 15px;
        background-color: #fff;
    }

    .nav-tabs > li.active > a {
        background-color: #26C281 !important;
        color: #fff !important;
    }

    .nav-tabs {
        display: flex;
        flex-wrap: nowrap;
        white-space: nowrap;
    }

    .nav-tabs > li {
        flex-shrink: 0;
    }

    .nav-tabs > li > a {
        padding: 8px 12px;
        font-size: 12px;
    }

    .section-box {
        border: 1px solid #c8c8c8;
        padding: 8px 10px;
        border-radius: 3px;
        background: #d9edf7;
        margin-bottom: 10px;
    }

    .section-title {
        font-size: 13px;
        font-weight: bold;
        margin-bottom: 6px;
        color: #003366;
    }

    .form-control-sm,
    .k-input,
    input[type=text],
    input[type=number],
    select {
        height: 26px !important;
        padding: 2px 6px !important;
    }

    label.small {
        font-size: 12px !important;
        margin-bottom: 2px;
    }

    .no-padding {
        padding: 0 !important;
    }

    #createPDCModal .modal-body {
        max-height: calc(103vh - 150px); /* Adjust 150px if header/footer are taller */
        overflow-y: auto;
        overflow-x: hidden;
    }

        /* Optional: remove extra padding if you want a compact scroll */
        #createPDCModal .modal-body .section-box {
            margin-bottom: 10px;
        }
    /* Context Menu Container */
    /* Overall menu */
    .pdc-context-menu {
        font-size: 12px;
        min-width: 170px;
        padding: 0; /* remove extra outer gap */
    }

        /* Each menu item */
        .pdc-context-menu li {
            padding: 4px 8px; /* reduce top/bottom gap */
            line-height: 1.2; /* tighter text spacing */
            display: flex;
            align-items: center;
        }

            /* Icons */
            .pdc-context-menu li i {
                width: 13px;
                margin-right: 6px; /* reduce icon gap */
                font-size: 12px;
            }

        /* Separator spacing */
        .pdc-context-menu .k-separator {
            margin: 2px 0; /* reduce vertical gap */
            height: 1px;
        }

        /* Hover */
        .pdc-context-menu li:hover {
            background-color: #f2f2f2;
        }

        /* Delete highlight */
        .pdc-context-menu li.danger {
            color: #d9534f;
        }

            .pdc-context-menu li.danger i {
                color: #d9534f;
            }

    /* Force scrollbar visibility in Kendo dropdown */
    .k-list-container {
        overflow-y: auto !important;
        max-height: 350px !important;
    }


</style>

<div class="row" id="PostDateChequeCtrl" ng-controller="PostDateChequeCtrl">
    <div class="col-md-12">
        <div class="portlet light form-fit bordered bottomspance" style="width: 100%">
            <div class="portlet mingap">
                <div class="portlet-title">
                    <div class="caption caption-title ng-binding">
                        <a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/DocumentTemplate/Home/Dashboard">
                            <i class="fa fa-arrow-circle-left"></i>
                        </a>
                        <i class="fa fa-money font-green-haze"></i>
                        <span class="caption-subject font-green-haze bold uppercase">{{FormName}}</span>
                    </div>
                    <div class="actions">
                        <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="OpenAddPDCModal(event)">
                            <i class="fa fa-plus"></i> Add
                        </a>
                        <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="PrintPDC()">
                            <i class="fa fa-print"></i> Print
                        </a>

                        <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="LoadData()">
                                <i class="fa fa-file"></i> Show Report
                            </a>
                    </div>
                </div>

                <div class="portlet-body">
                    <div class="row">
                        <div class="col-md-12 col-sm-12">
                            <!-- Search Options -->
                            <div class="col-sm-2 col-md-2 col-lg-2">
                                <div class="form-group">
                                    <label for="date-range-select">Date Range:</label>
                                    <select id="date-range-select" onchange="updateDateRange(this.value)" class="form-control">
                                        <option value="today">Today</option>
                                        <option value="yesterday">Yesterday</option>
                                        <option value="month" selected>This Month</option>
                                        <option value="year">This Year</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-3 col-md-3 col-lg-3">
                                <div class="form-group">
                                    <label for="englishdatedocument">From Date:</label>
                                    <div>
                                        <input id="englishdatedocument" kendo-date-picker
                                               ng-model="FROM_DATE"
                                               k-options="monthSelectorOptionsSingle" data-toggle="tooltip"
                                               title="Select date" class="form-control fromDate" style="width: calc(50% - 5px); display: inline-block; margin-right: 5px;" />

                                        <div class="col-xs-6 col-sm-6 col-md-6 nopadding-left pl-1" style="display: inline-block; vertical-align: top;">
                                            <input type="text" id="nepaliDate5"
                                                   data-checkfor="englishdatedocument" onchange="ConvertNepToEng(this)"
                                                   data-toggle="tooltip" title="Select date" class="nepali-calendar form-control" style="width: 100%; height: 25px" />
                                            <i class="fa fa-calendar form-control-feedback calendar-icon-2" data-toggle="tooltip" title="Select date" style="top:5px !important;"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-3 col-lg-3">
                                <label for="englishdatedocument1">To Date:</label>
                                <div>
                                    <input id="englishdatedocument1" kendo-date-picker
                                           ng-model="TO_DATE"
                                           k-options="monthSelectorOptionsSingle1" data-toggle="tooltip" title="Select date" style="width: calc(50% - 5px); display: inline-block; margin-right: 5px;" class="form-control toDate" />

                                    <div class="col-xs-6 col-sm-6 col-md-6 nopadding-left pl-1" style="display: inline-block; vertical-align: top;">
                                        <input type="text" id="nepaliDate51" data-checkfor="englishdatedocument" onchange="ConvertNepToEng(this)" data-toggle="tooltip" title="Select date" class="nepali-calendar form-control" style="width: 100%; height: 25px" />
                                        <i class="fa fa-calendar form-control-feedback calendar-icon-2" data-toggle="tooltip" title="Select date" style="top:5px !important;"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-2 col-md-2 col-lg-2">
                                <div class="form-group">
                                    <label>Cheque Type:</label>
                                    <select class="form-control" ng-model="CHEQUE_TYPE_FILTER">
                                        <option value="">All</option>
                                        <option value="PDC">PDC</option>
                                        <option value="Current">Current</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-2 col-md-2 col-lg-2" ng-show="showReceiptAddButton">
                                <div class="form-group">
                                    <label>PDC Type:</label>
                                    <select class="form-control" ng-model="PDC_TYPE_FILTER" ng-change="BindPDCGrid()">
                                        <option value="">All</option>
                                        <option value="Cheque in Hand">Cheque in Hand</option>
                                        <option value="In Transit">In Transit</option>
                                        <option value="Encashed">Encashed</option>
                                        <option value="Bounced">Bounced</option>
                                        <option value="Returned">Returned</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-2 col-md-2 col-lg-2" ng-show="showPaymentAddButton">
                                <div class="form-group">
                                    <label>PDC Type:</label>
                                    <select class="form-control" ng-model="PDC_TYPE_FILTER" ng-change="LoadData()">
                                        <option value="">All</option>
                                        <option value="Cheque in Hand">Cheque in Hand</option>      
                                        <option value="Encashed">OutCashed</option>
                                        <option value="Returned">Returned</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="divider"></div>

                <!-- Tabs -->
                <ul class="nav nav-tabs" role="tablist">
                    <li role="presentation" class="active">
                        <a href="javascript:void(0);" data-target="#receipt" aria-controls="receipt" role="tab" data-toggle="tab" ng-click="setActiveTab('receipt')">
                            <i class="fa fa-file-text-o"></i> Receipt
                        </a>
                    </li>
                    <li role="presentation">
                        <a href="javascript:void(0);" data-target="#payments" aria-controls="payments" role="tab" data-toggle="tab" ng-click="setActiveTab('payments')">
                            <i class="fa fa-money"></i> Payments
                        </a>
                    </li>
                    <li role="presentation">
                        <a href="javascript:void(0);" data-target="#preferences" aria-controls="preferences" role="tab" data-toggle="tab" ng-click="setActiveTab('preferences')">
                            <i class="fa fa-cog"></i> Preferences
                        </a>
                    </li>
                        @*<li role="presentation">
                            <a href="javascript:void(0);" data-target="#report" aria-controls="report" role="tab" data-toggle="tab" ng-click="setActiveTab('report')">
                                <i class="fa fa-bar-chart"></i> Report
                            </a>
                        </li>*@
                    <li role="presentation">
                        <a href="javascript:void(0);" data-target="#summaryInfo" aria-controls="summaryInfo" role="tab" data-toggle="tab" ng-click="setActiveTab('summaryInfo')">
                            <i class="fa fa-info-circle"></i> Summary Info
                        </a>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content">
                    <div role="tabpanel" class="tab-pane active" id="receipt">
                        <div class="row">
                            <div class="" style="overflow-x: hidden">
                                @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/PartialView/_GridToolbar.cshtml")
                                <kendo-grid id="pdcGrid" options="PDCGridOptions" class="kendo_gride_table" style="width:100%;">
                                </kendo-grid>
                            </div>
                            <!-- RIGHT CLICK CONTEXT MENU -->
                            <ul id="pdcContextMenu" class="pdc-context-menu">
                                <li data-action="transit">
                                    <i class="fa fa-random"></i> Cheque in Transit
                                </li>

                                <li data-action="encash">
                                    <i class="fa fa-money"></i> Encash
                                </li>

                                <li data-action="voucher">
                                    <i class="fa fa-file-text-o"></i> Generate Voucher
                                </li>

                                <li class="k-separator"></li>

                                <li data-action="direct-bounce">
                                    <i class="fa fa-ban"></i> Direct Bounce
                                </li>

                                <li class="k-separator"></li>

                                <li data-action="return">
                                    <i class="fa fa-undo"></i> Return to Party
                                </li>

                                <li class="k-separator"></li>

                                <li data-action="delete" class="danger">
                                    <i class="fa fa-trash"></i> Delete
                                </li>
                            </ul>

                        </div>
                    </div>

                    <div role="tabpanel" class="tab-pane" id="payments">
                        <div class="row">
                            <div class="" style="overflow-x: hidden">
                                @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/PartialView/_GridToolbar.cshtml")
                                <kendo-grid id="paymentsGrid" options="PaymentsGridOptions" class="kendo_gride_table" style="width:100%;">
                                </kendo-grid>
                            </div>
                            <!-- RIGHT CLICK CONTEXT MENU -->
                            <ul id="pdcpaymentContextMenu" class="pdc-payment-context-menu">
                                @*<li data-action="transit">
                                    <i class="fa fa-random"></i> Cheque in Transit
                                </li>*@

                                <li data-action="encash">
                                    <i class="fa fa-money"></i> OutCash
                                </li>

                                <li data-action="voucher">
                                    <i class="fa fa-file-text-o"></i> Generate Voucher
                                </li>

                                <li class="k-separator"></li>

                                @*<li data-action="direct-bounce">
                                    <i class="fa fa-ban"></i> Direct Bounce
                                </li>*@

                                <li class="k-separator"></li>

                                <li data-action="return">
                                    <i class="fa fa-undo"></i> Return from Party
                                </li>

                                <li class="k-separator"></li>

                                <li data-action="delete" class="danger">
                                    <i class="fa fa-trash"></i> Delete
                                </li>
                            </ul>
                        </div>
                    </div>


                    <div role="tabpanel" class="tab-pane" id="preferences">

                        <div class="panel panel-default" style="max-width: 550px; margin: 20px auto;">
                            <div class="panel-heading">
                                <strong>Document Integration Setup</strong>
                            </div>

                            <div class="panel-body" style="background-color: #F6F9FE; ">

                                <!-- Receipt Document -->
                                <div class="form-group">
                                    <label>Receipt Document</label>
                                    <select id="customerForPDC" name="customerCode"
                                            kendo-drop-down-list
                                            k-options="formDataForReceipt"
                                            k-on-change="onChangeReceiptDocumentCode(kendoEvent)"
                                            ng-model="preferencesModel.RECEIPT_FORM_CODE" k-value-primitive="true"
                                            style="width: 95%; font-size: 12px;" required></select>
                                </div>

                                <!-- Receipt Account -->
                                <div class="form-group">
                                    <label>Receipt Account</label>
                                    <select id="chartOfAccountsForPreferences"
                                            kendo-drop-down-list
                                            k-options="accDataForReceipt"
                                            k-on-change="onChangeReceiptAccCode(kendoEvent)"
                                            ng-model="preferencesModel.RECEIPT_ACC_CODE"
                                            k-value-primitive="true"
                                            style="width: 95%; font-size: 12px;">
                                    </select>

                                </div>

                                <!-- Payment Document -->
                                <div class="form-group">
                                    <label>Payment Document</label>
                                    <select id="customerForPDC" name="customerCode"
                                            kendo-drop-down-list
                                            k-options="formDataForPayment"
                                            k-on-change="onChangePaymentDocumentCode(kendoEvent)"
                                            ng-model="preferencesModel.PAYMENT_FORM_CODE" k-value-primitive="true"
                                            style="width: 95%; font-size: 12px;" required></select>
                                </div>

                                <!-- Payment Account -->
                                <div class="form-group">
                                    <label>Payment Account</label>
                                    <select id="chartOfAccountsPayment" name="chartOfAccountsPayment"
                                            kendo-drop-down-list
                                            k-options="accDataForPayment"
                                            k-on-open="loadAccountDataForPayment()"
                                            ng-model="preferencesModel.PAYMENT_ACC_CODE" k-value-primitive="true"
                                            style="width: 95%; font-size: 12px;"></select>
                                </div>

                                <div class="text-center" style="margin-top: 20px;">
                                    <button class="btn btn-primary" ng-click="savePreference()">Save Preference</button>
                                </div>

                            </div>
                        </div>


                    </div>


                    <div role="tabpanel" class="tab-pane" id="report">
                        <p>Report tab content will be displayed here.</p>
                    </div>

                    <div role="tabpanel" class="tab-pane" id="summaryInfo">
                        <p>Summary Info tab content will be displayed here.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="createPDCModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">

                <!-- HEADER -->
                <div class="modal-header py-1 bg-primary text-white"
                     style="display:flex; justify-content:space-between; align-items:center;">

                    <h4 ng-show="!editMode" class="font-weight-bold mb-1 mt-1"
                        style="color: green; font-weight: bold; margin:0;">
                        Post Date Cheque Entry / ODC Entry
                    </h4>

                    <h4 ng-show="editMode" class="font-weight-bold mb-1 mt-1"
                        style="color: green; font-weight: bold; margin:0;">
                        Update Post Date Cheque Entry / ODC Entry
                    </h4>

                    <button type="button" class="close text-white" data-dismiss="modal"
                            ng-click="resetPdcModel()" style="margin-left:10px;">
                        <span>&times;</span>
                    </button>
                </div>

                <form name="pdcEntryForm" novalidate>

                    <div class="modal-body py-1">

                        <!-- ============================== -->
                        <!-- PDC ENTRY DETAILS -->
                        <!-- ============================== -->
                        <div class="section-box" ng-style="disableOnEdit ? {'pointer-events':'none', 'opacity':'1.5'} : {}">
                            <div class="section-title">PDC Entry Details...</div>

                            <div class="row">

                                <div class="col-md-2 p-1">
                                    <label class="small">Receipt No</label>
                                    <input type="text" ng-model="pdcModel.RECEIPT_NO" name="receiptNo" ng-readonly="true" class="form-control form-control-sm" required>
                                    <span style="font-style: italic; font-size: 12px;" class="text-danger" ng-show="pdcEntryForm.receiptNo.$touched && pdcEntryForm.receiptNo.$error.required">
                                        Receipt No is required
                                    </span>
                                </div>

                                <div class="col-md-4 p-1">
                                    <label for="receiptEnglishDate" class="small">Receipt Date | Miti</label>
                                    <div class="row no-padding">
                                        <div class="col-xs-6 no-padding">
                                            <input kendo-date-picker ng-model="pdcModel.RECEIPT_DATE" k-options="monthSelectorOptionsReceiptSingle" data-toggle="tooltip"
                                                   class="form-control" id="receiptEnglishDate" name="receiptDate" />
                                        </div>
                                        <div class="col-xs-6 no-padding">
                                            <input type="text" id="nepaliDateReceipt" class="nepali-calendar form-control"
                                                   data-checkfor="receiptEnglishDate"
                                                   data-toggle="tooltip" title="Select date" style="width: 95%; height: 25px" />
                                            <i class="fa fa-calendar form-control-feedback calendar-icon-2" data-toggle="tooltip" title="Select date" style="top:5px !important;" />
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-2 p-1">
                                    <label class="small">Cheque Type</label>

                                    <select ng-model="pdcModel.CHEQUE_TYPE"
                                            class="form-control form-control-sm"
                                            name="chequeType">
                                        <option value="PDC">PDC</option>
                                        <option value="ODC">ODC</option>
                                    </select>
                                </div>

                                <div class="col-md-4 p-1">
                                    <label class="small">Cheque Date | Miti</label>
                                    <div class="row no-padding">
                                        <div class="col-xs-6 no-padding">
                                            <input kendo-date-picker ng-model="pdcModel.CHEQUE_DATE" k-options="monthSelectorOptionsChequeSingle" data-toggle="tooltip"
                                                   class="form-control" id="chequeEnglishDate" />
                                        </div>
                                        <div class="col-xs-6 no-padding">
                                            <input type="text" id="nepaliDateForCheque" class="nepali-calendar form-control"
                                                   data-checkfor="chequeEnglishDate" onchange="ConvertNepToEnglishCheque(this)"
                                                   data-toggle="tooltip" title="Select date" style="width: 95%; height: 25px" />
                                            <i class="fa fa-calendar form-control-feedback calendar-icon-2" data-toggle="tooltip" title="Select date" style="top:5px !important;" />
                                        </div>
                                    </div>
                                </div>

                            </div>


                        </div>

                        <!-- ============================== -->
                        <!-- CUSTOMER / PARTY -->
                        <!-- ============================== -->
                        <div class="section-box" ng-style="disableOnEdit ? {'pointer-events':'none', 'opacity':'1.5'} : {}">
                            <div class="section-title">Customer / Party Details</div>

                            <div class="row">

                                <div class="col-md-3 p-1">
                                    <label class="small">Customer Code</label>
                                    <select id="customerForPDC" name="customerCode"
                                            kendo-drop-down-list
                                            k-options="customerForPDCOptions"
                                            k-on-change="onChangeCustomerCode(kendoEvent)"
                                            ng-model="pdcModel.CUSTOMER_CODE" k-value-primitive="true"
                                            style="width: 95%; font-size: 12px;" required></select>
                                    <span style="font-style: italic; font-size: 12px;" class="text-danger" ng-show="pdcEntryForm.customerCode.$touched && !pdcModel.CUSTOMER_CODE">
                                        Customer code is required
                                    </span>
                                </div>

                                <div class="col-md-3 p-1">
                                    <label class="small">Party Type</label>
                                    <input ng-model="PARTY_TYPE_EDESC" type="text" ng-readonly="true" class="form-control form-control-sm">
                                </div>

                                <div class="col-md-3 p-1">
                                    <label class="small">PDC / ODC Amount</label>
                                    <input type="number" min="0" ng-model="pdcModel.PDC_AMOUNT" name="pdcAmount"
                                           class="form-control form-control-sm" required />
                                    <span style="font-style: italic; font-size: 12px;" class="text-danger" ng-show="pdcEntryForm.pdcAmount.$touched && pdcEntryForm.pdcAmount.$error.required">
                                        Amount is required
                                    </span>
                                </div>

                                <div class="col-md-3 p-1">
                                    <label class="small">PDC / ODC Details</label>
                                    <input type="text" ng-model="pdcModel.PDC_DETAILS" name="pdcDetails" class="form-control form-control-sm" required />
                                    <span style="font-style: italic; font-size: 12px;" class="text-danger" ng-show="pdcEntryForm.pdcDetails.$touched && pdcEntryForm.pdcDetails.$error.required">
                                        Details are required
                                    </span>
                                </div>

                            </div>
                        </div>

                        <!-- ============================== -->
                        <!-- BANKING DETAILS -->
                        <!-- ============================== -->
                        <div class="section-box" ng-style="disableOnEdit ? {'pointer-events':'none', 'opacity':'1.5'} : {}">
                            <div class="section-title">Bank Details</div>

                            <div class="row">

                                <div class="col-md-3 p-1">
                                    <label class="small">Party Bank Name</label>
                                    <input type="text" name="partyBankName" ng-model="pdcModel.BANK_NAME" class="form-control form-control-sm" required>
                                    <span style="font-style: italic; font-size: 12px;" class="text-danger" ng-show="pdcEntryForm.partyBankName.$touched && pdcEntryForm.partyBankName.$error.required">
                                        Party Bank Name is required
                                    </span>
                                </div>

                                <div class="col-md-2 p-1">
                                    <label class="small">Cheque No.</label>
                                    <input type="text" name="chequeNo" ng-model="pdcModel.CHEQUE_NO"
                                           class="form-control form-control-sm"
                                           ng-blur="checkDuplicateChequeNo()" required>

                                    <!-- Required message -->
