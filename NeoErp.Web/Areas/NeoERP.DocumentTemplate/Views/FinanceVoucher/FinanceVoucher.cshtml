                                                            <input type="number" class="form-control" ng-model="reff.TDS_AMOUNT" ng-change="calculateTotalTDS(key)" style="height: 32px; font-size: 13px; text-align: right;" readonly/>
                                                        </td>*@
                                                        @* Common Column *@
