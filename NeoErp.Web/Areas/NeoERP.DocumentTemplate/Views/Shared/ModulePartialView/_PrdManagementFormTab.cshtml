                    <!-- Optional: Bootstrap's default close button, uncomment if needed -->
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <form name="lookupForm" novalidate>
                        <!-- Find Input with Search Icon -->
                        <div class="form-group">
                            <div class="input-group">
                                <input type="text" class="form-control"
                                       placeholder="Find" ng-model="searchSerialText" ng-change="filterSerials()">
                                <span class="input-group-btn">
                                    <button class="btn btn-default" type="button" ng-click="filterSerials()">
                                        <i class="fa fa-search" aria-hidden="true"></i>
                                    </button>
                                </span>
                            </div>
                        </div>

                        <!-- Resource List Table -->
                        <div class="serial-table" style=" max-height: 70vh; overflow-y: auto;">
                            <table class="table table-condensed">
                                <!-- table-condensed for compact rows -->
                                <thead>
                                    <tr>
                                        <th>Unique Name</th>
                                        <th>SERIAL NO</th>
                                        <th>Total Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="itemSerial in currentSerialItems"
                                        ng-click="selectSerial(itemSerial)"
                                        ng-dblclick="doubleClickSelectSerial(itemSerial)"
                                        @*ng-class="{selected: selectedResource === resource}"*@>
                                        <td>{{ itemSerial.RESOURCE_UNIQUE_NAME }}</td>
                                        <td>{{ itemSerial.SERIAL_NO }}</td>
                                        <td>{{itemSerial.OUTPUT_CAPACITY }} {{itemSerial.UNIT}}</td>
                                    </tr>
                                    <tr ng-if="currentSerialItems.length === 0">
                                        <td colspan="2" class="text-center">No resources found.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>


                    </form>
                </div>
                <div class="modal-footer">
                    <!-- Buttons as seen in the image -->
                    <button type="button" class="btn btn-default" ng-click="serialOk()">OK</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal" aria-label="Close" ng-click="cancel()">Cancel</button>
                </div>
            </div>
        </div>
    </div>


</div>

<script>
    var myInventoryDropzone;
    $(document).ready(function () {


        $(".accordion-toggle-resource").click(function (e) {
            e.preventDefault();
            var $target = $($(this).attr("href"));
            $(".panel-collapse").not($target).slideUp().removeClass("in");
            $target.stop(true, true).slideToggle().toggleClass("in");
        });



        $('.nav-tabs a').on('click', function (e) {
            e.preventDefault();
            if ($(this).attr('href') == '#tab_15_2') {
                $('#tab_15_2').tab('show')
            }
            if ($(this).attr('href') == '#tab_15_3') {
                $('#tab_15_3').tab('show')
            }
            if ($(this).attr('href') == '#tab_15_4') {
                $('#tab_15_4').tab('show')
            }
            if ($(this).attr('href') == '#tab_15_5') {
                $('#tab_15_5').tab('show')
            }
            if ($(this).attr('href') == '#tab_15_6') {
                $('#tab_15_6').tab('show')
            }
            //if ($(this).attr('href') == '#tab_15_7') {
            //    $('#tab_15_7').tab('show')
            //}

        });
        myInventoryDropzone = new Dropzone('#dZInventoryUploads', { // Make the whole body a dropzone
            url: "/Inventory/InventoryFileUpload/",
            thumbnailWidth: 200,
            thumbnailHeight: 75,
            autoDiscover: false,
            autoProcessQueue: false,
            addRemoveLinks: true,
            paramName: "inputFiles",
            uploadMultiple: true,
            parallelUploads: 100,
            maxFiles: 100,
            maxFileSize: 10,
        });
        myInventoryDropzone.on('sending', function (file, xhr, formData) {

            var voucherno = angular.element('#InventoryCtrl').scope().dzvouchernumber;
            var voucherdate = angular.element('#InventoryCtrl').scope().dzvoucherdate;
            var formcode = angular.element('#InventoryCtrl').scope().dzformcode;

            formData.append('VoucherNo', voucherno);
            formData.append('VoucherDate', voucherdate);
            formData.append('FormCode', formcode);

        });
        myInventoryDropzone.on("success", function (file, responseText) {

            if (responseText.status == "Error") {
                displayPopupNotification("File upload does not success. Please update.", "error");
            }
            else {
                myInventoryDropzone.removeFile(file);
            }
        });
        myInventoryDropzone.on("removedfile", function (file, xhr, formData) {

            //alert('File will be permanently deleted.');
            var filename = file.name;
            var voucherno = angular.element('#InventoryCtrl').scope().OrderNo;
            var formcode = angular.element('#InventoryCtrl').scope().formcode;
            var model = {
                FILE_NAME: filename,
                FORM_CODE: formcode,
                VOUCHER_NO: voucherno
            };
            var staturl = window.location.protocol + "//" + window.location.host + "/api/TemplateApi/deleteUploadedFile";
            $.ajax({
                type: 'POST',
                url: staturl,
                data: model,
                dataType: "json",
                success: function (data) {


                }
            });

        });
        $('#shippingterms').on('change', function () {
            // if (this.value == '1'); { No semicolon and I used === instead of ==
            if (this.value === 'FOB') {
                $("#freghtrate").show();
                $("#freghtamount").show();
            } else {
                $("#freghtrate").hide();
                $("#freghtamount").hide();
                $("#FreightRatetxt").val("");
                $("#FreightAmounttxt").val("");
            }
        });

        $("#CNNo").keyup(function (e) {
            if (/\D/g.test(this.value)) {
                // Filter non-digits from input value.
                this.value = this.value.replace(/\D/g, '');
            }
        });
    });
</script>



