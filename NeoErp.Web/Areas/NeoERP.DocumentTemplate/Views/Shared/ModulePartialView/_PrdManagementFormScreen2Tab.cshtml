<script>
    // myInventoryScreen2Dropzone
    var myInventoryScreen2Dropzone;
    $(document).ready(function () {
        $('.nav-tabs a').on('click', function (e) {
            e.preventDefault();
            if ($(this).attr('href') == '#tabScrn2_15_2') {
                $('#tabScrn2_15_2').tab('show')
            }
            if ($(this).attr('href') == '#tabScrn2_15_3') {
                $('#tabScrn2_15_3').tab('show')
            }
            if ($(this).attr('href') == '#tabScrn2_15_4') {
                $('#tabScrn2_15_4').tab('show')
            }
            if ($(this).attr('href') == '#tabScrn2_15_5') {
                $('#tabScrn2_15_5').tab('show')
            }
            if ($(this).attr('href') == '#tabScrn2_15_6') {
                $('#tabScrn2_15_6').tab('show')
            }
            //if ($(this).attr('href') == '#tab_15_7') {
            //    $('#tab_15_7').tab('show')
            //}

        });
        myInventoryScreen2Dropzone = new Dropzone('#dZInventoryUploadsScree2', { // Make the whole body a dropzone
            url: "/Inventory/InventoryFileUpload/",
            thumbnailWidth: 200,
            thumbnailHeight: 75,
            autoDiscover: false,
            autoProcessQueue: false,
            addRemoveLinks: true,
            paramName: "inputFiles",
            uploadMultiple: true,
            parallelUploads: 100,
            maxFiles: 100,
            maxFileSize: 10,
        });
        myInventoryScreen2Dropzone.on('sending', function (file, xhr, formData) {

            var voucherno = angular.element('#InventoryScrn2Ctrl').scope().dzvouchernumber;
            var voucherdate = angular.element('#InventoryScrn2Ctrl').scope().dzvoucherdate;
            var formcode = angular.element('#InventoryScrn2Ctrl').scope().dzformcode;

            formData.append('VoucherNo', voucherno);
            formData.append('VoucherDate', voucherdate);
            formData.append('FormCode', formcode);

        });
        myInventoryScreen2Dropzone.on("success", function (file, responseText) {

            if (responseText.status == "Error") {
                displayPopupNotification("File upload does not success. Please update.", "error");
            }
            else {
                myInventoryScreen2Dropzone.removeFile(file);
            }
        });
        myInventoryScreen2Dropzone.on("removedfile", function (file, xhr, formData) {

            //alert('File will be permanently deleted.');
            var filename = file.name;
            var voucherno = angular.element('#InventoryScrn2Ctrl').scope().OrderNo;
            var formcode = angular.element('#InventoryScrn2Ctrl').scope().formcode;
            var model = {
                FILE_NAME: filename,
                FORM_CODE: formcode,
                VOUCHER_NO: voucherno
            };
            var staturl = window.location.protocol + "//" + window.location.host + "/api/TemplateApi/deleteUploadedFile";
            $.ajax({
                type: 'POST',
                url: staturl,
                data: model,
                dataType: "json",
                success: function (data) {


                }
            });

        });
        $('#shippingterms').on('change', function () {
            // if (this.value == '1'); { No semicolon and I used === instead of ==
            if (this.value === 'FOB') {
                $("#freghtrate").show();
                $("#freghtamount").show();
            } else {
                $("#freghtrate").hide();
                $("#freghtamount").hide();
                $("#FreightRatetxt").val("");
                $("#FreightAmounttxt").val("");
            }
        });

        $("#CNNo").keyup(function (e) {
            if (/\D/g.test(this.value)) {
                // Filter non-digits from input value.
                this.value = this.value.replace(/\D/g, '');
            }
        });
    });
</script>



