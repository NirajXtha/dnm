                <div class="modal-footer">

                    <button class="btn btn-sm btn-green" id="savedocumentformdata" ng-click="saveNewsupplier(groupsuppliersetupform.$valid)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
