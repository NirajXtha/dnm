<div class="portlet box green-box main">

    <div class="portlet-title">
        <div class="caption ng-binding">
            <i class="fa fa-list-alt"></i>
            <span class="caption-subject bold uppercase">
                Employee Setup
            </span>
            <a class="btn-help-custom" onclick="HelpPopup.showByKey('employeeManagement')" title="Help">
                <i class="fa fa-question-circle"></i>
            </a>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="openModal()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                <i class="fa fa-plus"></i> NEW
            </a>
        </div>
    </div>

    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-8 col-md-4 search_box">
                <div class="topsearch" style="display:block;">
                    <a class="btn-linkicon fa fa-search" style="margin-right: -13px;" ng-click="BindGrid()"></a>
                    <input class="k-textbox txtSearchString"
                           type="text"
                           id="itemtxtSearchString"
                           ng-model="txtSearchString"
                           ng-change="onItemSearchChange()"
                           name="search"
                           placeholder="enter search text..."
                           style="margin-left: 13px;" />
                </div>
            </div>
        </div>

        <div id="kGrid"
             kendo-grid
             k-options="EmployeeGridOptions"
             k-ng-delay="EmployeeGridOptions">
        </div>
    </div>

    <!-- Employee Setup Modal -->
    <div class="modal fade" id="employeeModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="employee-modal-header">
                    <h4 class="modal-title">Employee Setup</h4>
                    <button type="button" class="emp-btn-close" ng-click="closeModal()">&times;</button>
                </div>
                <div class="modal-body">


                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs">
                        <li ng-class="{active: activeTab === 'personalDetails'}">
                            <a ng-click="setActiveTab('personalDetails')">Employee Details</a>
                        </li>
                        @*<li ng-class="{active: activeTab === 'officialDetails'}">
                            <a ng-click="setActiveTab('officialDetails')">Official Details</a>
                        </li>*@
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content">
                        <!-- Personal Details Tab -->
                        <div ng-show="activeTab === 'personalDetails'">
                           
                                
                                    <div class="panel-body">
                                        <form class="form-horizontal" name="employeeForm" novalidate>

                                            <div class="form-group" ng-class="{'has-error': employeeForm.empName.$invalid && employeeForm.empName.$touched}">
                                                <label class="control-label col-sm-3" for="empName">Employee Name:</label>
                                                <div class="col-sm-5 text-left">
                                                    <input type="text" name="empName" class="form-control" id="empName"
                                                           ng-model="employeeModel.EMPLOYEE_EDESC" placeholder="Enter full name" required ng-minlength="3">
                                                    <span class="text-danger" ng-show="employeeForm.empName.$error.required && employeeForm.empName.$touched">Name is required.</span>
                                                    <span class="text-danger" ng-show="employeeForm.empName.$error.minlength">Name is too short.</span>
                                                </div>
                                            </div>  

                                            <div class="form-group" ng-class="{'has-error': employeeForm.empGender.$invalid && employeeForm.empGender.$touched}">
                                                <label class="control-label col-sm-3" for="empGender">Gender:</label>
                                                <div class="col-sm-5 text-left">
                                                    <select name="empGender" class="form-control" id="empGender" ng-model="employeeModel.SEX" required>
                                                        <option disabled value="">-- Select Gender --</option>
                                                        <option value="M">Male</option>
                                                        <option value="F">Female</option>
                                                        <option value="O">Others</option>
                                                    </select>
                                                    <span class="text-danger" ng-show="employeeForm.empGender.$error.required && employeeForm.empGender.$touched">Please select a gender.</span>
                                                </div>
                                            </div>

                                            <div class="form-group" ng-class="{'has-error': employeeForm.empEmail.$invalid && employeeForm.empEmail.$touched}">
                                                <label class="control-label col-sm-3" for="empEmail">Email:</label>
                                                <div class="col-sm-5 text-left">
                                                    <input type="email" name="empEmail" class="form-control" id="empEmail"
                                                           ng-model="employeeModel.EMAIL" placeholder="Enter email address" required>
                                                    <span class="text-danger" ng-show="employeeForm.empEmail.$error.required && employeeForm.empEmail.$touched">Email is required.</span>
                                                    <span class="text-danger" ng-show="employeeForm.empEmail.$error.email">Invalid email format.</span>
                                                </div>
                                            </div>  
                                            <div class="form-group" ng-class="{'has-error': employeeForm.empMobile.$invalid && employeeForm.empMobile.$touched}">
                                                <label class="control-label col-sm-3" for="empEmail">Phone:</label>
                                                <div class="col-sm-5 text-left">
                                                    <input type="text" name="empMobile" class="form-control" id="empMobile"
                                                           ng-model="employeeModel.MOBILE" placeholder="Enter Mobile Number" required>
                                                    <span class="text-danger" ng-show="employeeForm.empMobile.$error.required && employeeForm.empMobile.$touched">Mobile Number is required.</span>
                                                </div>
                                            </div>  
                                            <div class="form-group" >
                                                <label class="control-label col-sm-3" for="empPan">PAN No:</label>
                                                <div class="col-sm-5 text-left">
                                                    <input type="text"
                                                           class="form-control"
                                                           id="empPan"
                                                           ng-model="employeeModel.PAN_NO"
                                                           placeholder="Enter pan no">
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                               
                           
                        </div>
                        <!-- Official Details Tab -->
                        <!--<div ng-show="activeTab === 'officialDetails'">
                            <h4>Official Details</h4>
                            <p>Official details content goes here...</p>-->
                            <!-- Add your form fields here -->
                        <!--</div>-->
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button"
                            ng-hide="isUpdate"
                            class="btn btn-footer btn-save"
                            ng-click="save()">
                        Save
                    </button>

                    <button type="button" 
                            ng-show="isUpdate"
                            class="btn btn-footer btn-save"
                            ng-click="update()">
                        Update
                    </button>

                    <button type="button"
                            class="btn btn-footer btn-cancel"
                            ng-click="closeModal()">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    @Html.Partial("~/Views/Shared/Helper/GlobalHelper.cshtml")

</div>

<script>
    // Register help content for Employee Setup page
    HelpPopup.register(
        'employeeManagement',
        'Employee Management Help',
        [
            // Page 1 - Overview and Table Management
            `
                <h4>Employee Setup - Overview</h4>
                <p>This page allows you to manage the records of all employees within the organization. You can view, search, and organize employee data from a centralized table.</p>

                <h5>Key Features:</h5>
                <ul>
                    <li><strong>Add New Employee:</strong> Click the "+ NEW" button in the top right corner to register a new staff member.</li>
                    <li><strong>Search Records:</strong> Use the search bar at the top right of the table to filter by name, ID, or mobile number.</li>
                    <li><strong>Pagination:</strong> Navigate through large lists using the footer controls. You can also adjust how many items appear per page (e.g., 50 items).</li>
                    <li><strong>Status Tracking:</strong> Monitor whether an employee is currently "Working" or inactive.</li>
                </ul>

                <h5>Quick Actions:</h5>
                <p>In the "Action" column, you will find:</p>
                <ul>
                    <li><i class="fa fa-edit"></i> <strong>Edit (Green Icon):</strong> Click to modify existing employee details.</li>
                    <li><i class="fa fa-trash"></i> <strong>Delete (Red Icon):</strong> Remove an employee record from the system.</li>
                </ul>
            `,

            // Page 2 - Creating a New Employee
            `
                <h4>Creating and Editing Employees</h4>
                <p>When you click "+ NEW" or the Edit icon, the Employee Details form will appear.</p>

                <h5>Required Information:</h5>
                <ul>
                    <li><strong>Employee Name:</strong> Enter the full legal name of the staff member.</li>
                    <li><strong>Gender:</strong> Select the gender from the dropdown menu.</li>
                    <li><strong>Email:</strong> Provide a valid email address for official communication.</li>
                    <li><strong>Phone:</strong> Enter the mobile number (e.g., 984xxxxxxx).</li>
                    <li><strong>PAN No:</strong> Enter the Permanent Account Number for tax and payroll purposes.</li>
                </ul>

                <h5>Saving Records:</h5>
                <ol>
                    <li>Fill in all the required fields in the popup form.</li>
                    <li>Click the <strong>"Save"</strong> button (Green) to commit the changes.</li>
                    <li>Click <strong>"Cancel"</strong> (Red) or the "X" in the top corner to discard changes and close the form.</li>
                </ol>
            `,

            // Page 3 - Best Practices and Data Integrity
            `
                <h4>Best Practices and Tips</h4>

                <h5>Data Accuracy:</h5>
                <ul>
                    <li><strong>Unique Identifiers:</strong> Ensure the PAN and Mobile numbers are unique to avoid duplicate records.</li>
                    <li><strong>Consistent Formatting:</strong> Enter names in Title Case (e.g., Abadh Narayan Chaudhary) for professional reporting.</li>
                    <li><strong>Validation:</strong> Double-check the email format before saving to ensure system notifications are delivered correctly.</li>
                </ul>

                <h5>System Organization:</h5>
                <ul>
                    <li><strong>Department/Designation:</strong> Ensure these fields are filled (via the edit screen) to group employees correctly for payroll and attendance.</li>
                    <li><strong>Regular Audits:</strong> Periodically review the employee list to update the "Status" of staff members who are no longer with the company.</li>
                </ul>

                <h5>Helpful Reminder:</h5>
                <p>If you cannot find a specific employee, check the "items per page" setting or use the search box to see if they are on a different page of the results.</p>
            `
        ]
    );
</script>

