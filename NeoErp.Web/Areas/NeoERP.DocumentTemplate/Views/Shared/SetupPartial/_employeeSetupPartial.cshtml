 /*These CSS are for Confirm popup*/
/* Modal Overlay */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
}



/* Modal Header */
    .modal-header {
        padding: 20px 24px;
        background-color: #4caf50 !important;
        border-bottom: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
    }

.modal-header h3 {
    margin: 0;
    font-size: 22px;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.3px;
    flex: 1;
}

/* Close Button */
.btn-close {
    background: transparent;
    border: none;
    color: #ffffff;
    font-size: 24px;
    cursor: pointer;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: all 0.2s ease;
    margin-left: 16px;
}

.btn-close:hover {
    background-color: rgba(255, 255, 255, 0.2);
    transform: rotate(90deg);
}

.btn-close:active {
    background-color: rgba(255, 255, 255, 0.3);
}

.btn-close i {
    line-height: 1;
}

/* Modal Body */
.modal-body {
    padding: 32px 24px 24px 24px;
    text-align: center;
}

.warning-icon {
    margin-bottom: 20px;
}

.warning-icon i {
    font-size: 56px;
    color: #f59e0b;
    filter: drop-shadow(0 2px 4px rgba(245, 158, 11, 0.3));
}

.confirmation-message {
    font-size: 17px;
    color: #374151;
    margin-bottom: 20px;
    font-weight: 500;
    line-height: 1.5;
}

.employee-details {
    background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
    padding: 16px 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    border: 1px solid #e5e7eb;
}

.employee-details strong {
    display: block;
    font-size: 18px;
    color: #1f2937;
    margin-bottom: 6px;
    font-weight: 600;
}

.employee-details span {
    font-size: 15px;
    color: #6b7280;
    font-weight: 500;
}

.warning-text {
    font-size: 14px;
    color: #ef4444;
    margin: 0;
    font-weight: 500;
}

/* Modal Footer */
.modal-footer {
    padding: 20px 24px;
    border-top: 1px solid #e5e7eb;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    background-color: #fafafa;
}

/* Buttons */
.btn-cancel,
.btn-delete {
    padding: 11px 24px;
    border: none;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 120px;
}

.btn-cancel {
    background-color: #ffffff;
    color: #374151;
    border: 2px solid #d1d5db;
}

.btn-cancel:hover {
    background-color: #f9fafb;
    border-color: #9ca3af;
    transform: translateY(-1px);
}

.btn-cancel:active {
    transform: translateY(0);
}

.btn-delete {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
}

.btn-delete:hover {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    transform: translateY(-1px);
}

.btn-delete:active {
    transform: translateY(0);
}

/* Animations */
@@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

@@keyframes slideDown {
    from {
        transform: translateY(-100px) scale(0.95);
        opacity: 0;
    }
    to {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
}


