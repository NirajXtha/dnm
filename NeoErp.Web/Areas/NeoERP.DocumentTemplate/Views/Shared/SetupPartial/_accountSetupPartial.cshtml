<script>
    // Prem Prakash Dhakal 01-05-2025

    let sortDirection = "asc";
    $("#acctxtSearchString").on("keyup", function () {
        var searchTerm = $(this).val().toLowerCase().trim();
        filterAndSortGrid(searchTerm, sortDirection);
    });

    $(".fa-search").on("click", function () {
        sortDirection = (sortDirection === "asc") ? "desc" : "asc";
        var searchTerm = $("#acctxtSearchString").val().toLowerCase().trim();
        filterAndSortGrid(searchTerm, sortDirection);
    });

    function filterAndSortGrid(searchTerm, direction) {
        var grid = $("#kGrid").data("kendoGrid");
        var dataSource = grid.dataSource;
        dataSource.filter({});
        if (searchTerm) {
            dataSource.filter({
                logic: "or",
                filters: grid.columns
                    .filter(col => col.field)
                    .map(col => ({
                        field: col.field,
                        operator: function (value) {
                            return value && value.toString().toLowerCase().includes(searchTerm);
                        }
                    }))
            });
        }
        const firstField = grid.columns.find(col => col.field)?.field;
        if (firstField) {
            dataSource.sort({
                field: firstField,
                dir: direction
            });
        }
    }
</script>
<script>
    $(document).ready(function () {
        function createDateFromString(dateString) {
            const regex = /^\d{4}-\d{2}-\d{2}$/;
            if (!regex.test(dateString)) {
                console.error("Invalid date format. Expected YYYY-MM-DD.");
                return null;
            }

            const parts = dateString.split('-');
            const year = parseInt(parts[0], 10);
            const month = parseInt(parts[1], 10) - 1;
            const day = parseInt(parts[2], 10);

            const date = new Date(year, month, day);

            if (date.getFullYear() !== year || date.getMonth() !== month || date.getDate() !== day) {
                console.error("Invalid date components. Date created does not match input.");
                return null;
            }

            return date;
        }

