<style>
    .k-animation-container, .k-widget, .k-widget *, .k-animation-container *, .k-widget ::before, .k-animation-container ::after, .k-block .k-header, .k-list-container {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
    }

    /* .k-grid-content {
            height: 285px !important;
        }*/
    /* .k-grid-content {
            height: 280px !important;
        }*/

    .k-grid-content {
        height: 310px !important;
    }

    #kGrid {
        height: 427px !important;
    }

    .addcolor {
        color: #ffffff;
    }

    .k-list.k-reset {
        overflow: auto;
    }

    #pane1 {
        position: absolute !important;
        top: 0px !important;
        width: 302px !important;
        /*height: 510px !important;*/
        left: 0px !important;
    }

    .k-animation-container {
        max-height: 250px;
        overflow-y: auto !important;
    }

    .bordered-radio-group {
        border: 1px solid lightgray;
        border-radius: 5px;
        padding: 2px 5px;
    }

    div#ndp-nepali-box {
        z-index: 10076 !important;
    }

    #reportModal {
        display: none !important;
    }

    /* Desktop alignment styling to mimic legacy app (neutral colors per request) */
    .desktop-strip {
        padding: 8px 12px;
        margin-bottom: 8px;
        border: 0;
    }
    .desktop-strip label { font-weight: normal; }
    .ledger-panel {
        padding: 12px 10px 6px 10px;
        border: 0;
        border-radius: 2px;
        margin-bottom: 8px;
    }
    .ledger-panel .control-label { font-weight: normal; }
    .ledger-panel .form-control, .ledger-panel .k-dropdown { height: 26px; padding: 2px 6px; }
    .ledger-panel .bordered-radio-group { background: rgba(255,255,255,0.6); }

        /* Remove grey border from Under Group PL/BS dropdown (Kendo renders a widget after the select) */
        /* Handle multiple Kendo structures and states */
        .ledger-panel select#masteraccountcode1 + span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 + span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 + span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 ~ span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 ~ span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 ~ span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode1 + span.k-dropdown > span.k-picker-wrap,
        .ledger-panel select#masteraccountcode1 ~ span.k-dropdown > span.k-picker-wrap,
        .ledger-panel select#masteraccountcode_bs + span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs + span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs + span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs ~ span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs ~ span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs ~ span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_bs + span.k-dropdown > span.k-picker-wrap,
        .ledger-panel select#masteraccountcode_bs ~ span.k-dropdown > span.k-picker-wrap,
        .ledger-panel select#masteraccountcode_pl + span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl + span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl + span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl ~ span.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl ~ span.k-widget.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl ~ span.k-combobox > span.k-dropdown-wrap,
        .ledger-panel select#masteraccountcode_pl + span.k-dropdown > span.k-picker-wrap,
        .ledger-panel select#masteraccountcode_pl ~ span.k-dropdown > span.k-picker-wrap {
            border: 0 !important;
            box-shadow: none !important;
            background: transparent !important;
        }
        /* If Kendo transfers the class from the <select> to the generated wrapper */
        .ledger-panel span.borderless-kendo.k-dropdown > span.k-dropdown-wrap,
        .ledger-panel span.borderless-kendo.k-combobox > span.k-dropdown-wrap,
        .ledger-panel span.borderless-kendo .k-dropdown-wrap,
        .ledger-panel .borderless-kendo .k-dropdown-wrap {
            border: 0 !important;
            box-shadow: none !important;
            background: transparent !important;
        }
        /* Also ensure inner parts don't re-introduce a frame */
        .ledger-panel .borderless-kendo + span.k-dropdown .k-input,
        .ledger-panel .borderless-kendo + span.k-dropdown .k-select,
        .ledger-panel .borderless-kendo + span.k-dropdown .k-picker-wrap,
        .ledger-panel .borderless-kendo + span.k-dropdown .k-dropdown-wrap,
        .ledger-panel span.borderless-kendo .k-input,
        .ledger-panel span.borderless-kendo .k-select {
            border: 0 !important;
            box-shadow: none !important;
            background: transparent !important;
        }
            /* Disabled variants */
            .ledger-panel .borderless-kendo + span.k-dropdown .k-dropdown-wrap.k-state-disabled,
            .ledger-panel .borderless-kendo + span.k-dropdown .k-picker-wrap.k-state-disabled,
            .ledger-panel span.borderless-kendo .k-dropdown-wrap.k-state-disabled,
            .ledger-panel span.borderless-kendo .k-picker-wrap.k-state-disabled {
                border: 0 !important;
                box-shadow: none !important;
                background: transparent !important;
            }

        /* Also override hover/focus states */
        .ledger-panel select#masteraccountcode1 + span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode1 + span.k-dropdown > span.k-dropdown-wrap.k-state-focused,
        .ledger-panel select#masteraccountcode1 ~ span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode1 ~ span.k-dropdown > span.k-dropdown-wrap.k-state-focused,
        .ledger-panel select#masteraccountcode_bs + span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode_bs + span.k-dropdown > span.k-dropdown-wrap.k-state-focused,
        .ledger-panel select#masteraccountcode_bs ~ span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode_bs ~ span.k-dropdown > span.k-dropdown-wrap.k-state-focused,
        .ledger-panel select#masteraccountcode_pl + span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode_pl + span.k-dropdown > span.k-dropdown-wrap.k-state-focused,
        .ledger-panel select#masteraccountcode_pl ~ span.k-dropdown > span.k-dropdown-wrap.k-state-hover,
        .ledger-panel select#masteraccountcode_pl ~ span.k-dropdown > span.k-dropdown-wrap.k-state-focused {
            border: 0 !important;
            box-shadow: none !important;
        }

    /* Align Nature of Ledger to the far right – remove right gutter on the right column */
    .strip-right { padding-right: 15px !important; display: flex; justify-content: flex-end; align-items: center; }
    .strip-right > span { margin-right: 0 !important; }
    .strip-right .k-dropdown, .strip-right .k-picker-wrap, .strip-right .k-dropdown-wrap { margin-right: 0 !important; }

