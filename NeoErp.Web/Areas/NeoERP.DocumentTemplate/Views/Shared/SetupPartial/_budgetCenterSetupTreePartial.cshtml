
<style>
    .btnadd {
        margin-top: 2px;
        float: right;
        margin-right: 5px !important;
    }

    /* Ensure vertical scrolling for long budget center trees */
    #budgetcentertree {
        max-height: 60vh;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px; /* avoid scrollbar overlay */
    }

    #accounttree {
        margin-top: 30px;
    }

    .addcolor {
        color: #ffffff;
    }
</style>
@*<div ng-controller="accountSetupTreeCtrl">*@

<div class="portlet box green-box main">
    <budget></budget>
    <div class="portlet-title">
        <div class="caption ">
            <i class="icon-pin"></i>
            <span class="caption-subject bold uppercase">Budget Center</span>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm" id="adddocumentformdata" ng-click="addnewaccount(event)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> processing..." href="javascript:;">
                <i class="fa fa-plus addcolor"></i>
            </a>
        </div>
    </div>

    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-0 col-md-12">
                <div class="topmaingroupsearch">
                    <input class="k-textbox txtMainGroupSearchString"
                           type="text"
                           ng-model="txtMainGroupSearchString"
                           ng-change="filterTreeView()"
                           placeholder="Search Budget"
                           style="width:100%" />
                </div>
            </div>
        </div>
        <div id="budgetcentertree" class="disableLeftClickOnTree" kendo-tree-view="tree"
             k-data-source="budgetcentertreeData"
             k-options="bcoptions"
             k-data-bound="bconDataBound">
            <span k-template ng-click="BindGrid(dataItem.masterBudgetCenterCode)">
                {{dataItem.BUDGET_EDESC}}
            </span>
        </div>
        <ul kendo-context-menu
            k-filter="'.hasTreeCustomMenu'"
            k-on-open="menuOpen = menuOpen + 1"
            k-on-close="menuOpen = menuOpen - 1"
            k-on-select="onContextSelect(kendoEvent)">
            <li>Add</li>
            <li>Update</li>
            <li>Delete</li>
        </ul>
        <ul kendo-context-menu k-filter="'.disableLeftClickOnTree'"></ul>
    </div>
</div>
