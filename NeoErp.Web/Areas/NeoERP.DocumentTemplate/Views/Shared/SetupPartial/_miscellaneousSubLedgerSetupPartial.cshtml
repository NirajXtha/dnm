<style>
    .mb-0 {
        margin-bottom: 0px !important;
    }

    .k-animation-container, .k-widget, .k-widget *, .k-animation-container *, .k-widget ::before, .k-animation-container ::after, .k-block .k-header, .k-list-container {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
    }

    .addcolor {
        color: #ffffff;
    }

    div#ndp-nepali-box {
        z-index: 10076 !important;
    }

    div#ndp-nepali-box {
        font-family: 'Trebuchet MS', Tahoma, Verdana, Arial, sans-serif;
        border: 1px solid #CCC;
        background-color: #FFF;
        position: absolute;
        z-index: 9999;
        padding: 1px;
        margin-top: 1px;
    }
</style>
<div class="portlet box green-box main">

    <div class="portlet-title">
        <div class="caption ng-binding">
            <i class="fa fa-list-alt"></i>
            <span class="caption-subject bold uppercase">
                Miscellaneous Sub Ledger List
            </span>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="showModalForNew(event)" ng-disabled="treenodeselected!= 'Y'">
                <i class="fa fa-plus"></i> NEW
            </a>
        </div>
    </div>
    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-8 col-md-4 search_box">
                <div class="topsearch" style="display:block;">
                    <a class="btn-linkicon fa fa-search" style="margin-right: -13px;" ng-click="BindGrid('All')"></a>
                    <input class="k-textbox txtSearchString" type="text" id="misctxtSearchString" ng-model="txtSearchString" name="search" placeholder="enter search text..." style="margin-left: 13px;" />

                </div>
            </div>
        </div>
        <kendo-grid id="kGrid" options="miscellaneousSubLedgerChildGridOptions" k-rebind="miscellaneousSubLedgerChildGridOptions">
        </kendo-grid>
    </div>
    <div class="modal fade-out" id="miscellaneousSubLedgerModal" data-backdrop="static" tabindex="-1" data-width="760">
        <div class="modal-dialog modal-dialog-box popup">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</button>
                    <h4 class="modal-title">
                        <span class="fa fa-file"></span>
                        Miscellaneous Sub Ledger Setup
                    </h4>
                </div>

                <div class="modal-body">
                    <form id="miscellaneousSubLedgerArrform" name="miscellaneousSubLedgerArrform" class="form-horizontal" novalidate ng-if="miscellaneousSubLedgerArr.GROUP_SKU_FLAG == 'G'">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="row">
                                <div class="col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Group Code</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="autoGenCode" ng-model="miscellaneousSubLedgerArr.CHILD_AUTOGENERATED" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-offset-2 col-sm-offset-2 col-md-6 col-sm-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Parent Group:</label>
                                        <div class="col-sm-12">
                                            <select id="mastermiscellaneoussubledgercode" kendo-drop-down-list
                                                    k-options="miscellaneousSubLedgerGroupOptions"
                                                    ng-model="miscellaneousSubLedger.PARENT_MISC_CODE"
                                                    style="width: 100%" disabled></select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">
                                            Master Code
                                        </label>
                                        <div class="col-sm-12">
                                            <input type="text" id="masterMiscCode" name="masterMisCode" ng-model="miscellaneousSubLedger.MASTER_MISC_CODE" class="form-control" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-offset-2 col-md-offset-2 col-md-6 col-sm-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">
                                            Name In English:<span style="color:red" ng-show="miscellaneousSubLedgerArrform.miscEnglishName.$invalid">
                                                <span ng-show="miscellaneousSubLedgerArrform.miscEnglishName.$error.required">*</span>
                                            </span>
                                        </label>
                                        <div class="col-sm-12">
                                            <input type="text" id="miscEnglishName" name="miscEnglishName" ng-model="miscellaneousSubLedgerArr.MISC_EDESC" class="form-control" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <form id="miscellaneousSubLedgerArrform" name="miscellaneousSubLedgerArrform" class="form-horizontal" novalidate ng-if="miscellaneousSubLedgerArr.GROUP_SKU_FLAG != 'G'">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="row">
                                <div class="col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Auto Gen. Code:</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="autoGenCode" ng-model="miscellaneousSubLedgerArr.CHILD_AUTOGENERATED" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-8 col-sm-8">
                                    <div class="form-group">
                                        <fieldset class="fieldset-box">
                                            <legend>Type Flag</legend>
                                            <div class="radiobox">
                                                <label class="col-sm-6 col-md-6">
                                                    <input type="radio" name="miscType" ng-model="miscellaneousSubLedgerArr.GROUP_SKU_FLAG" value="G" ng-disabled="groupschilddisabled"> Group
                                                </label>
                                                <label class="col-sm-6 col-md-6">
                                                    <input type="radio" name="miscType" ng-model="miscellaneousSubLedgerArr.GROUP_SKU_FLAG" value="I" ng-disabled="groupschilddisabled"> Individual
                                                </label>
                                            </div>
                                        </fieldset>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-2 col-sm-2">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Master ID:</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="masterId" ng-model="miscellaneousSubLedger.MASTER_MISC_CODE" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Parent Group:</label>
                                        <div class="col-sm-12">
                                            <select id="mastermiscellaneoussubledgercode" kendo-drop-down-list
                                                    k-options="miscellaneousSubLedgerGroupOptions"
                                                    ng-model="miscellaneousSubLedger.PARENT_MISC_CODE"
                                                    style="width: 100%" disabled></select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">
                                            Name In English:<span style="color:red" ng-show="miscellaneousSubLedgerArrform.miscEnglishName.$invalid">
                                                <span ng-show="miscellaneousSubLedgerArrform.miscEnglishName.$error.required">*</span>
                                            </span>
                                        </label>
                                        <div class="col-sm-12">
                                            <input type="text" id="miscEnglishName" name="miscEnglishName" ng-model="miscellaneousSubLedgerArr.MISC_EDESC" class="form-control" required />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Address:</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="address" ng-model="miscellaneousSubLedgerArr.REGD_OFFICE_EADDRESS">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Account Map:</label>
                                        <div class="col-sm-12">
                                            <select id="custaccountMultiSelect" ng-model="miscellaneousSubLedgerArr.ACC_CODE" k-value-primitive="true" k-ng-model="miscellaneousSubLedgerArr.ACC_CODE" name="custaccountMultiSelect" kendo-drop-down-list
                                                    k-options="custaccountOptions" k-on-change="onChangecustaccount(kendoEvent)"
                                                    style="width: 100%"></select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">TPIN Vat No.:</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="tpinVatNo" ng-model="miscellaneousSubLedgerArr.VAT_NO">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2 col-sm-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Tel / Mobile:</label>
                                        <div class="col-sm-12">
                                            <input type="text" class="form-control" id="telMobile" ng-model="miscellaneousSubLedgerArr.TEL_MOBILE_NO1">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 col-sm-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-12">Subledger Type</label>
                                        <div class="col-sm-12">
                                            <select id="subledgerType" ng-model="miscellaneousSubLedgerArr.SL_TYPE" k-value-primitive="true" k-ng-model="miscellaneousSubLedgerArr.SUB_LEDGER_FLAG" ng-change="OnSubLedgerFlagChange()" name="subledgerType" style="width: 100%" kendo-drop-down-list>
                                                <option value="NL">Normal</option>
                                                <option value="LO">Loan</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row" ng-if="miscellaneousSubLedgerArr.SL_TYPE == 'LO'">
                                @*<div class="col-sm-3 col-md-3">
            <div class="form-group">
            </div>
        </div>*@
                                <div class="col-sm-6 col-md-6">
                                    <div class="row">
                                        <div class="col-sm-12 col-md-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">Opening Date</label>
                                                <div class="col-sm-4 col-md-4 col-lg-4 english_date">
                                                    <input style="width:100%;" id="englishdatedocument5" name="englishdatedocument5" class="englishdate" kendo-date-picker
                                                           ng-model="miscellaneousSubLedgerArr.ACC_OPENING_DATE"
                                                           k-options="monthSelectorOptions" ng-change="OnOpeningDateChange()" />

                                                </div>
                                                <div class="col-sm-4 col-md-4 col-lg-4 nepali_date">
                                                    <input type="text" id="nepaliDate5" name="nepaliDate5" data-checkfor="englishdatedocument5" class="nepali-calendar5 nepalidate form-control" next-on-tab />
                                                    <i class="fa fa-calendar form-control-feedback calendar-icon-2"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-12 col-md-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">Maturity Date</label>
                                                <div class="col-sm-4 col-md-4 col-lg-4 english_date">
                                                    <input style="width:100%;" type="text" id="englishdatedocument6" class="englishdate" name="englishdatedocument6" ng-model="miscellaneousSubLedgerArr.MATURITY_DATE" kendo-date-picker k-options="monthSelectorOptions" ng-change="OnMaturityDateChange()" />
                                                </div>

                                                <div class="col-sm-4 col-md-4 col-lg-4 nepali_date">
                                                    <input type="text" id="nepaliDate6" data-checkfor="englishdatedocument6" name="nepaliDate6" class="nepali-calendar6 nepalidate form-control" />
                                                    <i class="fa fa-calendar form-control-feedback calendar-icon-2"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-12 col-md-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3 col-md-3 col-lg-3">Total # Days:</label>
                                                <div class="col-sm-4 col-md-4">
                                                    <input type="text" id="totalDays" name="TOTAL_DAYS" ng-model="miscellaneousSubLedgerArr.MATURITY_DAYS" class="form-control" readonly />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6">
                                    <div class="row">
                                        <div class="col-sm-offset-4 col-md-offset-4 col-sm-8 col-md-8">
                                            <label class="control-label">
                                                Bank Account No:
                                            </label>
                                            <div>
                                                <input type="text" id="accountno" name="accountno" ng-model="miscellaneousSubLedgerArr.BANK_ACCOUNT_NO" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-offset-4 col-md-offset-4 col-sm-8 col-md-8">
                                            <label class="control-label">
                                                Bank Loan A/c Limit:
                                            </label>
                                            <div>
                                                <input type="text" id="limit" name="limit" ng-model="miscellaneousSubLedgerArr.LIMIT" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row" style="margin: 5px 0;">
                                        <div class="col-sm-12 col-md-12">
                                            <div class="form-group">
                                                <label class="control-label col-sm-offset-4 col-md-offset-4 col-sm-6 col-md-6">Alert prior maturity Days:</label>
                                                <div class="col-sm-2 col-md-2">
                                                    <select id="maturityDays"
                                                            name="MATURITY_DAYS"
                                                            ng-model="miscellaneousSubLedgerArr.PRIOR_ALERT_DAYS"
                                                            class="form-control"
                                                            ng-options="n for n in [] | range:1:100">
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-7 col-md-7 col-lg-7" id="accountInterestTableContainer">
                                    @* This will be Rendered from miscellaneousSubLedgerTreeCtrl *@
                                </div>
                                <div class="col-sm-offset-1 col-md-offset-1 col-lg-offset-1 col-sm-4 col-md-4 col-lg-4">
                                    <div class="row">
                                        <div class="col-sm-12 col-md-12 col-lg-12">
                                            <fieldset class="fieldset-box">
                                                <legend class="planOption">Interest Payment/Receive</legend>
                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-group">
                                                        <input type="radio" id="contactChoice1" ng-model="miscellaneousSubLedgerArr.LOAN_TERMS" name="contact" value="M" ng-checked>
                                                        <label for="contactChoice1">Monthly Basis</label> <br />
                                                        <input type="radio" id="contactChoice2" ng-model="miscellaneousSubLedgerArr.LOAN_TERMS" name="contact" value="Q">
                                                        <label for="contactChoice2">Quarterly Basis</label><br />
                                                        <input type="radio" id="contactChoice3" ng-model="miscellaneousSubLedgerArr.LOAN_TERMS" name="contact" value="Y">
                                                        <label for="contactChoice3">Yearly Basis</label><br />
                                                    </div>
                                                </div>
                                            </fieldset>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <hr />
                <div class="modal-footer" style="border-top: none;">
                    <button type="button" class="btn btn-sm btn-default" data-dismiss="modal" ng-click="SubLedger_Cancel($index)">Cancel</button>
                    <button type="button" class="btn btn-sm btn-green" id="savedocumentformdata" ng-click="saveNewMiscellaneousSubLedger((miscellaneousSubLedgerArrform.$valid))" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                        <i class="fa fa-floppy-o"></i> {{saveupdatebtn}}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger
        $(".topsearch").hide();
        $("#misctxtSearchString").keyup(function () {
            var val = $('#misctxtSearchString').val();
            $("#kGrid").data("kendoGrid").dataSource.filter({
                logic: "or",
                filters: [
                    {
                        field: "MISC_CODE",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "MISC_EDESC",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "REMARKS",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "CREATED_BY",
                        operator: "contains",
                        value: val
                    }
                ]
            });
        });
        setTimeout(function () {
            $('.k-list').slimScroll({
                height: '250px'
            });
        }, 100);
        $('.nav-tabs a').on('click', function (e) {
            e.preventDefault();
            //if ($(this).attr('href') == '#tab_1') {
            //    $('#tab_1').tab('show')
            //}
            if ($(this).attr('href') == '#tab_2') {
                $('#tab_2').tab('show')
            }
        });
    });
</script>
<script src="@Scripts.Url("~/JS/reportFilter.js")"></script>
<script>
    $(document).ready(function () {
        $(".nepali-calendar5").nepaliDatePicker({
            npdMonth: true,
            onFocus: true,
            npdYear: true,
            npdYearCount: 10,
            altFormat: "dd-MMM-YYYY",
            dateFormat: "dd-MMM-YYYY",
            onChange: function (evt) {
                debugger
                var nepalidate = $("#nepaliDate5").val();
                var Engdate = BS2AD(nepalidate);

                $("#englishdatedocument5").val(Engdate);

                var openingDate = $('#nepaliDate5').val();
                var maturityDate = $('#nepaliDate6').val();
                var oDate = moment(openingDate).format("MM-DD-YYYY");
                var mDate = moment(maturityDate).format("MM-DD-YYYY");
                if (maturityDate != "") {
                    if (mDate < oDate) {
                        $('#nepaliDate5').val("");
                        $('#englishdatedocument5').val("");
                        $("#savedocumentformdata").prop("disabled", true);
                        displayPopupNotification("Start date must be less than End Date!", "warning");
                        return;
                    }
                    else {
                        let maturityMomentDate = moment(maturityDate)
                        let openingMomentDate = moment(openingDate)
                        let dateDifference = maturityMomentDate.diff(openingMomentDate, 'days');
                        $("#totalDays").val(dateDifference)
                        $("#savedocumentformdata").prop("disabled", false);
                    }

                }
            }
        });
        $(".nepali-calendar6").nepaliDatePicker({
            ndpEnglishInput: 'englishdatedocument6',
            npdMonth: true,
            onFocus: true,
            npdYear: true,
            npdYearCount: 10,
            altFormat: "dd-MMM-YYYY",
            dateFormat: "dd-MMM-YYYY",
            onChange: function (evt) {
                debugger
                var nepalidate = $("#nepaliDate6").val();
                var Engdate = BS2AD(nepalidate);

                $("#englishdatedocument6").val(Engdate);

                var openingDate = $('#nepaliDate5').val();
                var maturityDate = $('#nepaliDate6').val();

                var oDate = moment(openingDate).format("MM-DD-YYYY");
                var mDate = moment(maturityDate).format("MM-DD-YYYY");
                if (mDate < oDate) {
                    $('#nepaliDate6').val("");
                    $('#englishdatedocument6').val("");
                    $("#savedocumentformdata").prop("disabled", true);
                    displayPopupNotification("End  date must be greater than Start Date!", "warning");
                    return;
                }
                else {
                    let maturityMomentDate = moment(maturityDate)
                    let openingMomentDate = moment(openingDate)
                    let dateDifference = maturityMomentDate.diff(openingMomentDate, 'days');
                    $("#totalDays").val(dateDifference)
                    $("#savedocumentformdata").prop("disabled", false);
                }
            }
        });
    })
</script>