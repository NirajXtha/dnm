<div class="portlet box green-box main">
    <div class="portlet-title">
        <div class="caption ng-binding">
            <i class="fa fa-list-alt"></i>
            <span class="caption-subject bold uppercase">
                Dealer
            </span>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="AddChildDealer(event)" ng-disabled="treenodeselected!= 'Y'">
                <i class="fa fa-plus"></i> New
            </a>
        </div>
    </div>
    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-8 col-md-4 search_box">
                <div class="topsearch">
                    <a class="btn-linkicon fa fa-search" @*ng-click="BindSearchGrid()" *@></a>
                    <input class="k-textbox txtSearchString" type="text" id="custtxtSearchString" ng-model="txtSearchString" name="search" placeholder="enter search text..." />
                </div>
            </div>
        </div>
        <kendo-grid id="kGrid" options="dealerChildGridOptions" k-rebind="dealerChildGridOptions">
        </kendo-grid>
    </div>
    <div class="modal fade-out" id="dealerModal" data-backdrop="static" tabindex="-1" data-width="760">
        <div class="modal-dialog  modal-dialog-box popup">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" ng-click="resetFormValidation()" aria-hidden="true" next-on-tab>&times;</button>
                    <h4 class="modal-title">
                        <span class="fa fa-file"></span>
                        Dealer Information
                    </h4>
                </div>
                <div class="modal-body">
                    <fieldset class="fieldset-box">
                        <legend style="text-align: right;">
                            <label>
                                <input type="checkbox" ng-model="dealerArr.IS_ACTIVE" /> InActive Dealer
                            </label>
                        </legend>
                        <form name="dealerform" class="form-horizontal" novalidate>

                            <div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Dealer Code</label>
                                            <div class="col-md-8">
                                                <input type="text" id="customerChildAutoGenerated" name="CHILD_AUTOGENERATED" ng-model="dealerArr.PARTY_TYPE_CODE" class="form-control" readonly />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label class="control-label col-md-8">Master Code</label>
                                            <div class="col-md-4">
                                                <div class="input-group">
                                                    <input type="text" id="masterPartyCode" name="MASTER_PARTY_CODE" ng-model="dealerArr.MASTER_PARTY_CODE" class="form-control" readonly />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label class="control-label col-md-offset-2 col-md-6">Pre Code</label>
                                            <div class="col-md-4">
                                                <div class="input-group">
                                                    <input type="text" id="prePartyCode" name="PRE_PARTY_CODE" ng-model="dealerArr.PRE_PARTY_CODE" class="form-control" readonly />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Dealer Type(G/I):</label>
                                            <div class="col-md-8" style="display: flex; align-items: center; justify-content: space-between;">
                                                <label class="radio-inline">
                                                    <input ng-model="dealerArr.GROUP_SKU_FLAG" type="radio" name="groupSkuFlag" value="G" /> Group
                                                </label>
                                                <label class="radio-inline">
                                                    <input ng-model="dealerArr.GROUP_SKU_FLAG" type="radio" name="groupSkuFlag" value="I" /> Individual
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Parent:</label>
                                            <div class="col-md-8">
                                                <select id="dealerparentundergroup" kendo-drop-down-list
                                                        ng-disabled="true"
                                                        k-options="dealerGroupOptions"
                                                        style="width: 100%"></select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <div class="col-md-offset-4 col-md-8" style="display: flex; align-items: center; justify-content: space-between;">
                                                <label>
                                                    <input type="checkbox" checked="checked" disabled /> Dealer Type
                                                </label>
                                                <label>
                                                    <input ng-model="dealerArr.PARTY_TYPE_FLAG" type="checkbox" /> CR Limit Control
                                                </label>
                                                @*<div class="checkbox">

                                                    </div>
                                                    <div class="checkbox">

                                                    </div>*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Remarks</label>
                                            <div class="col-md-8">
                                                <textarea id="remarks" name="REMARKS" ng-model="dealerArr.REMARKS" class="form-control" rows="2"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Dealer Company
                                            </label>
                                            <div class="col-md-8">
                                                <input type="text" id="dealerCompany" name="dealerCompany" ng-model="dealerArr.PARTY_TYPE_EDESC" class="form-control" required />
                                                <span class="text-danger"
                                                      style="font-style: italic; font-size: 12px;"
                                                      ng-show="dealerform.dealerCompany.$invalid && dealerform.dealerCompany.$touched">
                                                    Dealer Company is required
                                                </span>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Address</label>
                                            <div class="col-md-8">
                                                <input type="text" id="address" name="address" ng-model="dealerArr.ADDRESS" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Owner Name</label>
                                            <div class="col-md-8">
                                                <input type="text" id="ownername" name="ownername" ng-model="dealerArr.OWNER_NAME" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Pan No.
                                            </label>

                                            <div class="col-md-8">
                                                <input type="text"
                                                       id="panNo"
                                                       name="panNo"
                                                       ng-model="dealerArr.PAN_NO"
                                                       class="form-control"
                                                       maxlength="9"
                                                       ng-pattern="/^[0-9]{1,9}$/">

                                                <!-- Pattern validation message -->
                                                <span class="text-danger"
                                                      style="font-style: italic; font-size: 12px;"
                                                      ng-show="dealerform.panNo.$touched && dealerform.panNo.$error.pattern">
                                                    PAN No. must contain only digits (max 9)
                                                </span>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="control-label col-md-4">Credit Limit</label>
                                            <div class="col-md-8">
                                                <input type="text" id="creditLimit" name="creditLimit" ng-model="dealerArr.CREDIT_LIMIT" class="form-control" ng-disabled="!dealerArr.PARTY_TYPE_FLAG" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Bank Guarantee</label>
                                            <div class="col-md-8">
                                                <input type="text" id="bankguarantee" name="bankguarantee" ng-model="dealerArr.BG_AMOUNT" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Credit Days</label>
                                            <div class="col-md-8">
                                                <input type="text" id="creditdays" name="creditdays" ng-model="dealerArr.CREDIT_DAYS" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Mobile No.
                                            </label>
                                            <div class="col-md-8">
                                                <input type="text"
                                                       id="mobileNo"
                                                       name="mobileNo"
                                                       maxlength="10"
                                                       ng-model="dealerArr.TEL_NO"
                                                       ng-pattern="phoneNumbr"
                                                       class="form-control" />

                                                <!-- Pattern validation message -->
                                                <span class="text-danger"
                                                      style="font-style: italic; font-size: 12px;"
                                                      ng-show="dealerform.mobileNo.$touched && dealerform.mobileNo.$error.pattern">
                                                    Mobile No. is invalid
                                                </span>
                                            </div>
                                        </div>


                                        <div class="form-group">
                                            <label class="control-label col-md-4">Email</label>
                                            <div class="col-md-8">
                                                <input type="email" id="email" name="email" ng-model="dealerArr.EMAIL" class="form-control" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <fieldset class="scheduler-border">
                                            <legend class="scheduler-border">Location Map</legend>
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Link Account</label>
                                                <div class="col-md-8">
                                                    <div class="input-group col-md-12">
                                                        <select id="linkacc" k-value-primitive="true" ng-model="dealerArr.ACC_CODE" kendo-drop-down-list
                                                                k-options="accountsOptions"
                                                                style="width: 100%"></select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Branch Name</label>
                                                <div class="col-md-8">
                                                    <div class="input-group col-md-12">
                                                        <select id="childBranchName" ng-model="dealerArr.LINK_BRANCH_CODE" kendo-drop-down-list
                                                                k-options="branchOptions"
                                                                style="width: 100%"></select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Area Name</label>
                                                <div class="col-md-8">
                                                    <div class="input-group col-md-12">
                                                        <select id="childRegion" k-value-primitive="true" ng-model="dealerArr.AREA_CODE" kendo-drop-down-list
                                                                k-options="regionOptions"
                                                                style="width: 100%"></select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Zone</label>
                                                <div class="col-md-8">
                                                    <div class="input-group col-md-12">
                                                        <select id="childZone" k-value-primitive="true" ng-model="dealerArr.ZONE_CODE" kendo-drop-down-list
                                                                k-options="zoneOptions"
                                                                style="width: 100%"></select>
                                                    </div>
                                                </div>
                                            </div>
                                        </fieldset>

                                        <div class="form-group" style="margin-top: 10px !important;">
                                            <label class="control-label col-md-4">Credit Exceed ( %eg )</label>
                                            <div class="col-md-8">
                                                <input type="text" id="credexceed" name="credexceed" ng-model="dealerArr.EXCEED_LIMIT_PERCENTAGE" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Tel/Mobile</span>
                                            </label>
                                            <div class="col-md-8">
                                                <input type="text" maxlength="10" ng-pattern="phoneNumbr" id="telephone" name="telephone" ng-model="dealerArr.TEL_NO2" class="form-control" />
                                                <span class="text-danger"
                                                      style="font-style: italic; font-size: 12px;"
                                                      ng-show="dealerform.telephone.$touched && dealerform.telephone.$error.pattern">
                                                    Tel/Mobile No. is invalid
                                                </span>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">PDC Check Amount</label>
                                            <div class="col-md-8">
                                                <input type="text" id="pdcCheckamt" name="pdcCheckamt" ng-model="dealerArr.PDC_CHEQUE_AMT" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label col-md-4">Sales Target Amount</label>
                                            <div class="col-md-8">
                                                <input type="text" id="salesTargetamt" name="salesTargetamt" ng-model="dealerArr.SALES_TARGET" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">Trade Discount</label>
                                            <div class="col-md-6">
                                                <input type="text" id="tradeDiscount" name="tradeDiscount" ng-model="dealerArr.TRADE_DISCOUNT" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">BG/Unit Rate</label>
                                            <div class="col-md-6">
                                                <input type="text" id="bgunitRate" name="bgunitRate" ng-model="dealerArr.BG_PER_UNIT" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">PDC Check Amount</label>
                                            <div class="col-md-6">
                                                <input type="text" id="pdcCheckamt_bottom" name="pdcCheckamt_bottom" ng-model="dealerArr.PDC_CHEQUE_AMT" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">Annual Bonus</label>
                                            <div class="col-md-6">
                                                <input type="text" id="anualBonus" name="anualBonus" ng-model="dealerArr.ANNUAL_BONUS" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">CD/Unit Rate</label>
                                            <div class="col-md-6">
                                                <input type="text" id="cdunitrate" name="cdunitrate" ng-model="dealerArr.CD_PER_UNIT" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label col-md-6">Sales Target Amt</label>
                                            <div class="col-md-6">
                                                <input type="text" id="salesTargetamt_bottom" name="salesTargetamt_bottom" ng-model="dealerArr.SALES_TARGET" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group">
                                            <label class="control-label col-md-2">Terms & Condition</label>
                                            <div class="col-md-10">
                                                <textarea id="termsConditions" name="termsConditions" ng-model="dealerArr.TERMS_CONDITIONS" class="form-control" rows="3"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <fieldset class="fieldset-box">
                                <legend>Dealer/Customer Map Information</legend>
                                <div class="text-right" style="margin-bottom: 10px !important;">
                                    <button class="btn btn-success" id="createbtncustomer" ng-click="showModalForCustomer(event)">
                                        <i class="fa fa-plus"></i> Customer MAP
                                    </button>
                                </div>
                                <kendo-grid id="kGrid2" options="dealerChildGridOptions2" k-rebind="dealerChildGridOptions2">
                                </kendo-grid>
                            </fieldset>
                        </form>
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-sm btn-green" id="savedocumentformdatachild" ng-click="saveNewDealer()" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                        <i class="fa fa-floppy-o"></i> {{saveupdatebtn}}
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-dismiss="modal" ng-click="SubLedger_Cancel($index)">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade-out" id="CustomermapModal" data-backdrop="static" tabindex="-1" data-width="760">
        <div class="modal-dialog modal-medium-large">
            <div class="modal-content">
                <div class="modal-header">
                    <div type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</div>
