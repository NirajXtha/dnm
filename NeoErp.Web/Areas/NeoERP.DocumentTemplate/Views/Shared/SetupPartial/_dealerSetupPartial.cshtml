                                                    {{dataItem.customerName}}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-1 col-md-1 col-lg-1">
                                <button class="btn btn-primary" ng-click="addSelectedCustomers()" id="btnAddSelectedCustomers">Add</button>
                            </div>

                            <div class="col-sm-5 col-md-5 col-lg-5" style="display: flex; align-items: center; justify-content: flex-end">
                                <label class="control-label col-sm-5 col-md-5 col-lg-5">Dealer Name: </label>
                                <input type="text"
                                       id="dealerCompany"
                                       name="dealerCompany"
                                       ng-model="dealerArr.PARTY_TYPE_EDESC"
                                       class="form-control col-sm-7 col-7 col-7" readonly />
                            </div>

                            <div class="col-sm-1 col-md-1 col-lg-1">
                                <button class="btn btn-danger" ng-click="removeSelectedCustomers()" id="btnRemoveSelectedCustomers">Remove</button>
                            </div>
                        </div>
                    </div>

                    <div class="row" style="padding: 0 10px ">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <input style="margin-bottom: 5px;" type="text" ng-model="searchQuery" ng-change="filterGrid()" ng-keypress="onCustomerSearchKeypress($event)" placeholder="Search by Customer Name" class="form-control" id="btnSearchCustomerGrid">
                                <kendo-grid style="margin-bottom: 10px;" id="CustomerGrid" options="customerChildGridOptions" k-rebind="customerChildGridOptions">
                                </kendo-grid>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <input style="margin-bottom: 5px;" type="text" ng-model="searchSelectedCustomerQuery" ng-change="filterSelectedCustomerGrid()" placeholder="Search by Customer Name" class="form-control" id="btnSearchSelectedCustomerGrid">
                                <kendo-grid id="SelectedCustomerGrid" options="selectedCustomerGridOptions" k-rebind="selectedCustomerGridOptions"></kendo-grid>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-green" id="savedocumentformdata" ng-click="saveNewCustomers(companyform.$valid)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                            <i class="fa fa-floppy-o"></i> {{saveupdatebtn}}
                        </button>
                        <button type="button" class="btn btn-sm btn-default" data-dismiss="modal" ng-click="SubLedger_Cancel($index)">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
