                                                   ng-model="txtMainGroupSearchString"
                                                   ng-change="filterTreeView()"
                                                   placeholder="Select Customer"
                                                   ng-click="toggleTreeDropdown()" />
                                        </div>

                                        <div class="tree-dropdown-panel" ng-show="showTreeDropdown">
                                            <div id="customertree"
                                                 class="disableLeftClickOnTree"
                                                 kendo-tree-view="tree"
