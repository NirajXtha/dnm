                        <span class="fa fa-file"></span> Dealer Mapping
                    </h4>
                </div>

                <div class="form-group">
                    <div class="row" style="margin: 10px 0;">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="col-sm-5 col-md-5 col-sm-5">
                                <div id="customerDropdown" role="application">
                                    @*<input type='text' class='k-textbox' ng-model="searchtest" placeholder='search' ng-keyup="searchcustomerlist()" />
                <button class="btn btn-sm btn-success" ng-click="searchcustomerlist()">Search</button>*@
                                    <!-- Custom Dropdown with TreeView -->
                                    <div class="dropdown-tree-container">
                                        <label>Group: </label>
                                        <div class="search-input-wrapper">
                                            <input type="text"
