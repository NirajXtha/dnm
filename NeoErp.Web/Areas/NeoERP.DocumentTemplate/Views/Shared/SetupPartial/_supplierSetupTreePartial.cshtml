<div class="portlet box green-box">
    <supplier></supplier>
    <div class="portlet-title">
        <div class="caption">
            <i class="icon-pin"></i>
            <span class="caption-subject bold uppercase">Supplier</span>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm" id="adddocumentformdata" @*ng-disabled="newrootinsertFlag!= 'Y'" *@ ng-click="addNewsupplier(event)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                <i class="fa fa-plus addcolor"></i>
            </a>
        </div>
    </div>

    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-0 col-md-12">
                <div class="topmaingroupsearch">
                    <input class="k-textbox txtMainGroupSearchString"
                           type="text"
                           ng-model="txtMainGroupSearchString"
                           ng-change="filterTreeView()"
                           placeholder="Search Supplier"
                           style="width:100%" />
                </div>
            </div>
        </div>  

        <div id="suppliertree" class="disableLeftClickOnTree" kendo-tree-view="tree"
             k-data-source="treeData"
             k-options="supplieroptions"
             k-data-bound="supplieronDataBound">
            <span k-template ng-click="BindGrid(dataItem.masterSupplierCode)">
                {{dataItem.SUPPLIER_EDESC}}
            </span>
        </div>

        <ul kendo-context-menu
            k-filter="'.hasTreeCustomMenu'"
            k-on-open="menuOpen = menuOpen + 1"
            k-on-close="menuOpen = menuOpen - 1"
            k-on-select="onContextSelect(kendoEvent)">
            <li>Add</li>
            <li>Update</li>
            <li>Delete</li>
        </ul>
        <ul kendo-context-menu k-filter="'.disableLeftClickOnTree'"></ul>
    </div>
</div>
<script>
    // Native CSS-based scrolling is enabled on #suppliertree via max-height and overflow-y.
    // If any legacy slimScroll was applied elsewhere, it is intentionally not used here to avoid conflicts.
</script>

