
<style>
    .btnadd {
        margin-top: 2px;
        float: right;
        margin-right: 5px !important;
    }

    /* Ensure vertical scrolling for long supplier trees */
    #suppliertree {
        max-height: 60vh;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px; /* avoid scrollbar overlay */
    }

    .addcolor {
        color: #ffffff;
    }
</style>
