
<style>
    .btnadd {
        margin-top: 2px;
        float: right;
        margin-right: 5px !important;
    }

    /* Ensure vertical scrolling for long location trees */
    #locationtree {
        max-height: 60vh;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px; /* avoid scrollbar overlay */
    }
       .addcolor {
    color:#ffffff;
    }
   
</style>
@*<div ng-controller="locationSetupTreeCtrl">*@

<div class="portlet box green-box">
    <div class="portlet-title">
        <div class="caption">
            <i class="icon-pin"></i>
            <span class="caption-subject bold uppercase">Location</span>
        </div>
        <div class="actions">
            <a class="btn dark-green btn-sm" id="adddocumentformdata" ng-click="addNewLocation(event)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                <i class="fa fa-plus addcolor"></i>
            </a>
        </div>
    </div>

    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-0 col-md-12">
                <div class="topmaingroupsearch">
                    <input class="k-textbox txtMainGroupSearchString"
                           type="text"
                           ng-model="txtMainGroupSearchString"
                           ng-change="filterTreeView()"
                           placeholder="Search Location"
                           style="width:100%" />
                </div>
            </div>
        </div>
        <div id="locationtree" class="disableLeftClickOnTree" kendo-tree-view="tree"
             k-data-source="locationtreeData"
             k-options="locationoptions"
             k-data-bound="locationOnDataBound">
            <span k-template ng-click="BindGrid(dataItem.LocationId)">
                {{dataItem.LocationName}}
            </span>
        </div>
        <ul kendo-context-menu
            k-filter="'.hasTreeCustomMenu'"
            k-on-open="menuOpen = menuOpen + 1"
            k-on-close="menuOpen = menuOpen - 1"
            k-on-select="onContextSelect(kendoEvent)">
            <li>Add</li>
            <li>Update</li>
            <li>Delete</li>
        </ul>
        <ul kendo-context-menu k-filter="'.disableLeftClickOnTree'"></ul>
    </div>
</div>
            <script>
                // Native CSS-based scrolling is enabled on #locationtree via max-height and overflow-y.
                // Legacy slimScroll initialization removed.
            </script>
