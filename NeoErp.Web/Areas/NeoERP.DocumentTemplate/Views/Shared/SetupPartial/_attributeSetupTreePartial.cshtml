
<style>
    .btnadd {
        margin-top: 2px;
        float: right;
        margin-right: 5px !important;
    }

    div.k-treeview {
        overflow: unset !important;
    }

    .addcolor {
        color: #ffffff;
    }
</style>
<div class="portlet box green-box">
    <attribute></attribute>
    <div class="portlet-title">
        <div class="caption">
            <i class="icon-pin"></i>
            <span class="caption-subject  bold uppercase">
                Attribute Setup
            </span>
        </div>


        <div class="actions">
            <a class="btn dark-green btn-sm" id="adddocumentformdata" ng-click="addNewAttribute(event)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                <i class="fa fa-plus addcolor"></i>
            </a>
        </div>
    </div>
    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-0 col-md-12">
                <div class="topmaingroupsearch">
                    <input class="k-textbox txtMainGroupSearchString"
                           type="text"
                           ng-model="txtMainGroupSearchString"
                           ng-change="filterTreeView()"
                           placeholder="Search Attribute"
                           style="width:100%" />
                </div>
            </div>
        </div>
        <div id="attributetree" class="disableLeftClickOnTree" kendo-tree-view="tree"
             k-data-source="attributetreeData"
             k-options="attributeoptions"
             k-data-bound="attributeOnDataBound">
            <span k-template ng-click="BindGrid(dataItem.AttributeId)">
                {{dataItem.AttributeName}}
            </span>
        </div>
        <ul kendo-context-menu
            k-filter="'.hasTreeCustomMenu'"
            k-on-open="menuOpen = menuOpen + 1"
            k-on-close="menuOpen = menuOpen - 1"
            k-on-select="onContextSelect(kendoEvent)">  
            @*<li>Add</li>*@
            <li>Update</li>
            <li>Delete</li>
        </ul>
        <ul kendo-context-menu k-filter="'.disableLeftClickOnTree'"></ul>
    </div>
</div>
<script>
    $(document).ready(function () {
        setTimeout(function () {
            $('.treeviewspliter .k-widget.k-treeview').slimScroll({
                height: '250px'
            });
        }, 10);
    });

</script>
