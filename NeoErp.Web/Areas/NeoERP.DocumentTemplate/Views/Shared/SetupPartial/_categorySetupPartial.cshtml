<style>
    .k-animation-container, .k-widget, .k-widget *, .k-animation-container *, .k-widget ::before, .k-animation-container ::after, .k-block .k-header, .k-list-container {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
    }

    /*.k-grid-content .k-auto-scrollable, .k-auto-scrollable {
        height: auto !important;
    }*/

    .k-virtual-scrollable-wrap {
        height: 454px !important;
    }

    #createContractForm .k-multiselect-wrap ul li {
        font-size: 10px !important;
    }

    #createContractForm .k-multiselect-wrap .k-input {
        color: hsl(0, 0%, 80%);
    }

    #multiselect-wrap.k-floatwrap {
        max-height: 101px;
        overflow-y: auto;
    }

    .btn-help-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #4caf50;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-help-custom:hover {
            transform: scale(1.15);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
            border-color: white;
        }

        .btn-help-custom i {
            font-size: 17px;
        }
</style>
<form id="CategoryForm" name="CategoryForm" novalidate>
    <div class="portlet box green-box main">
        <div class="portlet-title">
            <div class="caption">
                <i class="fa fa-list-alt"></i>
                <span class="caption-subject  bold uppercase">
                    Category Infomation
                </span>
                <a class="btn-help-custom" onclick="HelpPopup.showByKey('categoryManagement')" title="Help">
                    <i class="fa fa-question-circle"></i>
                </a>
            </div>
            <div class="actions pull-right">
                <button type="button" id="deleteTransporter" name="deleteTransporter" ng-model="btnDelete" ng-disabled="!btnDelete" ng-click="deleteTransporter(CategoryForm.$valid)" class="btn btn-danger btn-sm">Delete</button>
                <button type="button" id="saveTransporter" name="saveTransporter" ng-click="SaveTransporter(CategoryForm.$valid)" class="btn dark-green btn-sm">{{saveAction}}</button>
                <button type="button" id="cancelTransporter" name="cancelTransporter" ng-click="Cancel()" class="btn btn-default btn-sm">New</button>
            </div>
        </div>
        <div class="portlet-body form-horizontal">
            <div class="row">
                @*<div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            In English<span style="color:red" ng-show="TDSForm.partyname.$invalid">
                                <span ng-show="TDSForm.partyname.$error.required">*</span>
                            </span>
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <input class="form-control" type="text" name="partyname" ng-model="PartyTypeSetup.PARTY_TYPE_EDESC" id="partyname" required>
                        </div>
                    </div>

                </div>*@
                <div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            Category Code<span style="color:red" ng-show="CategoryForm.categoryCode.$invalid">
                                <span ng-show="CategoryForm.categoryCode.$error.required">*</span>
                            </span>
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <input class="form-control" type="text" name="categoryCode" ng-model="CategorySetup.CATEGORY_CODE" id="categoryCode" placeholder="Category Code" maxlength="2" required>
                        </div>
                    </div>
                </div>
                <div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            In English<span style="color:red" ng-show="CategoryForm.inEnglish.$invalid">
                                <span ng-show="CategoryForm.inEnglish.$error.required">*</span>
                            </span>
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <input class="form-control" type="text" name="inEnglish" ng-model="CategorySetup.ENG_CATEGORY" id="inEnglish" placeholder="In English" required>
                        </div>
                    </div>
                </div>
                <div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            In Nepali
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <input class="form-control" type="text" name="inNepali" ng-model="CategorySetup.NEP_CATEGORY" id="nepCategory" placeholder="In Nepali">
                        </div>
                    </div>
                </div>
                <div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            Category Type
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            @*<input class="form-control" type="text" name="categoryType" ng-model="CategorySetup.CATEGORY_TYPE" id="categoryType" placeholder="Category Type">*@
                            <select id="categorycode" name="categorycode" k-options="categoryOptions" kendo-drop-down-list
                                    ng-model="CategorySetup.CATEGORY_TYPE" style="width:100%" required></select>
                        </div>
                    </div>
                </div>
                <div class="col-sm-12 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-3 col-md-4 col-lg-5">
                            Code Prefix
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <input class="form-control" type="text" name="prefix" ng-model="CategorySetup.PREFIX_TEXT" id="prefixText" placeholder="Prefix Text">
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-group">
                        <label class="control-label col-sm-4 col-md-4 col-lg-5">
                            Remarks
                        </label>
                        <div class="col-sm-9 col-md-8 col-lg-7">
                            <textarea class="form-control" type="text" rows="4" name="remarks" ng-model="CategorySetup.REMARKS" id="remarks" placeholder="Some Text"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @Html.Partial("~/Views/Shared/Helper/GlobalHelper.cshtml")
    </div>
</form>
<script>
    $(document).ready(function () {
        setTimeout(function () {
            $('.k-list').slimScroll({
                height: '250px'
            });
        }, 100)
        $('.nav-tabs a').on('click', function (e) {
            e.preventDefault();
            if ($(this).attr('href') == '#tab_2') {
                $('#tab_2').tab('show')
            }
        });
    });
</script>
<script>
    // Register help content for Category Setup page with pagination
    HelpPopup.register(
        'categoryManagement',
        'Category Setup Help',
        [
            // Page 1 - Overview and Classification
            `
                <h4>Category Setup - Overview</h4>
                <p>Category Setup allows you to classify your products and services into logical groups (e.g., Hard Disk, Mouse, Printer). Proper categorization is essential for accurate inventory tracking and sales reporting.</p>

                <h5>Key Navigation:</h5>
                <ul>
                    <li><strong>Category List (Left):</strong> A searchable list of all existing product categories.</li>
                    <li><strong>Category Information (Right):</strong> The workspace where you can view or modify the details of the selected category.</li>
                    <li><strong>Search:</strong> Use the "Enter Search Text Here..." box to quickly locate a specific category like "Powerbank" or "Server".</li>
                </ul>
            `,

            // Page 2 - Category Details & Coding
            `
                <h4>Category Information Fields</h4>
                <p>When creating or editing a category, ensure the following identity fields are accurately filled:</p>

                <ul>
                    <li><strong>Category Code (*):</strong> A unique system identifier for the category. This is a mandatory field used for backend data mapping.</li>
                    <li><strong>In English (*):</strong> The official name of the category in English (e.g., "Web Cam"). This is required.</li>
                    <li><strong>In Nepali:</strong> The category name in Devanagari script for local billing and reports.</li>
                    <li><strong>Code Prefix:</strong> An optional short prefix used when auto-generating item codes within this category.</li>
                    <li><strong>Category Type:</strong> Defines the nature of the category (e.g., Stockable, Service, or Non-Stock).</li>
                    <li><strong>Remarks:</strong> Additional descriptions or internal notes regarding what items belong in this category.</li>
                </ul>
            `,

            // Page 3 - Managing Categories
            `
                <h4>Managing Category Records</h4>
                <p>The Category Setup interface provides standard controls for record management located in the top-right corner of the Information panel.</p>

                <h5>Action Buttons:</h5>
                <ul>
                    <li><strong>New:</strong> Clears the form to allow the entry of a brand new product category.</li>
                    <li><strong>Save:</strong> Commits the current information to the database. Always Save after modifying the English name or Type.</li>
                    <li><strong>Delete:</strong> Removes the selected category. <em>Note: Categories currently linked to active inventory items cannot be deleted to maintain data integrity.</em></li>
                </ul>

                <h5>Best Practices:</h5>
                <p>Keep your category names concise. Instead of "Devices for Storage," use "Storage" or "Memory" to ensure reports remain clean and scannable.</p>
            `
        ]
    );
</script>