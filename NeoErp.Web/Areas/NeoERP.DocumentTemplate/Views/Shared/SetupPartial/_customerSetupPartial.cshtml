<style>
    .k-animation-container, .k-widget, .k-widget *, .k-animation-container *, .k-widget *:before, .k-animation-container *:after, .k-block .k-header, .k-list-container {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
    }

    #SelectedCustomerGrid, #CustomerGrid {
        height: auto !important;
    }

    #customerType_listbox {
        height: 80px !important;
    }

    .tree-dropdown-panel {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: #fff;
        border: 1px solid #ccc;
        z-index: 1060; /* Higher than modal */
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        padding: 10px;
        border-radius: 4px;
    }

    .fieldset-box {
        margin-bottom: 8px;
    }

    /*.englishdate {
        width: 117px !important;
    }

    .k-i-warning {
        display: none;
    }*/
    .document_child_table tbody.table_body {
        min-height: 86px !important;
    }

    div#ndp-nepali-box {
        z-index: 10076 !important;
    }

    div#ndp-nepali-box {
        font-family: 'Trebuchet MS', Tahoma, Verdana, Arial, sans-serif;
        border: 1px solid #CCC;
        background-color: #FFF;
        position: absolute;
        z-index: 9999;
        padding: 1px;
        margin-top: 1px;
    }

    .k-select {
        display: none;
    }

    .requiredAsterik {
        position: absolute;
        top: 0px;
        right: 5px;
    }

    .k-list-container {
        width: 250px !important;
    }

    table {
        table-layout: fixed;
    }

        table th, table td {
            overflow: hidden;
        }

    .k-grid-content {
        height: 280px !important;
    }

    #kGrid {
        height: 427px !important;
    }

    .borderRed {
        border: solid red 1px !important;
    }

    .addcolor {
        color: #ffffff;
    }

    .modal-dialog {
        min-width: 1100px !important;
    }


    .btn-help-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #4caf50;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-help-custom:hover {
            transform: scale(1.15);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
            border-color: white;
        }

        .btn-help-custom i {
            font-size: 17px;
        }
</style>

<div id="customerSetupTreeCtrl" class="portlet box green-box main">
    @Html.Partial("~/Views/Shared/Helper/GlobalHelper.cshtml")
    <div class="portlet-title">
        <div class="caption ng-binding">
            <i class="fa fa-list-alt"></i>
            <span class="caption-subject bold uppercase">
                Customer
            </span>
            <a class="btn-help-custom" onclick="HelpPopup.showByKey('customerManagement')" title="Help">
                <i class="fa fa-question-circle"></i>
            </a>
        </div>

        <div class="actions">
            <a class="btn dark-green btn-sm addcolor" id="createbtn" ng-click="showModalForNewChildCustomer(event)" ng-disabled="treenodeselected!= 'Y'">
                <i class="fa fa-plus"></i> New
            </a>
        </div>
    </div>

    <div class="portlet-body">
        <div class="row">
            <div class="col-md-offset-8 col-md-4 search_box">
                <div class="topsearch" style="display:block;">
                    <a class="btn-linkicon fa fa-search" style="margin-right: -13px;" ng-click="BindGrid('All')"></a>
                    <input class="k-textbox txtSearchString" type="text" id="custtxtSearchString" ng-model="txtSearchString" name="search" placeholder="enter search text..." style="margin-left: 13px;" />

                </div>
            </div>
        </div>
        <kendo-grid id="kGrid" options="customerChildGridOptions" k-rebind="customerChildGridOptions">
        </kendo-grid>
    </div>

    <div class="modal fade-out" id="groupCustomerModal" data-backdrop="static" tabindex="-1" data-width="760">
        <div class="modal-dialog modal-medium-large popup">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</button>
                    <h4 class="modal-title">
                        <span class="fa fa-file"></span>
                        Customer Model
                    </h4>
                </div>

                <div class="modal-body">

                    <form name="customersArrform" class="form-horizontal" novalidate>
                        <div class="row" style="scrollbar-base-color:yellow">


                        </div>
                        <!-- rendering master elements -->

                        <div class="row">

                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-sm-4 col-md-4 col-lg-4">Under Group:</label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <select id="mastercustomercode" ng-model="customersArr.CUSTOMER_CODE" kendo-drop-down-list ng-
                                                k-options="customerGroupOptions"
                                                style="width: 100%" disabled></select>
                                    </div>
                                </div>
                            </div>


                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">

                                    <label class="control-label col-sm-4 col-md-4 col-lg-4">Shortcut:</label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <input type="text" id="shortcut" name="shortcut" ng-model="customersArr.MASTER_CUSTOMER_CODE" class="form-control" disabled />
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">

                                    <label class="control-label col-sm-4 col-md-4 col-lg-4">
                                        In English:<span style="color:red" ng-show="customersArrform.customerEnglishName.$invalid">
                                            <span ng-show="customersArrform.customerEnglishName.$error.required">*</span>
                                        </span>
                                    </label>
                                    <div class=" col-sm-8 col-md-8 col-lg-8">
                                        <input type="text" id="customerEnglishName" name="customerEnglishName" ng-model="customersArr.CUSTOMER_EDESC" class="form-control" required />

                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">

                                    <label class="control-label  col-sm-4 col-md-4 col-lg-4">In Nepali:</label>
                                    <div class=" col-sm-8 col-md-8 col-lg-8">
                                        <input type="text" id="customerNepaliName" name="CUSTOMER_NDESC" ng-model="customersArr.CUSTOMER_NDESC" class="form-control" />

                                    </div>
                                </div>
                            </div>

                            @*<div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="form-group">
                                        <label class="control-label col-sm-4 col-md-4 col-lg-4">
                                        Account:<span style="color:red" ng-show="customersArrform.customerAccount.$invalid">
                                                 <span ng-show="customersArrform.customerAccount.$error.required">*</span>
                                               </span>
                                        </label>

                                        <div class="col-sm-8 col-md-8 col-lg-8">
                                            <select id="customerAccount" name="customerAccount" kendo-drop-down-list ng-model="customersArr.CUSTOMER_ACCOUNT"
                                                    k-options="accountGroupOptions"
                                                    style="width: 100%" required></select>
                                        </div>

                                    </div>
                                </div>*@
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">
                                    <label class="control-label  col-sm-4 col-md-4 col-lg-4">
                                        Type:<span style="color:red" ng-show="customersArrform.customerType.$invalid">
                                            <span ng-show="customersArrform.customerType.$error.required">*</span>
                                        </span>
                                    </label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <select id="customerType" name="customerType" ng-model="customersArr.CUSTOMER_TYPE" kendo-drop-down-list
                                                k-options="customerTypeOptions"
                                                style="width: 100%" required></select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">

                                    <label class="control-label  col-sm-4 col-md-4 col-lg-4">Prefix/Start ID:</label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <div class="row">
                                            <div class="col-sm-6 col-md-6 col-lg-6">
                                                <input type="text" id="customerPrefix" name="CUSTOMER_PREFIX" ng-model="customersArr.CUSTOMER_PREFIX" class="form-control" />
                                            </div>
                                            <div class="col-sm-6 col-md-6 col-lg-6">
                                                <input type="number" id="customerStartID" name="CUSTOMER_STARTID" ng-model="customersArr.CUSTOMER_STARTID" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-sm-4 col-md-4 col-lg-4">Party Type:</label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <select id="groupPartyType" name="groupPartyType" kendo-drop-down-list
                                                k-options="groupPartyTypeOptions" k-on-change="onChangeGroupPartyType(kendoEvent)"
                                                ng-model="customersArr.PARTY_TYPE_CODE" k-value-primitive="true"
                                                style="width: 100%"></select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-sm-4 col-md-4 col-lg-4">Accounts:</label>
                                    <div class="col-sm-8 col-md-8 col-lg-8">
                                        <input type="text" id="groupAccountEdesc" name="groupAccountEdesc" ng-model="groupAccountEdesc" class="form-control" readonly />
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-group">

                                    <label class="control-label  col-sm-4 col-md-4 col-lg-4">Remarks:</label>
                                    <div class=" col-sm-8 col-md-8 col-lg-8">
                                        <input type="text" id="customerRemarks" name="REMARKS" ng-model="customersArr.REMARKS" class="form-control" />

                                    </div>
                                </div>
                            </div>
                        </div>


                    </form>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-sm btn-green" id="savedocumentformdata" ng-click="saveNewCustomer(customersArrform.$valid)" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing..." href="javascript:;">
                        <i class="fa fa-floppy-o"></i> {{saveupdatebtn}}
                    </button>

                    <button type="button" class="btn btn-sm btn-default" data-dismiss="modal" ng-click="SubLedger_Cancel($index)">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade-out" id="customerModal" data-backdrop="static" tabindex="-1" data-width="760">
        <div class="modal-dialog  modal-dialog-box popup">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true" next-on-tab>&times;</button>
                    <h4 class="modal-title">
                        <span class="fa fa-file"></span>
                        Customer Model
                    </h4>
                </div>

                <div class="modal-body ">

                    <form name="customersChildArrform" class="form-horizontal" novalidate>
                        <!-- rendering master elements -->
                        <div class="row">

                            <fieldset class="fieldset-box fieldset-space">
                                <legend class="planOption">Customer Information</legend>

                                <div class="col-sm-6 col-md-6 col-lg-6">
