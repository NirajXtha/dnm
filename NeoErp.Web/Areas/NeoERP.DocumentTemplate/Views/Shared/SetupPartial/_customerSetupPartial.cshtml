                                        <label class="control-label col-sm-5 col-md-3 col-lg-3">Auto Gen.Code</label>

                                        <div class="col-sm-5 col-md-5 col-lg-5">
                                            <input type="text" id="customerChildAutoGenerated" name="CHILD_AUTOGENERATED" ng-model="customersChildArr.CHILD_AUTOGENERATED" class="form-control" readonly />
                                        </div>

                                    </div>
                                </div>

                                <div class="col-sm-6 col-md-6 col-lg-6">
