<script type="text/javascript">
    $(document).ready(function () {
        $(".topsearch").hide();
        $("#custtxtSearchString").keyup(function () {
            var val = $('#custtxtSearchString').val();
            $("#kGrid").data("kendoGrid").dataSource.filter({
                logic: "or",
                filters: [
                    {
                        field: "CUSTOMER_EDESC",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "REGD_OFFICE_EADDRESS",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "TELEPHONE",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "EMAIL",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "PARTY_TYPE_EDESC",
                        operator: "contains",
                        value: val
                    },
                    {
                        field: "ACC_EDESC",
                        operator: "contains",
                        value: val
                    },
                ]
            });
        });

        $(document).on("change", ".customerFile", function () {
            debugger
            if (window.FormData !== undefined) {
                var customerCode = $(this).closest(".customerFileContainer").find('.hiddenCustomerCode').val();
                var file_data = $(this).prop("files")[0];
                var file_column_name = $(this).closest(".customerFileContainer").find(".FILE_COLUMN_NAME").val()
                var form_data = new FormData();
                form_data.append("file", file_data)
                form_data.append("CUSTOMER_CODE", customerCode)
                form_data.append("FILE_COLUMN_NAME", file_column_name)

                var customerOwnerFileUploadUrl = window.location.protocol + "//" + window.location.host + "/CustomerFileUpload/CustomerOwnerFileUpload";
                $.ajax({
                    url: customerOwnerFileUploadUrl,
                    type: "POST",
                    contentType: false,
                    processData: false,
                    data: form_data,
                    success: function (result) {
                        if (result == "Warning-up") {
                            $('#itemimages').modal('show');
                            displayPopupNotification("Uploader Should not be empty.", "warning");
                        }
                        else if (result == "Warning-jp") {
                            displayPopupNotification("Only .jpg .jpeg and .png are supported.", "warning");
                            $('#itemimages').modal('show');
                        }
                        else if (result == "Warning-item") {
                            displayPopupNotification("Please select item to upload.", "warning");
                            $('#itemimages').modal('show');
                        }
                        else {
                            $('#image').attr('src', result)
                            displayPopupNotification("Successfully Inserted Images.", "success");
                            $('#avatar').val("");
                        }
                    },
                    error: function (err) {
                        displayPopupNotification(err.statusText, "error");
                    }
                });
            } else {
                alert("FormData is not supported.");
            }
        });

        function ImageDisplay(obj) {
            var ItemCode = obj.ItemCode;
            var itemdetail = { ItemCode: ItemCode }
            var imageurl = window.location.protocol + "//" + window.location.host + "/Areas/NeoErp.Pos/Images/images.jpg"
            $.ajax({
                url: '/ItemImage/ItemImageDisplay',
                type: "GET",
                contentType: "application/json;charset=utf-8",
                dataType: "json",
                data: itemdetail,
                success: function (result) {
                    if (result != null) {
                        var d = new Date();
                        $('#image').attr('src', result + "?" + d.getTime());
                    }
                    else {
                        $('#image').attr('src', imageurl)
                    }
                },
                error: function (err) {
                    alert(err.statusText);
                }
            });
        }
    });
</script>
<script>
