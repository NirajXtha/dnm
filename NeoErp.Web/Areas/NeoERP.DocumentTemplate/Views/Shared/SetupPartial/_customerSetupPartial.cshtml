                                            </span>
                                        </label>

                                        <div class="col-sm-7 col-md-9 col-lg-9">
                                            <input type="text" id="childCustomerEdesc" name="childCustomerEdesc" ng-model="customersChildArr.CHILD_CUSTOMER_EDESC" class="form-control" required />
                                        </div>

                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="form-group">

                                        <label class="control-label col-sm-4 col-md-3 col-lg-3">Customer Id</label>

                                        <div class="col-sm-8 col-md-9 col-lg-9">
                                            <input type="text" id="childCustomerId" name="CHILD_CUSTOMER_ID" ng-model="customersChildArr.CHILD_CUSTOMER_ID" class="form-control" />
                                        </div>

                                    </div>
                                </div>

                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="form-group">


                                        <label class="control-label col-sm-5 col-md-3 col-lg-3">In Nepali</label>

                                        <div class="col-sm-7 col-md-9 col-lg-9">
                                            <input type="text" id="childCustomerNdesc" name="CHILD_CUSTOMER_NDESC" ng-model="customersChildArr.CHILD_CUSTOMER_NDESC" class="form-control" />
                                        </div>

                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="form-group">

                                        <label class="control-label col-sm-4 col-md-3 col-lg-3">Group Id</label>

                                        <div class="col-sm-8 col-md-9 col-lg-9">
                                            <input type="text" id="childGroupId" name="CHILD_GROUP_ID" ng-model="customersChildArr.CHILD_GROUP_ID" class="form-control" />
                                        </div>

                                    </div>
                                </div>

                            </fieldset>

                        </div>







