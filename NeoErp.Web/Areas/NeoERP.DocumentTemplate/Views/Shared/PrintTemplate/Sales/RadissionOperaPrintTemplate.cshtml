    }

    .tableFontandSize {
        font-family: 'Open Sans', Arial, Helvetica, sans-serif;
        font-weight: 400;
        padding: 10px;
        font-size: 13px !important;
        line-height: 1.5;
    }

    table {
        border-collapse: collapse;
    }

    thead {
        border-top: 1px solid #333;
        border-bottom: 1px solid #333;
    }

    .billHeader {
        width: 50px;
        font-size: 13px;
        text-align: left;
        border-top: 1px solid #000000;
        border-bottom: 1px solid #000000;
        padding: 0;
    }

    #tblPrintTable {
        margin-top: 0px;
        padding-top: 0px;
    }

    .totalAmountSize {
        font-weight: 900;
    }

    .billLeftSide {
        width: 42px;
    }

    .billPaddingLeftSide {
        padding-left: 10px;
    }

    .hrboderLeft {
        margin: 0px 0;
        border: 2px;
        border-top: 1px solid #121212;
        border-bottom: 0;
        margin-left: 0px;
        margin-right: -50px;
