     .header {
        position: fixed;
        top: 0;
    }

    .footer {
        position: relative;
        bottom: 0;
    }

    #background {
        position: fixed;
        top: 30%;
        z-index: 0;
        display: block;
        min-height: 50%;
        min-width: 50%;
    }

    .fontsizedesign {
        font-size: 10px;
    }

    .large-font-table {
        font-size: 11px;
    }

        .large-font-table th,
