        <div class="order-info">

            <div style="font-size: large;">Vat No:   {{printCompanyInfo.tPinVatNo}}</div>
        </div>

        <h2 style="font-size: 18px; font-weight: bold; margin-top: 3px;">
            {{printCompanyInfo.formName}}
        </h2>

    </header>

    <div style="display:flex;justify-content:space-between;margin-bottom:25px;">
        <table class="vendinfo" style="width:400px;">
            <tr><td><strong>VENDOR: </strong></td><td style="font-size:11px !important">{{masterModels.SUPPLIER_CODE}}</td></tr>
            <tr><td><strong>Address:</strong></td><td style="font-size:11px !important">{{masterModels.REGD_OFFICE_EADDRESS}}</td></tr>
            <tr><td><strong>Pan No:</strong></td><td style="font-size:11px !important">{{masterModels.TPIN_VAT_NO}}</td></tr>
            <tr><td><strong>Contact No:</strong></td><td style="font-size:11px !important">{{masterModels.TEL_MOBILE_NO1}}</td></tr>
        </table>

        <table class="vendinfo" style="width:300px;margin-left:30px;">
            <tr><td><strong>Order No : </strong></td><td style="font-size:11px !important">{{dzvouchernumber}}</td></tr>
            <tr ng-repeat="element in MasterFormElement | orderBy: 'SERIAL_NO'" ng-if="element.COLUMN_HEADER.indexOf('Date') != -1">
                <td><strong>{{element.COLUMN_HEADER}} :</strong></td>
                <td style="font-size:11px !important">{{masterModels[element.COLUMN_NAME]}} / {{getNepaliDate(masterModels[element.COLUMN_NAME])}}</td>
            </tr>
        </table>
    </div>

    <style>
        .vendinfo tr td strong {
            font-size: 14px;
        }

        .vendinfo tr td {
            font-size: 13px;
        }

        .vendinfo {
            border-collapse: collapse;
        }
    </style>



