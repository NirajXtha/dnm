    <table class="totals-table"
           style="width: 40%; margin-left: auto; border-collapse: collapse; border: 1px solid #000;">
        <tr>
            <td style="border: 1px solid #000; padding: 6px; font-weight: bold;">Total</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: right;">
                {{summary.grandTotal | number:2}}
            </td>
        </tr>

        <tr ng-repeat="(key, value) in ChargeList">
            <td style="border: 1px solid #000; padding: 6px;">{{value.CHARGE_EDESC}}</td>
            <td style="border: 1px solid #000; padding: 6px; text-align: right;">
                {{value.CHARGE_AMOUNT | number:2}}
            </td>
        </tr>

        <tr>
