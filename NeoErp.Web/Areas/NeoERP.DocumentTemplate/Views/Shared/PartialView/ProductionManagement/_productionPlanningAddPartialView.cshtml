<style>
    .modal-body {
        padding: 20px 25px;
    }

    .modal-header {
        padding: 12px 20px;
    }

    .fieldset-box {
        padding: 15px 20px !important;
        margin-bottom: 0px;
    }

    legend {
        font-size: 16px;
        font-weight: 600;
        padding: 0 8px;
        margin-bottom: 10px;
    }

    .row {
        margin-bottom: 8px;
    }

    .form-label {
        font-weight: 500;
    }

    .form-inline {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-inline label {
            min-width: 90px;
            vertical-align: middle;
        }

        .form-inline .form-control,
        .form-inline .form-select {
            flex: 1;
        }

    .form-control,
    .form-select {
        height: calc(1.5em + .75rem + 2px);
    }

    .input-icon {
        position: relative;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .input-icon i,
        .input-icon svg {
            cursor: pointer;
            margin-left: 5px;
        }

    .table {
        margin-bottom: 5px;
    }

        .table thead th {
            padding: 3px 5px !important;
            line-height: 1.2;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .table {
        table-layout: fixed;
        width: 100%;
    }

        .table tbody td {
            white-space: normal;
        }


        .table th,
        .table td {
            vertical-align: middle !important;
            padding: 6px 8px;
        }

    .table-wrapper {
        max-height: 250px;
        overflow-y: auto;
    }

    .table > thead > tr > th, .table-hover th {
        font-size: 11px !important;
        font-weight: 1000 !important;
    }

    .btn {
        padding: 5px 14px;
    }

    .btn-sm {
        padding: 3px 10px;
    }

    .btn-calc {
        background-color: #f8d7da;
        border-color: #f5c2c7;
    }

    .highlight-input {
        background-color: #ffffcc;
    }

    .active-selected-resource-row {
        background-color: #428bca !important;
        cursor: pointer;
    }

    .text-center.mt-3 {
        margin-top: 20px !important;
        padding-bottom: 10px;
    }

    #productionPlanningNewAddModel .modal-body {
        max-height: calc(100vh - 85px);
        overflow-y: auto;
    }
</style>

