@*Tree model View*@
<div id="TreeViewPopupModel" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Search </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body container-fluid">



                <div class="row">
                    <div class="col-md-3 col-sm-3" style="height: 350px; overflow: scroll; overflow-x: hidden">
                        <!-- Left Column (small) -->
                        <div class="portlet light">
                            <div id="treeviewPPlan" kendo-tree-view="tree"
                                 k-data-source="treeData"
                                 k-on-change="onTreeSelect(dataItem)"
                                 k-options="treeOptions">
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6" style="height: 350px; overflow: scroll; overflow-x: hidden ">
                        <!-- Middle Column (large) -->
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Item Code</th>
                                    <th>Item Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                @*  {{dataObject.productItemList|json}}*@
                                <tr ng-repeat="item in dataObject.productItemList" style="cursor:pointer;" ng-class="{ 'active-selected-resource-row': dataObject.SelectProductItem === item }"
                                    ng-click="$evalAsync(GetProductItemDetails(item,item.item_code,true))"
                                    ng-dblclick="SelectAndCloseProductPopup()">
                                    <td>{{ item.item_code }}</td>
                                    <td>{{ item.item_edesc }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>


                    <div class="col-md-3 col-sm-3" style="height: 350px; overflow: scroll; overflow-x: hidden">
                        <!-- Right Column (small) -->
                        <div class="portlet light">
                            <table class="table table-bordered table-striped">
                                <tbody>
                                    <tr>
                                        <th>Title</th>
                                        <th>Value</th>
                                    </tr>
                                    <tr>
                                        <td>Code</td>
                                        <td>{{dataObject.productItemDetails.CODE}}</td>
                                    </tr>
                                    <tr>
                                        <td>Name</td>
                                        <td>{{dataObject.productItemDetails.NAME}}</td>
                                    </tr>
                                    <tr>
                                        <td>Category</td>
                                        <td>{{dataObject.productItemDetails.CATEGORY}}</td>
                                    </tr>
                                    <tr>
                                        <td>Unit</td>
                                        <td>{{dataObject.productItemDetails.UNIT}}</td>
                                    </tr>
                                    <tr>
                                        <td>HS Code</td>
                                        <td>{{dataObject.productItemDetails.HS_CODE}}</td>
                                    </tr>

                                    <tr ng-if="dataObject.productItemDetails && dataObject.productItemDetails.stockLocationInfo && dataObject.productItemDetails.stockLocationInfo.Quantity">
                                        <th>Location</th>
                                        <th>Stock</th>
                                    </tr>
                                    <tr ng-if="dataObject.productItemDetails && dataObject.productItemDetails.stockLocationInfo && dataObject.productItemDetails.stockLocationInfo.Quantity">
                                        <td>{{dataObject.productItemDetails.stockLocationInfo.LocationEdesc}}</td>
                                        <td>{{dataObject.productItemDetails.stockLocationInfo.Quantity}}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <br />
                <div class="row">
                    @*Tree Search*@
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="planQuantity" class="col-sm-2 col-form-label">Search  </label>
                            <div class="col-sm-8 d-flex">
                                <input type="text" class="form-control bg-warning-subtle me-2" ng-model="dataObject.ItemSearchText" ng-keypress="checkEnterItemSearch($event)">
                            </div>
                            <div>
                                <button class="btn btn-success" type="button" ng-click="searchProductItems()">
                                    <span class="glyphicon glyphicon-search"></span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>



            </div>
        </div>
    </div>
</div>




