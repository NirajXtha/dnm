        <tr ng-repeat="(key,row) in ChildFormElement">
            <td ng-repeat="item in row.element | orderBy: 'SERIAL_NO'" class="{{item.COLUMN_NAME}}_div"
                ng-style="isNextScreenRender?getColumnWidth(item.COLUMN_NAME):{}">


                <input type="hidden" class="childrow" name="index" value="{{key}}" ng-model="childRow">


                <div ng-if="item.COLUMN_NAME.indexOf('DATE') !== -1">
                    <input type="text" id="englishDate5__{{element.COLUMN_NAME}}" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control maskdate" />
                </div>

                <div ng-if="item.COLUMN_NAME.indexOf('CODE') !== -1">
                    <div ng-if="item.COLUMN_NAME.indexOf('DIVISION') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_divisionCodeChildPartial.cshtml")
                    </div>
                    <div ng-if="item.COLUMN_NAME.indexOf('ITEM') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_productCodeChildPartial.cshtml")
                    </div>
                    <div ng-if="item.COLUMN_NAME.indexOf('FROM_LOCATION') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_locationCodeChildPartial.cshtml")
                    </div>
                    <div ng-if="item.COLUMN_NAME.indexOf('TO_LOCATION') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_tolocationCodeChildPartial.cshtml")
                    </div>
                    <div ng-if="item.COLUMN_NAME.indexOf('SUPPLIER') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_supplierCodeChildPartial.cshtml")
                    </div>
                    <div ng-if="item.COLUMN_NAME.indexOf('CUSTOMER') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/DropDownPartialView/ChildPartialView/_customerCodeChildPartial.cshtml")
                    </div>

                    <div ng-if="item.COLUMN_NAME.indexOf('ACC') !== -1">
                        @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/PartialView/_accountCodePartial.cshtml")
                    </div>


                    <div ng-if="item.COLUMN_NAME.indexOf('MU') !== -1">
                        <input type="text" id="item.COLUMN_NAME" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control mutextbox" disabled />
                    </div>


                </div>

                <div ng-if="item.COLUMN_NAME ==='QUANTITY'">
                    <input type="number" id="item.COLUMN_NAME" min="0" placeholder="Enter quantity" ng-change="ChildSumOperations(key)" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox qty" />
                </div>

                <div ng-if="item.COLUMN_NAME.indexOf('CALC_QUANTITY') !== -1">
                    <input type="number" id="item.COLUMN_NAME" min="0" placeholder="Enter calc_quantity" ng-change="ChildCalcSum(key)" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" disabled />
                </div>




                @*<div ng-if="item.COLUMN_NAME =='COMPLETED_QUANTITY'">
                        <input type="number" id="item.COLUMN_NAME" min="0" placeholder="Enter completed quantity" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}} textbox qty" />
                    </div>*@

