                        <option value="DR" selected="selected">Dr</option>
                        <option value="CR">Cr</option>
                    </select>
                </div>
                <div ng-if="item.COLUMN_NAME ==='REQ_QUANTITY'">
                    <input type="number" id="item.COLUMN_NAME" min="0" placeholder="Enter required quantity" name="item.COLUMN_NAME" ng-model="childModels[key][item.COLUMN_NAME]" class="form-control {{item.COLUMN_NAME}}_{{key}} textbox" />
                </div>-->
            </td>


            <td class="btn-action plan-type-cls">

                <span ng-hide="$parent.invCtrlObject.SelectPlanDtl.PLAN_NO>0">

                    <a style="border:0px !important;" href="" id="add_child_element" name="add_child_element" class="buttonadd" ng-click="add_child_element($index)"><i class="fa fa-plus" data-toggle="tooltip" title="Add row"></i></a>
                    @*<a href="javascript:void(0)" class="buttondelete">
                 <i class="fa fa-trash text-danger" data-tooltip="Remove item" ng-click="remove_child_element($index)"></i>
                </a>*@
                    <a style="border:0px !important;" href="" id="remove_child_element" name="remove_child_element" class="buttondelete" ng-click="remove_child_element($index)"><i class="fa fa-trash" data-toggle="tooltip" title="Delete row"></i></a>
                    <a ng-if="dynamicSerialTrackingModalData[$index].TRACK[0].TRACKING_SERIAL_NO!='' &&  OrderNo != 'undefined'" href="" id="tds_trans_child_element" name="tds_trans_child_element" class="buttondelete" ng-click="ShowBatchTranDetail($index)"><i class="fa fa-file-text" data-toggle="tooltip" title="Serial Transaction Detail"></i></a>
