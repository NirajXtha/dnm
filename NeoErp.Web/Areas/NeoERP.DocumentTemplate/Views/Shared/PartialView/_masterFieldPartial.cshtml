                        </div>


                        <div class="col-xs-6 col-sm-6 col-md-6 nopadding-left pl-1">
                            <input type="text" id="nepaliDate5" data-checkfor="englishdatedocument" onchange="ConvertNepToEng(this)" @*ng-blur="ConvertNepToEng($event.keyCode);"*@ @*onfocusout="showNdpCalendarBox('nepaliDate5');"*@ class="nepali-calendar" next-on-tab />
