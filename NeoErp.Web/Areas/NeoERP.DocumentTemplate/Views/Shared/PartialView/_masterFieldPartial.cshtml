        <script>
            $(".nepali-calendar").nepaliDatePicker({
                //  ndpEnglishInput: 'englishdatedocument',
                npdMonth: true,
                onFocus: true,
                npdYear: true,
                npdYearCount: 10,
                altFormat: "dd-MMM-YYYY",
                dateFormat: "dd-MMM-YYYY",
                onChange: function (evt) {
                    //evt.stopPropagation();

                    var nepalidate = $("#nepaliDate5").val();
                    var Engdate = BS2AD(nepalidate);
                    var cmpEngDate = moment(Engdate).format('YYYY/MM/DD');
                    var FormattedEngDate = moment(Engdate).format('DD-MMM-YYYY');
                    var date = new Date();
                    var formBackDays = $('#hdnformBackDays').val();
                    date.setDate(date.getDate() - formBackDays);
                    var minDate = dateSet(date);
                    var maxDate = dateSet(new Date());
                    if ((cmpEngDate > maxDate) || (cmpEngDate < minDate)) {
                        alert("Selected date not available");
                        $("#nepaliDate5").focus();
                        var curDate = new Date();
                        curDate = curDate.getFullYear() + "-" + (curDate.getMonth() + 1) + "-" + curDate.getDate();
                        var nepdate = AD2BS(curDate);
                        $("#nepaliDate5").val(nepdate);
                        var months = ["jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec"];
                        var curEngDate = new Date();
                        curEngDate = curEngDate.getDate() + "-" + months[curEngDate.getMonth()] + "-" + curEngDate.getFullYear();
                        $("#englishdatedocument").val(curEngDate);
                    }
                    else {
                        $("#englishdatedocument").val(FormattedEngDate);
                    }
                }
            });

        </script>

