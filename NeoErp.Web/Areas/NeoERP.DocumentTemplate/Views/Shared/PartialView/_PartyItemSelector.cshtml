                </div>
                
                <div class="party-modal-container">
                    <div class="row" style="margin:0; height:100%;">
                        <div ng-class="{'col-sm-12': itemSelectMode=='group', 'col-sm-6': itemSelectMode=='individual'}" class="party-modal-left" style="padding-right:8px;">
                            <div class="row" style="margin-bottom:10px;">
                                <div class="col-xs-12">
                                    <input type="text" class="form-control input-sm" ng-model="itemTreeSearch" ng-change="filterItemTree(itemTreeSearch)" placeholder="Search tree..." />
                                </div>
                            </div>
                            <div class="tree-container">
                                <div id="itemTreeView"></div>
                            </div>
                        </div>
                        
                        <div ng-class="{'col-sm-6': itemSelectMode=='individual'}" ng-show="itemSelectMode=='individual'" class="party-modal-right" style="padding-left:8px;">
                            <div class="row" style="margin-bottom:10px;">
                                <div class="col-xs-12">
                                    <input type="text" class="form-control input-sm" id="itemGridSearch" placeholder="Search selected..." />
                                </div>
                            </div>
                            <div class="grid-container">
                                <div id="selectedItemsGrid"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" ng-click="selectItems()">Select Items</button>
            </div>
        </div>
    </div>
</div>

