@* Product Info Hover Tooltip Component *@
@* This component displays product information on hover *@
@* 
    Usage:
    @Html.Partial("~/Areas/NeoERP.DocumentTemplate/Views/Shared/PartialView/_productInfoHover.cshtml", 
        new {
            HeadOfficeStock = "-1.00",
            LastCustomerName = "Dary'S International",
            LastSalesPrice = "1,091.15",
            SecondLastCustomerName = "Sudarshan",
            SecondLastSalesPrice = "3,097.35",
            ThirdLastCustomerName = "Macto Spares",
            ThirdLastSalesPrice = "3,097.35",
            ProductName = "1-Vibe Go Lite Magnetic Wire",
            ProductCode = "2228",
            ProductId = "BS8B2",
            Unit = "Pieces",
            SecondUnit = "",
            Category = "Trading Goods",
            HsCode = "8518.22.00",
            CreatedBy = "SATISON",
            CreatedDate = "10/26/2025 5:39:28"
        })
*@

@{
    dynamic data = ViewBag.ProductInfoData ?? Model;
}

<div class="product-info-hover">
    <i class="fa fa-info-circle" style="font-size: 16px; color: #3498db;"></i>
    <div class="product-info-tooltip">
        <div class="info-section">
            <div class="section-header product-header">Current Product Info...</div>
            <div class="product-name-header">@(data?.ProductName ?? "1-Vibe Go Lite Magnetic Wire")</div>
            <table class="info-table">
                <tr>
                    <td>Product Code / ID</td>
                    <td>@(data?.ProductCode ?? "2228") / [ @(data?.ProductId ?? "BS8B2") ]</td>
                </tr>
                <tr>
                    <td>Unit</td>
                    <td>@(data?.Unit ?? "Pieces")</td>
                </tr>
                <tr>
                    <td>Second Unit</td>
                    <td>@(data?.SecondUnit ?? "")</td>
                </tr>
                <tr>
                    <td>Category</td>
                    <td>@(data?.Category ?? "Trading Goods")</td>
                </tr>
                <tr>
                    <td>HS Code</td>
                    <td>@(data?.HsCode ?? "8518.22.00")</td>
                </tr>
                <tr>
                    <td>Created By</td>
                    <td>@(data?.CreatedBy ?? "SATISON")</td>
                </tr>
                <tr>
                    <td>Created Date</td>
                    <td>@(data?.CreatedDate ?? "10/26/2025 5:39:28")</td>
                </tr>
            </table>
        </div>

        <div class="info-section">
            <div class="section-header sales-header">Closing Stock - Location wise</div>
            <table class="info-table">
                <tr>
                    <td>Head Office</td>
                    <td>@(data?.HeadOfficeStock ?? "-1.00")</td>
                </tr>
            </table>
            <div class="subsection-header">Sales Rate History</div>
            <table class="info-table">
                <tr>
                    <td>Last Customer Name</td>
                    <td>@(data?.LastCustomerName ?? "-Dary'S International")</td>
                </tr>
                <tr>
                    <td>Last Sales Price</td>
                    <td>@(data?.LastSalesPrice ?? "1,091.15")</td>
                </tr>
                <tr>
                    <td>2nd Last Customer Name</td>
                    <td>@(data?.SecondLastCustomerName ?? "Sudarshan")</td>
                </tr>
                <tr>
                    <td>2nd Last Sales Price</td>
                    <td>@(data?.SecondLastSalesPrice ?? "3,097.35")</td>
                </tr>
                <tr>
                    <td>3rd Last Customer Name</td>
                    <td>@(data?.ThirdLastCustomerName ?? "Macto Spares")</td>
                </tr>
                <tr>
                    <td>3rd Last Sales Price</td>
                    <td>@(data?.ThirdLastSalesPrice ?? "3,097.35")</td>
                </tr>
            </table>
        </div>
    </div>
</div>
