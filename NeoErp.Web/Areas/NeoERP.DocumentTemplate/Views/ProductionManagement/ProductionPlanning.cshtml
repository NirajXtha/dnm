    <div id="MappingFormViewPopupModel" class="modal fade" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">Mapping Form</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <form class="form-horizontal">
                        <div class="row">

                            <!-- Left Section - Requisition -->
                            <div class="col-md-6">
                                <div class="panel panel-default">
                                    <div class="panel-heading">
                                        <h6 class="panel-title">Requisition Form Mapping</h6>
                                    </div>
                                    <div class="panel-body">
                                        <!-- Requisition Form Selection -->
                                        <div class="form-group">
                                            <label class="col-sm-4 control-label">Requisition :</label>
                                            <div class="col-sm-8">
                                                <select class="form-control"
                                                        ng-model="selectedFormDetails.RequisitionFormCodeValue"
                                                        ng-options="form.FORM_CODE as form.FORM_EDESC for form in formsMappingList">
                                                    <option value="">-- Select Form --</option>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Requisition From Location -->
                                        <div class="form-group">
                                            <label class="col-sm-4 control-label">From Location :</label>
                                            <div class="col-sm-8">
                                                <div class="input-group">
                                                    <input id="reqFromLocation"
                                                           style="width:92% !important;"
                                                           ng-model="selectedFormDetails.RequisitionFromLocationValue"
                                                           name="reqFromLocation"
                                                           class="form-control"
                                                           kendo-combo-box
                                                           k-placeholder="'Select Location Code'"
                                                           k-data-text-field="'LocationName'"
                                                           k-data-value-field="'LocationCode'"
                                                           k-filter="'contains'"
                                                           k-auto-bind="true"
                                                           k-options="locationCodeOption"
                                                           k-suggest="false"
                                                           k-on-change="RequisitionFromLocationOnChange(kendoEvent)"
                                                           k-min-length="3"
                                                           k-data-source="locationDataSource" />
                                                    <span class="input-group-btn">
                                                        <button class="btn btn-default" style="height: 25px !important; padding-top: 2px;"
                                                                type="button"
                                                                ng-click="BrowseTreeListFortolocation('reqFromLocation')">
                                                            <i class="fa fa-search"></i>
                                                        </button>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Requisition To Location -->
