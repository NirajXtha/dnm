                {{toast.message}}
            </div>
        </div>*@


    <div class="col-md-12">

        <div class="portlet light form-fit bordered bottomspance">
            <div class="portlet mingap">

                <div class="portlet-title">

                    <div class="caption caption-title ng-binding">
                        <a class="btn-back pull-left" data-toggle="tooltip" data-placement="top" title="Back To Dashboard" href="/DocumentTemplate/Home/Dashboard">
                            <i class="fa fa-arrow-circle-left"></i>
                        </a>
                        <i class="fa fa-gift font-green-haze"></i>
                        <span class="caption-subject font-green-haze bold uppercase">{{FormName}}</span>
                    </div>

                    <div class="actions">

                        <a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="OpenMappingFormPopupModel()" href="javascript:;">
                            <i class="fa fa-plus-circle"></i> Mapping Forms
                        </a>

                        <a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="ShowAddNewPlanningPopup()" href="javascript:;">
                            <i class="fa fa-plus-circle"></i> New
                        </a>

                        @*<a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="saveIndenAdjustment()" href="javascript:;">
                                <i class="fa fa-check-circle"></i> Ok
                            </a>

                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="cancelIndentAdjustment()" href="javascript:;">
                                <i class="fa fa-close"></i> Cancel
                            </a>*@

                        @*<a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="printIndentAdjustment()" href="javascript:;">
                                <i class="fa fa-print"></i> Print
                            </a>

                            <a class="btn btn-success" data-toggle="tooltip" data-placement="top" ng-click="viewPlannedReport()" href="javascript:;">
                                <i class="fa fa-maxcdn"></i>
                            </a>*@

                    </div>

                </div>

                <div class="portlet-body">

                    <div class="row">

                        <div class="col-md-10 col-sm-12 form-group">

                            <div class="col-md-6">
                                @Html.Partial("~/Views/Shared/Controls/DateField.cshtml", true)
                            </div>



                            <div class="col-md-3 col-sm-2">
                                <label for="status">Status:</label>
                                <div class="btn-group">
                                    <select class="form-control input-small" ng-change="changeFilterStatus()"
                                            ng-model="dataObject.SelectedFilterStatus"
                                            name="status"
                                            id="status"
                                            ng-options="item.Value as item.Name for item in dataObject.FilterStatusList">
                                        @*<option value="">Select Status</option>*@
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3 col-sm-2">
                                <label for="status">Filter:</label>
                                <div class="btn-group">
                                    <input type="text" ng-model="dataObject.FilterListSearchText" placeholder="e.g: plan name, plan no, order no" />
                                </div>
                            </div>

                            <div class="col-md-6 col-sm-6" style="padding-top:2%;">
                                <div>
                                    <button ng-click="GridReCall()" class="btn green btn-success">Search</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <div class="row">
                        @*Grid Block *@
                        @* Plan No, Plan Date, Plan Miti, Plan Name, Product Name / Order No, Unit, Plan Type, Order Quantity, Planned Quantity, Prod. Iss. Quantity, Resource Name*@
                        <div class="tabbable">
                            <br />
                            <div class="" id="planGridContainer" style="overflow:auto">
                                <kendo-grid id="productionPlanningListGrid" options="productionPlanningListOptions" k-rebind="productionPlanningListOptions" class="kendo_gride_table" style="width:180%;">
                                </kendo-grid>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>



        <div class="portlet-body">
