@{
    ViewBag.Title = "Form Setup - Index";
    Layout = "~/Views/Shared/_LayoutNew.cshtml";
}


<style>
    /* ✅ Apply 90% size only to this popup */
    #tabPopupModal .modal-dialog.modal-lg {
        width: 90%;
        max-width: 90%;
    }

    #tabPopupModal .modal-content {
        /* height: 100%;*/
    }

    #tabPopupModal .modal-body {
        height: calc(100% - 120px);
        overflow-y: auto;
    }

    #tabPopupModal .text-center {
        /* margin-top: 20px;*/
    }
</style>


<link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />

<style>
    #informationSetupForm {
        padding: 20px;
    }

        #informationSetupForm .form-header {
            background-color: #5bc0de;
            color: #003d4d;
            padding: 8px 15px;
            margin-bottom: 20px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 16px;
        }

        #informationSetupForm .form-section {
            border: 1px solid silver;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 15px;
        }

        #informationSetupForm .section-title {
            font-weight: bold;
            margin-bottom: 10px;
            color: #003d4d;
        }

        #informationSetupForm .form-control {
            height: 15px;
        }

            #informationSetupForm .form-control[readonly] {
                background-color: #fff;
            }

        #informationSetupForm textarea:not([readonly]) {
            height: 30px;
        }
</style>

<style>


    #salesOrderSetup .form-section {
        margin-bottom: 20px;
    }

    #salesOrderSetup .top-section {
        border: 1px solid #ddd;
        padding: 15px;
        margin-bottom: 5px;
        min-height: 135px;
    }

    #salesOrderSetup .config-table-wrapper {
        border: 1px solid #ddd;
        overflow-x: auto;
        max-height: 400px;
        overflow-y: auto;
    }

    #salesOrderSetup .config-table {
        margin-bottom: 0;
        font-size: 12px;
    }

        #salesOrderSetup .config-table th {
            background-color: #f5f5f5;
            font-weight: bold;
            border: 1px solid #ddd;
            padding: 8px 4px;
            text-align: center;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        #salesOrderSetup .config-table td {
            border: 1px solid #ddd;
            padding: 4px;
            vertical-align: middle;
        }

        #salesOrderSetup .config-table .sn-col {
            width: 40px;
            text-align: center;
        }

        #salesOrderSetup .config-table .column-name-col {
            width: 150px;
        }

        #salesOrderSetup .config-table .header-col {
            width: 150px;
        }

        #salesOrderSetup .config-table .width-col,
        #salesOrderSetup .config-table .top-col,
        #salesOrderSetup .config-table .left-col {
            width: 60px;
            text-align: right;
        }

        #salesOrderSetup .config-table .master-child-col {
            width: 80px;
            text-align: center;
        }

        #salesOrderSetup .config-table .is-desc-col {
            width: 60px;
            text-align: center;
        }

        #salesOrderSetup .config-table .default-value-col,
        #salesOrderSetup .config-table .filter-value-col {
            width: 120px;
        }

        #salesOrderSetup .config-table .display-col {
            width: 60px;
            text-align: center;
        }

    #salesOrderSetup .emoji-cell {
        cursor: pointer;
        font-size: 16px;
    }

    #salesOrderSetup .new-field-section {
        margin-bottom: 15px;
    }

    #salesOrderSetup .inline-label {
        display: inline-block;
        margin-right: 10px;
        font-weight: bold;
    }

    #salesOrderSetup .format-section {
        text-align: right;
    }

    #salesOrderSetup .checkbox-inline-custom {
        margin-left: 20px;
    }

    #salesOrderSetup .form-control {
        height: 15px;
    }
</style>

<style>

    /* Force the modal to be vertically centered */
    .modal-centered {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 100vh !important;
    }



    .modal-content {
        border-radius: 8px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.3);
    }

    /* Prevent background scrolling when modal is open */
    body.modal-open {
        overflow: hidden !important;
    }
</style>

<style>
    .disabled-div {
        pointer-events: none;
        opacity: 0.7;
        cursor: not-allowed;
    }
</style>

<script src="@Scripts.Url("~/Scripts/ngScript/Module.js")"></script>
<script src="@Scripts.Url("~/Scripts/ngScript/Service.js")"></script>
<script src="@Scripts.Url("~/Scripts/ngScript/FormSetupController.js")"></script>
<script src="@Scripts.Url("~/Content/MainTheme/NotifyBar/jquery.notifyBar.js")"></script>
<script src="~/Scripts/plugins/dataTables/dataTables.bootstrap.js"></script>
<script src="~/Scripts/ngScript/ui-bootstrap-tpls-2.1.3.min.js"></script>
<script src="~/Content/Kendo/kendoAllNew.js"></script>
<script src="~/Scripts/ngScript/angular ui select/select2.js"></script>
<script src="~/JS/NeoErp.js"></script>

<div class="page-content-wrapper" id="operationContent">
    <div class="page-content full-width" style="min-height:310px">
        <div ng-app="erpApp">
            <div ng-controller="FormSetupController" id="FormSetupController">
                <div class="row">
                    <div class="col-md-4">
                        <select id="moduleSelect"
                                class="form-control"
                                ng-model="selectedFormModule"
                                ng-options="m as m.ITEM_EDESC for m in moduleList track by m.MASTER_ITEM_CODE"
                                ng-change="onModuleChange(m)">
                            <option value="">-- Select Module --</option>
                        </select>
                    </div>
                </div>

                <div style="float:right;">
                </div>

                <div class="divList" style="padding-top:1%;">
                    <div class="row">

                        <div class="col-md-12">

                            <div class="portlet box grey-cascade">
                                <div class="portlet-title">

                                    <div class="caption menutitle">
                                        <button type="button" class="btn btn-primary" ng-click="GetNextFormCode()">
                                            Create
                                        </button>
                                        <button type="button" class="btn btn-primary" ng-click="EditGroupedTreeItem()">
                                            Edit
                                        </button>
                                    </div>

                                    <div class="tools">
                                        <a href="javascript:;" class="collapse">
                                        </a>
                                        <a href="#portlet-config" data-toggle="modal" class="config">
                                        </a>
                                        <a href="javascript:;" class="reload" ng-click="ReloadGrid()">
                                        </a>
                                        <a href="javascript:;" class="remove">
                                        </a>
                                    </div>

                                </div>
                                <div class="portlet-body menu-controle">
                                    <div id="splitter" style="height:600px !important;" kendo-splitter
                                         k-panes="[{ collapsible: true, size: '20%' },{ collapsible: true, size: '80%'}]"
                                         k-orientation="orientation"
                                         k-rebind="orientation">

                                        <div class="portlet box green-box tab-box">
                                            @*<div class="portlet-title">
                                                    <div class="caption splitterfont">
                                                    </div>
                                                </div>*@
                                            <div class="portlet-body">
                                                <div class="form-body" id="moduleList">
                                                    <div id="categoryTreeGrid"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="">
                                            <div class="tabbable-line1 tabbox1" style="margin-top:1px;">

                                                <div class="row">
                                                    <button style="margin-left:16px;" type="button" class="btn btn-primary" ng-click="OpenTabPopup(false)" ng-if='selectedRowItemDataOnGrid != null'>
                                                        Edit Recored
                                                    </button>

                                                    <button type="button" class="btn btn-primary" ng-click="OpenTabPopup(true)" ng-if='selectedRowItemDataOnGrid != null'>
                                                        Duplicate Recored
                                                    </button>
                                                </div>

                                                <div>
                                                    <kendo-grid id="formSetupResultGrid" options="formSetupResultOptions" k-rebind="formSetupResultOptions" class="kendo_gride_table" style="width:100%;">
                                                    </kendo-grid>
                                                </div>

                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>





                <!-- Modal -->
                <div class="modal fade" id="documentGroupModal" tabindex="-1" role="dialog" aria-labelledby="documentGroupModalLabel">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">

                            <!-- Header -->
                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal">&times;</button>
                                <h4 class="modal-title" id="documentGroupModalLabel">Document Group Setup</h4>
                            </div>

                            <!-- Body -->
                            <div class="modal-body">
                                <form class="form-horizontal" name="documentGroupForm">

                                    <!-- Form Code / Parent -->
                                    <div class="form-group">
                                        <label class="col-sm-3 control-label">Form Code</label>
                                        <div class="col-sm-3">
                                            <input type="text" class="form-control" ng-model="document.FORM_CODE">
                                        </div>
                                        <label class="col-sm-2 control-label">Parent</label>
                                        <div class="col-sm-4">
                                            <div class="input-group">
                                                <input type="text" class="form-control" ng-model="document.PARENT">
                                                <span class="input-group-addon"><span class="glyphicon glyphicon-folder-open"></span></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- In English / Branch wise -->
                                    <div class="form-group">
                                        <label class="col-sm-3 control-label">In English</label>
                                        <div class="col-sm-3">
                                            <input type="text" class="form-control" ng-model="document.ENG_DESC">
                                        </div>
                                        <label class="col-sm-3 control-label">Branch wise Document</label>
                                        <div class="col-sm-3">
                                            <div class="input-group">
                                                <input type="text" class="form-control" ng-model="document.BRANCH_DOC">
                                                <span class="input-group-addon" ng-click="GetBranchList()"><span class="glyphicon glyphicon-list-alt"></span></span>
                                            </div>
                                        </div>

                                        <!-- Branch List -->
                                        <div ng-if="branches.length" class="branch-list col-sm-4" style="border: 1px solid #ccc; border-radius: 4px; margin-top: 5px; max-height: 100px; overflow-y: auto; padding: 5px; float:right; margin-right:15px;">
                                            <div ng-repeat="branch in branches">
                                                <label class="checkbox-inline" style="display: block;">
                                                    <input type="checkbox" ng-model="branch.checked"> {{branch.BRANCH_EDESC}}
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- In Nepali -->
                                    <div class="form-group">
                                        <label class="col-sm-3 control-label">In Nepali</label>
                                        <div class="col-sm-9">
                                            <input type="text" class="form-control" ng-model="document.NEP_DESC">
                                        </div>
                                    </div>

                                    <!-- Module -->
                                    <div class="form-group">
                                        <label class="col-sm-3 control-label">Module</label>
                                        <div class="col-sm-9">
                                            <select class="form-control" ng-model="document.MODULE_CODE" ng-options="m.MODULE_CODE as m.MODULE_EDESC for m in modules">
                                                <option value="">-- Select Module --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Remarks -->
                                    <div class="form-group">
                                        <label class="col-sm-3 control-label">Remarks</label>
                                        <div class="col-sm-9">
                                            <textarea class="form-control" rows="3" ng-model="document.REMARKS"></textarea>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            <!-- Footer -->
                            <div class="modal-footer">
                                <button type="button" class="btn btn-success" ng-click="saveDocument(document)">OK</button>
                                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                            </div>

                        </div>
                    </div>
                </div>



                <div style="top:17px !important;" class="modal fade" id="tabPopupModal" tabindex="-1" role="dialog" aria-labelledby="tabModalLabel">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">

                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal">&times;</button>
                                <h4 class="modal-title" id="tabModalLabel">Form Wizard Tabs</h4>
                            </div>

                            <div class="modal-body">
                                <!-- Kendo TabStrip -->
                                <div kendo-tab-strip="tabStrip"
                                     k-options="tabOptions"
                                     k-rebind="tabOptions">
                                    <ul>
                                        <li class="k-state-active">Information</li>
                                        <li ng-click="LoadFormattingData()">Formatting</li>
                                        <li ng-click="LoadReferenceTabData()">Reference</li>
                                        <li ng-click="LoadNumberingTabData()">Numbering</li>
                                        <li ng-click="LoadChargeSetupTabData()">Charge Setup</li>
                                        <li ng-click="LoadQualityCheckTabData()">Quality Check</li>
                                        <li ng-click="LoadCustomTabData()">Custom</li>
                                        <li ng-click="LoadQuickInfoValidationTabData()">Quick Info/Validation</li>
                                        <li ng-click="LoadMiscellaneousTabData()">Miscellaneous</li>

                                    </ul>

                                    <div>
                                        <p>This wizard allows you to setup different types of transaction screens.</p>

                                        <div id="informationSetupForm" class="container-fluid">

                                            <div style="height:300px; overflow-y:scroll;">
                                                <form name="formSetupForm" novalidate>
                                                    <div class="form-group row">
                                                        <label class="col-sm-2 control-label">Code</label>
                                                        <div class="col-sm-4" ng-if="!IsDuplicate">
                                                            <input type="text" class="form-control" ng-model="FormItemEntryUpdateModel.FORM_CODE" readonly>
                                                        </div>

                                                        <div class="col-sm-4" ng-if="IsDuplicate">
                                                            <input type="text" class="form-control" ng-model="FormItemEntryUpdateModel.NEXT_FORM_CODE" readonly>
                                                        </div>
                                                    </div>

                                                    <div class="form-group row">
                                                        <label class="col-sm-2 control-label">In English</label>
                                                        <div class="col-sm-8">
                                                            <input type="text" class="form-control" ng-model="FormItemEntryUpdateModel.FORM_EDESC" placeholder="Enter English name">
                                                        </div>
                                                    </div>

                                                    <div class="form-group row">
                                                        <label class="col-sm-2 control-label">In Nepali</label>
                                                        <div class="col-sm-8">
                                                            <input type="text" class="form-control" ng-model="FormItemEntryUpdateModel.FORM_NDESC" placeholder="Enter Nepali name">
                                                        </div>
                                                    </div>

                                                    <div class="form-group row">
                                                        <label class="col-sm-2 control-label"></label>
                                                        <div class="col-sm-8">
                                                            <div class="form-section">
                                                                <div class="section-title">

                                                                    @*{{FormItemEntryUpdateModel|json}}*@
                                                                    Select which of the following is needed for this document
                                                                </div>

                                                                <div class="row">
                                                                    <div class="col-sm-4">
                                                                        <select class="form-control"
                                                                                ng-model="FormItemEntryUpdateModel.FORM_ACTION_FLAG"
                                                                                ng-options="option.value as option.name for option in checkingOptions">
                                                                        </select>
                                                                    </div>
                                                                    <div class="col-sm-6">
                                                                        <div class="checkbox">
                                                                            <label>
                                                                                <input type="checkbox"
                                                                                       ng-model="FormItemEntryUpdateModel.INTER_BRANCH_FLAG"
                                                                                       ng-true-value="'Y'"
                                                                                       ng-false-value="'N'">
                                                                                Inter Branch Transaction
                                                                            </label>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div style="margin-top: 15px;">
                                                                    <div style="margin-top: 15px;">
                                                                        <div class="section-title">Document T </div>
                                                                        <div>
                                                                            <label class="radio-inline" ng-repeat="option in documentTypeOptions">
                                                                                <input type="radio"
                                                                                       name="documentType"
                                                                                       ng-model="FormItemEntryUpdateModel.FORM_TYPE"
                                                                                       ng-value="option.value">
                                                                                {{option.name}}
                                                                            </label>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="form-group row">
                                                        <label class="col-sm-2 control-label">Remarks   </label>
                                                        <div class="col-sm-8">
                                                            <textarea class="form-control" rows="3" ng-model="FormItemEntryUpdateModel.REMARKS"></textarea>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>



                                    <div class="container-fluid" id="formattingSetupTabId">
                                        <div id="salesOrderSetup">
                                            <!-- Top Section -->
                                            <div class="top-section">
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label class="inline-label">Select Table Name</label>
                                                            <select class="form-control"
                                                                    style="width: 300px; display: inline-block;"
                                                                    ng-model="FormattingTab_SaveToObj.TABLE_NAME"
                                                                    ng-options="item.TABLE_NAME as item.TABLE_DESC for item in FormattingTab_TableList"
                                                                    ng-disabled="true">
                                                                <option value="">-- Select Table --</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6 format-section">
                                                        <label style="font-weight: bold; display: block; margin-bottom: 10px;">Select valid format for Numeric and Date fields</label>
                                                        <div class="form-group">
                                                            <label class="inline-label">Number</label>
                                                            <select class="form-control"
                                                                    style="width: 200px; display: inline-block;"
                                                                    ng-model="FormattingTab_SaveToObj.NUMBERING_FORMAT"
                                                                    ng-options="item.key as item.name for item in FormattingTab_NumberList">
                                                                <option value="">-- Select Number --</option>
                                                            </select>
                                                        </div>
                                                        <div class="form-group">
                                                            <label class="inline-label">Date</label>
                                                            <select class="form-control"
                                                                    style="width: 200px; display: inline-block;"
                                                                    ng-model="FormattingTab_SaveToObj.DATE_FORMAT"
                                                                    ng-options="item.key as item.name for item in FormattingTab_DateFormatList">
                                                                <option value="">-- Select Date Format --</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row" style="float:right;">
                                                    <div class="col-md-12">
                                                        <label class="checkbox-inline checkbox-inline-custom">
                                                            <input type="checkbox" ng-model="FormattingTab_SaveToObj.COINAGE_FLAG" ng-true-value="'Y'" ng-false-value="'N'">
                                                            Coinage
                                                        </label>
                                                        <label class="inline-label" style="margin-left: 40px;">Sub Ledger</label>
                                                        <input type="text" ng-model="FormattingTab_SaveToObj.SUB_LEDGER_NAME" class="form-control" style="width: 280px; display: inline-block;">
                                                        <button class="btn btn-default" data-toggle="modal" data-target="#subLedgerModal">
                                                            <span class="glyphicon glyphicon-folder-open"></span>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- New Field Section -->
                                            <div class="new-field-section">
                                                <label class="inline-label">New Field :  {{FormattingTab_SaveToObj.SELECTED_COLUMN}}</label>
                                                <select class="form-control"
                                                        style="width: 250px; display: inline-block;"
                                                        ng-model="FormattingTab_SaveToObj.SELECTED_COLUMN"
                                                        ng-options="col for col in FormattingTab_UnmappedColumnList">
                                                    <option value="">None</option>
                                                </select>
                                                <button class="btn btn-primary" style="margin-left: 10px;" ng-click="AddUnMappedColumn(FormattingTab_SaveToObj.SELECTED_COLUMN)">Add</button>
                                            </div>


                                            <div class="modal fade" id="confirmModal" tabindex="-1" role="dialog">
                                                <div class="modal-dialog modal-sm modal-centered" role="document">
                                                    <div class="modal-content">
                                                        <div class="modal-header bg-info text-white">
                                                            <h5 class="modal-title">ERP Confirmation</h5>
                                                        </div>
                                                        <div class="modal-body text-center">
                                                            <p>New field as Master (Yes) or Child (No)?</p>
                                                        </div>
                                                        <div class="modal-footer justify-content-center">
                                                            <button class="btn btn-primary" ng-click="onConfirm('Y')">Yes</button>
                                                            <button class="btn btn-secondary" ng-click="onConfirm('N')">No</button>
                                                            <button class="btn btn-light" ng-click="closePopupModel('confirmModal')">Cancel</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Configuration Table with Corrected Dropdown -->
                                            <div class="config-table-wrapper">
                                                <table class="table table-bordered config-table small-table">
                                                    <thead>
                                                        <tr>
                                                            <th class="sn-col">S. N.</th>
                                                            <th class="column-name-col">Column Name</th>
                                                            <th class="header-col">Header</th>
                                                            <th class="width-col">Width</th>
                                                            <th class="top-col">Top</th>
                                                            <th class="left-col">Left</th>
                                                            <th class="master-child-col">Master/Child</th>
                                                            <th class="is-desc-col">Is Desc</th>
                                                            <th class="default-value-col">Default Value</th>
                                                            <th class="filter-value-col">Filter Value</th>
                                                            <th class="display-col">Display</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr ng-repeat="item in FormattingTab_FormDetailSteupList track by $index">
                                                            <td class="sn-col">{{item.SERIAL_NO}}</td>
                                                            <td class="column-name-col">
                                                                {{item.COLUMN_NAME}}
                                                            </td>
                                                            <td class="header-col">
                                                                <input type="text"
                                                                       class="form-control"
                                                                       ng-model="item.COLUMN_HEADER"
                                                                       placeholder="Enter Header"
                                                                       style="width:140px;" />
                                                            </td>
                                                            <td class="width-col">
                                                                <input type="text"
                                                                       class="form-control"
                                                                       ng-model="item.COLUMN_WIDTH"
                                                                       placeholder="Enter width"
                                                                       style="width: 30px;" />
                                                            </td>
                                                            <td class="top-col">
                                                                <input type="text"
                                                                       class="form-control"
                                                                       ng-model="item.TOP_POSITION"
                                                                       placeholder="Enter top position"
                                                                       style="width: 30px;" />
                                                            </td>
                                                            <td class="left-col">
                                                                <input type="text"
                                                                       class="form-control"
                                                                       ng-model="item.LEFT_POSITION"
                                                                       placeholder="Enter left position"
                                                                       style="width: 30px;" />
                                                            </td>

                                                            <!-- Convert M/C to Master/Child -->
                                                            <td class="master-child-col">


                                                                @*  {{ item.MASTER_CHILD_FLAG === 'M' ? 'Master' : 'Child' }}*@
                                                                <select class="form-control" ng-model="item.MASTER_CHILD_FLAG" style="width:55px;"
                                                                        ng-options="item.Key as item.Value for item in typeListMasterChild">
                                                                </select>
                                                            </td>

                                                            <!-- Convert Y/N to Yes/No -->
                                                            <td class="is-desc-col">
                                                                @*{{ item.IS_DESC_FLAG === 'Y' ? 'Yes' : 'No' }}*@
                                                                <select class="form-control"
                                                                        ng-model="item.IS_DESC_FLAG" style="width:38px;"
                                                                        ng-options="item.Key as item.Value for item in typeListYesNo">
                                                                </select>
                                                            </td>

                                                            <!-- Default Value Column -->
                                                            <td class="default-value-col" style="position: relative;">
                                                                <!-- Date Input -->
                                                                <span ng-if="item.COLUMN_NAME.indexOf('_DATE') != -1">
                                                                    <input type="date"
                                                                           ng-model="item.DEFA_VALUE"
                                                                           class="form-control"
                                                                           style="width: 110px;" />

