<body class="login">
    <!-- BEGIN : LOGIN PAGE 5-1 -->
    <div class="user-login-5">
        <div class="row bs-reset">
            <div class="col-md-7 bs-reset slider">
                <img class="login-logo" src="~/Pictures/Login/logo.png" />
                <div class="login-bg" style="background-image:url(../../Pictures/Login/bg1.jpg)"></div>
            </div>

            <div class="col-md-5 login-container bs-reset"
                 ng-app="loginApp"
                 ng-controller="LoginController">

                <div class="login-content">
                    <div class="loginbox">
                        <div class="logobox" style="text-align:center">
                            <div class="company_logo">
                                <img class="login-company-logo" src="~/Pictures/Login/company-logo.png" />
                            </div>
                        </div>

                        <form name="loginForm" novalidate method="post" action="@Url.Action("LogIn", "Home")">
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true)

                            <!-- ✅ Fixed Razor conditional class -->
                            <div class="alert alert-danger @(isErrorstring ? "" : "display-hide")">
                                <button class="close" data-close="alert"></button>
                                <span>@ViewBag.Message</span>
                            </div>

                            <div class="form-title">
                                <span class="form-title">Welcome.</span>
                                <span class="form-subtitle">Please login.</span>
                            </div>

                            <div class="input-icon right" id="dbSelect" ng-class="{'has-error': showDatabaseError}">
                                <i class="fa"></i>
                                <select id="ddlCustomer"
                                        name="SelectedDatabase"
                                        class="form-control form-control-solid placeholder-no-fix form-group"
                                        style="color: #333;"
                                        ng-model="formData.selectedDatabase"
                                        ng-change="clearError('database')"
                                        required>
                                    <option value="">---Select Database---</option>
                                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.DatabaseList)
                                    {
                                    <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <span class="validation-error" ng-show="showDatabaseError">
                                    <i class="fa fa-exclamation-circle"></i> Please select a database
                                </span>
                            </div>

                            <div id="left" style="margin-top:10px;">
                                <div class="row">
                                    <div class="col-xs-12 col-sm-6 col-md-6">
                                        <div class="input-icon right" ng-class="{'has-error': showUsernameError}">
                                            <i class="fa fa-user"></i>
                                            <input type="text"
                                                   id="UserName"
                                                   name="UserName"
                                                   class="form-control form-control-solid placeholder-no-fix form-group"
                                                   autofocus
                                                   placeholder="User Name"
                                                   ng-model="formData.userName"
                                                   ng-change="clearError('username')"
                                                   required />
                                            <span class="validation-error" ng-show="showUsernameError">
                                                <i class="fa fa-exclamation-circle"></i> User Name is required
                                            </span>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-6 col-md-6">
                                        <div class="input-icon right" ng-class="{'has-error': showPasswordError}">
                                            <i class="fa fa-lock"></i>
                                            <input type="password"
                                                   id="Password"
                                                   name="Password"
                                                   class="form-control form-control-solid placeholder-no-fix form-group"
                                                   placeholder="Password"
                                                   ng-model="formData.password"
                                                   ng-change="clearError('password')"
                                                   required />
                                            <span class="validation-error" ng-show="showPasswordError">
                                                <i class="fa fa-exclamation-circle"></i> Password is required
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="display:none" id="right">
                                <div class="row">
                                    <div class="col-xs-12 col-sm-6 col-md-6">
                                        <div class="form-group">
                                            <label>Company Name</label>
                                            <select name="company_name" multiple="" id="company_name" class="form-control" selectedIndex="0">
                                                <option>--Please Select Company--</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-6 col-md-6">
                                        <div class="form-group">
                                            <label>Branch Name</label>
                                            <select name="branch_code" id="branch_code" multiple="" class="form-control">
                                                <option>--Please Select Branch--</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-xs-12 col-md-12 col-sm-12">
                                    <div class="input-icon loginbutton-icon pull-right">
                                        <button id="btnNext" type="button" value="Next" name="btnNext" class="btn btn-theme" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing...">Next</button>
                                        <input id="btnBack" type="button" value="Back" name="btnBack" class="btn btn-primary" />
                                        <button id="btnLogin" type="submit" value="Log in" name="btnLogin" class="btn btn-theme" data-loading-text="<i class='fa fa-spinner fa-spin '></i> Processing...">Log in</button>
                                    </div>
                                </div>
                            </div>
                        </form>

                        @*<div class="lastlogin-time">
                                <i class="fa fa-calendar"></i>
                                <span>Last Login: 2017/05/28</span>
                            </div>*@



                        <div class="login-footer">
                            <div class="row bs-reset" style="display: flex; justify-content: flex-end; width: 100%; margin: 0; padding: 10px 0;">
                                <div class="col-xs-9 col-sm-7 col-md-7 bs-reset pull-right" style="text-align: right;">
                                    @*<div class="login-copyright text-right" style="text-align: right;">
                                         <p style="margin-bottom:0px">Copyright &copy; neo.erp 2017</p>
                                         <p style="margin-bottom:0px"> Synergy Web Erp </p>
                                         <p style="margin-bottom:0px"> Version 1 </p>

                                        </div>*@

                                    <div class="login-copyright text-right" style="text-align: right; display: inline-block;">
                                        <p style="margin-bottom:0px; font-family: sans-serif;">Copyright &copy; neo.erp @DateTime.Now.Year</p>
                                        <p style="margin-bottom:0px; font-family: sans-serif;"> Synergy AI </p>
                                        <p style="margin-bottom:0px; font-family: sans-serif;"> Version 1 </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- END : LOGIN PAGE 5-1 -->
    <!--[if lt IE 9]>
    <!-- BEGIN CORE PLUGINS -->
    <script src="~/Content/jquery.min.js"></script>
    <script src="~/Content/jquery-ui.js"></script>

    <!-- AngularJS - Load before other scripts -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <script src="@Scripts.Url("~/Content/MainTheme/assets/global/plugins/bootstrap/js/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Scripts.Url("~/Content/MainTheme/assets/global/plugins/jquery.cokie.min.js")" type="text/javascript"></script>
