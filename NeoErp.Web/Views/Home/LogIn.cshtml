        }

        .validation-error {
            color: #a94442;
            font-size: 11px;
            display: block;
            margin-top: -15px;
        }

        .ng-hide {
            display: none !important;
        }

        /* 5. Desktop Layout - NO SCROLL */
        @@media (min-width: 992px) {
            .user-login-5 .slider {
                width: 58.33333333%;
                height: 100%;
                display: block !important;
            }

            .user-login-5 .login-container {
                width: 41.66666667%;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
                overflow: hidden;
            }
        }

        /* 6. Mobile Layout - NO SCROLL */
        @@media (max-width: 991px) {
            .user-login-5 .slider {
                display: none !important;
            }

            .user-login-5 .login-container {
                width: 100% !important;
                height: 100% !important;
                padding: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden !important;
            }

            .loginbox {
                width: 90%;
                max-width: 450px;
                padding: 20px;
            }

            .loginbutton-icon {
                text-align: center;
            }

                .loginbutton-icon .btn {
                    margin: 5px;
                }
        }

        @@media (max-width: 480px) {
