            border-top: 1px solid #ddd;
            padding: 30px;
            background: linear-gradient(26deg, rgb(253 244 244), rgb(212 221 222), rgb(215 245 205));
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1), -2px -2px 8px rgba(255, 255, 255, 0.3);
        }

