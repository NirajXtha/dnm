    <!-- ✅ ANGULARJS APPLICATION - SCOPED MODULE -->
    <script type="text/javascript">
        // AngularJS Application - Now properly scoped
        var app = angular.module('loginApp', []);

        app.controller('LoginController', function ($scope, $window) {
            $scope.formData = {
                selectedDatabase: '',
                userName: '',
                password: ''
            };

            $scope.showDatabaseError = false;
            $scope.showUsernameError = false;
            $scope.showPasswordError = false;

            $scope.clearError = function (field) {
                if (field === 'database') {
                    $scope.showDatabaseError = false;
                } else if (field === 'username') {
                    $scope.showUsernameError = false;
                } else if (field === 'password') {
                    $scope.showPasswordError = false;
                }
            };

            // Expose validation function to global scope for jQuery
            $window.validateLoginForm = function () {
                var isValid = true;

                if (!$scope.formData.selectedDatabase || $scope.formData.selectedDatabase === '') {
                    $scope.showDatabaseError = true;
                    isValid = false;
                } else {
                    $scope.showDatabaseError = false;
                }

                if (!$scope.formData.userName || $scope.formData.userName.trim() === '') {
                    $scope.showUsernameError = true;
                    isValid = false;
                } else {
                    $scope.showUsernameError = false;
                }

                if (!$scope.formData.password || $scope.formData.password.trim() === '') {
                    $scope.showPasswordError = true;
                    isValid = false;
                } else {
                    $scope.showPasswordError = false;
                }

                $scope.$apply();
                return isValid;
            };
        });
    </script>

    <!-- Database Configuration Modal -->
    <div class="modal fade" id="dbConfigModal" tabindex="-1" role="dialog" aria-labelledby="dbConfigModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #008048; color: white;">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h4 class="modal-title" id="dbConfigModalLabel">
                        <i class="fa fa-database"></i> Database Configuration Info
                    </h4>
                </div>
                <div class="modal-body">
                    <form id="dbConfigForm">
