<script type="text/javascript">
        var _savedata = "";
        $(function () {
            $("#btnNext").show();
            $("#btnBack").hide();
            $("#btnLogin").hide();

            $("#UserName").focus(function () { $(this).select(); });

            $("#btnBack").on('click', function (e) {
                $("#btnNext").show();
                $("#btnBack").hide();
                $("#btnLogin").hide();
                $("#dbSelect").show();
                e.stopPropagation();
                e.preventDefault();
                $('#right').hide("slide", { direction: "right", width: "500px", overflow: "hidden" }, 300, function () {
                    $('#left').show("slide", { direction: "left", width: "500px", overflow: "hidden" }, 300);
                });
            });

            $(function () {
                var triggerNextStep = function() {
                    if ($("#btnNext").is(":disabled") || $("#btnNext").hasClass("disabled")) {
                        return;
                    }

                    $(".alert").hide().html("");
                    var $this = $("#btnNext");

                    if (typeof window.validateLoginForm === 'function') {
                        if (!window.validateLoginForm()) {
                            return;
                        }
                    }

                    var selectedDb = $("#ddlCustomer").val();
                    var selectedItem = $("#UserName").val();
                    var pass = $("#Password").val();
                    var ddlStates = $("#company_name");

                    $.ajax({
                        cache: false,
                        type: "GET",
                        url: '@Url.Action("CompanyBranchList", "Home")',
                        data: { "UserName": selectedItem, "Password": pass, "SelectedDatabase": selectedDb },
                        beforeSend: function (xhr, opts) {
                            $this.button('loading');
                        },
                        success: function (data) {
                            if (data.length > 0) {
                                _savedata = data;
                                $(".hideDiv").show();
                                $("#dbSelect").hide();
                                ddlStates.html('');
                                var uniqueCompany = _.uniq(data, function (y) { return y.company_edesc });
                                $.each(uniqueCompany, function (id, option) {
                                    ddlStates.append($('<option></option>').val(option.company_code).html(option.company_edesc));
                                });
                                $("#company_name").change();

                                $("#btnNext").hide();
                                $("#btnBack").show();
                                $("#btnLogin").show();

                                $('#left').hide("slide", { direction: "left", width: "50px", overflow: "hidden" }, 300, function () {
                                    $('#right').show("slide", { direction: "right", width: "50px", overflow: "hidden" }, 300);
                                });
                                $this.button('reset');
                            } else {
                                $(".alert").css({ display: 'block' }).html("Invalid Username or password");
                                $this.button('reset');
                            }
                        },
                        error: function (xhr, ajaxOptions, thrownError) {
                            alert('Failed to retrieve Company.');
                            $this.button('reset');
                        }
                    });
                };

                $("#btnNext").on('click', function (e) {
                    e.preventDefault();
                    triggerNextStep();
                });

                $(document).on('keypress', function (e) {
                    if (e.which == 13) {
                        if ($("#btnNext").is(":visible")) {
                            e.preventDefault();
                            triggerNextStep();
                        } else if ($("#btnLogin").is(":visible")) {
                            $("#btnLogin").click();
                        }
                    }
                });
            });

            $('#Password').on('change focus', function () {
                $('#UserName').change();
            });

            $('#Password').on('keypress', function (e) {
                var keyCode = (e.keyCode ? e.keyCode : e.which);
                if (keyCode == 13) {
                    var $this = this;
                    var selectedItem = $("#UserName").val();
                    var pass = $("#Password").val();
                    var selectedDb = $("#ddlCustomer").val();
                    var ddlStates = $("#company_name");
                    $.ajax({
                        cache: false,
                        type: "GET",
                        url: '@Url.Action("CompanyBranchList", "Home")',
                        data: { "UserName": selectedItem, "Password": pass, "SelectedDatabase": selectedDb },
                        beforeSend: function (xhr, opts) {
                            $('#btnNext').button('loading');
                        },
                        success: function (data) {
                            if (data.length > 0) {
                                _savedata = data;
                                $(".hideDiv").show();
                                ddlStates.html('');
                                var uniqueCompany = _.uniq(data, function (y) { return y.company_edesc })
                                $.each(uniqueCompany, function (id, option) {
                                    console.log("id===================>>>>" + id);
                                    console.log("options===================>>>>" + option);
                                    if (id == 0) {
                                        ddlStates.append($('<option selected></option>').val(option.company_code).html(option.company_edesc));
                                    } else {
                                        ddlStates.append($('<option></option>').val(option.company_code).html(option.company_edesc));
                                    }
                                });
                                $("#company_name").change();
                                $("#btnNext").hide();
                                $("#btnBack").show();
                                $("#btnLogin").show();
                                $('#left').hide("slide", { direction: "left", width: "50px", overflow: "hidden" }, 300, function () {
                                    $('#right').show("slide", { direction: "right", width: "50px", overflow: "hidden" }, 300);
                                });
                                $($this).button('reset');
                            } else {
                                $(".alert").css({ display: 'block' });
                                $(".alert").html("Invalid Username or password");
                                $($this).button('reset');
                            }
                        },
                        error: function (xhr, ajaxOptions, thrownError) {
                            alert('Failed to retrieve Company.');
                            $($this).button('reset');
                        }
                    });
                }
            });
        });
</script>

<script>
    $(function () {
        $("#company_name").selectedIndex = 0;
        $("#company_name").change(function () {
            var selectedItem = $(this).val();
            var userselectedItem = $("#UserName").val();
            if (userselectedItem == "" && selectedItem == null) {
                $(".hideDiv").hide();
                return
            } else {
                var ddlStates = $("#branch_code");
                $(".form-group").show();
                $(".hideDiv").show();
                ddlStates.html('');
                var _saveDataBranch = _.filter(_savedata, function (x) {
                    return x.company_code == selectedItem && x.group_sku_flag == "I";
                });

                $.each(_saveDataBranch, function (id, option) {
                    if (id == 0) {
                        ddlStates.append($('<option selected></option>').val(option.branch_code).html(option.branch_edesc));
                    } else {
                        ddlStates.append($('<option></option>').val(option.branch_code).html(option.branch_edesc));
                    }
                });
            }
        });
    });
</script>

<script type="text/javascript">
        $(document).ready(function () {
            $(document).on('keydown', function (e) {
                if (e.ctrlKey && e.altKey && event.key.toLowerCase() === "a") {
                    e.preventDefault();
                    $('#dbConfigModal').modal('show');
                    $('#dbConfigForm')[0].reset();
                    $('#dbConfigError').hide();
                    $('#dbConfigSuccess').hide();
                }
            });

            $('#btnSaveDbConfig').on('click', function () {
                var $btn = $(this);

                if (!$('#dbConfigForm')[0].checkValidity()) {
                    $('#dbConfigForm')[0].reportValidity();
                    return;
                }

                var dbConfig = {
                    dbUserName: $('#dbUserName').val().trim(),
                    dbPassword: $('#dbPassword').val().trim(),
                    service: $('#serviceName').val().trim(),
                    host: $('#dbHost').val().trim(),
                    port: parseInt($('#dbPort').val()),
                    name: $('#dbName').val().trim(),
                    active: "Y"
                };

                $btn.html('<i class="fa fa-spinner fa-spin"></i> Saving...').prop('disabled', true);
                $('#dbConfigError').hide();
                $('#dbConfigSuccess').hide();

                $.ajax({
                    url: '@Url.Action("SaveDatabaseConfig", "Home")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(dbConfig),
                    success: function (response) {
                        if (response.success) {
                            $('#dbConfigSuccess').show();
                            refreshDatabaseDropdown();
                            setTimeout(function () {
                                $('#dbConfigModal').modal('hide');
                                $('#dbConfigForm')[0].reset();
                            }, 1500);
                        } else {
                            $('#dbConfigErrorMessage').text(response.message || 'Failed to save database configuration.');
                            $('#dbConfigError').show();
                        }
                    },
                    error: function (xhr, status, error) {
                        $('#dbConfigErrorMessage').text('Error: ' + error);
                        $('#dbConfigError').show();
                    },
                    complete: function () {
                        $btn.html('<i class="fa fa-check"></i> OK').prop('disabled', false);
                    }
                });
            });

            function refreshDatabaseDropdown() {
                $.ajax({
                    url: '@Url.Action("GetDatabaseList", "Home")',
                    type: 'GET',
                    success: function (data) {
                        var $dropdown = $('#ddlCustomer');
                        $dropdown.empty();
                        $dropdown.append('<option value="">---Select Database---</option>');

                        $.each(data, function (index, db) {
                            $dropdown.append($('<option></option>')
                                .val(db.Value)
                                .text(db.Text));
                        });
                    }
                });
            }
        });
</script>

<script>
    $("#ddlCustomer option:first")
        .prop("disabled", true)
        .css("pointer-events", "none");
</script>

