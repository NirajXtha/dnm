                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dbUserName">User Name</label>
                                    <input type="text" class="form-control" id="dbUserName" name="dbUserName" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dbPassword">Password</label>
                                    <input type="password" class="form-control" id="dbPassword" name="dbPassword" required>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dsnName">DSN Name</label>
                                    <input type="text" class="form-control" id="dsnName" name="dsnName" value="ORACLE">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceName">Service Name</label>
                                    <input type="text" class="form-control" id="serviceName" name="serviceName" required>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dbHost">Host</label>
                                    <input type="text" class="form-control" id="dbHost" name="dbHost" value="localhost" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dbPort">Port</label>
                                    <input type="number" class="form-control" id="dbPort" name="dbPort" value="1521" required>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dbName">Database Name</label>
                                    <input type="text" class="form-control" id="dbName" name="dbName" required>
                                </div>
                            </div>
                        </div>
                        <div class="alert alert-danger" id="dbConfigError" style="display:none;">
                            <span id="dbConfigErrorMessage"></span>
                        </div>
                        <div class="alert alert-success" id="dbConfigSuccess" style="display:none;">
                            <span>Database configuration saved successfully!</span>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">
                        <i class="fa fa-times"></i> Cancel
                    </button>
                    <button type="button" class="btn" style="background-color: #008048; color:white;" id="btnSaveDbConfig">
                        <i class="fa fa-check"></i> OK
                    </button>
                </div>
            </div>
        </div>
    </div>
</body>
