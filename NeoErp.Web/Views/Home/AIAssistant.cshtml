                        </div>*@

                    <!-- Productivity Tools with submenu -->
                    @*<div class="menu-item has-submenu" onclick="toggleSubmenu(event, 'productivity-submenu')">
                            <div class="menu-icon">⚡</div>
                            <span>Productivity</span>
                            <span class="submenu-arrow">▶</span>
                        </div>*@
                    @*<div class="submenu" id="productivity-submenu">
