                </div>
            </aside>

            <!-- Main Content -->
            <div class="main-content ai-assistant-content">
                <!-- Chat Header -->
                @*<div class="chat-header">
                        <span class="back-arrow">‹</span>
                        <span class="chat-title">Neo AI-Assistant</span>
                    </div>*@

                <!-- Prompt Library Overlay -->
                <div class="prompt-library-overlay" 
                     ng-class="{'active': vm.showPromptLibrary}"
                     ng-mouseenter="vm.showPromptLibrary = true" 
                     ng-mouseleave="vm.showPromptLibrary = false">
                    <div class="prompt-card" ng-repeat="prompt in vm.promptLibrary" ng-click="vm.selectPrompt(prompt)">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <span style="font-size: 18px;">{{prompt.icon}}</span>
                            <span>{{prompt.text}}</span>
                        </div>
                    </div>
                </div>

                <!-- Chat History Area -->
                <div class="chat-history">
                    <div ng-repeat="msg in vm.messages" class="message-wrapper {{msg.type}}">
                        <div class="message-icon">
                            <span ng-if="msg.type === 'assistant'">🤖</span>
                            <span ng-if="msg.type === 'user'">👤</span>
                        </div>
                        <div class="message-bubble">
                            <div ng-if="!msg.isTable" class="message-text">
                                {{msg.text}}
                                <div ng-if="msg.isLoading" class="typing-indicator">
                                    <div class="typing-dot"></div>
                                    <div class="typing-dot"></div>
                                    <div class="typing-dot"></div>
                                </div>
                            </div>

                            <!-- Table View -->
                            <div ng-if="msg.isTable" class="table-container shadow-sm">
                                <div class="table-view-header">
                                    <div ng-click="vm.toggleTable(msg)" style="cursor: pointer; user-select: none; flex-grow: 1;">
                                        <span style="text-transform: capitalize; font-weight: 600;">{{msg.vizType}} View</span>
                                        <span class="report-toggle-btn" style="margin-left: 10px;">
                                            {{msg.isCollapsed ? 'Show' : 'Hide'}}
                                        </span>
                                    </div>
                                    <div style="display: flex; align-items: center;">
                                        <!-- Graph Key Selector Web Dropdown -->
                                        <div class="key-selector-container" ng-if="msg.vizType !== 'table' && msg.graphKeys.length > 1">
                                            <select class="ai-viz-select" 
                                                    ng-model="msg.selectedKeyIndex" 
                                                    ng-change="vm.changeKey(msg, msg.selectedKeyIndex)"
                                                    ng-options="idx*1 as (pair[0] + ' & ' + pair[1]) for (idx, pair) in msg.graphKeys">
                                            </select>
                                        </div>

                                        <div class="viz-menu-container">
                                            <span class="menu-dots" ng-click="msg.showMenu = !msg.showMenu; $event.stopPropagation()">⋮</span>
                                            <div class="visualization-menu" ng-class="{'active': msg.showMenu}">
                                                <div class="viz-menu-item" ng-class="{'active': msg.vizType === 'table'}" ng-click="vm.changeViz(msg, 'table'); $event.stopPropagation()">
                                                    <i class="fa fa-table"></i> Table
                                                </div>
                                                <div class="viz-menu-item" ng-class="{'active': msg.vizType === 'pie'}" ng-click="vm.changeViz(msg, 'pie'); $event.stopPropagation()">
                                                    <i class="fa fa-pie-chart"></i> Pie
                                                </div>
                                                <div class="viz-menu-item" ng-class="{'active': msg.vizType === 'column'}" ng-click="vm.changeViz(msg, 'column'); $event.stopPropagation()">
                                                    <i class="fa fa-bar-chart"></i> Column
                                                </div>
                                                <div class="viz-menu-item" ng-class="{'active': msg.vizType === 'line'}" ng-click="vm.changeViz(msg, 'line'); $event.stopPropagation()">
                                                    <i class="fa fa-line-chart"></i> Line
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="table-responsive" ng-show="!msg.isCollapsed && msg.vizType === 'table'">
                                    <table class="ai-table">
                                        <thead>
                                            <tr>
                                                <th ng-repeat="header in msg.table.headers">{{header}}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr ng-repeat="row in msg.table.rows">
                                                <td ng-repeat="header in msg.table.headers">{{row[header]}}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <!-- Chart Display -->
                                <div ng-if="msg.vizType === 'pie' && !msg.isCollapsed" class="chart-container" style="position: relative;">
                                    <div class="chart-layout">
                                        <div class="chart-canvas-wrapper">
                                            <canvas ai-chart viz-type="msg.vizType" raw-data="msg.rawData" graph-keys="msg.graphKeys" legend-data="msg.legendData" selected-index="msg.selectedKeyIndex"></canvas>
                                        </div>
                                        <div class="chart-legend" ng-if="msg.legendData.length > 0">
                                            <div ng-repeat="item in msg.legendData" class="legend-item">
                                                <div class="legend-color" ng-style="{'background-color': item.color}"></div>
                                                <div class="legend-label">{{item.label}}</div>
                                                <div class="legend-value">{{item.value}}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div ng-if="msg.vizType === 'column' && !msg.isCollapsed" class="chart-container" style="position: relative;">
                                    <div class="chart-layout">
                                        <div class="chart-canvas-wrapper">
                                            <canvas ai-chart viz-type="msg.vizType" raw-data="msg.rawData" graph-keys="msg.graphKeys" legend-data="msg.legendData" selected-index="msg.selectedKeyIndex"></canvas>
                                        </div>
                                        <div class="chart-legend" ng-if="msg.legendData.length > 0 && msg.vizType === 'column'">
                                            <div ng-repeat="item in msg.legendData" class="legend-item">
                                                <div class="legend-color" ng-style="{'background-color': item.color}"></div>
                                                <div class="legend-label">{{item.label}}</div>
                                                <div class="legend-value">{{item.value}}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div ng-if="msg.vizType === 'line' && !msg.isCollapsed" class="chart-container" style="position: relative;">
                                    <div class="chart-layout">
                                        <div class="chart-canvas-wrapper">
                                            <canvas ai-chart viz-type="msg.vizType" raw-data="msg.rawData" graph-keys="msg.graphKeys" legend-data="msg.legendData" selected-index="msg.selectedKeyIndex"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Clarification Options -->
                            <div ng-if="msg.isOptions" class="options-container">
                                <div ng-repeat="(category, list) in msg.options" class="option-category">
                                    <div class="category-label">Choose {{category}}:</div>
                                    <div class="option-buttons">
                                        <button ng-repeat="opt in list"
                                                class="option-btn"
                                                ng-class="{'selected': msg.selections[category].code === opt.code}"
                                                ng-click="vm.selectOption(msg, category, opt)">
                                            {{opt.name}}
                                        </button>
                                    </div>
                                </div>
                                <div class="selection-footer" ng-if="vm.allOptionsSelected(msg)">
                                    <button class="confirm-btn" ng-click="vm.confirmOptions(msg)">
                                        Proceed with Selection ➔
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chat Input Area -->
                <div class="chat-input-area">
                    <div class="input-box-wrapper">
                        <span class="prompts-trigger-input" 
                              title="Prompt Library"
                              ng-mouseenter="vm.showPromptLibrary = true" 
                              ng-mouseleave="vm.showPromptLibrary = false">
                            <i class="fa fa-plus-circle"></i>
                        </span>
                        <input type="text"
                               id="aiAssistantPromptInput"
                               class="message-input-field"
                               ng-model="vm.userPrompt"
                               ng-keypress="vm.handleKeyPress($event)"
                               placeholder="monthly sales report">
                        <button class="submit-btn" ng-click="vm.sendMessage()">
                            Submit ↵
                        </button>
                    </div>
                </div>



            </div>
        </div>

    </div>

    @*<script src="./assets/js/bootstrap.bundle.min.js"></script>
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
        <script src="./assets/js/main.js"></script>*@

    <!-- Angular.js Library -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <!-- jQuery -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>

    <!-- Bootstrap -->
    <script src="@Url.Content("~/assets/js/bootstrap.bundle.min.js")"></script>

    <!-- Chart.js Library -->
    <script src="@Url.Content("~/Sales/Resource/js/Chart.js")"></script>

    <!-- AI Assistant Angular Controller -->
    <script src="@Url.Content("~/assets/js/controller/aiAssistantCtrl.js")"></script>

    <!-- Main JS -->
    <script src="@Url.Content("~/assets/js/main.js")"></script>
</body>
</html>
