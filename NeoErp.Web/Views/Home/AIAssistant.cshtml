                </nav>

                <div class="sidebar-footer">
                    <div class="user-profile">
                        <div class="user-avatar"></div>
                        <span class="user-name">
                            @if (Request.IsAuthenticated)
                            {
                                <span> @workingContent.CurrentUserinformation.login_code</span><br />
                                <span class="company-name">
                                    @workingContent.CurrentUserinformation.company_name
                                    @*<span>|</span> (@workingContent.CurrentUserinformation.branch_name)*@
                                </span>
                            }
                        </span>
                    </div>
