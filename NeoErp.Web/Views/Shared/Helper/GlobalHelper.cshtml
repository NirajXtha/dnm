<style>
    /* helpPopup.css - Global Help Modal Styles with Pagination */

    .help-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 10000;
    }

    .help-modal-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        cursor: pointer;
    }

    .help-modal-content {
        position: relative;
        background-color: #fff;
        margin: 50px auto;
        padding: 0;
        width: 90%;
        max-width: 650px;
        border-radius: 6px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        animation: slideDown 0.3s ease;
        height: 80vh; /* Fixed height */
        max-height: 600px; /* Maximum height */
        display: flex;
        flex-direction: column;
    }

    @@keyframes slideDown {
        from {
            transform: translateY(-50px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .help-modal-header {
        padding: 15px 20px;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #f8f9fa;
        border-radius: 6px 6px 0 0;
        flex-shrink: 0; /* Prevent header from shrinking */
    }

        .help-modal-header h3 {
            margin: 0;
            color: #333;
            font-size: 20px;
            font-weight: 600;
        }

    .help-modal-close {
        font-size: 32px;
        font-weight: bold;
        color: #aaa;
        cursor: pointer;
        line-height: 20px;
        transition: color 0.2s;
    }

        .help-modal-close:hover {
            color: #000;
        }

    .help-modal-body {
        padding: 25px;
        overflow-y: auto;
        color: #555;
        line-height: 1.6;
        flex: 1; /* Takes up remaining space */
        position: relative;
        min-height: 0; /* Important for Firefox */
    }

        .help-modal-body h4 {
            color: #333;
            margin-top: 0;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .help-modal-body h5 {
            color: #444;
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: 15px;
            font-weight: 600;
        }

        .help-modal-body ul {
            margin-left: 20px;
            margin-bottom: 15px;
        }

        .help-modal-body ol {
            margin-left: 20px;
            margin-bottom: 15px;
        }

        .help-modal-body li {
            margin-bottom: 8px;
        }

        .help-modal-body strong {
            color: #333;
            font-weight: 600;
        }

        .help-modal-body p {
            margin-bottom: 12px;
        }

    /* Page content sections */
    .help-page {
        display: none;
        animation: fadeIn 0.2s ease;
    }

        .help-page.active {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* Pagination indicator */
    .help-pagination {
        text-align: center;
        padding: 10px;
        color: #999;
        font-size: 13px;
        border-top: 1px solid #f0f0f0;
        background-color: #fafafa;
        flex-shrink: 0; /* Prevent pagination from shrinking */
    }

    .help-modal-footer {
        padding: 15px 20px;
        border-top: 1px solid #e5e5e5;
        background-color: #f8f9fa;
        border-radius: 0 0 6px 6px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0; /* Prevent footer from shrinking */
    }

        .help-modal-footer .footer-left {
            display: flex;
            gap: 10px;
        }

        .help-modal-footer .footer-right {
            display: flex;
            gap: 10px;
        }

        .help-modal-footer .btn {
            min-width: 80px;
            padding: 8px 16px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
        }

        .help-modal-footer .btn-primary {
            background-color: #007bff;
            color: white;
        }

            .help-modal-footer .btn-primary:hover:not(:disabled) {
                background-color: #0056b3;
            }

        .help-modal-footer .btn-secondary {
            background-color: #6c757d;
            color: white;
        }

            .help-modal-footer .btn-secondary:hover:not(:disabled) {
                background-color: #545b62;
            }

        .help-modal-footer .btn-green {
            background-color: #28a745;
            color: white;
        }

            .help-modal-footer .btn-green:hover:not(:disabled) {
                background-color: #218838;
            }

        .help-modal-footer .btn-red {
            background-color: #dc3545;
            color: white;
        }

            .help-modal-footer .btn-red:hover:not(:disabled) {
                background-color: #c82333;
            }

        .help-modal-footer .btn:disabled {
            background-color: #e9ecef;
            color: #6c757d;
            cursor: not-allowed;
            opacity: 0.6;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .help-modal-content {
            width: 95%;
            margin: 20px auto;
            height: 85vh;
            max-height: none;
        }

        .help-modal-body {
            padding: 15px;
        }

        .help-modal-footer {
            flex-direction: column;
            gap: 10px;
        }

            .help-modal-footer .footer-left,
            .help-modal-footer .footer-right {
                width: 100%;
                justify-content: center;
            }
    }

    /* Tablet view */
    @@media (min-width: 769px) and (max-width: 1024px) {
        .help-modal-content {
            height: 75vh;
            max-height: 550px;
        }
    }

    /* Large screens */
    @@media (min-width: 1025px) {
        .help-modal-content {
            height: 80vh;
            max-height: 650px;
        }
    }
</style>

<!-- Global Help Modal -->
<div id="helpModal" class="help-modal" style="display: none;">
    <div class="help-modal-overlay" onclick="HelpPopup.close()"></div>
    <div class="help-modal-content">
        <div class="help-modal-header">
            <h3 id="helpModalTitle">Help</h3>
            <span class="help-modal-close" onclick="HelpPopup.close()">&times;</span>
        </div>
        <div class="help-modal-body">
            <div id="helpModalDescription"></div>
        </div>
        <div class="help-pagination" id="helpPagination" style="display: none;">
            Page <span id="currentPage">1</span> of <span id="totalPages">1</span>
        </div>
        <div class="help-modal-footer">
            <div class="footer-left">

            </div>
            <div class="footer-right">
                <button onclick="HelpPopup.previousPage()" class="btn btn-secondary" id="prevPageBtn" style="display: none;">
                    Previous
                </button>
                <button onclick="HelpPopup.nextPage()" class="btn btn-green" id="nextPageBtn" style="display: none;">
                    Next
                </button>
                <button onclick="HelpPopup.close()" class="btn btn-red" id="closeBtn">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // helpPopup.js - Global Help Popup Handler with Pagination
    var HelpPopup = (function () {

        // Storage for all page help content
        var helpContent = {};
        var currentPageIndex = 0;
        var totalPagesCount = 0;

        // Register help content for a page (can be array of pages or single content)
        function register(pageKey, title, description) {
            // Check if description is an array (multiple pages)
            if (Array.isArray(description)) {
                helpContent[pageKey] = {
                    title: title,
                    pages: description,
                    isPaginated: true
                };
            } else {
                helpContent[pageKey] = {
                    title: title,
                    description: description,
                    isPaginated: false
                };
            }
        }

        // Show help by page key
        function showByKey(pageKey) {
            var content = helpContent[pageKey];
            if (content) {
                if (content.isPaginated) {
                    showPaginated(content.pages, content.title);
                } else {
                    show(content.description, content.title);
                }
            } else {
                show('No help available for this page.', 'Help');
            }
        }

        // Show paginated content
        function showPaginated(pages, title) {
            currentPageIndex = 0;
            totalPagesCount = pages.length;

            var modal = document.getElementById('helpModal');
            var titleElement = document.getElementById('helpModalTitle');
            var descriptionElement = document.getElementById('helpModalDescription');
            var paginationElement = document.getElementById('helpPagination');
            var nextBtn = document.getElementById('nextPageBtn');
            var prevBtn = document.getElementById('prevPageBtn');
            var closeBtn = document.getElementById('closeBtn');

            if (!modal) {
                console.error('Help modal not found.');
                return;
            }

            // Set title
            titleElement.textContent = title || 'Help';

            // Create page structure
            var pagesHTML = '';
            for (var i = 0; i < pages.length; i++) {
                pagesHTML += '<div class="help-page' + (i === 0 ? ' active' : '') + '" data-page="' + i + '">' + pages[i] + '</div>';
            }
            descriptionElement.innerHTML = pagesHTML;

            // Show pagination if more than one page
            if (pages.length > 1) {
                paginationElement.style.display = 'block';
                nextBtn.style.display = 'inline-block';
                prevBtn.style.display = 'inline-block';
                updatePaginationUI();
            } else {
                paginationElement.style.display = 'none';
                nextBtn.style.display = 'none';
                prevBtn.style.display = 'none';
            }

            // Show modal
            modal.style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        // Show help directly with content (single page)
        function show(description, title) {
            var modal = document.getElementById('helpModal');
            var titleElement = document.getElementById('helpModalTitle');
            var descriptionElement = document.getElementById('helpModalDescription');
            var paginationElement = document.getElementById('helpPagination');
            var nextBtn = document.getElementById('nextPageBtn');
            var prevBtn = document.getElementById('prevPageBtn');

            if (!modal) {
                console.error('Help modal not found.');
                return;
            }

            // Set content
            titleElement.textContent = title || 'Help';
            descriptionElement.innerHTML = description || 'No help available';

            // Hide pagination for single page
            paginationElement.style.display = 'none';
            nextBtn.style.display = 'none';
            prevBtn.style.display = 'none';

            // Show modal
            modal.style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        // Next page
        function nextPage() {
            if (currentPageIndex < totalPagesCount - 1) {
                currentPageIndex++;
                updatePageDisplay();
                updatePaginationUI();

                // Scroll to top of modal body
                var modalBody = document.querySelector('.help-modal-body');
                if (modalBody) {
                    modalBody.scrollTop = 0;
                }
            }
        }

        // Previous page
        function previousPage() {
            if (currentPageIndex > 0) {
                currentPageIndex--;
                updatePageDisplay();
                updatePaginationUI();

                // Scroll to top of modal body
                var modalBody = document.querySelector('.help-modal-body');
                if (modalBody) {
                    modalBody.scrollTop = 0;
                }
            }
        }

        // Update page display
        function updatePageDisplay() {
            var pages = document.querySelectorAll('.help-page');
            for (var i = 0; i < pages.length; i++) {
                if (i === currentPageIndex) {
                    pages[i].classList.add('active');
                } else {
                    pages[i].classList.remove('active');
                }
            }
        }

        // Update pagination UI
        function updatePaginationUI() {
            var currentPageSpan = document.getElementById('currentPage');
            var totalPagesSpan = document.getElementById('totalPages');
            var nextBtn = document.getElementById('nextPageBtn');
            var prevBtn = document.getElementById('prevPageBtn');

            if (currentPageSpan) currentPageSpan.textContent = currentPageIndex + 1;
            if (totalPagesSpan) totalPagesSpan.textContent = totalPagesCount;

            // Update button states - disable instead of hide
            if (prevBtn) {
                if (currentPageIndex === 0) {
                    prevBtn.disabled = true;
                } else {
                    prevBtn.disabled = false;
                }
            }

            if (nextBtn) {
                if (currentPageIndex === totalPagesCount - 1) {
                    nextBtn.disabled = true;
                } else {
                    nextBtn.disabled = false;
                }
            }
        }

        // Close modal
        function close() {
            var modal = document.getElementById('helpModal');
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = 'auto';
                currentPageIndex = 0;
            }
        }

        // Close on ESC key
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' || event.keyCode === 27) {
                close();
            }
        });

        // Public API
        return {
            register: register,
            showByKey: showByKey,
            show: show,
            nextPage: nextPage,
            previousPage: previousPage,
            close: close
        };
    })();
</script>